    async function runLoop() {
        if (!bot.isRunning) { loopRunning = false; return; }
        if (loopRunning) return;
        loopRunning = true;
        
        try {
            if (checkStopConditions()) { loopRunning = false; return; }
            
            const now = Date.now();
            if (now - bot.lastBetTime < bot.betDelay) {
                await new Promise(r => setTimeout(r, bot.betDelay - (now - bot.lastBetTime)));
            }
            bot.lastBetTime = Date.now();
            
            const result = await placeBaccaratBet();
            
            if (result && result.success) {
                bot.stats.bets++;
                bot.stats.wagered += result.amount;
                updateWageredUSD(result.amount);
                bot.stats.profit += result.profit;
                
                if (result.isWin) {
                    bot.stats.wins++;
                    bot.lastResult = "win";
                } else if (result.isTie) {
                    bot.stats.ties++;
                    bot.lastResult = "tie";
                } else {
                    bot.stats.loss++;
                    bot.lastResult = "loss";
                }
                
                if (result.amount > bot.highestBet) bot.highestBet = result.amount;
                if (result.profit > bot.highestPayout) bot.highestPayout = result.profit;
                
                const currentBalance = getCurrentBalance();
                if (currentBalance < bot.worstBalance || bot.worstBalance === 0) {
                    bot.worstBalance = currentBalance;
                    const dd = ((bot.startBalance - currentBalance) / bot.startBalance) * 100;
                    if (dd > bot.worstDrawdown) bot.worstDrawdown = dd;
                }
                
                updateBalanceHistory();
                
                // HITUNG NEXT BET (ini akan mengupdate bot.currentBet)
                calculateNextBet(result.isWin);
                
                // TENTUKAN NEXT SIDE
                const newSide = determineNextSide(result.isWin, bot.betSide, result.winner);
                if (newSide !== bot.betSide) {
                    let reason = "";
                    if (bot.wagerStrategy === "martingale") reason = result.isWin ? "Menang, pindah alternate" : "Kalah, tetap (Follow The Loss)";
                    else if (bot.wagerStrategy === "parlay") reason = result.isWin ? "Menang, tetap (Follow The Win)" : "Kalah, ikuti winner";
                    else reason = "Fixed mode";
                    updateConsoleLog(`🔄 SIDE: ${bot.betSide.toUpperCase()} → ${newSide.toUpperCase()} (${reason})`);
                    bot.betSide = newSide;
                    const sideSelect = document.getElementById("cfg_side");
                    if (sideSelect) sideSelect.value = bot.betSide;
                } else {
                    if (bot.wagerStrategy === "martingale" && !result.isWin && bot.martingaleStep > 1) 
                        updateConsoleLog(`📌 STAY: ${bot.betSide.toUpperCase()} (Martingale Step ${bot.martingaleStep})`);
                    if (bot.wagerStrategy === "parlay" && result.isWin && bot.parlayStep > 1) 
                        updateConsoleLog(`📌 STAY: ${bot.betSide.toUpperCase()} (Parlay Step ${bot.parlayStep})`);
                }
                
                updateHud(true);
            }
            
            loopRunning = false;
            if (bot.isRunning) setTimeout(() => runLoop(), 0);
        } catch (err) {
            console.error("Loop error:", err);
            updateConsoleLog("Loop error: " + err.message);
            loopRunning = false;
            if (bot.isRunning) setTimeout(() => runLoop(), 2000);
        }
    }

    function makeDraggable(element) {
        element.style.cursor = 'move';
        element.addEventListener('mousedown', (e) => {
            if (e.target.closest('button') || e.target.closest('select') || e.target.closest('input')) return;
            isDragging = true;
            const rect = element.getBoundingClientRect();
            dragOffsetX = e.clientX - rect.left;
            dragOffsetY = e.clientY - rect.top;
            element.style.transition = 'none';
        });
        document.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            let left = e.clientX - dragOffsetX;
            let top = e.clientY - dragOffsetY;
            left = Math.max(10, Math.min(window.innerWidth - element.offsetWidth - 10, left));
            top = Math.max(10, Math.min(window.innerHeight - element.offsetHeight - 10, top));
            element.style.left = left + 'px';
            element.style.top = top + 'px';
            element.style.bottom = 'auto';
            element.style.transform = 'none';
        });
        document.addEventListener('mouseup', () => { isDragging = false; element.style.transition = ''; });
    }

