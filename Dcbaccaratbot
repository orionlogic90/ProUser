    async function placeBaccaratBet() {
        const sideMap = { player: 0, banker: 0, tie: 0 };
        sideMap[bot.betSide] = parseFloat(bot.currentBet);
        
        const payload = {
            currency: bot.selectedCurrency.toLowerCase(),
            identifier: randomIdentifier(),
            player: sideMap.player,
            banker: sideMap.banker,
            tie: sideMap.tie
        };
        
        updateConsoleLog(`🎰 Betting ${bot.currentBet.toFixed(8)} on ${bot.betSide.toUpperCase()}`);
        
        try {
            const response = await fetch(`${CONFIG.apiUrl}/casino/baccarat/bet`, {
                method: "POST",
                headers: { "Content-Type": "application/json", "x-access-token": bot.token, "x-lockdown-token": "s5MNWtjTM5TvCMkAzxov" },
                body: JSON.stringify(payload)
            });
            
            const data = await response.json();
            if (data?.errors) {
                updateConsoleLog(`❌ API Error: ${data.errors[0]?.message}`);
                return null;
            }
            
            const betResult = data?.baccaratBet || data;
            if (!betResult) {
                updateConsoleLog(`❌ No bet result`);
                return null;
            }
            
            const result = betResult.state?.result || "unknown";
            const payout = betResult.payout || 0;
            let isWin = false, isTie = false;
            
            if (result === bot.betSide) {
                isWin = true;
                updateConsoleLog(`✅ WIN! Payout: ${payout.toFixed(8)} | Profit: +${(payout - bot.currentBet).toFixed(8)}`);
            } else if (result === "tie") {
                isTie = true;
                updateConsoleLog(`🔄 TIE! Bet returned: ${payout.toFixed(8)}`);
            } else {
                updateConsoleLog(`❌ LOSS! Lost: ${bot.currentBet.toFixed(8)} | Winner: ${result}`);
            }
            
            bot.lastWinner = result;
            updateLastWinnerDisplay();
            
            return { success: true, isWin, isTie, payout, amount: bot.currentBet, profit: payout - bot.currentBet, result, winner: result };
        } catch (err) {
            updateConsoleLog(`❌ Bet error: ${err.message}`);
            return null;
        }
    }
    
