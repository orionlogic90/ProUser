    function determineNextSide(wasWin, currentSide, winner) {
        if (bot.wagerStrategy === "martingale") {
            if (wasWin) {
                return currentSide === "player" ? "banker" : "player";
            } else {
                return currentSide;
            }
        } else if (bot.wagerStrategy === "parlay") {
            if (wasWin) {
                return currentSide;
            } else {
                if (winner !== "tie") return winner;
                return currentSide === "player" ? "banker" : "player";
            }
        } else {
            return currentSide;
        }
    }

    // ========== BET CALCULATION YANG BENAR ==========
    function calculateNextBet(wasWin) {
        let newBet = bot.currentBet;
        
        if (wasWin) {
            bot.consecutiveWins++;
            bot.consecutiveLosses = 0;
            bot.currentLossCount = 0;
            
            updateConsoleLog(`✅ WIN #${bot.consecutiveWins}`);
            
            if (bot.wagerStrategy === "parlay") {
                // PARLAY: naikkan bet setelah menang
                if (bot.parlayAfterWins > 0 && bot.consecutiveWins >= bot.parlayAfterWins) {
                    bot.parlayStep = Math.min(bot.parlayStep * bot.parlayMultiplier, bot.maxBetMultiplier);
                    newBet = bot.basebet * bot.parlayStep;
                    updateConsoleLog(`📈 PARLAY ACTIVE! Step: ${bot.parlayStep} | Bet: ${newBet.toFixed(8)}`);
                } else {
                    bot.parlayStep = 1;
                    newBet = bot.basebet;
                }
            } else if (bot.wagerStrategy === "martingale") {
                // MARTINGALE: reset bet setelah menang
                newBet = bot.basebet;
                bot.martingaleStep = 1;
                updateConsoleLog(`🔁 MARTINGALE RESET after WIN | Bet back to ${newBet.toFixed(8)}`);
            } else {
                // FIXED
                newBet = bot.basebet;
            }
            
        } else {
            bot.consecutiveLosses++;
            bot.consecutiveWins = 0;
            bot.currentLossCount++;
            
            updateConsoleLog(`❌ LOSS #${bot.consecutiveLosses}`);
            
            if (bot.wagerStrategy === "martingale") {
                // MARTINGALE: naikkan bet setelah kalah
                if (bot.martingaleAfterLosses > 0 && bot.consecutiveLosses >= bot.martingaleAfterLosses) {
                    bot.martingaleStep = Math.min(bot.martingaleStep * bot.martingaleMultiplier, bot.maxBetMultiplier);
                    newBet = bot.basebet * bot.martingaleStep;
                    updateConsoleLog(`🔁 MARTINGALE ACTIVE! Step: ${bot.martingaleStep} | Bet: ${newBet.toFixed(8)}`);
                } else {
                    newBet = bot.basebet;
                }
            } else if (bot.wagerStrategy === "parlay") {
                // PARLAY: reset bet setelah kalah
                newBet = bot.basebet;
                bot.parlayStep = 1;
                updateConsoleLog(`📈 PARLAY RESET after LOSS | Bet back to ${newBet.toFixed(8)}`);
            } else {
                // FIXED
                newBet = bot.basebet;
            }
        }
        
        // Reset conditions
        let shouldReset = false;
        let reason = "";
        
        if (bot.resetAfterWinstreak > 0 && bot.consecutiveWins >= bot.resetAfterWinstreak) {
            shouldReset = true;
            reason = `Win streak ${bot.consecutiveWins}`;
        }
        
        if (bot.resetAfterLossstreak > 0 && bot.consecutiveLosses >= bot.resetAfterLossstreak) {
            shouldReset = true;
            reason = `Loss streak ${bot.consecutiveLosses}`;
        }
        
        if (bot.resetAfterProfit > 0 && bot.stats.profit >= bot.resetAfterProfit) {
            shouldReset = true;
            reason = `Profit ${bot.stats.profit.toFixed(6)}`;
        }
        
        if (shouldReset) {
            newBet = bot.basebet;
            bot.consecutiveWins = 0;
            bot.consecutiveLosses = 0;
            bot.currentLossCount = 0;
            bot.martingaleStep = 1;
            bot.parlayStep = 1;
            updateConsoleLog(`🔄 RESET: ${reason} | Bet back to ${newBet.toFixed(8)}`);
        }
        
        // Safety check
        const currentBalance = getCurrentBalance();
        const maxBet = currentBalance * 0.25;
        if (newBet > maxBet) {
            newBet = maxBet;
            updateConsoleLog(`⚠️ Bet capped at 25% balance: ${newBet.toFixed(8)}`);
        }
        if (newBet < 0.00000001) newBet = bot.basebet;
        
        // SIMPAN ke bot.currentBet
        bot.currentBet = newBet;
        updateConsoleLog(`💰 Next bet set to: ${bot.currentBet.toFixed(8)}`);
        return newBet;
    }

    function checkStopConditions() {
        const currentBalance = getCurrentBalance();
        const lossPct = ((bot.startBalance - currentBalance) / bot.startBalance) * 100;
        
        if (bot.stopLossPercent > 0 && lossPct >= bot.stopLossPercent) {
            updateConsoleLog(`🛑 STOP LOSS: ${lossPct.toFixed(2)}%`);
            stopBot();
            return true;
        }
        if (bot.targetWager > 0 && bot.stats.wagered >= bot.targetWager) {
            updateConsoleLog(`✅ TARGET WAGER: ${bot.stats.wagered.toFixed(2)}/${bot.targetWager}`);
            stopBot();
            return true;
        }
        if (bot.targetProfit > 0 && bot.stats.profit >= bot.targetProfit) {
            updateConsoleLog(`✅ TARGET PROFIT: ${bot.stats.profit.toFixed(4)}`);
            stopBot();
            return true;
        }
        return false;
    }

