    function generateRandomFields() {
        let fieldsToSelect = bot.fieldsCount;
        
        if (bot.fieldsRangeMode && bot.minFields > 0 && bot.maxFields > 0 && bot.minFields <= bot.maxFields) {
            fieldsToSelect = Math.floor(Math.random() * (bot.maxFields - bot.minFields + 1)) + bot.minFields;
        }
        
        const totalFields = 25;
        const shuffled = Array.from({ length: totalFields }, (_, i) => i);
        for (let i = shuffled.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
        }
        return shuffled.slice(0, fieldsToSelect);
    }

    async function placeMinesBet() {
        let fieldsToUse;
        let actualFieldsCount = bot.fieldsCount;
        
        if (bot.fieldsMode === "random") {
            const randomFields = generateRandomFields();
            fieldsToUse = randomFields;
            actualFieldsCount = randomFields.length;
        } else {
            fieldsToUse = [...bot.fixedFields];
            if (fieldsToUse.length > bot.fieldsCount) {
                fieldsToUse = fieldsToUse.slice(0, bot.fieldsCount);
            } else if (fieldsToUse.length < bot.fieldsCount) {
                const allFields = Array.from({ length: 25 }, (_, i) => i);
                const available = allFields.filter(f => !fieldsToUse.includes(f));
                for (let i = fieldsToUse.length; i < bot.fieldsCount && available.length > 0; i++) {
                    const randIndex = Math.floor(Math.random() * available.length);
                    fieldsToUse.push(available[randIndex]);
                    available.splice(randIndex, 1);
                }
            }
            actualFieldsCount = fieldsToUse.length;
        }
        
        const payload = {
            amount: parseFloat(bot.currentBet),
            currency: bot.selectedCurrency.toLowerCase(),
            identifier: Math.random().toString(36).slice(2) + Date.now().toString(36),
            minesCount: bot.minesCount,
            fields: fieldsToUse
        };
        
        try {
            const response = await fetch(`${CONFIG.apiUrl}/casino/mines/bet`, {
                method: "POST",
                headers: { "Content-Type": "application/json", "x-access-token": bot.token },
                body: JSON.stringify(payload)
            });
            const data = await response.json();
            
            const betData = data?.data?.minesBet || data?.minesBet;
            
            if (!betData) {
                updateConsoleLog(`❌ API Error: ${JSON.stringify(data).substring(0, 200)}`);
                return null;
            }
            
            const payout = betData.payout;
            const won = payout > 0;
            const payoutMultiplier = parseFloat(betData.payoutMultiplier || 0);
            const amount = parseFloat(betData.amount);
            const profitAmount = won ? payout - amount : -amount;
            
            if (payoutMultiplier > bot.highestPayout) bot.highestPayout = payoutMultiplier;
            
            return {
                success: true,
                won: won,
                payout: payout,
                payoutMultiplier: payoutMultiplier,
                amount: amount,
                profit: profitAmount,
                betId: betData.id,
                fieldsCount: actualFieldsCount
            };
        } catch (err) {
            updateConsoleLog(`❌ Bet error: ${err.message}`);
            return null;
        }
    }

    function checkResetConditions() {
        let reset = false;
        let reason = "";
        
        if (bot.resetAfterWinstreak > 0 && bot.consecutiveWins >= bot.resetAfterWinstreak) {
            reset = true;
            reason = `Win streak ${bot.consecutiveWins} >= ${bot.resetAfterWinstreak}`;
        }
        
        if (bot.resetAfterLossstreak > 0 && bot.consecutiveLosses >= bot.resetAfterLossstreak) {
            reset = true;
            reason = `Loss streak ${bot.consecutiveLosses} >= ${bot.resetAfterLossstreak}`;
        }
        
        if (bot.resetAfterProfit > 0 && bot.stats.profit >= bot.resetAfterProfit) {
            reset = true;
            reason = `Profit ${bot.stats.profit.toFixed(6)} >= ${bot.resetAfterProfit}`;
        }
        
        if (reset) {
            bot.currentBet = bot.basebet;
            bot.consecutiveWins = 0;
            bot.consecutiveLosses = 0;
            bot.currentLossCount = 0;
            updateConsoleLog(`🔄 Reset BB: ${reason} → ${bot.currentBet.toFixed(8)}`);
            return true;
        }
        return false;
    }

    function calculateNextBet(wasWin) {
        let newBet = bot.currentBet;
        
        checkResetConditions();
        
        if (wasWin) {
            bot.consecutiveWins++;
            bot.consecutiveLosses = 0;
            bot.currentLossCount = 0;
            
            if (bot.resetAfterWin) {
                newBet = bot.basebet;
                updateConsoleLog(`🔄 Reset to base bet after win → ${newBet.toFixed(8)}`);
            } else {
                newBet = bot.currentBet;
            }
        } else {
            bot.consecutiveLosses++;
            bot.consecutiveWins = 0;
            bot.currentLossCount++;
            
            if (bot.resetAfterLoss) {
                newBet = bot.basebet;
                bot.currentLossCount = 0;
                updateConsoleLog(`🔄 Reset to base bet after loss → ${newBet.toFixed(8)}`);
            } else {
                if (bot.martingaleAfterLosses > 0 && bot.currentLossCount > bot.martingaleAfterLosses) {
                    newBet = bot.currentBet * bot.ifLose;
                } else if (bot.martingaleAfterLosses > 0 && bot.currentLossCount <= bot.martingaleAfterLosses) {
                    newBet = bot.currentBet;
                } else {
                    newBet = bot.currentBet * bot.ifLose;
                }
            }
        }
        
        const currentBalance = getCurrentBalance();
        const maxBet = currentBalance * 0.25;
        if (newBet > maxBet) {
            newBet = maxBet;
            updateConsoleLog(`⚠️ Bet capped at 25% balance: ${newBet.toFixed(8)}`);
        }
        if (newBet < 0.00000001) newBet = bot.basebet;
        
        return newBet;
    }

    function checkStopConditions() {
        const currentBalance = getCurrentBalance();
        const lossPct = ((bot.startBalance - currentBalance) / bot.startBalance) * 100;
        
        if (bot.stopLossPercent > 0 && lossPct >= bot.stopLossPercent) {
            updateConsoleLog(`🛑 STOP LOSS: ${lossPct.toFixed(2)}% >= ${bot.stopLossPercent}%`);
            stopBot();
            return true;
        }
        
        if (bot.targetWager > 0 && bot.stats.wagered >= bot.targetWager) {
            updateConsoleLog(`✅ TARGET WAGER: ${bot.stats.wagered.toFixed(2)}/${bot.targetWager}`);
            stopBot();
            return true;
        }
        
        if (bot.targetProfit > 0 && bot.stats.profit >= bot.targetProfit) {
            updateConsoleLog(`✅ TARGET PROFIT: ${bot.stats.profit.toFixed(4)} >= ${bot.targetProfit}`);
            stopBot();
            return true;
        }
        
        return false;
    }

    function stopBot() {
        if (bot.isRunning) {
            bot.isRunning = false;
            if (reportInterval) { clearInterval(reportInterval); reportInterval = null; }
            if (uptimeInterval) { clearInterval(uptimeInterval); uptimeInterval = null; }
            loopRunning = false;
            updateConsoleLog("🛑 BOT STOPPED");
            sendTelegramReport("🛑 BOT STOPPED");
            updateHUDStatus("STOPPED");
        }
    }

    function updateConsoleLog(msg) {
        const logEl = document.getElementById("orion-console-log");
        if (logEl) {
            const time = new Date().toLocaleTimeString();
            logEl.innerHTML = `[${time}] ${msg}<br>` + logEl.innerHTML;
            if (logEl.innerHTML.length > 5000) logEl.innerHTML = logEl.innerHTML.substring(0, 3000);
        }
        console.log(msg);
    }

    async function runLoop() {
        if (!bot.isRunning) { loopRunning = false; return; }
        if (loopRunning) return;
        loopRunning = true;
        
        try {
            if (checkStopConditions()) { loopRunning = false; return; }
            
            // Rate limiting check
            const now = Date.now();
            if (now - bot.lastBetTime < bot.betDelay) {
                await new Promise(r => setTimeout(r, bot.betDelay - (now - bot.lastBetTime)));
            }
            bot.lastBetTime = Date.now();
            
            const result = await placeMinesBet();
            if (!result) {
                loopRunning = false;
                setTimeout(() => runLoop(), Math.max(100, bot.betDelay));
                return;
            }
            
            bot.stats.bets++;
            bot.stats.wagered += result.amount;
            updateWageredUSD(result.amount);
            bot.stats.profit += result.profit;
            
            if (result.won) {
                bot.stats.wins++;
                if (bot.stats.bets % 5 === 0) { // Log setiap 5 bet saja untuk kecepatan
                    updateConsoleLog(`✅ WIN | +${result.profit.toFixed(8)} | ${result.payoutMultiplier.toFixed(2)}x`);
                }
            } else {
                bot.stats.loss++;
                if (bot.stats.bets % 5 === 0) {
                    updateConsoleLog(`❌ LOSS | -${result.amount.toFixed(8)}`);
                }
            }
            
            if (result.amount > bot.highestBet) bot.highestBet = result.amount;
            const currentBalance = getCurrentBalance();
            if (currentBalance < bot.worstBalance || bot.worstBalance === 0) {
                bot.worstBalance = currentBalance;
                const dd = ((bot.startBalance - currentBalance) / bot.startBalance) * 100;
                if (dd > bot.worstDrawdown) bot.worstDrawdown = dd;
            }
            updateBalanceHistory();
            
            const newBet = calculateNextBet(result.won);
            bot.currentBet = newBet;
            
            updateHud(true);
            
            loopRunning = false;
            if (bot.isRunning) {
                setTimeout(() => runLoop(), 0); // Minimal delay between loops
            }
        } catch (err) {
            console.error("Loop error:", err);
            updateConsoleLog("Loop error: " + err.message);
            loopRunning = false;
            if (bot.isRunning) setTimeout(() => runLoop(), 200);
        }
    }

    function makeDraggable(element) {
        element.style.cursor = 'move';
        element.addEventListener('mousedown', (e) => {
            if (e.target.closest('button') || e.target.closest('select') || e.target.closest('input')) return;
            isDragging = true;
            const rect = element.getBoundingClientRect();
            dragOffsetX = e.clientX - rect.left;
            dragOffsetY = e.clientY - rect.top;
            element.style.transition = 'none';
        });
        document.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            let left = e.clientX - dragOffsetX;
            let top = e.clientY - dragOffsetY;
            left = Math.max(10, Math.min(window.innerWidth - element.offsetWidth - 10, left));
            top = Math.max(10, Math.min(window.innerHeight - element.offsetHeight - 10, top));
            element.style.left = left + 'px';
            element.style.top = top + 'px';
            element.style.bottom = 'auto';
            element.style.transform = 'none';
        });
        document.addEventListener('mouseup', () => { isDragging = false; element.style.transition = ''; });
    }

