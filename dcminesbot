                if (selectedFields.includes(i)) {
                    cell.style.background = "#F6465D";
                    cell.style.color = "#fff";
                }
                cell.onclick = () => {
                    if (selectedFields.includes(i)) {
                        selectedFields = selectedFields.filter(f => f !== i);
                        cell.style.background = "#2D333B";
                        cell.style.color = "#EAECEF";
                    } else {
                        if (selectedFields.length < bot.fieldsCount) {
                            selectedFields.push(i);
                            cell.style.background = "#F6465D";
                            cell.style.color = "#fff";
                        } else {
                            updateConsoleLog(`⚠️ Max ${bot.fieldsCount} fields only!`);
                        }
                    }
                    info.innerText = `Select ${bot.fieldsCount} positions (currently selected: ${selectedFields.length})`;
                };
                grid.appendChild(cell);
            }
        }
        updateGrid();
        
        const saveBtn = document.createElement("button");
