        const now = Date.now();
        if (!force && now - bot.lastUiMs < 200) return;
        bot.lastUiMs = now;
        
        const curB = getCurrentBalance();
        const profit = curB - bot.startBalance;
        const lossPct = getTotalLossPercentage();
        const wagerPercent = bot.targetWager > 0 ? (bot.stats.wagered / bot.targetWager) * 100 : 0;
        
        const balEl = document.getElementById("HUD_STARTBAL");
        if (balEl) balEl.innerText = curB.toFixed(4);
        
        const profitEl = document.getElementById("HUD_PROFIT");
        if (profitEl) { profitEl.innerText = (profit >= 0 ? "+" : "") + profit.toFixed(4); profitEl.style.color = profit >= 0 ? "#48BB78" : "#F6465D"; }
        
        const wagerEl = document.getElementById("HUD_WAGER");
        if (wagerEl) wagerEl.innerText = bot.stats.wagered.toFixed(4);
        
        const lossEl = document.getElementById("HUD_LOSSPCT");
        if (lossEl) { lossEl.innerText = lossPct.toFixed(2) + "%"; lossEl.style.color = lossPct > 10 ? "#F6465D" : (lossPct > 3 ? "#F0B90B" : "#48BB78"); }
        
        const payoutEl = document.getElementById("HUD_PAYOUT");
        if (payoutEl) payoutEl.innerText = bot.highestPayout > 0 ? bot.highestPayout.toFixed(2) + "x" : "0x";
        
        const fillEl = document.getElementById("wager-progress-fill");
        const textEl = document.getElementById("wager-progress-text");
        if (fillEl) fillEl.style.width = Math.min(100, wagerPercent) + "%";
        if (textEl) textEl.innerText = wagerPercent.toFixed(1) + "%";
        
        const wagerCurr = document.getElementById("wager-current");
        if (wagerCurr) wagerCurr.innerText = bot.stats.wagered.toFixed(4);
        
        const wagerTarget = document.getElementById("wager-target");
        if (wagerTarget) wagerTarget.innerText = bot.targetWager > 0 ? bot.targetWager.toFixed(2) : "∞";
        
        const betCount = document.getElementById("bet-count");
        if (betCount) betCount.innerText = bot.stats.bets;
        
        const wlCount = document.getElementById("wl-count");
        if (wlCount) wlCount.innerText = `${bot.stats.wins}/${bot.stats.loss}`;
        
        const streakCount = document.getElementById("streak-count");
        if (streakCount) streakCount.innerText = bot.consecutiveWins > 0 ? `+${bot.consecutiveWins}` : (bot.consecutiveLosses > 0 ? `-${bot.consecutiveLosses}` : "0");
        
        if (bot.isRunning) {
            const uptimeEl = document.getElementById("HUD_UPTIME");
            if (uptimeEl) uptimeEl.innerText = getUptime();
        }
        
        const badge = document.getElementById("ORION_HUD_BADGE");
        if (badge) {
            if (bot.isRunning) {
                badge.innerText = "RUNNING";
                badge.style.background = "rgba(72,187,120,0.15)";
                badge.style.color = "#48BB78";
            } else {
                badge.innerText = "STOPPED";
                badge.style.background = "rgba(246,70,93,0.15)";
                badge.style.color = "#F6465D";
            }
        }
    }
    
    function updateHUDStatus(status) {
        const badge = document.getElementById("ORION_HUD_BADGE");
        if (badge) badge.innerText = status;
        updateHud(true);
    }
    
    function init() {
        ensureHudAndControls().then(() => updateConsoleLog("✅ Mines Bot v5.2 Ready! SPEED MODE | Dual TG Bot | 1000 History Points"));
    }
    
    setInterval(() => updateHud(false), 300);
    init();
    
    setTimeout(async () => {
        const token = getAuthToken();
        if (token) {
            try {
                const query = `query{user{name balances{available{amount currency}}}}`;
                const res = await fetch(`${CONFIG.apiUrl}/graphql`, {
                    method: "POST", headers: { "Content-Type": "application/json", "x-access-token": token },
                    body: JSON.stringify({ query })
                });
                const json = await res.json();
                if (json?.data?.user) {
                    bot.stakeUser = json.data.user.name;
                    const bals = json.data.user.balances || [];
                    const currencySelect = document.getElementById("orion-currency");
                    if (currencySelect && currencySelect.options.length === 0) {
                        bals.forEach(b => {
                            const opt = document.createElement("option");
                            opt.value = b.available.currency;
                            opt.textContent = b.available.currency.toUpperCase();
                            currencySelect.appendChild(opt);
                        });
                        if (bals.length > 0) currencySelect.value = bals[0].available.currency;
                    }
                    if (currencySelect && currencySelect.value) bot.selectedCurrency = currencySelect.value;
                }
            } catch (e) {}
        }
    }, 1000);
})();
