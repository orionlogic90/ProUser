        var mode = bot.isHarvesting ? " [H]" : "";
        var rollTxt = roll !== null ? " R:" + roll.toFixed(2) : "";
        entry.textContent = timestamp + mode + " " + amt.toFixed(8) + "|" + ch.toFixed(1) + "%|" + (pft > 0 ? '+' : '') + pft.toFixed(8) + rollTxt;
