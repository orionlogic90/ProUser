    // ==================== VIRTUAL CHANCE (PERSIS ORION) ====================
    const VIRTUAL_CHANCES = [];
    for (var c = 2; c <= 49.5; c = c + 0.5) {
        VIRTUAL_CHANCES.push(parseFloat(c.toFixed(1)));
    }
    VIRTUAL_CHANCES.push(98.0);
    VIRTUAL_CHANCES.sort(function(a, b) { return a - b; });
    
    const BASE_CHANCE = 98.0;
    const BASE_BET_MIN = 1e-12;
    
    var virtualLs = {};
    var thresholds = {};
    var readyChances = [];
    var memory = {};
    
    function initMemory() {
        for (var i = 0; i < VIRTUAL_CHANCES.length; i++) {
            var c = VIRTUAL_CHANCES[i];
            var key = Math.floor(c).toString();
            memory[key] = {
                wins: 0,
                loss: 0,
                max_ls: 0,
                ls_now: 0,
                target: Math.ceil(99.0 / c) * 3
            };
            virtualLs[c] = 0;
            thresholds[c] = Math.ceil(99.0 / c) * 3;
        }
        readyChances = [];
        updateUILog("Virtual chance initialized (" + VIRTUAL_CHANCES.length + " chances)");
    }
    
    function updateMemory(chance, win) {
        var key = Math.floor(chance).toString();
        if (!memory[key]) {
            memory[key] = { wins: 0, loss: 0, max_ls: 0, ls_now: 0, target: Math.ceil(99.0 / chance) * 3 };
        }
        var mem = memory[key];
        if (win) {
            mem.wins++;
            mem.max_ls = Math.max(mem.max_ls, mem.ls_now);
            mem.ls_now = 0;
        } else {
            mem.loss++;
            mem.ls_now++;
            mem.max_ls = Math.max(mem.max_ls, mem.ls_now);
        }
    }
    
    function virtualCheckWin(roll, chance) {
        var number = 100 - chance;
        return roll > number;
    }
    
    function updateVirtualStreaks(roll) {
        var changed = false;
        
        for (var i = 0; i < VIRTUAL_CHANCES.length; i++) {
            var c = VIRTUAL_CHANCES[i];
            var isWin = virtualCheckWin(roll, c);
            
            if (isWin) {
                virtualLs[c] = 0;
                var idx = readyChances.indexOf(c);
                if (idx > -1) readyChances.splice(idx, 1);
            } else {
                virtualLs[c]++;
                if (virtualLs[c] >= thresholds[c] && readyChances.indexOf(c) === -1) {
                    readyChances.push(c);
                    changed = true;
                    updateUILog("Chance " + c + "% READY! (streak " + virtualLs[c] + "/" + thresholds[c] + ")");
                }
            }
            updateMemory(c, isWin);
        }
        
        if (changed) {
            readyChances.sort(function(a, b) { return b - a; });
        }
    }
    
    function getBestTriggerChance() {
        if (readyChances.length === 0) return null;
        var best = null;
        var bestStreak = 0;
        for (var i = 0; i < readyChances.length; i++) {
            var c = readyChances[i];
            if (virtualLs[c] > bestStreak) {
                bestStreak = virtualLs[c];
                best = c;
            }
        }
        return best;
    }
    
    function expectedThresholdTrigger(chance, factor) {
        return Math.ceil(99.0 / chance) * factor;
    }
    
    function computeAdaptiveBaseBet(balance, overallStartBalance, targetPct, sessionTotal, riskFactor, profitSoFar) {
        if (sessionTotal <= 0) sessionTotal = 1;
        var perSessionPct = targetPct / sessionTotal;
        var targetAbsPerSession = (perSessionPct / 100.0) * overallStartBalance;
        if (targetAbsPerSession <= 0) return Math.max(balance * 1e-6, BASE_BET_MIN);
        var progress = profitSoFar / targetAbsPerSession;
        var adj = Math.max(0.12, (1.0 - progress));
        var dynamic = balance * (perSessionPct / 100.0) * adj * riskFactor;
        return Math.max(dynamic, BASE_BET_MIN);
    }
    
