        bot.lastUiMs = now;

        const curB = getCurrentBalance();
        const profit = curB - bot.startBalance;
        const lossPct = getTotalLossPercentage();
        const wagerPercent = bot.wagtarget > 0 ? (bot.wager / bot.wagtarget) * 100 : 0;
        
        const balEl = document.getElementById("HUD_STARTBAL");
        if (balEl) balEl.innerText = curB.toFixed(4);
        
        const profitEl = document.getElementById("HUD_PROFIT");
        if (profitEl) { 
            profitEl.innerText = (profit >= 0 ? "+" : "") + profit.toFixed(4); 
            profitEl.style.color = profit >= 0 ? "#48BB78" : "#F6465D"; 
        }
        
        const wagerEl = document.getElementById("HUD_WAGER");
        if (wagerEl) wagerEl.innerText = bot.stats.wagered.toFixed(4);
        
        const lossEl = document.getElementById("HUD_LOSSPCT");
        if (lossEl) { 
            lossEl.innerText = lossPct.toFixed(2) + "%"; 
            lossEl.style.color = lossPct > 10 ? "#F6465D" : (lossPct > 3 ? "#F0B90B" : "#48BB78"); 
        }
        
        const highestEl = document.getElementById("HUD_HIGHESTBET");
        if (highestEl) highestEl.innerText = bot.highestBet > 0 ? bot.highestBet.toFixed(4) : "0";
        
        const ddEl = document.getElementById("HUD_WORSTDD");
        if (ddEl) ddEl.innerText = bot.worstDrawdown > 0 ? bot.worstDrawdown.toFixed(2) + "%" : "0%";
        
        const fillEl = document.getElementById("wager-progress-fill");
        const textEl = document.getElementById("wager-progress-text");
        const currentEl = document.getElementById("wager-current");
        const targetEl = document.getElementById("wager-target");
