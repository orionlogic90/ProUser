  function simulateMinesBet(amount, minesCount, fields) {
    const win = Math.random() > (minesCount / 25);
    const multiplier = 25 / (25 - minesCount);
    const payout = win ? amount * multiplier : 0;
    
    return {
      data: {
        minesBet: {
          id: "demo_" + Date.now(),
          amount: amount,
          payout: payout,
          payoutMultiplier: multiplier,
          state: {
            rounds: fields.map((f, i) => ({
              field: f,
              payoutMultiplier: i < 2 ? multiplier : 0
            }))
          }
        }
      }
    };
  }

  function updateBetSpeed() {
    const now = Date.now();
    const timeDiff = (now - bot.lastSpeedUpdate) / 1000;
    
    if (timeDiff >= 1) {
      bot.betSpeed = bot.speedBetsCount / timeDiff;
      bot.speedBetsCount = 0;
      bot.lastSpeedUpdate = now;
      
      const speedEl = document.getElementById("speed-value");
      if (speedEl) {
        speedEl.innerText = bot.betSpeed.toFixed(2) + "/s";
      }
    }
  }

  // Martingale Functions
  function calculateMartingaleBet(baseBet, win) {
    if (!bot.martingale.enabled) return baseBet;
    
    if (win) {
      // Handle win streak
      bot.streak.winStreak++;
      bot.streak.lossStreak = 0;
      bot.martingale.currentStep = 0;
      
      if (bot.streak.enabled && bot.streak.winStreak >= bot.streak.winThreshold) {
        // Apply win streak multiplier
        bot.martingale.currentBet = baseBet * bot.streak.winMultiplier;
      } else {
        // After win, reset or adjust based on settings
        switch(bot.martingale.afterWin) {
          case 'reset':
            bot.martingale.currentBet = bot.martingale.baseBet;
            break;
          case 'increase':
            bot.martingale.currentBet = bot.martingale.currentBet * 1.2;
            break;
          case 'decrease':
            bot.martingale.currentBet = bot.martingale.currentBet * 0.8;
            break;
        }
      }
    } else {
      // Handle loss streak
      bot.streak.lossStreak++;
      bot.streak.winStreak = 0;
      bot.martingale.currentStep++;
      
      if (bot.streak.enabled && bot.streak.lossStreak >= bot.streak.lossThreshold) {
        // Apply loss streak multiplier
        bot.martingale.currentBet = baseBet * bot.streak.lossMultiplier;
      } else {
        // After loss, apply martingale based on mode
        switch(bot.martingale.mode) {
          case 'fixed':
            bot.martingale.currentBet = baseBet * Math.pow(bot.martingale.multiplier, bot.martingale.currentStep);
            break;
          case 'dynamic':
            bot.martingale.currentBet = baseBet * (1 + (bot.martingale.currentStep * 0.5));
            break;
          case 'progressive':
            bot.martingale.currentBet = baseBet * (bot.martingale.multiplier + (bot.martingale.currentStep * 0.3));
            break;
        }
      }
      
      // Check max steps
      if (bot.martingale.currentStep >= bot.martingale.maxSteps) {
        console.log("⚠️ Max martingale steps reached, resetting");
        bot.martingale.currentStep = 0;
        bot.martingale.currentBet = bot.martingale.baseBet;
      }
    }
    
    // Ensure bet doesn't exceed balance
    if (bot.martingale.currentBet > bot.stats.currentBal * 0.1) {
      bot.martingale.currentBet = bot.stats.currentBal * 0.1;
    }
    
    return bot.martingale.currentBet;
  }

  function checkTargets() {
    // Check target profit
    if (bot.target.enabled && !bot.target.reached) {
      let targetMet = false;
      
      if (bot.target.type === 'percent') {
        targetMet = (bot.stats.profit / bot.stats.startBal * 100) >= bot.target.value;
      } else {
        targetMet = bot.stats.profit >= bot.target.value;
      }
      
      if (targetMet) {
        bot.target.reached = true;
        API.kirimPesan(`🎯 *TARGET REACHED!*\nProfit: ${bot.stats.profit.toFixed(8)} ${bot.selectedCurrency.toUpperCase()}`);
        bot.isRunning = false;
        return true;
      }
    }
    
    // Check stop loss
    if (bot.stopLoss.enabled && !bot.stopLoss.reached) {
      let stopMet = false;
      const loss = -bot.stats.profit;
      
      if (bot.stopLoss.type === 'percent') {
        stopMet = (loss / bot.stats.startBal * 100) >= bot.stopLoss.value;
      } else {
        stopMet = loss >= bot.stopLoss.value;
      }
      
      if (stopMet) {
        bot.stopLoss.reached = true;
        API.kirimPesan(`🛑 *STOP LOSS TRIGGERED!*\nLoss: ${loss.toFixed(8)} ${bot.selectedCurrency.toUpperCase()}`);
        bot.isRunning = false;
        return true;
      }
    }
    
    return false;
  }

