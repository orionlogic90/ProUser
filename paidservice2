    // ==================== UPDATE VARIABLES DARI INPUT ====================
    function updateFromInputs() {
        // Limbo variables
        bot.baselimbo = parseFloat(document.getElementById("p-baselimbo")?.value) || 0.00008;
        bot.chmin = parseInt(document.getElementById("p-chmin")?.value) || 10;
        bot.chmax = parseInt(document.getElementById("p-chmax")?.value) || 60;
        bot.chdiv = parseInt(document.getElementById("p-chdiv")?.value) || 550;
        bot.multi = parseFloat(document.getElementById("p-multi")?.value) || 1.1587;
        bot.modulus = parseInt(document.getElementById("p-modulus")?.value) || 35;
        
        // Dice variables
        bot.basedice = parseFloat(document.getElementById("p-basedice")?.value) || 0.000001;
        bot.chancef = parseFloat(document.getElementById("p-chancef")?.value) || 90;
        bot.chancer = parseFloat(document.getElementById("p-chancer")?.value) || 9.9;
        bot.multir = parseFloat(document.getElementById("p-multir")?.value) || 1.28;
        
        // Common
        bot.maxbet = parseFloat(document.getElementById("p-maxbet")?.value) || 0.002;
        bot.maxdrop = parseFloat(document.getElementById("p-maxdrop")?.value) || -2;
        bot.trailingf = parseFloat(document.getElementById("p-trailingf")?.value) || -5;
        bot.minbet = parseFloat(document.getElementById("p-minbet")?.value) || 1e-8;
        bot.maxSteps = parseInt(document.getElementById("p-steps")?.value) || 900000;
        
        bot.trailing = bot.trailingf;
