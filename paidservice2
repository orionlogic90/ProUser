  /************** BOT LOGIC **************/
  async function startBot() {
    if (bot.isRunning) return;
    
    // Get settings
    bot.targetProfit = parseFloat(document.getElementById("targetProfit").value) / 100;
    bot.stopLoss = parseFloat(document.getElementById("stopLoss").value) / 100;
    bot.resetOnWinStreak = parseInt(document.getElementById("resetWin").value);
    bot.resetOnLossStreak = parseInt(document.getElementById("resetLoss").value);
    bot.selectedMines = parseInt(document.getElementById("minesCount").value);
    
    // Get token
    bot.token = localStorage.getItem('apitoken') || 
                (document.cookie.match(/session=([^;]+)/) ? 
                document.cookie.match(/session=([^;]+)/)[1] : null);
    
    if (!bot.token) {
      alert("No token found!");
      return;
    }
    
    // Sync
    await syncUser();
    const balance = await getBalance(bot.selectedCurrency);
    
    if (balance <= 0) {
      alert("Insufficient balance!");
      return;
    }
    
    // Reset stats
    bot.stats = {
      profit: 0,
      wagered: 0,
      startBal: balance,
      currentBal: balance,
      bets: 0,
      wins: 0,
      loss: 0,
      startTime: Date.now(),
      maxDD: 0,
      history: [balance]
    };
    
    bot.currentStreak = 0;
    bot.isRunning = true;
    
    document.getElementById("start").disabled = true;
    document.getElementById("stop").disabled = false;
    
    addLog(`Started | Balance: ${balance.toFixed(8)}`, true);
    kirimPesanTelegram(`🚀 MINES STARTED\nBalance: ${balance.toFixed(8)} ${bot.selectedCurrency.toUpperCase()}`);
    
    runLoop();
  }
  
  function stopBot() {
    bot.isRunning = false;
    document.getElementById("start").disabled = false;
    document.getElementById("stop").disabled = true;
    
    addLog(`Stopped | Profit: ${bot.stats.profit.toFixed(8)}`, false);
    kirimPesanTelegram(`⏹ MINES STOPPED\nProfit: ${bot.stats.profit.toFixed(8)} ${bot.selectedCurrency.toUpperCase()}`);
  }
  
  async function runLoop() {
    if (!bot.isRunning) return;
    
    try {
      // Check target/stop loss
      const profitPct = bot.stats.profit / bot.stats.startBal;
      
      if (bot.targetProfit > 0 && profitPct >= bot.targetProfit) {
        addLog(`🎯 Target reached! +${(profitPct*100).toFixed(1)}%`, true);
        kirimPesanTelegram(`🎯 TARGET REACHED!\nProfit: ${(profitPct*100).toFixed(1)}%`);
        stopBot();
        return;
      }
      
      if (bot.stopLoss > 0 && profitPct <= -bot.stopLoss) {
        addLog(`🛑 Stop loss! ${(profitPct*100).toFixed(1)}%`, false);
        kirimPesanTelegram(`🛑 STOP LOSS\nLoss: ${(profitPct*100).toFixed(1)}%`);
        stopBot();
        return;
      }
      
      // Get fields
      let fields = bot.selectedFields;
      if (bot.randomFields) {
        fields = generateRandomFields(bot.selectedMines);
      }
      
      if (fields.length === 0) {
        addLog("❌ No fields selected!", false);
        stopBot();
        return;
      }
      
      const amount = parseFloat(document.getElementById("amount").value);
      
      if (amount > bot.stats.currentBal) {
        addLog("❌ Insufficient balance!", false);
        stopBot();
        return;
      }
      
      // Place bet
      const result = await placeMinesBet(amount, bot.selectedMines, fields);
      const d = result?.data?.minesBet || result?.minesBet;
      
      if (d) {
        bot.speedBetsCount++;
        
        const win = d.payout > 0;
        const payout = d.payout || 0;
        const multiplier = d.payoutMultiplier || 0;
        
        const profit = payout - amount;
        bot.stats.bets++;
        bot.stats.wagered += amount;
        bot.stats.profit += profit;
        bot.stats.currentBal += profit;
        
        if (win) {
          bot.stats.wins++;
          bot.currentStreak = bot.currentStreak > 0 ? bot.currentStreak + 1 : 1;
          addLog(`✅ WIN ${multiplier.toFixed(2)}x | +${profit.toFixed(8)}`, true);
          
          // Reset on win streak
          if (bot.resetOnWinStreak > 0 && bot.currentStreak >= bot.resetOnWinStreak) {
            addLog(`🔄 Reset after ${bot.currentStreak} wins`, true);
            bot.currentStreak = 0;
            // Reset fields or other logic here
          }
        } else {
          bot.stats.loss++;
          bot.currentStreak = bot.currentStreak < 0 ? bot.currentStreak - 1 : -1;
          addLog(`❌ LOSS | -${amount.toFixed(8)}`, false);
          
          // Reset on loss streak
          if (bot.resetOnLossStreak > 0 && Math.abs(bot.currentStreak) >= bot.resetOnLossStreak) {
            addLog(`🔄 Reset after ${Math.abs(bot.currentStreak)} losses`, true);
            bot.currentStreak = 0;
          }
        }
        
        if (multiplier > bot.globalMaxPayout) {
          bot.globalMaxPayout = multiplier;
        }
        
        updateDisplay();
      }
      
      // Telegram report every 3 mins
      const now = Date.now();
      if (now - bot.lastTelegramTime >= 180000) {
        sendReport();
        bot.lastTelegramTime = now;
      }
      
      if (bot.isRunning) {
        setTimeout(runLoop, 300);
      }
      
    } catch (e) {
      addLog(`⚠️ Error: ${e.message}`, false);
      if (bot.isRunning) {
        setTimeout(runLoop, 2000);
      }
    }
  }
  
  function updateDisplay() {
    document.getElementById("st-balance").innerText = bot.stats.currentBal.toFixed(8);
    document.getElementById("st-profit").innerText = (bot.stats.profit >= 0 ? '+' : '') + bot.stats.profit.toFixed(8);
    document.getElementById("st-bets").innerText = bot.stats.bets;
    document.getElementById("st-wl").innerText = bot.stats.wins + "/" + bot.stats.loss;
    
    const winRate = bot.stats.bets > 0 ? (bot.stats.wins / bot.stats.bets * 100).toFixed(1) : 0;
    document.getElementById("st-winrate").innerText = winRate + "%";
    document.getElementById("st-streak").innerText = bot.currentStreak;
  }
  
  function addLog(text, isWin) {
    const logs = document.getElementById("logs");
    const div = document.createElement("div");
    div.className = isWin ? "log-win" : "log-loss";
    div.style.padding = "2px 0";
    div.innerText = `[${new Date().toLocaleTimeString()}] ${text}`;
    logs.prepend(div);
    if (logs.children.length > 10) logs.lastChild.remove();
  }
  
  function sendReport() {
    const runtime = Math.floor((Date.now() - bot.stats.startTime) / 1000);
    const hours = Math.floor(runtime / 3600);
    const minutes = Math.floor((runtime % 3600) / 60);
    
    const msg = `📊 MINES REPORT\n` +
      `Runtime: ${hours}h ${minutes}m\n` +
      `Bets: ${bot.stats.bets} | W/L: ${bot.stats.wins}/${bot.stats.loss}\n` +
      `Profit: ${bot.stats.profit.toFixed(8)} ${bot.selectedCurrency.toUpperCase()}`;
    
    kirimPesanTelegram(msg);
  }

