                        console.log(`🎲 DEMO DICE: Target ${target}, Roll ${diceData.roll}, ${win ? 'WIN' : 'LOSS'}`);
                        
                        return { 
                            diceRoll: { 
                                amount: amount, 
                                payout: payout,
                                roll: diceData.roll,
                                win: win
                            } 
                        };
                    }
                } catch (e) {
                    console.log("⚠️ Demo dice error, fallback:", e);
                    const win = Math.random() * 100 < chance;
                    return { 
                        diceRoll: { 
                            amount: amount, 
                            payout: win ? (amount * (99 / chance)) : 0,
                            win: win
                        } 
                    };
