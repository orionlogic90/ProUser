    function initbet_limbo() {
        updateFromInputs();
        // baselimbo bisa dari input atau tetap pakai rumus
        if (document.getElementById("p-baselimbo-use-rule")?.checked) {
            bot.baselimbo = (bot.stats.currentBal / 50) * 8e-5;
        }
        bot.basebet = bot.baselimbo;
        bot.currentChance = Math.floor(Math.random() * (bot.chmax - bot.chmin + 1) + bot.chmin) / bot.chdiv;
        bot.nextbet = bot.basebet;
        bot.playgame = "limbo";
        bot.on_limbo = true;
        
        console.log(`>>> LIMBO MODE: basebet=${bot.basebet.toFixed(8)}, chance=${bot.currentChance.toFixed(4)}`);
    }

    function initbet_dice() {
        updateFromInputs();
        // basedice bisa dari input atau tetap pakai rumus
        if (document.getElementById("p-basedice-use-rule")?.checked) {
            bot.basedice = (bot.stats.currentBal / 50) * 1e-6;
        }
        bot.basebet = bot.basedice;
        bot.currentChance = bot.chancef;
        bot.nextbet = bot.basebet;
        bot.playgame = "dice";
        bot.on_limbo = false;
        bot.ctwin = 0;
        
        console.log(`>>> DICE MODE: basebet=${bot.basebet.toFixed(8)}, chance=${bot.chancef}%`);
    }

    function updateConstants() {
        updateFromInputs();
        
        // Update basebet berdasarkan mode
        if (bot.on_limbo) {
            if (document.getElementById("p-baselimbo-use-rule")?.checked) {
                bot.baselimbo = (bot.stats.currentBal / 50) * 8e-5;
                document.getElementById("p-baselimbo").value = bot.baselimbo.toFixed(8);
            }
            bot.basebet = bot.baselimbo;
        } else {
            if (document.getElementById("p-basedice-use-rule")?.checked) {
                bot.basedice = (bot.stats.currentBal / 50) * 1e-6;
                document.getElementById("p-basedice").value = bot.basedice.toFixed(8);
            }
            bot.basebet = bot.basedice;
        }
        
        bot.trailing = bot.trailingf + bot.stats.profit;
    }

    // ==================== FUNGSI BETTING UTAMA ====================
    async function runLoop() {
        if (!bot.isRunning) return;
        
        try {
            updateConstants();
            
            // Cek kondisi switch
            if (bot.stats.profit > 0) {
                if (bot.on_limbo) {
                    console.log(">>> Profit positif, switch ke LIMBO");
                    await new Promise(resolve => setTimeout(resolve, 5000));
                    initbet_limbo();
                }
            }
            
            if (bot.stats.profit < bot.maxdrop && bot.on_limbo) {
                console.log(`>>> Profit ${bot.stats.profit.toFixed(8)} < maxdrop ${bot.maxdrop}, switch ke DICE`);
                initbet_dice();
            }

            let result;
            let win = false;
            let payout = 0;
            let amount = bot.nextbet;
            
            if (bot.on_limbo) {
                // LIMBO MODE
                bot.currentChance = Math.floor(Math.random() * (bot.chmax - bot.chmin + 1) + bot.chmin) / bot.chdiv;
                const multiplierTarget = 1 / bot.currentChance;
                
                result = await API.placeLimboBet(amount, multiplierTarget);
                const limboData = result?.data?.limboRoll || result?.limboRoll;
                
                if (limboData) {
                    win = limboData.win; // SUDAH FIX!
                    payout = limboData.payout;
                    
                    if (win) {
                        bot.nextbet = bot.basebet;
                    } else {
                        if (Math.abs(bot.stats.loss) % bot.modulus === 0) {
                            bot.nextbet = bot.nextbet * bot.multi;
                        }
                    }
                }
                
            } else {
                // DICE MODE
                result = await API.placeDiceBet(amount, bot.currentChance);
                const diceData = result?.data?.diceRoll || result?.diceRoll;
                
                if (diceData) {
                    win = diceData.win; // SUDAH FIX!
                    payout = diceData.payout;
                    
                    if (win) {
                        bot.ctwin++;
                        bot.currentChance = bot.chancef;
                        
                        if (bot.ctwin >= 20) {
                            bot.ctwin = 0;
                            bot.currentChance = bot.chancer;
                        }
                        
                        if (bot.nextbet > bot.maxbet && bot.maxbet > 0) {
                            bot.nextbet = bot.basebet;
                        }
                        bot.nextbet = Math.max(bot.nextbet, bot.basebet);
                        
                    } else {
                        if (bot.currentChance < bot.chancef) {
                            const streak = Math.abs(bot.stats.loss);
                            if (bot.stats.profit < bot.trailing) {
                                bot.nextbet = Math.abs(bot.stats.profit) / ((99 / bot.currentChance) - 1) * 1.01;
                            } else {
                                bot.nextbet = bot.nextbet * bot.multir;
                            }
                            bot.streakx = Math.max(bot.streakx, streak);
                        }
                    }
                }
            }

            if (result) {
                const pft = payout - amount;
                
                // Update stats
                bot.stats.bets++;
                bot.currentSteps++;
                bot.stats.wagered += amount;
                bot.stats.profit += pft;
                bot.stats.currentBal += pft;
                
                if (win) {
                    bot.stats.wins++;
                } else {
                    bot.stats.loss++;
                }
                
                // Update max drawdown
                if (bot.stats.currentBal < bot.stats.startBal) {
                    let dd = bot.stats.startBal - bot.stats.currentBal;
                    let ddPerc = (dd / bot.stats.startBal) * 100;
                    if (dd > bot.stats.maxDD) bot.stats.maxDD = dd;
                    if (ddPerc > bot.stats.maxDDPerc) bot.stats.maxDDPerc = ddPerc;
                }
                
                // Log
                const mode = bot.on_limbo ? "LIMBO" : "DICE";
                const chance = bot.on_limbo ? (bot.currentChance * 100).toFixed(2) + "%" : bot.currentChance + "%";
                updateLogs(amount, pft, chance, mode, win);
                updateDisplay();
            }
            
            // Telegram
            const now = Date.now();
            if (now - bot.lastTelegramTime >= bot.telegramInterval) {
                await API.sendTelegramReport();
                bot.lastTelegramTime = now;
            }
            
            // Next loop
            if (bot.isRunning) {
                const delay = bot.isDemo ? 50 : 0;
                setTimeout(runLoop, delay);
            }
            
        } catch (e) { 
            console.log("Error:", e);
            if (bot.isRunning) setTimeout(runLoop, 1000); 
        }
    }

    function updateLogs(amt, pft, chance, mode, win) {
        const logBox = document.getElementById("p-logs");
        const entry = document.createElement("div");
        const winLoss = win ? "✅ WIN" : "❌ LOSS";
        entry.style.cssText = "margin:2px 0; padding:2px; font-size:11px; border-left:2px solid " + (win ? "#2ecc71" : "#e74c3c");
        entry.innerHTML = `${new Date().toLocaleTimeString()} | ${mode} ${winLoss} | ${amt.toFixed(8)} | ${pft>0?"+":""}${pft.toFixed(8)} | ${chance}`;
        logBox.prepend(entry);
        if (logBox.children.length > 8) logBox.lastChild.remove();
    }

