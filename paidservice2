        document.getElementById("st-r").innerText = `${bot.stats.bets} (${bot.stats.wins}/${bot.stats.loss})`;
        document.getElementById("st-wagered").innerText = bot.stats.wagered.toFixed(8);
        document.getElementById("st-steps").innerText = bot.currentSteps + "/" + bot.maxSteps.toLocaleString();
        document.getElementById("st-mode").innerText = bot.on_limbo ? "LIMBO" : "DICE";
        document.getElementById("st-next").innerText = bot.nextbet.toFixed(8);
        
        const chance = bot.on_limbo ? (bot.currentChance * 100).toFixed(2) + "%" : bot.currentChance + "%";
        document.getElementById("st-chance").innerText = chance;
        
        document.getElementById("st-ctwin").innerText = bot.ctwin + "/20";
        document.getElementById("st-trailing").innerText = bot.trailing.toFixed(2);
        
        if (bot.stats.currentBal >= bot.stats.startBal) {
            document.getElementById("st-bal").style.color = "#2ecc71";
        } else {
            document.getElementById("st-bal").style.color = "#e74c3c";
        }
    }

