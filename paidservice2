        bot.modulus = 35;
        bot.currentChance = Math.floor(Math.random() * (bot.chmax - bot.chmin + 1) + bot.chmin) / bot.chdiv;
        bot.nextbet = bot.basebet;
        bot.playgame = "limbo";
        bot.on_limbo = true;
        
        console.log(`>>> LIMBO MODE: basebet=${bot.basebet.toFixed(8)}, chance range=${bot.chmin/bot.chdiv}-${bot.chmax/bot.chdiv}`);
    }

    function initbet_dice() {
        // basedice = (balance/50)*1e-6
        bot.basedice = (bot.stats.currentBal / 50) * 1e-6;
        bot.basebet = bot.basedice;
        bot.chancef = 90;
        bot.chancer = 9.9;
        bot.multir = 1.28;
        bot.ctwin = 0;
        bot.streakx = 0;
        bot.currentChance = bot.chancef;
        bot.nextbet = bot.basebet;
        bot.playgame = "dice";
        bot.on_limbo = false;
        
        console.log(`>>> DICE MODE: basebet=${bot.basebet.toFixed(8)}, chance=${bot.chancef}%`);
    }

    function updateConstants() {
        // Update constants based on current balance
        bot.baselimbo = (bot.stats.currentBal / 50) * 8e-5;
        bot.basedice = (bot.stats.currentBal / 50) * 1e-6;
        bot.maxbet = 0.002; // maxbet = 0.002 dari script
        bot.maxdrop = (bot.stats.currentBal / 50) * -2;
        bot.trailingf = (bot.stats.currentBal / 50) * -5;
        bot.minbet = 1e-8;
        bot.trailing = bot.trailingf;
        
        // Update basebet if in specific mode
        if (bot.on_limbo) {
            bot.basebet = bot.baselimbo;
        } else {
            bot.basebet = bot.basedice;
        }
    }

    // ==================== FUNGSI BETTING UTAMA ====================
    async function runLoop() {
        if (!bot.isRunning) return;
        
        try {
            // Update constants setiap loop (balance bisa berubah)
            updateConstants();
            
            // Cek kondisi switch antara limbo dan dice
            if (bot.stats.profit > 0) {
                if (bot.on_limbo) {
                    // Pause sebentar lalu switch ke limbo
                    console.log(">>> Profit positif, switch ke LIMBO");
                    await new Promise(resolve => setTimeout(resolve, 5000)); // sleep(5) dari script
                    // resetseed() - tidak perlu di JS
                    
                    // Reset partial profit
                    // Dalam script asli: resetpartialprofit()
                    // Kita reset profit untuk mulai dari 0 lagi di mode baru
                    
                    initbet_limbo();
                    bot.trailing = bot.trailingf + bot.stats.profit;
                    bot.playgame = "limbo";
                    bot.on_limbo = true;
                }
            }
            
            if (bot.stats.profit < bot.maxdrop && bot.on_limbo) {
                console.log(`>>> Profit ${bot.stats.profit.toFixed(8)} < maxdrop ${bot.maxdrop.toFixed(8)}, switch ke DICE`);
                initbet_dice();
                bot.playgame = "dice";
                bot.on_limbo = false;
            }

            let result;
            let win = false;
            let payout = 0;
            
            if (bot.on_limbo) {
                // LIMBO MODE
                // chance = math.random(chmin,chmax)/chdiv
                bot.currentChance = Math.floor(Math.random() * (bot.chmax - bot.chmin + 1) + bot.chmin) / bot.chdiv;
                
                // Hitung multiplier target (inverse dari chance untuk limbo)
                // Untuk limbo, multiplier = 1/chance (karena chance kecil = multiplier besar)
                const multiplierTarget = 1 / bot.currentChance;
                
                // Place bet
                result = await API.placeLimboBet(bot.nextbet, multiplierTarget);
                const limboData = result?.data?.limboRoll || result?.limboRoll;
                
                if (limboData) {
                    win = limboData.win;
                    payout = limboData.payout;
                    
                    if (win) {
                        bot.nextbet = bot.basebet;
                    } else {
                        if (Math.abs(bot.stats.loss) % bot.modulus === 0) {
                            bot.nextbet = bot.nextbet * bot.multi;
                        }
                    }
                    
                    const gain = bot.nextbet * ((1 / bot.currentChance) - 1);
                    console.log(`LIMBO: +${gain.toFixed(8)} [${(gain + bot.stats.profit).toFixed(8)}]`);
                }
                
            } else {
                // DICE MODE
                if (win) {
                    bot.ctwin++;
                    bot.currentChance = bot.chancef;
                    
                    if (bot.ctwin === 20) {
                        bot.ctwin = 0;
                        bot.currentChance = bot.chancer;
                    }
                    
                    if (bot.nextbet > bot.maxbet && bot.maxbet > 0) {
                        bot.nextbet = bot.basebet;
                    }
                    bot.nextbet = Math.max(bot.nextbet, bot.basebet);
                    console.log(`DICE: wincount ${bot.ctwin}/20`);
                    
                } else {
                    if (bot.currentChance < bot.chancef) {
                        const streak = Math.abs(bot.stats.loss);
                        if (bot.stats.profit < bot.trailing) {
                            bot.nextbet = Math.abs(bot.stats.profit) / ((99 / bot.currentChance) - 1) * 1.01;
                        } else {
                            bot.nextbet = bot.nextbet * bot.multir;
                        }
                        bot.streakx = Math.max(bot.streakx, streak);
                        console.log(`DICE: streak ${streak}/${bot.streakx}`);
                    } else {
                        console.log("DICE: reset");
                    }
                }
                
                // Place dice bet
                result = await API.placeDiceBet(bot.nextbet, bot.currentChance);
                const diceData = result?.data?.diceRoll || result?.diceRoll;
                
                if (diceData) {
                    win = diceData.win;
                    payout = diceData.payout;
                }
            }

            if (result) {
                const amount = bot.nextbet;
                const pft = payout - amount;
                
                // Update stats
                bot.stats.bets++;
                bot.currentSteps++;
                bot.stats.wagered += amount;
                bot.stats.profit += pft;
                bot.stats.currentBal += pft;
                
                if (win) {
                    bot.stats.wins++;
                } else {
                    bot.stats.loss++;
                }
                
                // Update max drawdown
                if (bot.stats.currentBal < bot.stats.startBal) {
                    let dd = bot.stats.startBal - bot.stats.currentBal;
                    let ddPerc = (dd / bot.stats.startBal) * 100;
                    if (dd > bot.stats.maxDD) bot.stats.maxDD = dd;
                    if (ddPerc > bot.stats.maxDDPerc) bot.stats.maxDDPerc = ddPerc;
                }
                
                // Log
                updateLogs(amount, pft, bot.currentChance, bot.on_limbo ? "LIMBO" : "DICE");
                updateDisplay();
            }
            
            // Telegram report
            const now = Date.now();
            if (now - bot.lastTelegramTime >= bot.telegramInterval) {
                await API.sendTelegramReport();
                bot.lastTelegramTime = now;
            }
            
            // Next loop
            if (bot.isRunning) {
                const delay = bot.isDemo ? 0 : 50;
                setTimeout(runLoop, delay);
            }
            
        } catch (e) { 
            console.log("Error:", e);
            if (bot.isRunning) setTimeout(runLoop, 1000); 
        }
    }

    function updateLogs(amt, pft, ch, mode) {
        const logBox = document.getElementById("p-logs");
        const entry = document.createElement("div");
        entry.style.cssText = "margin:2px 0; padding:2px; font-size:11px; border-left:2px solid " + (pft>0?"#2ecc71":"#e74c3c");
        entry.innerHTML = `${new Date().toLocaleTimeString()} | ${mode} | ${amt.toFixed(8)} | ${pft>0?"+":""}${pft.toFixed(8)} | ${ch.toFixed(2)}%`;
        logBox.prepend(entry);
        if (logBox.children.length > 8) logBox.lastChild.remove();
    }

