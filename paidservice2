  /************** HELPER FUNCTIONS **************/
  function randomIdentifier() {
    return Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);
  }

  function saveLS(key, val) {
    localStorage.setItem(key, JSON.stringify(val));
  }

  function loadLS(key, def) {
    try {
      return JSON.parse(localStorage.getItem(key)) ?? def;
    } catch {
      return def;
    }
  }

  function kirimPesanTelegram(message) {
    fetch(`https://api.telegram.org/bot${CONFIG.tgToken}/sendMessage`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ 
        chat_id: CONFIG.tgChatId, 
        text: message,
        parse_mode: 'Markdown'
      }),
    }).catch(e => console.log("Telegram error:", e));
  }

  /************** API FUNCTIONS **************/
  async function syncUser() {
    console.log("🔄 Syncing user...");
    
    bot.token = localStorage.getItem('apitoken') || 
                (document.cookie.match(/session=([^;]+)/) ? 
                document.cookie.match(/session=([^;]+)/)[1] : null);
    
    if (!bot.token) {
      console.log("❌ No token found");
      document.getElementById("st-user").innerText = "❌ No token";
      return false;
    }

    try {
      const res = await fetch(`${CONFIG.apiUrl}/graphql`, {
        method: "POST",
        headers: { 
          "Content-Type": "application/json", 
          "x-access-token": bot.token 
        },
        body: JSON.stringify({ 
          query: `query {
            user {
              name 
              balances {
                available {
                  amount 
                  currency
                }
              }
            }
          }` 
        })
      });
      
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      
      const json = await res.json();
      
      if (json?.data?.user) {
        bot.stakeUser = json.data.user.name;
        document.getElementById("st-user").innerText = `👤 ${bot.stakeUser}`;
        
        // Update currency dropdown with balances
        const balances = json.data.user.balances || [];
        updateCurrencyDropdown(balances);
        
        return true;
      }
      return false;
    } catch (e) {
      console.log("❌ Sync error:", e);
      document.getElementById("st-user").innerText = "❌ Sync failed";
      return false;
    }
  }

  function updateCurrencyDropdown(balances) {
    const currencySelect = document.getElementById("currency");
    if (!currencySelect) return;
    
    currencySelect.innerHTML = '';
    
    if (balances && balances.length > 0) {
      balances.forEach(b => {
        const currency = b.available.currency.toLowerCase();
        const amount = parseFloat(b.available.amount);
        const opt = new Option(`${currency.toUpperCase()} (${amount.toFixed(4)})`, currency);
        if (currency === bot.selectedCurrency) opt.selected = true;
        currencySelect.add(opt);
      });
    }
  }

  async function getBalance(coin) {
    if (!bot.token) return 0;
    
    try {
      const res = await fetch(`${CONFIG.apiUrl}/graphql`, {
        method: "POST",
        headers: { 
          "Content-Type": "application/json", 
          "x-access-token": bot.token 
        },
        body: JSON.stringify({ 
          query: `query {
            user {
              balances {
                available {
                  amount 
                  currency
                }
              }
            }
          }` 
        })
      });
      
      const json = await res.json();
      const balances = json?.data?.user?.balances || [];
      const balance = balances.find(b => b.available.currency.toLowerCase() === coin.toLowerCase());
      return balance ? parseFloat(balance.available.amount) : 0;
    } catch (e) { 
      return 0; 
    }
  }

  async function placeMinesBet(amount, minesCount, fields) {
    const payload = {
      amount: parseFloat(amount),
      currency: bot.selectedCurrency,
      identifier: randomIdentifier(),
      minesCount: parseInt(minesCount),
      fields: fields
    };

    console.log("🎲 Betting:", payload);

    const response = await fetch(`${CONFIG.apiUrl}/casino/mines/bet`, {
      method: "POST",
      headers: {
        "accept": "*/*",
        "content-type": "application/json",
        "x-access-token": bot.token
      },
      body: JSON.stringify(payload),
      credentials: "include"
    });
    
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    
    const data = await response.json();
    console.log("✅ Bet result:", data);
    return data;
  }

