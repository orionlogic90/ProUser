  /************** START BOT FUNCTION **************/
  async function startBot() {
    debugLog("=== START BOT CLICKED ===");
    
    if (bot.isRunning) {
      debugLog("Bot already running");
      return;
    }

    // Get values
    const amountEl = document.getElementById("amount");
    const currencyEl = document.getElementById("currency");
    const minesCountEl = document.getElementById("minesCount");

    bot.selectedCurrency = currencyEl.value;
    bot.selectedMines = parseInt(minesCountEl.value);
    
    // Get selected fields from modal
    const grid = document.querySelector("#grid");
    if (grid) {
      bot.selectedFields = [...grid.children]
        .filter(c => c.classList.contains("active"))
        .map(c => +c.textContent);
    }

    debugLog("Bot config:", {
      currency: bot.selectedCurrency,
      mines: bot.selectedMines,
      fields: bot.selectedFields.length,
      amount: amountEl.value,
      isDemo: bot.isDemo
    });

    // Validate fields
    if (bot.selectedFields.length === 0) {
      alert("Please select at least 1 field!");
      return;
    }

    // Save to localStorage
    saveLS("mine_amount", amountEl.value);
    saveLS("mine_currency", bot.selectedCurrency);
    saveLS("mine_minesCount", bot.selectedMines);

    // Reset stats - PASTIKAN startTime DI SET
    bot.stats = {
      profit: 0,
      wagered: 0,
      startBal: 0,
      currentBal: 0,
      bets: 0,
      wins: 0,
      loss: 0,
      startTime: Date.now(), // <-- INI PENTING!
      maxDD: 0,
      maxDDPerc: 0,
      history: []
    };
    
    bot.lastTelegramTime = Date.now();
    bot.lastBetTime = 0;
    bot.speedBetsCount = 0;
    bot.lastSpeedUpdate = Date.now();
    bot.betSpeed = 0;
    bot.globalMaxPayout = 0;
    
    // Reset martingale
    bot.martingale = {
      enabled: false,
      baseBet: parseFloat(amountEl.value),
      currentBet: parseFloat(amountEl.value),
      currentStep: 0,
      maxSteps: 5,
      mode: 'dynamic',
      multiplier: 2.0
    };

    // Get initial balance
    if (!bot.isDemo) {
      debugLog("Real mode - getting balance...");
      
      // Sync first
      const synced = await API.syncOnce();
      if (!synced) {
        alert("❌ Failed to sync. Please check your login/token.");
        bot.isRunning = false;
        return;
      }
      
      bot.stats.startBal = await API.getBalance(bot.selectedCurrency);
      debugLog(`Initial balance: ${bot.stats.startBal} ${bot.selectedCurrency}`);
      
      if (bot.stats.startBal <= 0) {
        alert(`❌ Insufficient ${bot.selectedCurrency.toUpperCase()} balance!`);
        bot.isRunning = false;
        return;
      }
    } else {
      debugLog("Demo mode - using fake balance");
      bot.stats.startBal = 100.0;
    }

    bot.stats.currentBal = bot.stats.startBal;
    bot.stats.history = [bot.stats.startBal];
    
    // Update UI
    bot.isRunning = true;
    document.getElementById("start").disabled = true;
    document.getElementById("stop").disabled = false;
    
    // Update display immediately
    updateDisplay();
    
    // Send start notification
    API.kirimPesan(`🚀 *MINES BOT STARTED*\nCurrency: ${bot.selectedCurrency.toUpperCase()}\nMines: ${bot.selectedMines}\nFields: ${bot.selectedFields.length}\nBalance: ${bot.stats.startBal.toFixed(8)}`);

    debugLog("✅ Bot started, starting loop...");
    
    // Start betting loop
    runMinesLoop();
  }

  /************** STOP BOT **************/
  function stopBot() {
    debugLog("Stopping bot...");
    bot.isRunning = false;
    document.getElementById("start").disabled = false;
    document.getElementById("stop").disabled = true;
    
    API.kirimPesan(`⏹ *MINES BOT STOPPED*\nProfit: ${bot.stats.profit.toFixed(8)} ${bot.selectedCurrency.toUpperCase()}\nBets: ${bot.stats.bets}`);
  }

  /************** MINES BETTING LOOP **************/
  async function runMinesLoop() {
    if (!bot.isRunning) {
      debugLog("Loop stopped - bot not running");
      return;
    }

    try {
      bot.lastBetTime = Date.now();
      
      // Get amount
      let amount = parseFloat(document.getElementById("amount").value);
      
      // Ensure amount doesn't exceed balance
      if (amount > bot.stats.currentBal) {
        amount = bot.stats.currentBal * 0.95;
        debugLog("Adjusted amount to:", amount);
      }
      
      if (amount <= 0) {
        debugLog("❌ Invalid amount:", amount);
        bot.isRunning = false;
        document.getElementById("start").disabled = false;
        document.getElementById("stop").disabled = true;
        return;
      }
      
      debugLog(`Betting ${amount} ${bot.selectedCurrency}...`);
      
      // Place bet
      const result = await API.placeMinesBet(amount, bot.selectedMines, bot.selectedFields);
      
      const d = result?.data?.minesBet || result?.minesBet;
      
      if (d) {
        bot.speedBetsCount++;
        updateBetSpeed();
        
        const win = d.payout > 0;
        const payout = d.payout || 0;
        const multiplier = d.payoutMultiplier || 0;
        
        const profit = payout - amount;
        bot.stats.bets++;
        bot.stats.wagered += amount;
        bot.stats.profit += profit;
        bot.stats.currentBal += profit;
        
        if (win) {
          bot.stats.wins++;
          debugLog("✅ WIN -", multiplier, "x");
        } else {
          bot.stats.loss++;
          debugLog("❌ LOSS");
        }
        
        // Track max payout
        if (multiplier > bot.globalMaxPayout) {
          bot.globalMaxPayout = multiplier;
        }
        
        // Update history
        bot.stats.history.push(bot.stats.currentBal);
        if (bot.stats.history.length > 50) {
          bot.stats.history.shift();
        }
        
        // Add log
        addLog(amount, payout, multiplier, win);
        
        // Update display
        updateDisplay();
        
        // Check for big win
        if (multiplier > 20) {
          API.kirimPesan(`💰 *BIG WIN!*\nPayout: ${multiplier.toFixed(2)}x\nAmount: ${payout.toFixed(8)} ${bot.selectedCurrency.toUpperCase()}`);
        }
      }
      
      // Continue loop with delay
      if (bot.isRunning) {
        setTimeout(runMinesLoop, 500); // Delay 500ms antara bet
      }
      
    } catch (e) {
      debugLog("❌ Bet error:", e);
      if (bot.isRunning) {
        setTimeout(runMinesLoop, 2000); // Lebih lama kalau error
      }
    }
  }

  /************** INITIALIZATION **************/
  function init() {
    debugLog("Initializing Orion Mines...");
    
    // Create UI
    createUI();
    
    // Try to sync immediately
    setTimeout(() => {
      API.syncOnce().then(success => {
        if (success) {
          debugLog("Initial sync successful");
          // Get balance for default currency
          API.getBalance(bot.selectedCurrency).then(bal => {
            bot.stats.currentBal = bal;
            updateDisplay();
          });
        } else {
          debugLog("Initial sync failed, will retry...");
        }
      });
    }, 1000);
    
    // Update display periodically even when not running
    setInterval(() => {
      if (!bot.isRunning) {
        updateDisplay();
      }
    }, 1000);
  }

  // Start everything
  init();
})();
