    // Validate fields
    if (bot.selectedFields.length === 0) {
      alert("Please select at least 1 field!");
      return;
    }

    // Save to localStorage
    saveLS("mine_amount", amountEl.value);
    saveLS("mine_currency", currencyEl.value);
    saveLS("mine_minesCount", minesCountEl.value);

    // Start bot
    bot.isRunning = true;
    document.getElementById("start").disabled = true;
    document.getElementById("stop").disabled = false;

    // Reset stats
    bot.stats = {
      profit: 0,
      wagered: 0,
      startBal: 0,
      currentBal: 0,
      bets: 0,
      wins: 0,
      loss: 0,
      startTime: Date.now(),
      maxDD: 0,
      maxDDPerc: 0,
      history: []
    };
    
    bot.lastTelegramTime = Date.now();
    bot.lastBetTime = 0;
    bot.speedBetsCount = 0;
    bot.lastSpeedUpdate = Date.now();
    bot.betSpeed = 0;
    bot.globalMaxPayout = 0;
    
    // Reset martingale
    bot.martingale.baseBet = parseFloat(amountEl.value);
    bot.martingale.currentBet = bot.martingale.baseBet;
    bot.martingale.currentStep = 0;
    bot.streak.lossStreak = 0;
    bot.streak.winStreak = 0;

    // Get initial balance
    if (!bot.isDemo) {
      await API.syncOnce();
      bot.stats.startBal = await API.getBalance(bot.selectedCurrency);
    } else {
      bot.stats.startBal = parseFloat(document.getElementById("demo-balance")?.value) || 100.0;
    }

    bot.stats.currentBal = bot.stats.startBal;
    bot.stats.history = [bot.stats.startBal];

    // Send start report
    API.kirimPesan(`🚀 *MINES BOT STARTED*\nCurrency: ${bot.selectedCurrency.toUpperCase()}\nMines: ${bot.selectedMines}\nFields: ${bot.selectedFields.length}\nBalance: ${bot.stats.startBal.toFixed(8)}`);

    // Start betting loop
    runMinesLoop();
  };

  /************** STOP BOT **************/
  document.getElementById("stop").onclick = async () => {
    bot.isRunning = false;
    document.getElementById("start").disabled = false;
    document.getElementById("stop").disabled = true;
    
    API.kirimPesan(`⏹ *MINES BOT STOPPED*\nProfit: ${bot.stats.profit.toFixed(8)} ${bot.selectedCurrency.toUpperCase()}\nBets: ${bot.stats.bets}`);
    await API.sendTelegramReport();
  };

  /************** MINES BETTING LOOP **************/
  async function runMinesLoop() {
    if (!bot.isRunning) return;

    try {
      bot.lastBetTime = Date.now();
      
      // Calculate bet amount with martingale
      let amount = bot.martingale.enabled ? bot.martingale.currentBet : parseFloat(document.getElementById("amount").value);
      
      // Ensure amount doesn't exceed balance
      if (amount > bot.stats.currentBal) {
        amount = bot.stats.currentBal * 0.95;
      }
      
      // Place bet
      const result = await API.placeMinesBet(amount, bot.selectedMines, bot.selectedFields);
      
      const d = result?.data?.minesBet || result?.minesBet;
      
      if (d) {
        bot.speedBetsCount++;
        updateBetSpeed();
        
        const win = d.payout > 0;
        const payout = d.payout || 0;
        const multiplier = d.payoutMultiplier || 0;
        
        // Calculate profit
        const profit = payout - amount;
        bot.stats.bets++;
        bot.stats.wagered += amount;
        bot.stats.profit += profit;
        bot.stats.currentBal += profit;
        
        // Track wins/losses
        if (win) {
          bot.stats.wins++;
        } else {
          bot.stats.loss++;
        }
        
        // Track max payout
        if (multiplier > bot.globalMaxPayout) {
          bot.globalMaxPayout = multiplier;
          API.kirimPesan(`🔥 *New Max Payout!*\n${multiplier.toFixed(2)}x`);
        }
        
        // Update history
        bot.stats.history.push(bot.stats.currentBal);
        if (bot.stats.history.length > 50) {
          bot.stats.history.shift();
        }
        
        // Calculate drawdown
        if (bot.stats.currentBal < bot.stats.startBal) {
          const dd = bot.stats.startBal - bot.stats.currentBal;
          const ddPerc = (dd / bot.stats.startBal) * 100;
          if (dd > bot.stats.maxDD) bot.stats.maxDD = dd;
          if (ddPerc > bot.stats.maxDDPerc) bot.stats.maxDDPerc = ddPerc;
        }
        
        // Update martingale
        if (bot.martingale.enabled) {
          const nextBet = calculateMartingaleBet(bot.martingale.baseBet, win);
          bot.martingale.currentBet = nextBet;
        }
        
        // Add log
        addLog(amount, payout, multiplier, win);
        
        // Update display
        updateDisplay();
        
        // Check for chart report
        const currentWagerFloor = Math.floor(bot.stats.wagered / bot.chartReportInterval);
        const lastWagerFloor = Math.floor(bot.lastChartWagerAmount / bot.chartReportInterval);
        
        if (currentWagerFloor > lastWagerFloor && bot.stats.bets > 0) {
          await API.sendChartReport();
        }
        
        bot.lastChartWagerAmount = bot.stats.wagered;
        
        // Check for big win
        if (multiplier > 20) {
          API.kirimPesan(`💰 *BIG WIN!*\nPayout: ${multiplier.toFixed(2)}x\nAmount: ${payout.toFixed(8)} ${bot.selectedCurrency.toUpperCase()}`);
        }
        
        // Check targets
        if (checkTargets()) {
          bot.isRunning = false;
          document.getElementById("start").disabled = false;
          document.getElementById("stop").disabled = true;
          return;
        }
      }
      
      // Send periodic telegram report
      const now = Date.now();
      if (now - bot.lastTelegramTime >= bot.telegramInterval) {
        await API.sendTelegramReport();
        bot.lastTelegramTime = now;
      }
      
      // Continue loop
      if (bot.isRunning) {
        setTimeout(runMinesLoop, 200);
      }
      
    } catch (e) {
      console.error("Bet error:", e);
      if (bot.isRunning) {
        setTimeout(runMinesLoop, 1000);
      }
    }
  }

  /************** DRAGGABLE **************/
  const dragElement = (el) => {
    let offsetX = 0, offsetY = 0, startX = 0, startY = 0;

    const onMouseDown = (e) => {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT' || e.target.tagName === 'BUTTON') return;
      startX = e.clientX;
      startY = e.clientY;
      offsetX = el.offsetLeft;
      offsetY = el.offsetTop;
      document.addEventListener('mousemove', onMouseMove);
      document.addEventListener('mouseup', onMouseUp);
      e.preventDefault();
    };

    const onMouseMove = (e) => {
      const dx = e.clientX - startX;
      const dy = e.clientY - startY;
      el.style.left = offsetX + dx + 'px';
      el.style.top = offsetY + dy + 'px';
      el.style.right = 'auto';
    };

    const onMouseUp = () => {
      document.removeEventListener('mousemove', onMouseMove);
      document.removeEventListener('mouseup', onMouseUp);
    };

    el.addEventListener('mousedown', onMouseDown);
  };

  dragElement(ui);

  // Initial sync
  setTimeout(() => {
    API.syncOnce();
  }, 1000);
})();
