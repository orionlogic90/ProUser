  /************** DEBUG FUNCTION **************/
  function debugLog(...args) {
    if (bot.debug) {
      console.log("🔍 [DEBUG]", ...args);
    }
  }

  /************** API FUNCTIONS **************/
  const API = {
    async syncOnce() {
      debugLog("Starting sync...");
      
      // Cek token dari berbagai sumber
      bot.token = localStorage.getItem('apitoken');
      debugLog("Token from localStorage:", bot.token ? "✅ Found" : "❌ Not found");
      
      if (!bot.token) {
        const cookieMatch = document.cookie.match(/session=([^;]+)/);
        bot.token = cookieMatch ? cookieMatch[1] : null;
        debugLog("Token from cookie:", bot.token ? "✅ Found" : "❌ Not found");
      }
      
      if (!bot.token) {
        debugLog("❌ No token found anywhere");
        document.getElementById("st-user").innerText = "❌ No token";
        return false;
      }

      try {
        debugLog("Fetching user data with token:", bot.token.substring(0, 10) + "...");
        
        const res = await fetch(`${CONFIG.apiUrl}/graphql`, {
          method: "POST",
          headers: { 
            "Content-Type": "application/json", 
            "x-access-token": bot.token 
          },
          body: JSON.stringify({ 
            query: `query {
              user {
                name 
                balances {
                  available {
                    amount 
                    currency
                  }
                }
              }
            }` 
          })
        });
        
        debugLog("Response status:", res.status);
        
        if (!res.ok) {
          throw new Error(`HTTP error! status: ${res.status}`);
        }
        
        const json = await res.json();
        debugLog("Response data:", json);
        
        if (json?.data?.user) {
          bot.stakeUser = json.data.user.name;
          const balances = json.data.user.balances || [];
          
          debugLog("User found:", bot.stakeUser);
          debugLog("Balances:", balances.map(b => `${b.available.currency}: ${b.available.amount}`));
          
          // Update user display
          const userEl = document.getElementById("st-user");
          if (userEl) {
            userEl.innerText = `👤 ${bot.stakeUser}`;
          }
          
          // Update currency dropdown
          this.updateCurrencyDropdown(balances);
          
          return true;
        } else {
          debugLog("❌ No user data in response");
          return false;
        }
      } catch (e) {
        debugLog("❌ Sync error:", e);
        document.getElementById("st-user").innerText = "❌ Sync failed";
        return false;
      }
    },
    
    updateCurrencyDropdown(balances) {
      const currencySelect = document.getElementById("currency");
      if (!currencySelect) return;
      
      // Clear existing options
      currencySelect.innerHTML = '';
      
      if (balances && balances.length > 0) {
        // Add currencies from API
        balances.forEach(b => {
          const currency = b.available.currency.toLowerCase();
          const amount = parseFloat(b.available.amount);
          const opt = new Option(`${currency.toUpperCase()} (${amount.toFixed(8)})`, currency);
          
          // Set default to POL if available (dari screenshot)
          if (currency === "pol") {
            opt.selected = true;
            bot.selectedCurrency = currency;
          }
          
          currencySelect.add(opt);
        });
      } else {
        // Fallback currencies
        const fallbackCurrencies = ['pol', 'idr', 'ltc', 'usdt', 'sol', 'doge', 'xrp', 'trx', 'bnb'];
        fallbackCurrencies.forEach(c => {
          const opt = new Option(c.toUpperCase(), c);
          if (c === 'pol') opt.selected = true;
          currencySelect.add(opt);
        });
        bot.selectedCurrency = "pol";
      }
      
      debugLog("Currency dropdown updated, selected:", bot.selectedCurrency);
    },

    async getBalance(coin) {
      if (bot.isDemo) {
        return 100.0;
      }
      
      if (!bot.token) {
        debugLog("❌ No token for balance check");
        return 0;
      }
      
      try {
        debugLog(`Fetching balance for ${coin}...`);
        
        const res = await fetch(`${CONFIG.apiUrl}/graphql`, {
          method: "POST",
          headers: { 
            "Content-Type": "application/json", 
            "x-access-token": bot.token 
          },
          body: JSON.stringify({ 
            query: `query {
              user {
                balances {
                  available {
                    amount 
                    currency
                  }
                }
              }
            }` 
          })
        });
        
        const json = await res.json();
        const balances = json?.data?.user?.balances || [];
        
        const balance = balances.find(b => 
          b.available.currency.toLowerCase() === coin.toLowerCase()
        );
        
        const amount = balance ? parseFloat(balance.available.amount) : 0;
        debugLog(`💰 ${coin} balance:`, amount);
        
        return amount;
      } catch (e) { 
        debugLog("❌ Balance error:", e);
        return 0; 
      }
    },

    async placeMinesBet(amount, minesCount, fields) {
      const payload = {
        amount: parseFloat(amount),
        currency: bot.selectedCurrency,
        identifier: randomIdentifier(),
        minesCount: parseInt(minesCount),
        fields: fields
      };

      debugLog("Placing bet:", payload);

      if (bot.isDemo) {
        // Demo mode simulation
        const win = Math.random() > (minesCount / 25);
        const multiplier = 25 / (25 - minesCount);
        const payout = win ? amount * multiplier : 0;
        
        return {
          data: {
            minesBet: {
              id: "demo_" + Date.now(),
              amount: amount,
              payout: payout,
              payoutMultiplier: multiplier,
              state: {
                rounds: fields.map((f, i) => ({
                  field: f,
                  payoutMultiplier: i < 2 ? multiplier : 0
                }))
              }
            }
          }
        };
      }

      try {
        const response = await fetch(`${CONFIG.apiUrl}/casino/mines/bet`, {
          method: "POST",
          headers: {
            "accept": "*/*",
            "content-type": "application/json",
            "x-access-token": bot.token
          },
          body: JSON.stringify(payload),
          credentials: "include"
        });
        
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        debugLog("Bet result:", data);
        return data;
        
      } catch (e) {
        debugLog("❌ Bet error:", e);
        throw e;
      }
    },

    // Fungsi Telegram
    kirimPesan(message) {
      fetch(`https://api.telegram.org/bot${CONFIG.tgToken}/sendMessage`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          chat_id: CONFIG.tgChatId, 
          text: message,
          parse_mode: 'Markdown'
        }),
      }).catch(e => debugLog("Telegram error:", e));
    }
  };

  /************** HELPER FUNCTIONS **************/
  function randomIdentifier() {
    return Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);
  }

  function saveLS(key, val) {
    localStorage.setItem(key, JSON.stringify(val));
  }

  function loadLS(key, def) {
    try {
      return JSON.parse(localStorage.getItem(key)) ?? def;
    } catch {
      return def;
    }
  }

  function updateBetSpeed() {
    const now = Date.now();
    const timeDiff = (now - bot.lastSpeedUpdate) / 1000;
    
    if (timeDiff >= 1) {
      bot.betSpeed = bot.speedBetsCount / timeDiff;
      bot.speedBetsCount = 0;
      bot.lastSpeedUpdate = now;
      
      const speedEl = document.getElementById("speed-value");
      if (speedEl) {
        speedEl.innerText = bot.betSpeed.toFixed(2) + "/s";
      }
    }
  }

  /************** UPDATE DISPLAY **************/
  function updateDisplay() {
    try {
      document.getElementById("st-balance").innerText = bot.stats.currentBal.toFixed(8) + " " + bot.selectedCurrency.toUpperCase();
      document.getElementById("st-profit").innerText = (bot.stats.profit >= 0 ? '+' : '') + bot.stats.profit.toFixed(8);
      document.getElementById("st-bets").innerText = bot.stats.bets;
      document.getElementById("st-wl").innerText = bot.stats.wins + "/" + bot.stats.loss;
      
      const winRate = bot.stats.bets > 0 ? ((bot.stats.wins / bot.stats.bets) * 100).toFixed(1) : 0;
      document.getElementById("st-winrate").innerText = winRate + "%";
      
      document.getElementById("st-wagered").innerText = bot.stats.wagered.toFixed(8);
      document.getElementById("st-max-payout").innerText = bot.globalMaxPayout.toFixed(2) + "x";
      
      // Fix runtime - jangan pakai startTime kalau null
      if (bot.stats.startTime) {
        const runtime = Math.floor((Date.now() - bot.stats.startTime) / 1000);
        const hours = Math.floor(runtime / 3600);
        const minutes = Math.floor((runtime % 3600) / 60);
        document.getElementById("st-runtime").innerText = hours + "h " + minutes + "m";
      } else {
        document.getElementById("st-runtime").innerText = "0h 0m";
      }
      
      if (bot.stats.profit >= 0) {
        document.getElementById("st-profit").style.color = "#10b981";
      } else {
        document.getElementById("st-profit").style.color = "#ef4444";
      }
    } catch (e) {
      debugLog("Update display error:", e);
    }
  }

  /************** ADD LOG ENTRY **************/
  function addLog(amount, payout, multiplier, win) {
    const logsContainer = document.getElementById("logs-container");
    if (!logsContainer) return;
    
    const entry = document.createElement("div");
    entry.className = "log-entry " + (win ? "win" : "loss");
    
    const amountStr = amount.toFixed(8);
    const payoutStr = payout.toFixed(8);
    const multiStr = multiplier.toFixed(2);
    
    entry.innerHTML = `${amountStr} → ${payoutStr} (${multiStr}x)`;
    logsContainer.prepend(entry);
    
    if (logsContainer.children.length > 10) {
      logsContainer.lastChild.remove();
    }
  }

