  /************** HELPER FUNCTIONS **************/
  function randomIdentifier() {
    const length = Math.floor(Math.random() * (32 - 20 + 1)) + 20;
    return Array.from({ length }, () => Math.floor(Math.random() * 10)).join("");
  }

