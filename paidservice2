    // ==================== FUNGSI INITIALIZATION ====================
    function initbet_limbo() {
        // baselimbo = (balance/50)*8e-5
        bot.baselimbo = (bot.stats.currentBal / 50) * 8e-5;
        bot.basebet = bot.baselimbo;
