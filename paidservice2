  /************** START BOT **************/
  async function startBot() {
    console.log("▶️ START clicked");
    
    if (bot.isRunning) {
      alert("Bot already running");
      return;
    }
    
    // Get selected fields
    const fieldGrid = document.querySelector("#fieldGrid");
    if (fieldGrid) {
      bot.selectedFields = [...fieldGrid.children]
        .filter(c => c.classList.contains("active"))
        .map(c => +c.textContent);
    }
    
    if (bot.selectedFields.length === 0) {
      alert("Pilih minimal 1 field!");
      return;
    }
    
    // Get token
    bot.token = localStorage.getItem('apitoken') || 
                (document.cookie.match(/session=([^;]+)/) ? 
                document.cookie.match(/session=([^;]+)/)[1] : null);
    
    if (!bot.token) {
      alert("❌ Tidak ada token! Login dulu di Stake.");
      return;
    }
    
    // Sync user and get balance
    const synced = await syncUser();
    if (!synced) {
      alert("❌ Gagal sync user. Coba refresh.");
      return;
    }
    
    const balance = await getBalance(bot.selectedCurrency);
    console.log(`💰 Balance: ${balance} ${bot.selectedCurrency}`);
    
    if (balance <= 0) {
      alert(`❌ Balance ${bot.selectedCurrency.toUpperCase()} 0!`);
      return;
    }
    
    // Reset stats
    bot.stats = {
      profit: 0,
      wagered: 0,
      startBal: balance,
      currentBal: balance,
      bets: 0,
      wins: 0,
      loss: 0,
      startTime: Date.now(),
      maxDD: 0,
      maxDDPerc: 0,
      history: [balance]
    };
    
    bot.isRunning = true;
    bot.lastTelegramTime = Date.now();
    bot.globalMaxPayout = 0;
    
    document.getElementById("start").disabled = true;
    document.getElementById("stop").disabled = false;
    
    updateDisplay();
    addLog(`🚀 Bot started | Balance: ${balance.toFixed(8)}`, true);
    
    // Send Telegram notification
    kirimPesanTelegram(`🚀 *MINES BOT STARTED*\nCurrency: ${bot.selectedCurrency.toUpperCase()}\nMines: ${bot.selectedMines}\nFields: ${bot.selectedFields.length}\nBalance: ${balance.toFixed(8)}`);
    
    // Start loop
    runLoop();
  }
  
  function stopBot() {
    console.log("⏹️ STOP clicked");
    bot.isRunning = false;
    document.getElementById("start").disabled = false;
    document.getElementById("stop").disabled = true;
    
    addLog(`⏹️ Bot stopped | Profit: ${bot.stats.profit.toFixed(8)}`, false);
    
    kirimPesanTelegram(`⏹ *MINES BOT STOPPED*\nProfit: ${bot.stats.profit.toFixed(8)} ${bot.selectedCurrency.toUpperCase()}\nBets: ${bot.stats.bets}`);
  }
  
  /************** BETTING LOOP **************/
  async function runLoop() {
    if (!bot.isRunning) return;
    
    try {
      const amount = parseFloat(document.getElementById("amount").value);
      
      // Validate amount
      if (amount > bot.stats.currentBal) {
        addLog(`❌ Insufficient balance!`, false);
        stopBot();
        return;
      }
      
      // Place bet
      const result = await placeMinesBet(amount, bot.selectedMines, bot.selectedFields);
      const d = result?.data?.minesBet || result?.minesBet;
      
      if (d) {
        bot.speedBetsCount++;
        updateBetSpeed();
        
        const win = d.payout > 0;
        const payout = d.payout || 0;
        const multiplier = d.payoutMultiplier || 0;
        
        const profit = payout - amount;
        bot.stats.bets++;
        bot.stats.wagered += amount;
        bot.stats.profit += profit;
        bot.stats.currentBal += profit;
        bot.stats.history.push(bot.stats.currentBal);
        
        if (win) {
          bot.stats.wins++;
          addLog(`✅ WIN ${multiplier.toFixed(2)}x | +${profit.toFixed(8)}`, true);
        } else {
          bot.stats.loss++;
          addLog(`❌ LOSS | ${amount.toFixed(8)}`, false);
        }
        
        // Track max payout
        if (multiplier > bot.globalMaxPayout) {
          bot.globalMaxPayout = multiplier;
          if (multiplier > 10) {
            kirimPesanTelegram(`🔥 *New Max Payout!*\n${multiplier.toFixed(2)}x`);
          }
        }
        
        updateDisplay();
        
        // Check for big win
        if (multiplier > 20) {
          kirimPesanTelegram(`💰 *BIG WIN!*\nPayout: ${multiplier.toFixed(2)}x\nAmount: ${payout.toFixed(8)} ${bot.selectedCurrency.toUpperCase()}`);
        }
      }
      
      // Send periodic Telegram report (every 3 minutes)
      const now = Date.now();
      if (now - bot.lastTelegramTime >= 180000) {
        sendTelegramReport();
        bot.lastTelegramTime = now;
      }
      
      // Continue loop with delay
      if (bot.isRunning) {
        setTimeout(runLoop, 500);
      }
      
    } catch (e) {
      console.log("❌ Loop error:", e);
      addLog(`⚠️ Error: ${e.message}`, false);
      if (bot.isRunning) {
        setTimeout(runLoop, 2000);
      }
    }
  }
  
  function updateBetSpeed() {
    const now = Date.now();
    const diff = (now - bot.lastSpeedUpdate) / 1000;
    
    if (diff >= 1) {
      bot.betSpeed = bot.speedBetsCount / diff;
      bot.speedBetsCount = 0;
      bot.lastSpeedUpdate = now;
    }
  }
  
  function sendTelegramReport() {
    const runtime = Math.floor((Date.now() - bot.stats.startTime) / 1000);
    const hours = Math.floor(runtime / 3600);
    const minutes = Math.floor((runtime % 3600) / 60);
    
    const winRate = bot.stats.bets > 0 ? (bot.stats.wins / bot.stats.bets * 100).toFixed(1) : 0;
    const pnlPct = (bot.stats.profit / bot.stats.startBal * 100).toFixed(2);
    
    let message = "```\n";
    message += `⚡ MINES REPORT ⚡\n`;
    message += `════════════════\n`;
    message += `Runtime : ${hours}h ${minutes}m\n`;
    message += `Currency: ${bot.selectedCurrency.toUpperCase()}\n`;
    message += `Mines   : ${bot.selectedMines}\n`;
    message += `\n`;
    message += `Start   : ${bot.stats.startBal.toFixed(8)}\n`;
    message += `Current : ${bot.stats.currentBal.toFixed(8)}\n`;
    message += `P/L     : ${bot.stats.profit >= 0 ? '+' : ''}${bot.stats.profit.toFixed(8)} (${pnlPct}%)\n`;
    message += `Max Payout: ${bot.globalMaxPayout.toFixed(2)}x\n`;
    message += `\n`;
    message += `Bets    : ${bot.stats.bets}\n`;
    message += `W/L     : ${bot.stats.wins}/${bot.stats.loss}\n`;
    message += `WinRate : ${winRate}%\n`;
    message += `Wagered : ${bot.stats.wagered.toFixed(8)}\n`;
    message += "```";
    
    kirimPesanTelegram(message);
  }
  
  /************** UPDATE DISPLAY **************/
  function updateDisplay() {
    try {
      document.getElementById("st-balance").innerText = bot.stats.currentBal.toFixed(8) + " " + bot.selectedCurrency.toUpperCase();
      document.getElementById("st-profit").innerText = (bot.stats.profit >= 0 ? '+' : '') + bot.stats.profit.toFixed(8);
      document.getElementById("st-bets").innerText = bot.stats.bets;
      document.getElementById("st-wl").innerText = bot.stats.wins + "/" + bot.stats.loss;
      
      const winRate = bot.stats.bets > 0 ? ((bot.stats.wins / bot.stats.bets) * 100).toFixed(1) : 0;
      document.getElementById("st-winrate").innerText = winRate + "%";
      
      document.getElementById("st-wagered").innerText = bot.stats.wagered.toFixed(8);
      document.getElementById("st-max-payout").innerText = bot.globalMaxPayout.toFixed(2) + "x";
      
      if (bot.stats.startTime) {
        const runtime = Math.floor((Date.now() - bot.stats.startTime) / 1000);
        const hours = Math.floor(runtime / 3600);
        const minutes = Math.floor((runtime % 3600) / 60);
        document.getElementById("st-runtime").innerText = hours + "h " + minutes + "m";
      }
      
      if (bot.stats.profit >= 0) {
        document.getElementById("st-profit").style.color = "#00c853";
      } else {
        document.getElementById("st-profit").style.color = "#d50000";
      }
    } catch (e) {
      console.log("Update error:", e);
    }
  }
  
  /************** ADD LOG **************/
  function addLog(text, isWin) {
    const logs = document.getElementById("logs");
    if (!logs) return;
    
    const div = document.createElement("div");
    div.className = isWin ? "log-win" : "log-loss";
    div.style.padding = "2px 0";
    div.style.borderBottom = "1px solid #334155";
    div.style.fontSize = "11px";
    div.innerText = `[${new Date().toLocaleTimeString()}] ${text}`;
    
    logs.prepend(div);
    
    if (logs.children.length > 15) {
      logs.lastChild.remove();
    }
  }

  /************** INIT **************/
  function init() {
    console.log("🚀 Initializing Orion Mines...");
    createUI();
    
    // Auto sync on load
    setTimeout(() => {
      syncUser().then(() => {
        if (bot.token) {
          getBalance(bot.selectedCurrency).then(bal => {
            bot.stats.currentBal = bal;
            updateDisplay();
          });
        }
      });
    }, 1000);
    
    // Update display periodically
    setInterval(updateDisplay, 1000);
  }
  
  // Start
  init();
})();
