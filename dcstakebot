    function getCurrentBalance() {
        return bot.stats.startBal + bot.stats.profit;
    }

    function getTotalLossPercentage() {
        const currentBalance = getCurrentBalance();
        if (bot.startBalance === 0) return 0;
        return ((bot.startBalance - currentBalance) / bot.startBalance) * 100;
    }
    
    function updateBalanceHistory() {
        const currentBalance = getCurrentBalance();
        bot.balanceHistory.push({
            time: Date.now(),
            balance: currentBalance
        });
        if (bot.balanceHistory.length > bot.maxChartPoints) {
            bot.balanceHistory.shift();
        }
        
        if (balanceChart && bot.balanceHistory.length > 1) {
            const labels = bot.balanceHistory.map((_, idx) => idx);
            const data = bot.balanceHistory.map(p => p.balance);
            balanceChart.data.labels = labels;
            balanceChart.data.datasets[0].data = data;
            balanceChart.update('none');
        }
    }
    
