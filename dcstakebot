        if (dom.badge) dom.badge.innerText = bot.isRunning ? "● RUNNING" : "○ STOPPED";
        if (dom.eta) dom.eta.innerText = estimateTimeRemaining();
    }

    function updateBetSpeed() {
        let now = Date.now();
        bot.betCount++;
        if (now - bot.lastSecCalc >= 1000) {
            bot.betsPerSec = bot.betCount;
            bot.betCount = 0;
            bot.lastSecCalc = now;
        }
    }

    function resetToPhase1() {
        bot.phase = 1;
        bot.chance = bot.phase1.chance;
        bot.playgame = "dice";
        bot.nextbet = Math.max(bot.minbet, getCurrentBalance() / bot.phase1.basebetDiv);
        bot.phase3Chance = bot.phase3.minChance;
    }

    function goToPhase2() { 
        bot.phase = 2; 
        bot.playgame = "limbo";
        bot.nextbet = Math.max(bot.minbet, getCurrentBalance() * bot.phase2.basebetMult);
    }
    
    function goToPhase3() { 
        bot.phase = 3; 
        bot.chance = bot.phase3.minChance; 
        bot.phase3Chance = bot.phase3.minChance; 
        bot.playgame = "dice"; 
        bot.nextbet = Math.max(bot.minbet, getCurrentBalance() * bot.phase3.basebetMult);
    }

    function stopBot() {
        if (bot.isRunning) {
            bot.isRunning = false;
            if (reportInterval) { clearInterval(reportInterval); reportInterval = null; }
            loopRunning = false;
            sendTelegramReport("🛑 BOT STOPPED");
            if (dom.badge) dom.badge.innerText = "○ STOPPED";
            updateUI();
        }
    }

