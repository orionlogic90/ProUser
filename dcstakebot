                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ chat_id: CONFIG.tgChatId, photo: chartUrl, caption: "📊 Balance Chart" })
                    }).catch(() => {});
                }, 500);
            }
        },
        async placeBet(amount, payout, game) {
            const endpoint = game === "dice" ? `${CONFIG.apiUrl}/casino/dice/roll` : `${CONFIG.apiUrl}/casino/limbo/bet`;
            const payload = { amount: parseFloat(amount), currency: bot.selectedCurrency, identifier: Math.random().toString(36).slice(2) + Date.now().toString(36) };
            if (game === "dice") { payload.target = 100 - (100 / payout); payload.condition = "above"; }
            else { payload.multiplierTarget = parseFloat(payout); }
            return fetch(endpoint, { method: "POST", headers: { "Content-Type": "application/json", "x-access-token": bot.token }, body: JSON.stringify(payload) }).then(r => r.json());
        }
    };

    function init() {
        ensureHudAndControls().then(() => {
            document.getElementById("orion-start-btn").onclick = async () => {
                if (!bot.isRunning) {
                    await API.syncOnce();
                    loadConfigFromUI();
                    bot.startBalance = bot.stats.startBal;
                    bot.balst = bot.stats.startBal;
                    bot.balhigh = bot.stats.startBal;
                    bot.worstBalance = bot.stats.startBal;
                    bot.target = bot.stats.startBal * 10;
                    bot.wagtarget = bot.stats.startBal * bot.targetWager;
                    bot.stime = Date.now() / 1000;
                    bot.wager = 0;
                    bot.phase3LossStreak = 0;
                    bot.lastWin = false;
                    bot.highestBet = 0;
                    bot.worstDrawdown = 0;
                    bot.pendingStopAfterRecovery = false;
                    bot.stats = { profit: 0, wagered: 0, wageredUSD: 0, startBal: bot.stats.startBal, bets: 0, wins: 0, loss: 0, maxDD: 0, ties: 0 };
                    bot.isRunning = true;
                    bot.startTime = new Date();
                    resetToPhase1();
                    setTimeout(() => API.sendTg("🚀 BOT STARTED"), 1000);
                    if (reportInterval) clearInterval(reportInterval);
                    reportInterval = setInterval(() => { if (bot.isRunning) API.sendTg("📊 PERIODIC"); }, 180000);
                    updateHud(true);
                    runLoop();
                }
            };
            document.getElementById("orion-stop-btn").onclick = () => { if (bot.isRunning) stopBot(); };
        });
    }
    
    setInterval(() => { updateHud(false); }, 300);
    init();
    API.syncOnce();
})();
