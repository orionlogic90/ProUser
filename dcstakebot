            <div style="background: rgba(0, 0, 0, 0.3); border-radius: 10px; padding: 8px;">
                <div style="color: #6c7293; font-size: 9px; margin-bottom: 4px;">📊 TOTAL BETS</div>
                <div id="HUD_BTS" style="color: #ffffff; font-size: 14px; font-weight: 700;">0</div>
            </div>
            <div style="background: rgba(0, 0, 0, 0.3); border-radius: 10px; padding: 8px;">
                <div style="color: #6c7293; font-size: 9px; margin-bottom: 4px;">⏰ ETA</div>
                <div id="HUD_ETA" style="color: #00ff88; font-size: 11px; font-weight: 600;">Calculating...</div>
            </div>
        `;
        dashboard.appendChild(stats);
        
        // Progress Wager
        let prog = document.createElement("div");
        prog.style.cssText = "background: rgba(0, 0, 0, 0.3); border-radius: 10px; padding: 10px; margin-bottom: 16px;";
        prog.innerHTML = `
            <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                <span style="color: #6c7293; font-size: 9px; font-weight: 600;">🎯 WAGER PROGRESS</span>
                <span id="WAGER_PCT" style="color: #ffd93d; font-size: 10px; font-weight: 700;">0%</span>
            </div>
            <div style="background: rgba(0, 0, 0, 0.5); border-radius: 6px; height: 6px; overflow: hidden;">
                <div id="WAGER_FILL" style="width: 0%; height: 100%; background: linear-gradient(90deg, #00ff88, #ffd93d); border-radius: 6px;"></div>
            </div>
            <div style="display: flex; justify-content: space-between; margin-top: 6px;">
                <span id="WAGER_CUR" style="color: #ffffff; font-size: 9px; font-weight: 600;">0</span>
                <span id="WAGER_TAR" style="color: #6c7293; font-size: 9px;">0</span>
            </div>
        `;
        dashboard.appendChild(prog);
        
        // Buttons
        let btns = document.createElement("div");
        btns.style.cssText = "display: flex; gap: 8px;";
        btns.innerHTML = `
            <button id="BTN_START" style="flex: 1; background: linear-gradient(135deg, #00ff88, #00cc6a); border: none; border-radius: 8px; padding: 8px; color: #0a0e1a; font-weight: 700; font-size: 11px; cursor: pointer; transition: transform 0.1s;">▶ START</button>
            <button id="BTN_STOP" style="flex: 1; background: rgba(255, 71, 87, 0.15); border: 1px solid rgba(255, 71, 87, 0.3); border-radius: 8px; padding: 8px; color: #ff4757; font-weight: 700; font-size: 11px; cursor: pointer;">■ STOP</button>
            <button id="BTN_REPORT" style="flex: 1; background: rgba(255, 217, 61, 0.15); border: 1px solid rgba(255, 217, 61, 0.3); border-radius: 8px; padding: 8px; color: #ffd93d; font-weight: 700; font-size: 11px; cursor: pointer;">📋 REPORT</button>
        `;
        dashboard.appendChild(btns);
        
        // Config Panel
        let configPanel = document.createElement("div");
        configPanel.id = "PANEL_CONF";
        configPanel.style.cssText = "display: none; padding: 16px; max-height: 400px; overflow-y: auto;";
        
        let cfgContent = document.createElement("div");
        cfgContent.style.cssText = "background: rgba(0, 0, 0, 0.3); border-radius: 10px; padding: 12px;";
        cfgContent.innerHTML = '<div style="font-size: 11px; font-weight: 700; color: #00ff88; margin-bottom: 12px;">⚙️ SYSTEM CONFIGURATION</div>';
        
        let cfgItems = [
            ["💰 Min Bet", "CFG_MINBET", "0.0015"],
            ["--- PHASE 1 ---", "", ""],
            ["🎲 P1 Chance %", "CFG_P1_CH", "99.98"],
            ["📊 P1 Basebet Div", "CFG_P1_DIV", "650"],
            ["⚠️ P1 Trigger %", "CFG_P1_TRIG", "0.5"],
            ["--- PHASE 2 ---", "", ""],
            ["🎯 P2 Min Payout", "CFG_P2_MIN", "1.30"],
            ["🎯 P2 Max Payout", "CFG_P2_MAX", "1.50"],
            ["📈 P2 Basebet Mult", "CFG_P2_MULT", "0.001"],
            ["⚠️ P2 Trigger Loss %", "CFG_P2_TRIG", "2"],
            ["--- PHASE 3 ---", "", ""],
            ["🎲 P3 Min Chance %", "CFG_P3_MIN", "60"],
            ["🎲 P3 Max Chance %", "CFG_P3_MAX", "77"],
            ["📈 P3 Basebet Mult", "CFG_P3_MULT", "0.0015"],
            ["🔄 P3 Loss Reset %", "CFG_P3_RESET", "55"],
            ["--- TARGET ---", "", ""],
            ["🛑 Stop Loss %", "CFG_SL", "30"],
            ["🎯 Target X (Wager)", "CFG_TX", "5"]
        ];
        
        cfgItems.forEach(i => {
            if (i[0].startsWith("---")) {
                let divider = document.createElement("div");
                divider.style.cssText = "border-top: 1px solid rgba(0, 255, 136, 0.2); margin: 10px 0 8px 0; text-align: center;";
                let label = document.createElement("div");
                label.style.cssText = "font-size: 8px; color: #00ff88; margin-top: -10px; background: rgba(0, 0, 0, 0.8); display: inline-block; padding: 0 8px; width: fit-content; margin-left: auto; margin-right: auto;";
                label.innerText = i[0].replace(/---/g, "").trim();
                divider.appendChild(label);
                cfgContent.appendChild(divider);
                return;
            }
            
            let row = document.createElement("div");
            row.style.cssText = "display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;";
            row.innerHTML = `
                <span style="font-size: 9px; color: #6c7293; font-weight: 500;">${i[0]}</span>
                <input id="${i[1]}" type="number" value="${i[2]}" step="any" style="width: 100px; background: rgba(0, 0, 0, 0.5); border: 1px solid rgba(0, 255, 136, 0.2); color: #00ff88; border-radius: 5px; font-size: 9px; padding: 6px 10px; text-align: right; font-weight: 600;">
            `;
            cfgContent.appendChild(row);
        });
        
        let saveBtn = document.createElement("button");
        saveBtn.innerText = "💾 SAVE CONFIGURATION";
        saveBtn.style.cssText = "width: 100%; margin-top: 15px; padding: 8px; background: linear-gradient(135deg, #00ff88, #00cc6a); border: none; border-radius: 6px; color: #0a0e1a; font-size: 10px; font-weight: 700; cursor: pointer; transition: transform 0.1s;";
        saveBtn.onmouseenter = () => { saveBtn.style.transform = 'translateY(-1px)'; };
        saveBtn.onmouseleave = () => { saveBtn.style.transform = 'translateY(0)'; };
        saveBtn.onclick = () => { loadConfig(); alert('✅ Configuration saved!'); };
        cfgContent.appendChild(saveBtn);
        
        configPanel.appendChild(cfgContent);
        
        c.appendChild(dashboard);
        c.appendChild(configPanel);
        document.body.appendChild(c);
        
        // Tab switching
        let tabDash = document.getElementById("TAB_DASH");
        let tabConf = document.getElementById("TAB_CONF");
        let panelDash = document.getElementById("PANEL_DASH");
        let panelConf = document.getElementById("PANEL_CONF");
        
        tabDash.onclick = () => {
            panelDash.style.display = "block";
            panelConf.style.display = "none";
            tabDash.style.color = "#00ff88";
            tabDash.style.borderBottom = "2px solid #00ff88";
            tabConf.style.color = "#6c7293";
            tabConf.style.borderBottom = "2px solid transparent";
        };
        
        tabConf.onclick = () => {
            panelDash.style.display = "none";
            panelConf.style.display = "block";
            tabConf.style.color = "#00ff88";
            tabConf.style.borderBottom = "2px solid #00ff88";
            tabDash.style.color = "#6c7293";
            tabDash.style.borderBottom = "2px solid transparent";
        };
        
        // Cache DOM
        dom = {
            badge: document.getElementById("ORION_BADGE"),
            uptime: document.getElementById("ORION_UPTIME"),
            balance: document.getElementById("HUD_BAL"),
            profit: document.getElementById("HUD_PL"),
            drawdown: document.getElementById("HUD_DD"),
            maxbet: document.getElementById("HUD_MAX"),
            phase: document.getElementById("HUD_PH"),
            speed: document.getElementById("HUD_SPD"),
            bets: document.getElementById("HUD_BTS"),
            eta: document.getElementById("HUD_ETA"),
            fill: document.getElementById("WAGER_FILL"),
            progText: document.getElementById("WAGER_PCT"),
            wagerCur: document.getElementById("WAGER_CUR"),
            wagerTar: document.getElementById("WAGER_TAR")
        };
        
        // Config cache
        configCache = {
            minbet: document.getElementById("CFG_MINBET"),
            p1chance: document.getElementById("CFG_P1_CH"),
            p1div: document.getElementById("CFG_P1_DIV"),
            p1trigger: document.getElementById("CFG_P1_TRIG"),
            p2min: document.getElementById("CFG_P2_MIN"),
            p2max: document.getElementById("CFG_P2_MAX"),
            p2mult: document.getElementById("CFG_P2_MULT"),
            p2trigger: document.getElementById("CFG_P2_TRIG"),
            p3min: document.getElementById("CFG_P3_MIN"),
            p3max: document.getElementById("CFG_P3_MAX"),
            p3mult: document.getElementById("CFG_P3_MULT"),
            p3reset: document.getElementById("CFG_P3_RESET"),
            stoploss: document.getElementById("CFG_SL"),
            targetX: document.getElementById("CFG_TX")
        };
        
        // Events
        document.getElementById("BTN_START").onclick = startBot;
        document.getElementById("BTN_STOP").onclick = () => { if (bot.isRunning) stopBot(); };
        document.getElementById("BTN_REPORT").onclick = () => { sendTelegramReport("📊 MANUAL"); };
        
        document.getElementById("orion-currency").onchange = (e) => {
            bot.selectedCurrency = e.target.value;
            API.syncOnce();
        };
        
        // Button hover effects
        const btnsList = ['BTN_START', 'BTN_STOP', 'BTN_REPORT'];
        btnsList.forEach(id => {
            const btn = document.getElementById(id);
            if (btn) {
                btn.onmouseenter = () => { btn.style.transform = 'translateY(-1px)'; };
                btn.onmouseleave = () => { btn.style.transform = 'translateY(0)'; };
            }
        });
        
        // Draggable
        let dragEl = c;
        dragEl.addEventListener("mousedown", (e) => {
            if (e.target.closest("button") || e.target.closest("select") || e.target.closest("input") || e.target.closest(".orion-tab")) return;
            isDragging = true;
            let rect = dragEl.getBoundingClientRect();
            dragX = e.clientX - rect.left;
            dragY = e.clientY - rect.top;
        });
        document.addEventListener("mousemove", (e) => {
            if (!isDragging) return;
            let left = e.clientX - dragX;
            let top = e.clientY - dragY;
            left = Math.max(5, Math.min(window.innerWidth - dragEl.offsetWidth - 5, left));
            top = Math.max(5, Math.min(window.innerHeight - dragEl.offsetHeight - 5, top));
            dragEl.style.left = left + "px";
            dragEl.style.top = top + "px";
            dragEl.style.right = "auto";
            dragEl.style.bottom = "auto";
        });
        document.addEventListener("mouseup", () => { isDragging = false; });
        
        setInterval(() => {
            if (dom.phase) dom.phase.innerText = bot.phase;
            if (dom.eta && bot.isRunning) dom.eta.innerText = estimateTimeRemaining();
        }, 500);
    }

    function init() {
        buildUI();
        setInterval(() => {
            updateUptime();
            updateUI();
        }, 500);
        API.syncOnce();
    }
    
    init();
})();
