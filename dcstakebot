    }

    function checkStopLoss() {
        const lossPct = getTotalLossPercentage();
        if (lossPct >= bot.stopLossPercent) {
            updateConsoleLog(`STOP LOSS: ${lossPct.toFixed(2)}% >= ${bot.stopLossPercent}%`);
            stopBot();
            return true;
        }
        return false;
    }
    
    function canStop() {
        const lossPct = getTotalLossPercentage();
        if (bot.pendingStopAfterRecovery && lossPct <= 0.5) {
            updateConsoleLog(`Recovery complete! Loss ${lossPct.toFixed(2)}% < 0.5%. Stopping.`);
            stopBot();
            return true;
        }
        return false;
    }
    
    function checkWagerTarget() {
        const lossPct = getTotalLossPercentage();
        const wagerComplete = bot.wager >= bot.wagtarget;
        
        if (wagerComplete && !bot.pendingStopAfterRecovery) {
            if (lossPct <= 0.5) {
                updateConsoleLog(`Wager target reached, loss ${lossPct.toFixed(2)}% < 0.5%. Stopping.`);
                stopBot();
                return true;
            } else {
                bot.pendingStopAfterRecovery = true;
                updateConsoleLog(`Wager target reached, loss ${lossPct.toFixed(2)}% > 0.5%. Will stop after recovery.`);
                return false;
            }
        }
        return false;
    }

