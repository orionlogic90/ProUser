    function handleBetResponse(res) {
        if (!res || res.errors) { bot.lastWin = false; return; }
        let bet = res?.data?.diceRoll || res?.data?.diceBet || res?.data?.limboBet || res?.diceRoll || res?.diceBet || res?.limboBet;
        if (bet && bot.isRunning) {
            bot.stats.bets++;
            let pft = bet.payout - bet.amount;
            bot.stats.profit += pft;
            bot.lastWin = pft > 0;
            if (pft > 0) bot.stats.wins++;
            else bot.stats.loss++;
        }
    }

    async function runLoop() {
        if (!bot.isRunning) { loopRunning = false; return; }
        if (loopRunning) return;
        loopRunning = true;
        
        try {
            let now = Date.now();
            if (now - bot.lastBetTime < bot.minDelayMs) {
                await new Promise(r => setTimeout(r, bot.minDelayMs - (now - bot.lastBetTime)));
            }
            
            let balance = getCurrentBalance();
            let prevBet = bot.nextbet;
            
            bot.wager += prevBet;
            bot.stats.wagered += prevBet;
            
            if (prevBet > bot.highestBet) bot.highestBet = prevBet;
            if (balance > bot.balhigh) bot.balhigh = balance;
            bot.currentDrawdown = ((bot.balhigh - balance) / bot.balhigh) * 100;
            
            if (balance <= bot.stoploss) { stopBot(); loopRunning = false; return; }
            if (bot.wager >= bot.wagtarget) { stopBot(); loopRunning = false; return; }
            
            updateUI();
            
            if (bot.phase === 1) {
                bot.chance = bot.phase1.chance;
                bot.nextbet = Math.max(bot.minbet, balance / bot.phase1.basebetDiv);
                
                if (bot.currentDrawdown >= bot.phase1.triggerDrawdown) {
                    goToPhase2();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                let payout = 100 / bot.chance;
                bot.lastBetTime = Date.now();
                let res = await API.placeBet(bot.nextbet, payout, "dice");
                handleBetResponse(res);
                updateBetSpeed();
            }
            else if (bot.phase === 2) {
                let payout = parseFloat((Math.random() * (bot.phase2.maxPayout - bot.phase2.minPayout) + bot.phase2.minPayout).toFixed(2));
                bot.nextbet = Math.max(bot.minbet, balance * bot.phase2.basebetMult);
                let loss = ((bot.startBalance - balance) / bot.startBalance) * 100;
                
                if (loss >= bot.phase2.triggerLoss) {
                    goToPhase3();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                if (balance >= bot.startBalance) {
                    resetToPhase1();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                bot.lastBetTime = Date.now();
                let res = await API.placeBet(bot.nextbet, payout, "limbo");
                handleBetResponse(res);
                updateBetSpeed();
            }
            else if (bot.phase === 3) {
                let totalLoss = Math.abs(bot.startBalance - balance);
                
                if (bot.lastWin) {
                    if (balance >= bot.startBalance) {
                        resetToPhase1();
                        loopRunning = false;
                        setTimeout(() => runLoop(), 0);
                        return;
                    } else {
                        if (bot.phase3Chance > bot.phase3.minChance) {
                            bot.phase3Chance = Math.max(bot.phase3.minChance, bot.phase3Chance - 0.5);
                        }
                        bot.chance = bot.phase3Chance;
                        bot.nextbet = Math.max(bot.minbet, balance * bot.phase3.basebetMult);
                    }
                } else {
                    if (bot.phase3Chance < bot.phase3.maxChance) {
                        bot.phase3Chance = Math.min(bot.phase3.maxChance, bot.phase3Chance + 0.1);
                    }
                    bot.chance = bot.phase3Chance;
                    let profitPerBet = (99 / bot.chance) - 1;
                    if (profitPerBet > 0) {
                        bot.nextbet = Math.max(bot.minbet, (totalLoss / profitPerBet) * 0.65);
                    } else {
                        bot.nextbet = Math.max(bot.minbet, prevBet * 1.2);
                    }
                }
                
                if (totalLoss >= bot.phase3.lossReset) {
                    resetToPhase1();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                let payout = 100 / bot.chance;
                bot.lastBetTime = Date.now();
                let res = await API.placeBet(bot.nextbet, payout, "dice");
                handleBetResponse(res);
                updateBetSpeed();
            }
            
            loopRunning = false;
            if (bot.isRunning) setTimeout(() => runLoop(), 0);
        } catch(err) {
            loopRunning = false;
            if (bot.isRunning) setTimeout(() => runLoop(), 100);
        }
    }

