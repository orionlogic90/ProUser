    function updateMonitoringStats(betAmount) {
        if (betAmount > bot.highestBet) {
            bot.highestBet = betAmount;
        }
        
        const currentBalance = getCurrentBalance();
        if (currentBalance < bot.worstBalance || bot.worstBalance === 0) {
            bot.worstBalance = currentBalance;
            const drawdownPct = ((bot.startBalance - currentBalance) / bot.startBalance) * 100;
            if (drawdownPct > bot.worstDrawdown) {
                bot.worstDrawdown = drawdownPct;
            }
        }
        
        updateBalanceHistory();
    }

    function applyMaxBetLimit(betAmount) {
        if (bot.maxBetLimit > 0 && betAmount > bot.maxBetLimit) {
