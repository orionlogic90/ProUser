    async function runLoop() {
        if (!bot.isRunning) { loopRunning = false; return; }
        if (loopRunning) return;
        loopRunning = true;
        
        try {
            if (checkStopLoss() || canStop() || checkWagerTarget()) { loopRunning = false; return; }
            
            const balance = getCurrentBalance();
            const previousbet = bot.nextbet;
            bot.wager += previousbet;
            updateMonitoringStats(previousbet);
            
            const elapsed = (Date.now() / 1000) - bot.stime;
            if (elapsed >= bot.HRstop * 3600) { updateConsoleLog("Time limit reached"); stopBot(); loopRunning = false; return; }
            if (balance >= bot.target || balance <= bot.balst * 0.075) { updateConsoleLog("Target balance reached"); stopBot(); loopRunning = false; return; }
            
            if (balance > bot.balhigh) bot.balhigh = balance;
            const netLossPercent = ((bot.balhigh - balance) / bot.balhigh) * 100;
            
            if (bot.phase === 1) {
                bot.chance = bot.phase1.chance;
                const payout = 100 / bot.chance;
                bot.nextbet = !bot.lastWin && bot.phase1.martingale > 1.0 ? previousbet * bot.phase1.martingale : Math.max(bot.minbet, balance / bot.phase1.basebetDiv);
                bot.nextbet = applyMaxBetLimit(bot.nextbet);
                bot.floatingLossP1 = netLossPercent;
                if (bot.floatingLossP1 >= 0.5) { goToPhase2(); loopRunning = false; setTimeout(() => runLoop(), 0); return; }
                const res = await API.placeBet(bot.nextbet, payout, "dice");
                if (handleBetResponse(res, previousbet, balance, "P1", `Dice ${bot.chance}%`)) { loopRunning = false; setTimeout(() => runLoop(), 0); return; }
            }
            else if (bot.phase === 2) {
                const payout = parseFloat((Math.random() * (bot.phase2.maxPayout - bot.phase2.minPayout) + bot.phase2.minPayout).toFixed(2));
                bot.nextbet = !bot.lastWin && bot.phase2.martingale > 1.0 ? previousbet * bot.phase2.martingale : Math.max(bot.minbet, balance / bot.phase2.basebetDiv);
                bot.nextbet = applyMaxBetLimit(bot.nextbet);
                bot.lossPhase2 = ((bot.phase2StartBalance - balance) / bot.phase2StartBalance) * 100;
                if (bot.lossPhase2 >= bot.phase2.lossThreshold) { goToPhase3(); loopRunning = false; setTimeout(() => runLoop(), 0); return; }
                if (balance >= bot.startBalance) { resetToPhase1(); loopRunning = false; setTimeout(() => runLoop(), 0); return; }
                const res = await API.placeBet(bot.nextbet, payout, "limbo");
                if (handleBetResponse(res, previousbet, balance, "P2", `Limbo ${payout}x`)) { loopRunning = false; setTimeout(() => runLoop(), 0); return; }
            }
            else if (bot.phase === 3) {
                bot.chance = bot.phase3.chance;
                const payout = 100 / bot.chance;
                if (bot.lastWin) { bot.phase3LossStreak = 0; bot.nextbet = Math.max(bot.minbet, balance / bot.phase3.basebetDiv); }
                else { bot.phase3LossStreak++; bot.nextbet = previousbet * bot.phase3.martingale; }
                if (bot.nextbet > balance * 0.1) bot.nextbet = balance * 0.1;
                bot.nextbet = Math.max(bot.minbet, applyMaxBetLimit(bot.nextbet));
                if (bot.phase3LossStreak >= bot.phase3.maxMartingaleSteps) { updateConsoleLog(`Max loss streak ${bot.phase3LossStreak} → reset`); resetToPhase1(); loopRunning = false; setTimeout(() => runLoop(), 0); return; }
                if (balance >= bot.startBalance) { resetToPhase1(); loopRunning = false; setTimeout(() => runLoop(), 0); return; }
                const res = await API.placeBet(bot.nextbet, payout, "dice");
                if (handleBetResponse(res, previousbet, balance, "P3", `Dice ${bot.chance}%`)) { loopRunning = false; setTimeout(() => runLoop(), 0); return; }
            }
            
            updateHud(false);
            loopRunning = false;
            if (bot.isRunning) runLoop();
        } catch (err) {
            console.error("Loop error:", err);
            updateConsoleLog("Loop error: " + err.message);
            loopRunning = false;
            if (bot.isRunning) setTimeout(() => runLoop(), 500);
        }
    }
    
    function handleBetResponse(res, previousbet, balance, phaseName, gameInfo) {
        if (res.errors) { updateConsoleLog(`[${phaseName}] Error: ${res.errors[0].message}`); return true; }
        const data = res?.data || res;
        let bet = data.diceRoll || data.diceBet || data.limboBet;
        if (bet && bot.isRunning) {
            bot.stats.bets++;
            bot.stats.wagered += bet.amount;
            updateWageredUSD(bet.amount);
            const pft = (bet.payout - bet.amount);
            bot.stats.profit += pft;
            bot.lastWin = (pft > 0);
            if (pft > 0) bot.stats.wins++; else bot.stats.loss++;
            const lossPct = getTotalLossPercentage();
            updateConsoleLog(`${bot.lastWin ? "✅ WIN" : "❌ LOSS"} | ${phaseName} | ${gameInfo} | Bet: ${previousbet.toFixed(8)} | Loss%: ${lossPct.toFixed(2)}% | Profit: ${bot.stats.profit.toFixed(6)}`);
        }
        return false;
    }

