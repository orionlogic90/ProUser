    function getCurrentBalance() { return bot.stats.startBal + bot.stats.profit; }

    function updateUptime() {
        if (!dom.uptime) return;
        if (!bot.startTime || !bot.isRunning) {
            dom.uptime.innerText = "00:00:00";
            return;
        }
        let e = (Date.now() - bot.startTime) / 1000;
        let h = Math.floor(e / 3600);
        let m = Math.floor((e % 3600) / 60);
        let s = Math.floor(e % 60);
        dom.uptime.innerText = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
    }

    function estimateTimeRemaining() {
        if (!bot.isRunning || bot.wager <= 0 || bot.betsPerSec <= 0) return "Calculating...";
        let remainingWager = bot.wagtarget - bot.wager;
        let avgBetSize = bot.wager / bot.stats.bets;
        if (avgBetSize <= 0) return "Calculating...";
        let betsNeeded = remainingWager / avgBetSize;
        let secondsNeeded = betsNeeded / bot.betsPerSec;
        
        if (secondsNeeded < 60) return `${Math.ceil(secondsNeeded)}s`;
        if (secondsNeeded < 3600) return `${Math.ceil(secondsNeeded / 60)}m`;
        return `${(secondsNeeded / 3600).toFixed(1)}h`;
    }

    function updateUI() {
        if (!bot.isRunning) return;
        let cur = getCurrentBalance();
        let profit = cur - bot.startBalance;
        let wagerPct = bot.wagtarget ? (bot.wager / bot.wagtarget) * 100 : 0;
        
        if (dom.balance) dom.balance.innerText = cur.toFixed(4);
        if (dom.profit) { 
            dom.profit.innerText = (profit >= 0 ? "+" : "") + profit.toFixed(4);
            dom.profit.style.color = profit >= 0 ? "#00ff88" : "#ff4757";
        }
        if (dom.drawdown) dom.drawdown.innerText = bot.currentDrawdown.toFixed(1) + "%";
        if (dom.maxbet) dom.maxbet.innerText = bot.highestBet.toFixed(6);
