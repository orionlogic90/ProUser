    // Update function for integrated HUD
    function updateHud(force = false) {
        const now = Date.now();
        if (!force && now - bot.lastUiMs < 200) return;
        bot.lastUiMs = now;

        const curB = getCurrentBalance();
        const profit = curB - bot.startBalance;
        const lossPct = getTotalLossPercentage();
        
        const startEl = document.getElementById("HUD_STARTBAL");
        if (startEl) startEl.innerText = bot.startBalance.toFixed(6);
        const profitEl = document.getElementById("HUD_PROFIT");
        if (profitEl) {
            profitEl.innerText = (profit >= 0 ? "+" : "") + profit.toFixed(6);
            profitEl.style.color = profit >= 0 ? "#4ADE80" : "#F87171";
        }
        const wagerEl = document.getElementById("HUD_WAGER");
        if (wagerEl) wagerEl.innerText = bot.stats.wagered.toFixed(6);
        const lossEl = document.getElementById("HUD_LOSSPCT");
        if (lossEl) {
            lossEl.innerText = lossPct.toFixed(2) + "%";
            lossEl.style.color = lossPct > 10 ? "#F87171" : (lossPct > 3 ? "#FBBF24" : "#4ADE80");
        }
        
        const phaseEl = document.getElementById("HUD_PHASE");
        if (phaseEl) {
            let txt = "";
            if (bot.phase === 1) txt = `Phase 1: DICE ${bot.phase1.chance}%`;
            else if (bot.phase === 2) txt = `Phase 2: LIMBO (${bot.phase2.minPayout}-${bot.phase2.maxPayout}x)`;
            else txt = `Phase 3: RECOVERY ${bot.phase3.chance}%`;
            phaseEl.innerText = txt;
        }
        
        const streakEl = document.getElementById("HUD_STREAK");
        if (streakEl) {
            if (bot.phase === 3) streakEl.innerText = `Loss Streak: ${bot.phase3LossStreak}`;
            else streakEl.innerText = `Status: ${bot.lastWin ? "WIN" : "LOSS"}`;
        }
        
        const badge = document.getElementById("ORION_HUD_BADGE");
        const dot = document.getElementById("ORION_HUD_DOT");
        if (badge && dot) {
            if (bot.isRunning) {
                badge.innerText = "RUNNING";
                badge.style.background = "rgba(45,212,191,0.15)";
                badge.style.borderColor = "rgba(45,212,191,0.4)";
                badge.style.color = "#2DD4BF";
                dot.style.background = "#2DD4BF";
            } else {
                badge.innerText = "STOPPED";
                badge.style.background = "rgba(239,68,68,0.15)";
                badge.style.borderColor = "rgba(239,68,68,0.4)";
                badge.style.color = "#F87171";
                dot.style.background = "#F87171";
            }
        }
    }

