        document.body.appendChild(panel);
        
        document.getElementById("orion-start-btn").onclick = async () => { 
            if(!bot.isRunning){ 
                await API.syncOnce(); 
                
                const wgrdivVal = parseFloat(document.getElementById("param-wgrdiv")?.value);
                if (!isNaN(wgrdivVal) && wgrdivVal > 0) bot.wgrdiv = wgrdivVal;
                
                const minbetVal = parseFloat(document.getElementById("param-minbet")?.value);
                if (!isNaN(minbetVal) && minbetVal > 0) bot.minbet = minbetVal;
                
                const targetWagerVal = parseFloat(document.getElementById("param-targetwager")?.value);
                if (!isNaN(targetWagerVal) && targetWagerVal > 0) bot.targetWager = targetWagerVal;
                
                const currencySel = document.getElementById("orion-currency");
                if (currencySel && currencySel.value) bot.selectedCurrency = currencySel.value;
                
                bot.startBalance = bot.stats.startBal;
                bot.balst = bot.stats.startBal;
                bot.balhigh = bot.stats.startBal;
                bot.target = bot.stats.startBal * 10;
                bot.wagtarget = bot.stats.startBal * bot.targetWager;
