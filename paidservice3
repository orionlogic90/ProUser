        reportBtn.style.border = "1px solid rgba(240, 185, 11, 0.5)";
        reportBtn.style.borderRadius = "6px";
        reportBtn.style.fontWeight = "bold";
        reportBtn.style.fontSize = "10px";
        reportBtn.style.color = "#F0B90B";
