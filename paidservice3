    async function placeBet(amount, payout, game) {
        const endpoint = game === "dice" ? `${window.location.origin}/_api/casino/dice/roll` : `${window.location.origin}/_api/casino/limbo/bet`;
        const payload = { 
            amount: parseFloat(amount), 
            currency: bot.selectedCurrency, 
            identifier: Math.random().toString(36).slice(2) + Date.now().toString(36) 
        };
        if (game === "dice") { 
            payload.target = 100 - (100 / payout); 
            payload.condition = "above"; 
        } else { 
            payload.multiplierTarget = parseFloat(payout); 
        }
        const res = await fetch(endpoint, { method: "POST", headers: { "Content-Type": "application/json", "x-access-token": bot.token }, body: JSON.stringify(payload) });
        return res.json();
    }

    async function runLoop() {
        while (bot.isRunning) {
            if (checkStopLoss()) break;
            
            const balance = getCurrentBalance();
            const previousbet = bot.nextbet;
            const lossPct = getTotalLossPercent();
            
            bot.wager += previousbet;
            
            if (bot.wager >= bot.wagtarget) {
                bot.wagerTargetReached = true;
                stopBot();
                break;
            }
            
            if ((Date.now() / 1000) - bot.stime >= 22 * 3600 && bot.lastWin) {
                stopBot();
                break;
            }
            
            if (balance >= bot.target || balance <= bot.balst * 0.075) {
                stopBot();
                break;
            }
            
            if (balance > bot.balhigh) bot.balhigh = balance;
            const netLossPercent = ((bot.balhigh - balance) / bot.balhigh) * 100;
            
            let payout = 0;
            let betAmount = 0;
            
            if (bot.phase === 1) {
                bot.chance = bot.phase1Chance;
                payout = 100 / bot.chance;
                betAmount = balance * (bot.phase1BaseBetPercent / 100);
                if (betAmount < bot.minbet) betAmount = bot.minbet;
                bot.nextbet = betAmount;
                bot.floatingLossP1 = netLossPercent;
                if (bot.floatingLossP1 >= bot.triggerP1toP2) goToPhase2();
            }
            else if (bot.phase === 2) {
                const minMulti = bot.phase2MinMultiplier;
                const maxMulti = bot.phase2MaxMultiplier;
                payout = (Math.floor(Math.random() * ((maxMulti - minMulti) * 100 + 1)) / 100) + minMulti;
                betAmount = balance * (bot.phase2BaseBetPercent / 100) * bot.factor;
                if (betAmount < bot.minbet) betAmount = bot.minbet;
                bot.nextbet = betAmount;
                const phase2NetLoss = ((bot.phase2StartBalance - balance) / bot.phase2StartBalance) * 100;
                bot.lossPhase2 = phase2NetLoss;
                if (bot.lossPhase2 >= bot.triggerP2toP3) goToPhase3();
                if (lossPct <= bot.triggerP2toP1) resetToPhase1();
            }
            else {
                bot.chance = bot.phase3Chance;
                payout = 100 / bot.chance;
                if (bot.martingaleEnabled) {
                    if (bot.lastWin) {
                        bot.phase3LossStreak = 0;
                        betAmount = balance * (bot.phase3BaseBetPercent / 100);
                    } else {
                        bot.phase3LossStreak++;
                        betAmount = previousbet * bot.martingaleMultiplier;
                    }
                } else {
                    betAmount = balance * (bot.phase3BaseBetPercent / 100);
                }
                if (betAmount > balance * 0.05) betAmount = balance * 0.05;
                if (betAmount < bot.minbet) betAmount = bot.minbet;
                bot.nextbet = betAmount;
                if (bot.phase3LossStreak >= bot.martingaleMaxStreak) { resetToPhase1(); continue; }
                if (lossPct <= bot.triggerP3toP2) resetToPhase1();
            }
            
            try {
                const res = await placeBet(betAmount, payout, bot.playgame);
                if (res.errors) { continue; }
                
                const bet = res?.data?.diceRoll || res?.diceRoll || res?.data?.limboBet || res?.limboBet;
                if (bet && bot.isRunning) {
                    bot.stats.bets++;
                    bot.stats.wagered += bet.amount;
                    const pft = bet.payout - bet.amount;
                    bot.stats.profit += pft;
                    bot.lastWin = pft > 0;
                    if (pft > 0) bot.stats.wins++; else bot.stats.loss++;
                    if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
                }
                updateUI();
            } catch (e) { continue; }
        }
    }

    const API = {
        async syncOnce() {
            bot.token = getAuthToken();
            const query = `query{user{name balances{available{amount currency}}}}`;
            try {
                const res = await fetch(`${window.location.origin}/_api/graphql`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "x-access-token": bot.token },
                    body: JSON.stringify({ query })
                });
                const json = await res.json();
                if (json?.data?.user) {
                    bot.stakeUser = json.data.user.name;
                    const userEl = document.getElementById("UI_USER");
                    if (userEl) userEl.innerText = maskUsername(bot.stakeUser);
                    
                    const bals = json.data.user.balances || [];
                    const sel = document.getElementById("UI_CURRENCY");
                    if (sel && sel.options.length === 0) {
                        for (let i = 0; i < bals.length; i++) {
                            const b = bals[i];
                            const opt = document.createElement("option");
                            opt.value = b.available.currency;
                            opt.textContent = b.available.currency.toUpperCase();
                            if (b.available.currency === "doge") opt.selected = true;
                            sel.appendChild(opt);
                        }
                    }
                    if (sel) bot.selectedCurrency = sel.value;
                    const active = bals.find(function(b) { return b.available.currency === bot.selectedCurrency; });
                    bot.stats.startBal = active ? parseFloat(active.available.amount) : 0;
                }
            } catch (e) { 
                bot.lastError = "Sync Failed"; 
            }
        }
    };

