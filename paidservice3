    }

    function convertToUSD(amount) {
        return amount * 0.12;
    }
    
    function updateWageredUSD(amount) {
        bot.stats.wageredUSD += convertToUSD(amount);
    }

    function getCurrentBalance() {
        return bot.stats.startBal + bot.stats.profit;
    }

    function getTotalLossPercentage() {
        const currentBalance = getCurrentBalance();
        if (bot.startBalance === 0) return 0;
        return ((bot.startBalance - currentBalance) / bot.startBalance) * 100;
    }

    // Check stop loss (total loss from start)
    function checkStopLoss() {
        const lossPct = getTotalLossPercentage();
        if (lossPct >= bot.stopLossPercent) {
            updateConsoleLog(`STOP LOSS TRIGGERED: Total loss ${lossPct.toFixed(2)}% >= ${bot.stopLossPercent}%`);
            stopBot();
            return true;
        }
        return false;
    }

    function resetToPhase1() {
        bot.phase = 1;
        bot.lossPhase2 = 0;
        bot.lossPhase3 = 0;
        bot.betCountPhase3 = 0;
        bot.floatingLossP1 = 0;
        bot.phase3LossStreak = 0;
        bot.chance = bot.phase1.chance;
        bot.playgame = bot.phase1.game;
        // Basebet from phase1 config
        let newBet = getCurrentBalance() / bot.phase1.basebetDiv;
        bot.nextbet = Math.max(bot.minbet, newBet);
        updateConsoleLog("Reset to Phase 1 - Dice 97% | Basebet: " + bot.nextbet.toFixed(8));
    }

    function goToPhase2() {
        bot.phase = 2;
        bot.lossPhase2 = 0;
        bot.floatingLossP1 = 0;
        bot.phase2StartBalance = getCurrentBalance();
        bot.playgame = bot.phase2.game;
        bot.chance = null; // not used for limbo
        updateConsoleLog("Entering Phase 2 - Limbo | Start Balance: " + bot.phase2StartBalance.toFixed(4));
    }

    function goToPhase3() {
        bot.phase = 3;
        bot.lossPhase3 = 0;
        bot.betCountPhase3 = 0;
        bot.phase3LossStreak = 0;
        bot.phase3StartBalance = getCurrentBalance();
        bot.playgame = bot.phase3.game;
        bot.chance = bot.phase3.chance;
        let newBet = getCurrentBalance() * bot.phase3.basebetPercent;
        bot.nextbet = Math.max(bot.minbet, newBet);
        updateConsoleLog("Entering Phase 3 - Recovery Mode | Basebet: " + bot.nextbet.toFixed(8));
    }

