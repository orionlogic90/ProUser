                if (reportInterval) clearInterval(reportInterval);
                reportInterval = setInterval(() => {
                    if (bot.isRunning) API.sendTg("📊 *PERIODIC REPORT*");
                }, 180000);
                
                runLoop();
            } 
        };
        
        document.getElementById("orion-stop-btn").onclick = () => { 
            if(bot.isRunning){ 
                stopBot();
            } 
        };
    }

    // Periodic UI update
    setInterval(() => {
        if (bot.isRunning) {
            const totalLossPct = getTotalLossPercentage();
            updateHud(false);
            
            const phaseText = bot.phase === 1 ? "1 - DICE 97%" : (bot.phase === 2 ? "2 - LIMBO" : "3 - RECOVERY");
            let statusText = "";
            if (bot.phase === 1) statusText = `PHASE 1 - DICE 97%`;
            else if (bot.phase === 2) statusText = `PHASE 2 - LIMBO | Loss: ${bot.lossPhase2.toFixed(2)}%`;
            else statusText = `PHASE 3 - RECOVERY | Streak: ${bot.phase3LossStreak}`;
            
            const lossPctEl = document.getElementById("orion-loss-pct");
            if (lossPctEl) {
                lossPctEl.innerText = totalLossPct.toFixed(2) + "%";
                if (totalLossPct > 7) lossPctEl.style.color = "#F87171";
                else if (totalLossPct > 0.5) lossPctEl.style.color = "#FBBF24";
                else lossPctEl.style.color = "#4ADE80";
            }
        }
    }, 500);

    createUI();
    API.syncOnce();
    ensureHud();
})();
