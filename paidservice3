    // Main betting loop (optimized speed)
    async function runLoop() {
        if (!bot.isRunning) {
            loopRunning = false;
            return;
        }
        if (loopRunning) return;
        loopRunning = true;
        
        try {
            // Check stop loss first
            if (checkStopLoss()) {
                loopRunning = false;
                return;
            }
            
            const balance = getCurrentBalance();
            const previousbet = bot.nextbet;
            bot.lastBetAmount = previousbet;
            
            // Update wagered
            bot.wager += previousbet;
            
            // Wager target check
            if (bot.wager >= bot.wagtarget) {
                updateConsoleLog("Wager Target reached");
                stopBot();
                loopRunning = false;
                return;
            }
            
            // Time limit check
            const elapsed = (Date.now() / 1000) - bot.stime;
            if (elapsed >= bot.HRstop * 3600) {
                updateConsoleLog("Time limit reached (22h)");
                stopBot();
                loopRunning = false;
                return;
            }
            
            // Stop target: balance >= target OR balance <= startBalance * 0.075
            if (balance >= bot.target || balance <= bot.balst * 0.075) {
                updateConsoleLog("Target reached - stopping");
                stopBot();
                loopRunning = false;
                return;
            }
            
            // Track highest balance
            if (balance > bot.balhigh) bot.balhigh = balance;
            const netLossPercent = ((bot.balhigh - balance) / bot.balhigh) * 100;
            
            // ================= PHASE 1 =================
            if (bot.phase === 1) {
                bot.playgame = bot.phase1.game;
                bot.chance = bot.phase1.chance;
                const payout = 100 / bot.chance;
                
                // Calculate next bet (with martingale if loss, but phase1 typically no martingale)
                if (!bot.lastWin && bot.phase1.martingale > 1.0) {
                    bot.nextbet = previousbet * bot.phase1.martingale;
                } else {
                    let newBet = balance / bot.phase1.basebetDiv;
                    bot.nextbet = Math.max(bot.minbet, newBet);
                }
                
                bot.floatingLossP1 = netLossPercent;
                if (bot.floatingLossP1 >= 0.5) {
                    goToPhase2();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                const res = await API.placeBet(bot.nextbet, payout, "dice");
                if (handleBetResponse(res, previousbet, balance, "Phase 1", `Dice ${bot.chance}%`)) {
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
            }
            // ================= PHASE 2 =================
            else if (bot.phase === 2) {
                bot.playgame = bot.phase2.game;
                const randomPayout = Math.random() * (bot.phase2.maxPayout - bot.phase2.minPayout) + bot.phase2.minPayout;
                const payout = parseFloat(randomPayout.toFixed(2));
                
                // Martingale for phase2
                if (!bot.lastWin && bot.phase2.martingale > 1.0) {
                    bot.nextbet = previousbet * bot.phase2.martingale;
                } else {
                    let newBet = balance * bot.phase2.basebetPercent;
                    bot.nextbet = Math.max(bot.minbet, newBet);
                }
                
                const phase2NetLoss = ((bot.phase2StartBalance - balance) / bot.phase2StartBalance) * 100;
                bot.lossPhase2 = phase2NetLoss;
                
                if (bot.lossPhase2 >= bot.phase2.lossThreshold) {
                    goToPhase3();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                if (balance >= bot.startBalance) {
                    resetToPhase1();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                const res = await API.placeBet(bot.nextbet, payout, "limbo");
                if (handleBetResponse(res, previousbet, balance, "Phase 2", `Limbo ${payout}x`)) {
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
            }
            // ================= PHASE 3 =================
            else if (bot.phase === 3) {
                bot.playgame = bot.phase3.game;
                bot.chance = bot.phase3.chance;
                const payout = 100 / bot.chance;
                
                if (bot.lastWin) {
                    bot.phase3LossStreak = 0;
                    let newBet = balance * bot.phase3.basebetPercent;
                    bot.nextbet = Math.max(bot.minbet, newBet);
                } else {
                    bot.phase3LossStreak++;
                    bot.nextbet = previousbet * bot.phase3.martingale;
                }
                
                // Cap bet to 10% balance
                if (bot.nextbet > balance * 0.1) bot.nextbet = balance * 0.1;
                bot.nextbet = Math.max(bot.minbet, bot.nextbet);
                
                // Anti death streak
                if (bot.phase3LossStreak >= bot.phase3.maxMartingaleSteps) {
                    updateConsoleLog(`Max loss streak (${bot.phase3LossStreak}) reached → reset to Phase 1`);
                    resetToPhase1();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                if (balance >= bot.startBalance) {
                    resetToPhase1();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                const res = await API.placeBet(bot.nextbet, payout, "dice");
                if (handleBetResponse(res, previousbet, balance, "Phase 3", `Dice ${bot.chance}%`)) {
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
            }
            
            updateHud(false);
            loopRunning = false;
            if (bot.isRunning) {
                // Faster loop - no delay (as fast as network allows)
                runLoop();
            }
        } catch (err) {
            console.error("Loop error:", err);
            bot.lastError = err.message;
            updateConsoleLog("Loop error: " + err.message);
            loopRunning = false;
            if (bot.isRunning) setTimeout(() => runLoop(), 500);
        }
    }
    
    // Helper to process bet response
    function handleBetResponse(res, previousbet, balance, phaseName, gameInfo) {
        if (res.errors) {
            bot.lastError = res.errors[0].message;
            updateConsoleLog(`[${phaseName}] Error: ${res.errors[0].message}`);
            return true; // retry later
        }
        
        const data = res?.data || res;
        let bet = null;
        if (data.diceRoll || data.diceBet) bet = data.diceRoll || data.diceBet;
        else if (data.limboBet) bet = data.limboBet;
        
        if (bet && bot.isRunning) {
            bot.stats.bets++;
            bot.stats.wagered += bet.amount;
            updateWageredUSD(bet.amount);
            const pft = (bet.payout - bet.amount);
            bot.stats.profit += pft;
            bot.lastWin = (pft > 0);
            if (pft > 0) bot.stats.wins++;
            else bot.stats.loss++;
            if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
            bot.lastError = "None";
            
            updateConsoleLog(`${bot.lastWin ? "✅ WIN" : "❌ LOSS"} | ${phaseName} | ${gameInfo} | Bet: ${previousbet.toFixed(8)} | Bal: ${balance.toFixed(4)} | Profit: ${bot.stats.profit.toFixed(6)}`);
            
            // Update drawdown
            if (!bot.lastWin) {
                bot.DD = bot.stats.profit;
                if (bot.MaXDD > bot.DD) bot.MaXDD = bot.DD;
            } else bot.DD = 0;
        }
        return false;
    }

    const API = {
        async syncOnce() {
            bot.token = getAuthToken();
            const query = `query{user{name balances{available{amount currency}}}}`;
            try {
                const res = await fetch(`${CONFIG.apiUrl}/graphql`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "x-access-token": bot.token },
                    body: JSON.stringify({ query })
                });
                const json = await res.json();
                if (json?.data?.user) {
                    bot.stakeUser = json.data.user.name;
                    const bals = json.data.user.balances || [];
                    const currencySelect = document.getElementById("orion-currency");
                    if (currencySelect && currencySelect.options.length === 0) {
                        bals.forEach(b => {
                            const opt = document.createElement("option");
                            opt.value = b.available.currency;
                            opt.textContent = b.available.currency.toUpperCase();
                            if (b.available.currency === "doge") opt.selected = true;
                            currencySelect.appendChild(opt);
                        });
                    }
                    if (currencySelect) bot.selectedCurrency = currencySelect.value;
                    const active = bals.find(b => b.available.currency === bot.selectedCurrency);
                    bot.stats.startBal = active ? parseFloat(active.available.amount) : 0;
                    bot.startBalance = bot.stats.startBal;
                }
            } catch (e) {
                bot.lastError = "Sync Failed";
                updateConsoleLog("Sync Failed: " + e.message);
            }
        },
        async sendTg(statusHeader) {
            const now = Date.now();
            if (now - lastReportTime < 30000) return;
            lastReportTime = now;
            
            const elapsed = bot.startTime ? (new Date() - bot.startTime) / 1000 : 0;
            const timeStr = new Date(elapsed * 1000).toISOString().substr(11, 8);
            const speed = (bot.stats.bets / (elapsed || 1)).toFixed(2);
            const profitColor = bot.stats.profit >= 0 ? '🟢' : '🔴';
            const currentBalance = getCurrentBalance().toFixed(8);
            const lossPct = getTotalLossPercentage();
            
            let phaseIcon = bot.phase === 1 ? "🔥" : (bot.phase === 2 ? "⚡" : "🃏");
            let phaseText = bot.phase === 1 ? `DICE ${bot.phase1.chance}%` : (bot.phase === 2 ? `LIMBO ${bot.phase2.minPayout}-${bot.phase2.maxPayout}x` : `RECOVERY ${bot.phase3.chance}%`);
            
            const text = 
`🔷 *SANYA CUSTOM BOT* 🔷
${statusHeader}

👤 *User:* \`${bot.stakeUser}\`
🪙 *Asset:* \`${bot.selectedCurrency.toUpperCase()}\`
${phaseIcon} *Phase ${bot.phase}:* ${phaseText}
📉 *Total Loss %:* \`${lossPct.toFixed(2)}%\`
⚙️ *Stop Loss:* ${bot.stopLossPercent}% | *Target Wager:* ${bot.targetWager}x

⏱ *Uptime:* \`${timeStr}\`
💰 *Balance:* \`${currentBalance}\`
📈 *Profit:* ${profitColor} \`${bot.stats.profit.toFixed(8)}\`
📊 *Wagered:* \`${bot.stats.wagered.toFixed(8)}\`
💵 *Wagered USD:* \`$${bot.stats.wageredUSD.toFixed(2)}\`

🎰 *Bets:* \`${bot.stats.bets}\`
🏁 *W/L:* \`${bot.stats.wins}/${bot.stats.loss}\`
⚡ *Speed:* \`${speed} bets/s\`

🆔 *Sanya Custom Bot v1.0*`;

            fetch(`https://api.telegram.org/bot${CONFIG.tgToken}/sendMessage`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ chat_id: CONFIG.tgChatId, text: text, parse_mode: "Markdown", disable_web_page_preview: true })
            }).catch(() => {});
        },
        async placeBet(amount, payout, game) {
            const endpoint = game === "dice" ? `${CONFIG.apiUrl}/casino/dice/roll` : `${CONFIG.apiUrl}/casino/limbo/bet`;
            const payload = {
                amount: parseFloat(amount),
                currency: bot.selectedCurrency,
                identifier: Math.random().toString(36).slice(2) + Date.now().toString(36)
            };
            if (game === "dice") {
                payload.target = 100 - (100 / payout);
                payload.condition = "above";
            } else {
                payload.multiplierTarget = parseFloat(payout);
            }
            return fetch(endpoint, {
                method: "POST",
                headers: { "Content-Type": "application/json", "x-access-token": bot.token },
                body: JSON.stringify(payload)
            }).then(r => r.json());
        }
    };

    // Initialize
    function init() {
        ensureHudAndControls();
        
        document.getElementById("orion-start-btn").onclick = async () => {
            if (!bot.isRunning) {
                await API.syncOnce();
                loadConfigFromUI();
                
                bot.startBalance = bot.stats.startBal;
                bot.balst = bot.stats.startBal;
                bot.balhigh = bot.stats.startBal;
                bot.target = bot.stats.startBal * 10;
                bot.wagtarget = bot.stats.startBal * bot.targetWager;
                bot.factor = bot.stats.startBal / 100;
                bot.stime = Date.now() / 1000;
                bot.wager = 0;
                bot.tick = 0;
                bot.MaXDD = 0;
                bot.DD = 0;
                bot.phase3LossStreak = 0;
                bot.lastWin = false;
                bot.profitc = 0;
                bot.stats.bets = 0;
                bot.stats.profit = 0;
                bot.stats.wagered = 0;
                bot.stats.wageredUSD = 0;
                bot.stats.wins = 0;
                bot.stats.loss = 0;
                bot.stats.maxDD = 0;
                
                bot.isRunning = true;
                bot.startTime = new Date();
                resetToPhase1();
                
                setTimeout(() => API.sendTg("🚀 *SYSTEM ENGAGED - Sanya Custom Bot* 🚀\nPhase 1: DICE 97% | Stop Loss: " + bot.stopLossPercent + "%"), 1000);
                
                if (reportInterval) clearInterval(reportInterval);
                reportInterval = setInterval(() => {
                    if (bot.isRunning) API.sendTg("📊 *PERIODIC REPORT*");
                }, 180000);
                
                updateHud(true);
                runLoop();
            }
        };
        
        document.getElementById("orion-stop-btn").onclick = () => {
            if (bot.isRunning) stopBot();
        };
    }
    
    // Periodic HUD update
    setInterval(() => {
        if (bot.isRunning) updateHud(false);
    }, 300);
    
    init();
    API.syncOnce();
})();
