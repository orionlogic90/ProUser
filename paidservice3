    async function runLoop() {
        if (!bot.isRunning) return;
        
        const balance = getCurrentBalance();
        const win = bot.lastWin || false;
        const previousbet = bot.nextbet;
        
        bot.wager += previousbet;
        
        // Wager target check
        if (bot.wager >= bot.wagtarget && balance >= bot.balst - bot.balst/120) {
            updateConsoleLog("Wager Target reached");
            stopBot();
            return;
        }
        
        // Update DD
        if (!win) {
            bot.DD = bot.stats.profit;
            if (bot.MaXDD > bot.DD) {
                bot.MaXDD = bot.DD;
            }
        } else {
            bot.DD = 0;
        }
        
        bot.tick++;
        if (bot.tick >= 20) {
            updateConsoleLog("MaxDD: " + bot.MaXDD);
            bot.tick = 0;
        }
        
        // Time limit check (22 hours)
        const elapsed = (Date.now() / 1000) - bot.stime;
        if (elapsed >= bot.HRstop * 3600 && win) {
            updateConsoleLog("Time limit reached");
            stopBot();
            return;
        }
        
        // Stop target: balance >= target OR balance <= startBalance * 0.075
        if (balance >= bot.target || balance <= bot.balst * 0.075) {
            updateConsoleLog("Target reached - stopping");
            stopBot();
            return;
        }
        
        bot.profitc = bot.profitc + bot.stats.profit;
        
        // Track highest balance
        if (balance > bot.balhigh) {
            bot.balhigh = balance;
        }
        
        const netLossPercent = ((bot.balhigh - balance) / bot.balhigh) * 100;
        
        // ================= PHASE 1 =================
        if (bot.phase === 1) {
            bot.playgame = "dice";
            bot.chance = 97;
            const payout = 100 / bot.chance;
            
            bot.nextbet = balance / bot.wgrdiv;
            bot.nextbet = Math.max(bot.minbet, bot.nextbet);
            
            bot.floatingLossP1 = netLossPercent;
            
            if (bot.floatingLossP1 >= 0.5) {
                goToPhase2();
            }
            
            try {
                const res = await API.placeBet(bot.nextbet, payout, "dice");
                
                if (res.errors) {
                    bot.lastError = res.errors[0].message;
                    updateConsoleLog("Error: " + res.errors[0].message);
                    setTimeout(runLoop, 800);
                    return;
                }
                
                const data = res?.data || res;
                const bet = data.diceRoll || data.diceBet;
                
                if (bet && bot.isRunning) {
                    bot.stats.bets++;
                    bot.stats.wagered += bet.amount;
                    updateWageredUSD(bet.amount);
                    const pft = (bet.payout - bet.amount);
                    bot.stats.profit += pft;
                    bot.lastWin = (pft > 0);
                    if (pft > 0) bot.stats.wins++; else bot.stats.loss++;
                    if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
                    bot.lastError = "None";
                    
                    updateConsoleLog(`${bot.lastWin ? "WIN" : "LOSS"} | Phase 1 | Dice 97% | Bet: ${previousbet.toFixed(8)} | Bal: ${balance.toFixed(4)}`);
                    updateHud(false);
                }
                
                if (bot.isRunning) setTimeout(runLoop, 0);
                
            } catch (e) {
                bot.lastError = "Network Error";
                updateConsoleLog("Network Error: " + e.message);
                if (bot.isRunning) setTimeout(runLoop, 1000);
            }
        }
        
        // ================= PHASE 2 =================
        else if (bot.phase === 2) {
            bot.playgame = "limbo";
            
            const randomPayout = Math.floor(Math.random() * (150 - 130 + 1) + 130) / 100;
            const payout = randomPayout;
            
            bot.nextbet = balance * 0.0010 * bot.factor;
            bot.nextbet = Math.max(bot.minbet, bot.nextbet);
            
            const phase2NetLoss = ((bot.phase2StartBalance - balance) / bot.phase2StartBalance) * 100;
            bot.lossPhase2 = phase2NetLoss;
            
            if (bot.lossPhase2 >= 7.0) {
                goToPhase3();
            }
            
            if (balance >= bot.startBalance) {
                resetToPhase1();
            }
            
            try {
                const res = await API.placeBet(bot.nextbet, payout, "limbo");
                
                if (res.errors) {
                    bot.lastError = res.errors[0].message;
                    updateConsoleLog("Error: " + res.errors[0].message);
                    setTimeout(runLoop, 800);
                    return;
                }
                
                const data = res?.data || res;
                const bet = data.limboBet;
                
                if (bet && bot.isRunning) {
                    bot.stats.bets++;
                    bot.stats.wagered += bet.amount;
                    updateWageredUSD(bet.amount);
                    const pft = (bet.payout - bet.amount);
                    bot.stats.profit += pft;
                    bot.lastWin = (pft > 0);
                    if (pft > 0) bot.stats.wins++; else bot.stats.loss++;
                    if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
                    bot.lastError = "None";
                    
                    updateConsoleLog(`${bot.lastWin ? "WIN" : "LOSS"} | Phase 2 | Limbo ${payout}x | Bet: ${previousbet.toFixed(8)} | Bal: ${balance.toFixed(4)}`);
                    updateHud(false);
                }
                
                if (bot.isRunning) setTimeout(runLoop, 0);
                
            } catch (e) {
                bot.lastError = "Network Error";
                updateConsoleLog("Network Error: " + e.message);
                if (bot.isRunning) setTimeout(runLoop, 1000);
            }
        }
        
        // ================= PHASE 3 =================
        else if (bot.phase === 3) {
            bot.playgame = "dice";
            bot.chance = 60;
            const payout = 100 / bot.chance;
            
            if (bot.lastWin) {
                bot.phase3LossStreak = 0;
                bot.nextbet = balance * 0.0008 * bot.factor;
            } else {
                bot.phase3LossStreak = bot.phase3LossStreak + 1;
                bot.nextbet = previousbet * 2.5;
            }
            
            // soft brake
            if (bot.nextbet > balance * 0.1) {
                bot.nextbet = balance * 0.1;
            }
            
            // anti death streak
            if (bot.phase3LossStreak >= 12) {
                updateConsoleLog("Danger streak → reset Phase 1");
                resetToPhase1();
                if (bot.isRunning) setTimeout(runLoop, 0);
                return;
            }
            
            bot.nextbet = Math.max(bot.minbet, bot.nextbet);
            
            if (balance >= bot.startBalance) {
                resetToPhase1();
            }
            
            try {
                const res = await API.placeBet(bot.nextbet, payout, "dice");
                
                if (res.errors) {
                    bot.lastError = res.errors[0].message;
                    updateConsoleLog("Error: " + res.errors[0].message);
                    setTimeout(runLoop, 800);
                    return;
                }
                
                const data = res?.data || res;
                const bet = data.diceRoll || data.diceBet;
                
                if (bet && bot.isRunning) {
                    bot.stats.bets++;
                    bot.stats.wagered += bet.amount;
                    updateWageredUSD(bet.amount);
                    const pft = (bet.payout - bet.amount);
                    bot.stats.profit += pft;
                    bot.lastWin = (pft > 0);
                    if (pft > 0) bot.stats.wins++; else bot.stats.loss++;
                    if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
                    bot.lastError = "None";
                    
                    updateConsoleLog(`${bot.lastWin ? "WIN" : "LOSS"} | Phase 3 | Dice 60% | Bet: ${previousbet.toFixed(8)} | Bal: ${balance.toFixed(4)} | Streak: ${bot.phase3LossStreak}`);
                    updateHud(false);
                }
                
                if (bot.isRunning) setTimeout(runLoop, 0);
                
            } catch (e) {
                bot.lastError = "Network Error";
                updateConsoleLog("Network Error: " + e.message);
                if (bot.isRunning) setTimeout(runLoop, 1000);
            }
        }
    }

