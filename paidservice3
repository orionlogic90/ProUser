    function getTotalLossPercent() {
        if (bot.startBalance === 0) return 0;
        return ((bot.startBalance - getCurrentBalance()) / bot.startBalance) * 100;
    }

    function checkStopLoss() {
        const loss = getTotalLossPercent();
        if (loss >= bot.stopLossPercent && bot.isRunning) {
