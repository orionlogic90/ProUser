    async function runLoop() {
        if (!bot.isRunning) return;
        
        const balance = getCurrentBalance();
        const win = bot.lastWin || false;
        const previousbet = bot.nextbet;
        
        bot.wager += previousbet;
        
        if (bot.wager >= bot.wagtarget && balance >= bot.balst - bot.balst/120) {
            updateConsoleLog("✅ Wager Target reached");
            stopBot();
            return;
        }
        
        if (!win) {
            bot.DD = bot.stats.profit;
            if (bot.MaXDD > bot.DD) bot.MaXDD = bot.DD;
        } else {
            bot.DD = 0;
        }
        
        bot.tick++;
        if (bot.tick >= 20) {
            bot.tick = 0;
        }
        
        const elapsed = (Date.now() / 1000) - bot.stime;
        if (elapsed >= bot.HRstop * 3600 && win) {
            updateConsoleLog("⏰ Time limit reached");
            stopBot();
            return;
        }
        
        if (balance >= bot.target || balance <= bot.balst * 0.075) {
            updateConsoleLog("🎯 Target reached");
            stopBot();
            return;
        }
        
        bot.profitc = bot.profitc + bot.stats.profit;
        
        if (balance > bot.balhigh) bot.balhigh = balance;
        
        const netLossPercent = getHighestBalanceLossPct();
        
        // ================= PHASE 1 =================
        if (bot.phase === 1) {
            bot.playgame = "dice";
            bot.chance = bot.phase1Chance;
            const payout = 100 / bot.chance;
            
            bot.nextbet = balance / bot.wgrdiv;
            bot.nextbet = Math.max(bot.minbet, bot.nextbet);
            bot.floatingLossP1 = netLossPercent;
            
            if (bot.floatingLossP1 >= bot.phase1TriggerLossPct) goToPhase2();
            
            try {
                const res = await API.placeBet(bot.nextbet, payout, "dice");
                if (res.errors) {
                    bot.lastError = res.errors[0].message;
                    updateConsoleLog("❌ Error: " + res.errors[0].message);
                    setTimeout(runLoop, 500);
                    return;
                }
                const data = res?.data || res;
                const bet = data.diceRoll || data.diceBet;
                if (bet && bot.isRunning) {
                    bot.stats.bets++;
                    bot.stats.wagered += bet.amount;
                    updateWageredUSD(bet.amount);
                    const pft = (bet.payout - bet.amount);
                    bot.stats.profit += pft;
                    bot.lastWin = (pft > 0);
                    if (pft > 0) bot.stats.wins++; else bot.stats.loss++;
                    if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
                    updateConsoleLog(`${bot.lastWin ? "✅ WIN" : "❌ LOSS"} | P1 | Bet: ${previousbet.toFixed(8)}`);
                    updateGlassHUD();
                }
                if (bot.isRunning) setTimeout(runLoop, 0);
            } catch (e) {
                updateConsoleLog("🌐 Error: " + e.message);
                if (bot.isRunning) setTimeout(runLoop, 1000);
            }
        }
        
        // ================= PHASE 2 =================
        else if (bot.phase === 2) {
            bot.playgame = "limbo";
            const randomPayout = Math.floor(Math.random() * ((bot.phase2PayoutMax * 100) - (bot.phase2PayoutMin * 100) + 1) + (bot.phase2PayoutMin * 100)) / 100;
            const payout = randomPayout;
            bot.nextbet = balance * bot.phase2BasebetMultiplier;
            bot.nextbet = Math.max(bot.minbet, bot.nextbet);
            const phase2NetLoss = ((bot.phase2StartBalance - balance) / bot.phase2StartBalance) * 100;
            bot.lossPhase2 = phase2NetLoss;
            if (bot.lossPhase2 >= bot.phase2TriggerLossPct) goToPhase3();
            if (balance >= bot.startBalance) resetToPhase1();
            
            try {
                const res = await API.placeBet(bot.nextbet, payout, "limbo");
                if (res.errors) {
                    bot.lastError = res.errors[0].message;
                    updateConsoleLog("❌ Error: " + res.errors[0].message);
                    setTimeout(runLoop, 500);
                    return;
                }
                const data = res?.data || res;
                const bet = data.limboBet;
                if (bet && bot.isRunning) {
                    bot.stats.bets++;
                    bot.stats.wagered += bet.amount;
                    updateWageredUSD(bet.amount);
                    const pft = (bet.payout - bet.amount);
                    bot.stats.profit += pft;
                    bot.lastWin = (pft > 0);
                    if (pft > 0) bot.stats.wins++; else bot.stats.loss++;
                    if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
                    updateConsoleLog(`${bot.lastWin ? "✅ WIN" : "❌ LOSS"} | P2 | ${payout}x | Bet: ${previousbet.toFixed(8)}`);
                    updateGlassHUD();
                }
                if (bot.isRunning) setTimeout(runLoop, 0);
            } catch (e) {
                updateConsoleLog("🌐 Error: " + e.message);
                if (bot.isRunning) setTimeout(runLoop, 1000);
            }
        }
        
        // ================= PHASE 3 =================
        else if (bot.phase === 3) {
            bot.playgame = "dice";
            bot.chance = bot.phase3Chance;
            const payout = 100 / bot.chance;
            
            if (bot.lastWin) {
                bot.phase3LossStreak = 0;
                bot.nextbet = balance * bot.phase3BasebetMultiplier;
            } else {
                bot.phase3LossStreak = bot.phase3LossStreak + 1;
                bot.nextbet = previousbet * bot.phase3MartingaleMultiplier;
            }
            
            const maxBet = balance * bot.phase3MaxBetPct;
            if (bot.nextbet > maxBet) bot.nextbet = maxBet;
            
            if (bot.phase3LossStreak >= bot.phase3DangerStreak) {
                updateConsoleLog("🛡️ Danger streak → reset Phase 1");
                resetToPhase1();
                if (bot.isRunning) setTimeout(runLoop, 0);
                return;
            }
            
            bot.nextbet = Math.max(bot.minbet, bot.nextbet);
            if (balance >= bot.startBalance) resetToPhase1();
            
            try {
                const res = await API.placeBet(bot.nextbet, payout, "dice");
                if (res.errors) {
                    bot.lastError = res.errors[0].message;
                    updateConsoleLog("❌ Error: " + res.errors[0].message);
                    setTimeout(runLoop, 500);
                    return;
                }
                const data = res?.data || res;
                const bet = data.diceRoll || data.diceBet;
                if (bet && bot.isRunning) {
                    bot.stats.bets++;
                    bot.stats.wagered += bet.amount;
                    updateWageredUSD(bet.amount);
                    const pft = (bet.payout - bet.amount);
                    bot.stats.profit += pft;
                    bot.lastWin = (pft > 0);
                    if (pft > 0) bot.stats.wins++; else bot.stats.loss++;
                    if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
                    updateConsoleLog(`${bot.lastWin ? "✅ WIN" : "❌ LOSS"} | P3 | Streak: ${bot.phase3LossStreak} | Bet: ${previousbet.toFixed(8)}`);
                    updateGlassHUD();
                }
                if (bot.isRunning) setTimeout(runLoop, 0);
            } catch (e) {
                updateConsoleLog("🌐 Error: " + e.message);
                if (bot.isRunning) setTimeout(runLoop, 1000);
            }
        }
    }

    const API = {
        async syncOnce() {
            bot.token = getAuthToken();
            const query = `query{user{name balances{available{amount currency}}}}`;
            try {
                const res = await fetch(`${CONFIG.apiUrl}/graphql`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "x-access-token": bot.token },
                    body: JSON.stringify({ query })
                });
                const json = await res.json();
                if (json?.data?.user) {
                    bot.stakeUser = json.data.user.name;
                    const bals = json.data.user.balances || [];
                    const sel = document.getElementById("orion-currency");
                    if (sel && sel.options.length === 0) {
                        bals.forEach(b => {
                            const opt = document.createElement("option");
                            opt.value = b.available.currency;
                            opt.textContent = b.available.currency.toUpperCase();
                            if(b.available.currency === "doge") opt.selected = true;
                            sel.appendChild(opt);
                        });
                    }
                    if (sel) bot.selectedCurrency = sel.value;
                    const active = bals.find(b => b.available.currency === bot.selectedCurrency);
                    bot.stats.startBal = active ? parseFloat(active.available.amount) : 0;
                }
            } catch (e) { 
                updateConsoleLog("Sync Failed: " + e.message);
            }
        },
        async sendTg(statusHeader) {
            const now = Date.now();
            if (now - lastReportTime < 30000) return;
            lastReportTime = now;
            const elapsed = bot.startTime ? (new Date() - bot.startTime) / 1000 : 0;
            const timeStr = new Date(elapsed * 1000).toISOString().substr(11, 8);
            const speed = (bot.stats.bets / (elapsed || 1)).toFixed(2);
            const profitColor = bot.stats.profit >= 0 ? '🟢' : '🔴';
            const currentBalance = getCurrentBalance().toFixed(8);
            const totalLossPct = getTotalLossPercentage();
            const text = `🔷 *ORION V3*\n${statusHeader}\n👤 ${bot.stakeUser}\n💰 Balance: ${currentBalance}\n📈 Profit: ${profitColor} ${bot.stats.profit.toFixed(8)}\n📊 Wagered: ${bot.stats.wagered.toFixed(8)}\n🎰 Bets: ${bot.stats.bets}\n⚡ Speed: ${speed} b/s`;
            try {
                fetch(`https://api.telegram.org/bot${CONFIG.tgToken}/sendMessage`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ chat_id: CONFIG.tgChatId, text: text, parse_mode: "Markdown" })
                }).catch(() => {});
            } catch (e) {}
        },
        async placeBet(amount, payout, game) {
            const endpoint = game === "dice" ? `${CONFIG.apiUrl}/casino/dice/roll` : `${CONFIG.apiUrl}/casino/limbo/bet`;
            const payload = { 
                amount: parseFloat(amount), 
                currency: bot.selectedCurrency, 
                identifier: Math.random().toString(36).slice(2) + Date.now().toString(36)
            };
            if (game === "dice") { 
                payload.target = 100 - (100 / payout); 
                payload.condition = "above"; 
            } else { 
                payload.multiplierTarget = parseFloat(payout); 
            }
            return fetch(endpoint, {
                method: "POST",
                headers: { "Content-Type": "application/json", "x-access-token": bot.token },
                body: JSON.stringify(payload)
            }).then(r => r.json());
        }
    };

    // Initialize
    createGlassHUD();
    API.syncOnce();
    
    setInterval(() => {
        if (bot.isRunning) updateGlassHUD();
    }, 500);
    
    document.getElementById("orion-start-btn").onclick = async () => { 
        if(!bot.isRunning){ 
            await API.syncOnce();
            
            // Load all params
            bot.wgrdiv = parseFloat(document.getElementById("param-wgrdiv")?.value) || 50000;
            bot.minbet = parseFloat(document.getElementById("param-minbet")?.value) || 0.0015;
            bot.targetWager = parseFloat(document.getElementById("param-targetwager")?.value) || 10;
            bot.phase1Chance = parseFloat(document.getElementById("param-phase1-chance")?.value) || 97;
            bot.phase1TriggerLossPct = parseFloat(document.getElementById("param-phase1-trigger")?.value) || 0.5;
            bot.phase2BasebetMultiplier = parseFloat(document.getElementById("param-phase2-basebet")?.value) || 0.0010;
            bot.phase2PayoutMin = parseFloat(document.getElementById("param-phase2-payout-min")?.value) || 1.30;
            bot.phase2PayoutMax = parseFloat(document.getElementById("param-phase2-payout-max")?.value) || 1.50;
            bot.phase2TriggerLossPct = parseFloat(document.getElementById("param-phase2-trigger")?.value) || 7.0;
            bot.phase3Chance = parseFloat(document.getElementById("param-phase3-chance")?.value) || 60;
            bot.phase3BasebetMultiplier = parseFloat(document.getElementById("param-phase3-basebet")?.value) || 0.0008;
            bot.phase3MartingaleMultiplier = parseFloat(document.getElementById("param-phase3-martingale")?.value) || 2.5;
            bot.phase3MaxBetPct = (parseFloat(document.getElementById("param-phase3-maxbet")?.value) || 10) / 100;
            bot.phase3DangerStreak = parseInt(document.getElementById("param-phase3-streak")?.value) || 12;
            
            const currencySel = document.getElementById("orion-currency");
            if (currencySel && currencySel.value) bot.selectedCurrency = currencySel.value;
            
            bot.startBalance = bot.stats.startBal;
            bot.balst = bot.stats.startBal;
            bot.balhigh = bot.stats.startBal;
            bot.target = bot.stats.startBal * 10;
            bot.wagtarget = bot.stats.startBal * bot.targetWager;
            bot.factor = bot.stats.startBal / 100;
            bot.stime = Date.now() / 1000;
            bot.wager = 0;
            bot.tick = 0;
            bot.MaXDD = 0;
            bot.phase3LossStreak = 0;
            bot.lastWin = false;
            
            bot.isRunning = true;
            bot.startTime = new Date();
            bot.stats.bets = 0;
            bot.stats.profit = 0;
            bot.stats.wagered = 0;
            bot.stats.wageredUSD = 0;
            bot.stats.wins = 0;
            bot.stats.loss = 0;
            bot.stats.maxDD = 0;
            
            resetToPhase1();
            setTimeout(() => API.sendTg("🚀 *SYSTEM STARTED*"), 1000);
            if (reportInterval) clearInterval(reportInterval);
            reportInterval = setInterval(() => { if (bot.isRunning) API.sendTg("📊 *PERIODIC REPORT*"); }, 180000);
            runLoop();
        } 
    };
    
    document.getElementById("orion-stop-btn").onclick = () => { if(bot.isRunning) stopBot(); };
})();
