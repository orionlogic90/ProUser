                </div>
                
                <div class="ui-buttons">
                    <button class="ui-btn-start" id="BTN_START">▶ START</button>
                    <button class="ui-btn-stop" id="BTN_STOP" disabled>⏹ STOP</button>
                </div>
            </div>
        `;
        document.body.appendChild(ui);
        
        const dragHandle = document.getElementById("UI_DRAG_HANDLE");
        const dragContainer = document.getElementById("ORION_UNIFIED_UI");
        
        dragHandle.addEventListener("mousedown", function(e) {
            if (e.target.closest(".ui-input") || e.target.closest(".ui-select") || e.target.closest("button")) return;
            isDragging = true;
            const rect = dragContainer.getBoundingClientRect();
            dragOffsetX = e.clientX - rect.left;
            dragOffsetY = e.clientY - rect.top;
            dragContainer.classList.add("dragging");
            e.preventDefault();
        });
        
        document.addEventListener("mousemove", function(e) {
            if (!isDragging) return;
            let newLeft = e.clientX - dragOffsetX;
            let newTop = e.clientY - dragOffsetY;
            newLeft = Math.max(5, Math.min(window.innerWidth - dragContainer.offsetWidth - 5, newLeft));
            newTop = Math.max(5, Math.min(window.innerHeight - dragContainer.offsetHeight - 5, newTop));
            dragContainer.style.left = newLeft + "px";
            dragContainer.style.top = newTop + "px";
            dragContainer.style.right = "auto";
            dragContainer.style.bottom = "auto";
        });
        
        document.addEventListener("mouseup", function() {
            if (isDragging) {
                isDragging = false;
                dragContainer.classList.remove("dragging");
            }
        });
        
        document.getElementById("BTN_START").onclick = async function() {
            if (!bot.isRunning) {
                await API.syncOnce();
                
                const minbetVal = parseFloat(document.getElementById("PARAM_MINBET")?.value);
                if (!isNaN(minbetVal) && minbetVal > 0) bot.minbet = minbetVal;
                
                const targetVal = parseFloat(document.getElementById("PARAM_TARGET_WAGER")?.value);
                if (!isNaN(targetVal) && targetVal > 0) bot.targetWager = targetVal;
                
                const slVal = parseFloat(document.getElementById("PARAM_STOP_LOSS")?.value);
                if (!isNaN(slVal) && slVal > 0) bot.stopLossPercent = slVal;
                
                const p1Chance = parseFloat(document.getElementById("P1_CHANCE")?.value);
                if (!isNaN(p1Chance) && p1Chance > 0 && p1Chance < 100) bot.phase1Chance = p1Chance;
                
                const p1BaseBet = parseFloat(document.getElementById("P1_BASE_BET")?.value);
                if (!isNaN(p1BaseBet) && p1BaseBet > 0) bot.phase1BaseBetPercent = p1BaseBet;
                
                const p2MinMulti = parseFloat(document.getElementById("P2_MIN_MULTI")?.value);
                if (!isNaN(p2MinMulti) && p2MinMulti > 1) bot.phase2MinMultiplier = p2MinMulti;
                
                const p2MaxMulti = parseFloat(document.getElementById("P2_MAX_MULTI")?.value);
                if (!isNaN(p2MaxMulti) && p2MaxMulti > p2MinMulti) bot.phase2MaxMultiplier = p2MaxMulti;
                
                const p2BaseBet = parseFloat(document.getElementById("P2_BASE_BET")?.value);
                if (!isNaN(p2BaseBet) && p2BaseBet > 0) bot.phase2BaseBetPercent = p2BaseBet;
                
                const p3Chance = parseFloat(document.getElementById("P3_CHANCE")?.value);
                if (!isNaN(p3Chance) && p3Chance > 0 && p3Chance < 100) bot.phase3Chance = p3Chance;
                
                const p3BaseBet = parseFloat(document.getElementById("P3_BASE_BET")?.value);
                if (!isNaN(p3BaseBet) && p3BaseBet > 0) bot.phase3BaseBetPercent = p3BaseBet;
                
                const t1 = parseFloat(document.getElementById("TRIGGER_P1_P2")?.value);
                if (!isNaN(t1) && t1 > 0) bot.triggerP1toP2 = t1;
                
                const t2 = parseFloat(document.getElementById("TRIGGER_P2_P3")?.value);
                if (!isNaN(t2) && t2 > 0) bot.triggerP2toP3 = t2;
                
                const t3 = parseFloat(document.getElementById("TRIGGER_P3_P2")?.value);
                if (!isNaN(t3) && t3 > 0) bot.triggerP3toP2 = t3;
                
                const t4 = parseFloat(document.getElementById("TRIGGER_P2_P1")?.value);
                if (!isNaN(t4) && t4 > 0) bot.triggerP2toP1 = t4;
                
                const mult = parseFloat(document.getElementById("MARTI_MULT")?.value);
                if (!isNaN(mult) && mult > 0) bot.martingaleMultiplier = mult;
                
                const maxStreak = parseInt(document.getElementById("MARTI_MAX")?.value);
                if (!isNaN(maxStreak) && maxStreak > 0) bot.martingaleMaxStreak = maxStreak;
                
                bot.martingaleEnabled = document.getElementById("MARTI_ENABLED")?.checked || false;
                
                const cs = document.getElementById("UI_CURRENCY");
                if (cs && cs.value) bot.selectedCurrency = cs.value;
                
                bot.startBalance = bot.stats.startBal;
                bot.balst = bot.stats.startBal;
                bot.balhigh = bot.stats.startBal;
                bot.target = bot.stats.startBal * 10;
                bot.wagtarget = bot.stats.startBal * bot.targetWager;
                bot.factor = bot.stats.startBal / 100;
                bot.stime = Date.now() / 1000;
                bot.wager = 0;
                bot.wagerTargetReached = false;
                bot.stats.bets = 0;
                bot.stats.profit = 0;
                bot.stats.wagered = 0;
                bot.stats.wins = 0;
                bot.stats.loss = 0;
                bot.stats.maxDD = 0;
                bot.isRunning = true;
                bot.startTime = new Date();
                resetToPhase1();
                updateUIStatus(true);
                const targetEl = document.getElementById("UI_TARGET");
                if (targetEl) targetEl.innerText = bot.wagtarget.toFixed(0);
                await sendTelegramNow("🚀 *Orion V3 STARTED*\n```\n👤 " + maskUsername(bot.stakeUser) + "\n💰 " + bot.startBalance.toFixed(6) + " " + bot.selectedCurrency.toUpperCase() + "\n🎯 Target: " + bot.wagtarget.toFixed(2) + " | SL: " + bot.stopLossPercent + "%\n📞 @OrionLogic\n```");
                if (reportInterval) clearInterval(reportInterval);
                reportInterval = setInterval(function() { if (bot.isRunning) sendTelegram(); }, 180000);
                runLoop();
            }
        };
        
        document.getElementById("BTN_STOP").onclick = function() { if (bot.isRunning) stopBot(); };
    }

    setInterval(function() {
        if (bot.isRunning) {
            updateUI();
            const targetEl = document.getElementById("UI_TARGET");
            if (targetEl && bot.wagtarget) targetEl.innerText = bot.wagtarget.toFixed(0);
        }
    }, 300);

    createUnifiedUI();
    API.syncOnce();
})();
