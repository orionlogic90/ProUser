                runLoop();
            }
        };
        
        stopBtn.onclick = () => { if (bot.isRunning) stopBot(); };
        reportBtn.onclick = () => { sendManualReport(); };
        
        updateConsoleLog("⚡ Ultra-fast mode active | Delay: 50ms");
    }

    function updateHud(force = false) {
        const now = Date.now();
        if (!force && now - bot.lastUiMs < 150) return;
        bot.lastUiMs = now;

        const curB = getCurrentBalance();
        const profit = curB - bot.startBalance;
        const wagerPercent = bot.wagtarget > 0 ? (bot.wager / bot.wagtarget) * 100 : 0;
        const winLoss = `${bot.stats.wins}/${bot.stats.loss}`;
        
        const balEl = document.getElementById("HUD_BALANCE");
        if (balEl) balEl.innerText = curB.toFixed(4);
        
        const profitEl = document.getElementById("HUD_PROFIT");
        if (profitEl) { 
            profitEl.innerText = (profit >= 0 ? "+" : "") + profit.toFixed(4); 
            profitEl.style.color = profit >= 0 ? "#48BB78" : "#F6465D"; 
        }
        
        const phaseEl = document.getElementById("HUD_PHASE");
        if (phaseEl) phaseEl.innerText = bot.phase;
        
        const chanceEl = document.getElementById("HUD_CHANCE");
        if (chanceEl) chanceEl.innerText = (bot.phase === 3 ? bot.phase3Chance.toFixed(1) : bot.chance.toFixed(2)) + "%";
        
        const nextEl = document.getElementById("HUD_NEXTBET");
        if (nextEl) nextEl.innerText = bot.nextbet.toFixed(6);
        
        const wlEl = document.getElementById("HUD_WLRATIO");
        if (wlEl) wlEl.innerText = winLoss;
        
        const fillEl = document.getElementById("wager-progress-fill");
        const textEl = document.getElementById("wager-progress-text");
        const currentEl = document.getElementById("wager-current");
        const targetEl = document.getElementById("wager-target");
        if (fillEl) fillEl.style.width = Math.min(100, wagerPercent) + "%";
        if (textEl) textEl.innerText = wagerPercent.toFixed(1) + "%";
        if (currentEl) currentEl.innerText = bot.wager.toFixed(2);
        if (targetEl) targetEl.innerText = bot.wagtarget.toFixed(2);
        
        const badge = document.getElementById("ORION_HUD_BADGE");
        if (badge) {
            if (bot.isRunning) {
                badge.innerText = "RUNNING";
                badge.style.background = "rgba(72, 187, 120, 0.2)";
                badge.style.color = "#48BB78";
            } else { 
                badge.innerText = "STOPPED"; 
                badge.style.background = "rgba(246, 70, 93, 0.2)"; 
                badge.style.color = "#F6465D"; 
            }
        }
    }

    function updateHUDStatus(status) {
        const badge = document.getElementById("ORION_HUD_BADGE");
        if (badge) badge.innerText = status;
        updateHud(true);
    }

    function loadConfigFromUI() {
        const minbet = document.getElementById("cfg_minbet");
        if (minbet) bot.minbet = parseFloat(minbet.value) || 0.0015;
        
        const wgrdiv = document.getElementById("cfg_wgrdiv");
        if (wgrdiv) bot.wgrdiv = parseFloat(wgrdiv.value) || 650;
        
        const p2min = document.getElementById("cfg_p2_min");
        if (p2min) bot.phase2.minPayout = parseFloat(p2min.value) || 1.30;
        
        const p2max = document.getElementById("cfg_p2_max");
        if (p2max) bot.phase2.maxPayout = parseFloat(p2max.value) || 1.50;
        
        const p3base = document.getElementById("cfg_p3_base");
        if (p3base) {
            bot.phase3Chance = parseFloat(p3base.value) || 60;
            if (bot.phase === 3) bot.chance = bot.phase3Chance;
        }
        
        const currencySel = document.getElementById("orion-currency");
        if (currencySel && currencySel.value) bot.selectedCurrency = currencySel.value;
        
        if (bot.isRunning) {
            const stoplossPct = parseFloat(document.getElementById("cfg_stoploss_pct")?.value || "30");
            const targetX = parseFloat(document.getElementById("cfg_target_x")?.value || "5");
            bot.stoploss = bot.startBalance * (stoplossPct / 100);
            bot.wagtarget = bot.startBalance * targetX;
        }
        
        updateHud(true);
    }

    async function runLoop() {
        if (!bot.isRunning) { loopRunning = false; return; }
        if (loopRunning) return;
        loopRunning = true;
        
        try {
            const now = Date.now();
            if (now - bot.lastBetTime < bot.minDelayMs) {
                await new Promise(r => setTimeout(r, bot.minDelayMs - (now - bot.lastBetTime)));
            }
            
            const balance = getCurrentBalance();
            const previousbet = bot.nextbet;
            
            bot.wager += previousbet;
            bot.stats.wagered += previousbet;
            updateWageredUSD(previousbet);
            updateMonitoringStats(previousbet);
            
            if (balance <= bot.stoploss) {
                updateConsoleLog(`🛑 Stop loss: ${balance.toFixed(4)} <= ${bot.stoploss.toFixed(4)}`);
                stopBot();
                loopRunning = false;
                return;
            }
            
            if (bot.wager >= bot.wagtarget) {
                updateConsoleLog(`🎯 Target achieved: ${bot.wager.toFixed(2)}/${bot.wagtarget.toFixed(2)}`);
                stopBot();
                loopRunning = false;
                return;
            }
            
            if (balance > bot.balhigh) bot.balhigh = balance;
            const drawdown = ((bot.balhigh - balance) / bot.balhigh) * 100;
            
            if (bot.phase === 1) {
                bot.playgame = "dice";
                bot.chance = 99.98;
                let newBet = balance / bot.wgrdiv;
                newBet = Math.max(bot.minbet, newBet);
                bot.nextbet = newBet;
                
                if (drawdown >= 0.5) {
                    goToPhase2();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                const payout = 100 / bot.chance;
                bot.lastBetTime = Date.now();
                const res = await API.placeBet(bot.nextbet, payout, "dice");
                handleBetResponse(res, previousbet, balance, 1);
            }
            else if (bot.phase === 2) {
                bot.playgame = "limbo";
                const randomPayout = Math.random() * (bot.phase2.maxPayout - bot.phase2.minPayout) + bot.phase2.minPayout;
                const payout = parseFloat(randomPayout.toFixed(2));
                let newBet = balance * 0.001;
                newBet = Math.max(bot.minbet, newBet);
                bot.nextbet = newBet;
                
                const phase2Loss = ((bot.startBalance - balance) / bot.startBalance) * 100;
                
                if (phase2Loss >= 2) {
                    goToPhase3();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                if (balance >= bot.startBalance) {
                    resetToPhase1();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                bot.lastBetTime = Date.now();
                const res = await API.placeBet(bot.nextbet, payout, "limbo");
                handleBetResponse(res, previousbet, balance, 2);
            }
            else if (bot.phase === 3) {
                bot.playgame = "dice";
                const totalLoss = Math.abs(bot.startBalance - balance);
                
                if (bot.lastWin) {
                    if (balance >= bot.startBalance) {
                        resetToPhase1();
                        loopRunning = false;
                        setTimeout(() => runLoop(), 0);
                        return;
                    } else {
                        if (bot.phase3Chance > 60) {
                            bot.phase3Chance = Math.max(60, bot.phase3Chance - 0.5);
                        }
                        bot.chance = bot.phase3Chance;
                        let newBet = balance * 0.0008;
                        newBet = Math.max(bot.minbet, newBet);
                        bot.nextbet = newBet;
                    }
                } else {
                    if (bot.phase3Chance < 77) {
                        bot.phase3Chance = Math.min(77, bot.phase3Chance + 0.1);
                    }
                    bot.chance = bot.phase3Chance;
                    
                    const profitPerBet = (99 / bot.chance) - 1;
                    
                    if (profitPerBet > 0) {
                        let newBet = (totalLoss / profitPerBet) * 0.65;
                        newBet = Math.max(bot.minbet, newBet);
                        bot.nextbet = newBet;
                    } else {
                        bot.nextbet = previousbet * 1.2;
                        bot.nextbet = Math.max(bot.minbet, bot.nextbet);
                    }
                }
                
                if (totalLoss >= 55) {
                    updateConsoleLog("⚠️ Loss >55% - Reset to Phase 1");
                    resetToPhase1();
                    loopRunning = false;
                    setTimeout(() => runLoop(), 0);
                    return;
                }
                
                const payout = 100 / bot.chance;
                bot.lastBetTime = Date.now();
                const res = await API.placeBet(bot.nextbet, payout, "dice");
                handleBetResponse(res, previousbet, balance, 3);
            }
            
            updateHud(false);
            loopRunning = false;
            if (bot.isRunning) setTimeout(() => runLoop(), 0);
        } catch (err) {
            console.error("Loop error:", err);
            loopRunning = false;
            if (bot.isRunning) setTimeout(() => runLoop(), 100);
        }
    }
    
    function handleBetResponse(res, previousbet, balance, phaseNum) {
        if (res && res.errors) { 
            updateConsoleLog(`❌ Error P${phaseNum}: ${res.errors[0].message}`); 
            bot.lastWin = false;
            return false; 
        }
        
        const data = res?.data || res;
        let bet = data?.diceRoll || data?.diceBet || data?.limboBet;
        
        if (bet && bot.isRunning) {
            bot.stats.bets++;
            const pft = bet.payout - bet.amount;
            bot.stats.profit += pft;
            bot.lastWin = (pft > 0);
            
            if (pft > 0) bot.stats.wins++;
            else bot.stats.loss++;
            
            const gameInfo = bot.phase === 1 ? `99.98%` : (bot.phase === 2 ? `Limbo` : `${bot.chance.toFixed(2)}%`);
            updateConsoleLog(`${bot.lastWin ? "✅" : "❌"} P${phaseNum} ${gameInfo} | Bet:${previousbet.toFixed(6)} Bal:${getCurrentBalance().toFixed(4)}`);
        }
        return false;
    }

    const API = {
        async syncOnce() {
            bot.token = getAuthToken();
            const query = `query{user{name balances{available{amount currency}}}}`;
            try {
                const res = await fetch(`${CONFIG.apiUrl}/graphql`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "x-access-token": bot.token },
                    body: JSON.stringify({ query })
                });
                const json = await res.json();
                if (json?.data?.user) {
                    bot.stakeUser = json.data.user.name;
                    const bals = json.data.user.balances || [];
                    bot.availableCurrencies = bals.map(b => b.available.currency.toUpperCase());
                    
                    const currencySelect = document.getElementById("orion-currency");
                    if (currencySelect && currencySelect.options.length === 0) {
                        bals.forEach(b => {
                            const opt = document.createElement("option");
                            opt.value = b.available.currency;
                            opt.textContent = b.available.currency.toUpperCase();
                            if (b.available.currency === "doge") opt.selected = true;
                            currencySelect.appendChild(opt);
                        });
                        if (currencySelect.options.length > 0 && !currencySelect.value) {
                            currencySelect.value = "doge";
                        }
                        bot.selectedCurrency = currencySelect.value || "doge";
                    }
                    
                    const active = bals.find(b => b.available.currency === bot.selectedCurrency);
                    bot.stats.startBal = active ? parseFloat(active.available.amount) : 0;
                    bot.startBalance = bot.stats.startBal;
                    bot.balhigh = bot.startBalance;
                    bot.worstBalance = bot.startBalance;
                    updateHud(true);
                    updateConsoleLog(`✅ Synced | Balance: ${bot.stats.startBal.toFixed(4)} ${bot.selectedCurrency.toUpperCase()}`);
                }
            } catch (e) { updateConsoleLog("Sync error: " + e.message); }
        },
        async placeBet(amount, payout, game) {
            const endpoint = game === "dice" ? `${CONFIG.apiUrl}/casino/dice/roll` : `${CONFIG.apiUrl}/casino/limbo/bet`;
            const payload = { 
                amount: parseFloat(amount), 
                currency: bot.selectedCurrency, 
                identifier: Date.now().toString(36) + Math.random().toString(36).substr(2, 5)
            };
            if (game === "dice") { 
                payload.target = 100 - (100 / payout); 
                payload.condition = "above"; 
            } else { 
                payload.multiplierTarget = parseFloat(payout); 
            }
            return fetch(endpoint, { 
                method: "POST", 
                headers: { "Content-Type": "application/json", "x-access-token": bot.token }, 
                body: JSON.stringify(payload) 
            }).then(r => r.json());
        }
    };

    function init() {
        ensureHudAndControls();
    }
    
    setInterval(() => { updateHud(false); }, 200);
    init();
    API.syncOnce();
})();
