                    <span class="bot-stat-value" id="st-losses">0</span>
                </div>
                <div class="bot-stat-row">
                    <span class="bot-stat-label">WINRATE</span>
                    <span class="bot-stat-value" id="st-winrate">0%</span>
                </div>
            </div>
            
            <div class="bot-status" id="bot-status">
                Ready
            </div>
            
            <div class="bot-speed">
                SPEED: <span id="st-speed">0</span> bet/sec
            </div>
            
            <!-- Hidden inputs untuk menjaga kompatibilitas -->
            <input type="hidden" id="p-multiplier" value="2">
            <input type="hidden" id="p-max-steps" value="5">
            <input type="hidden" id="p-pfpump" value="0.15">
            <input type="hidden" id="p-pfdump" value="0.05">
            <input type="hidden" id="p-divider" value="400">
        `;
        
        document.body.appendChild(d);
        
        document.getElementById("p-save-token").onclick = () => {
            saveTokenAndReload();
        };
        
        document.getElementById("p-start").onclick = async () => { 
            if(!bot.isRunning){ 
                bot.stopOnWin = false;
                bot.stopOnWinTriggered = false;
                
                const syncSuccess = await API.syncOnce();
                if (!syncSuccess || !bot.stakeUser || bot.stakeUser === "Not logged in") {
                    updateUILog("❌ Auth failed!");
                    return;
                }
                
                bot.isRunning = true; 
                bot.startTime = new Date(); 
                bot.stats.bets = 0; 
                bot.stats.profit = 0; 
                bot.stats.wagered = 0; 
                bot.stats.wins = 0; 
                bot.stats.loss = 0; 
                bot.stats.ties = 0;
                bot.stats.maxDD = 0;
                bot.stats.peakBalance = bot.stats.startBal;
                bot.currentGame = "mode1";
                bot.lossStreak = 0;
                bot.stopOnWinTriggered = false;
                
                const currentBalance = bot.stats.startBal;
                const defaultBaseBet = currentBalance * 3e-5;
                const minBet = parseFloat(document.getElementById("p-minbet").value) || 0.00123;
                let baseVal = defaultBaseBet;
                if (baseVal < minBet) baseVal = minBet;
                bot.baseBet = baseVal;
                bot.currentBet = baseVal;
                bot.lastBetSide = "player";
                bot.lastWinner = null;
                
                const baseBetInput = document.getElementById("p-basebet");
                if (baseBetInput) baseBetInput.value = baseVal.toFixed(8);
                
                updateUILog("🚀 BOT RUNNING");
                runLoop(); 
            } 
        };
        
        document.getElementById("p-stop").onclick = () => { 
            if(bot.isRunning){ 
                bot.isRunning = false; 
                updateUILog("🛑 BOT STOPPED"); 
            } 
        };
        
        document.getElementById("p-reset").onclick = async () => { 
            if(bot.isRunning) bot.isRunning = false;
            await API.syncOnce();
            bot.stats.bets = 0;
            bot.stats.profit = 0;
            bot.stats.wagered = 0;
            bot.stats.wins = 0;
            bot.stats.loss = 0;
            bot.stats.ties = 0;
            bot.stats.maxDD = 0;
            bot.stats.peakBalance = bot.stats.startBal;
            bot.currentGame = "mode1";
            bot.lossStreak = 0;
            bot.lastBetSide = "player";
            bot.lastWinner = null;
            
            const currentBalance = bot.stats.startBal;
            const defaultBaseBet = currentBalance * 3e-5;
            const minBet = parseFloat(document.getElementById("p-minbet").value) || 0.00123;
            let baseVal = defaultBaseBet;
            if (baseVal < minBet) baseVal = minBet;
            bot.baseBet = baseVal;
            bot.currentBet = baseVal;
            
            const baseBetInput = document.getElementById("p-basebet");
            if (baseBetInput) baseBetInput.value = baseVal.toFixed(8);
            
            updateUILog("🔄 Stats reset");
            updateUIStats();
        };
        
        const savedToken = getAuthToken();
        if (savedToken) {
            const tokenInput = document.getElementById("p-api-token");
            if (tokenInput) tokenInput.value = savedToken;
            API.syncOnce();
        }
    }

    setInterval(() => {
        if (!document.getElementById("st-balance")) return;
        
        const currentBalance = bot.stats.startBal + bot.stats.profit;
        
        document.getElementById("st-balance").innerText = currentBalance.toFixed(8);
        
        const profitEl = document.getElementById("st-profit");
        profitEl.innerText = bot.stats.profit.toFixed(8);
        if (bot.stats.profit > 0) {
            profitEl.className = "bot-stat-value positive";
        } else if (bot.stats.profit < 0) {
            profitEl.className = "bot-stat-value negative";
        } else {
            profitEl.className = "bot-stat-value";
        }
        
        document.getElementById("st-wager").innerText = bot.stats.wagered.toFixed(8);
        document.getElementById("st-bets").innerText = bot.stats.bets;
        document.getElementById("st-wins").innerText = bot.stats.wins;
        document.getElementById("st-losses").innerText = bot.stats.loss;
        document.getElementById("st-winrate").innerText = bot.stats.bets > 0 ? ((bot.stats.wins / bot.stats.bets) * 100).toFixed(1) + "%" : "0%";
        
        const userEl = document.getElementById("bot-user");
        if (userEl && bot.stakeUser && bot.stakeUser !== "Not logged in") {
            userEl.innerText = bot.stakeUser;
        }
        
        updateSpeed();
        
    }, 400);

    createUI(); 
})();
