(function () {
    const CONFIG = {
        get apiUrl() { return window.location.origin + '/_api'; },
        version: "ORION Bot v3.0"
    };

    const bot = {
        isRunning: false,
        token: null,
        startTime: null,
        stakeUser: "",
        stats: { profit: 0, wagered: 0, startBal: 0, bets: 0, wins: 0, loss: 0, ties: 0, maxDD: 0, peakBalance: 0 },
        selectedCurrency: "POL",
        currentStatus: "IDLE",
        lastError: "None",
        
        currentGame: "mode1",
        
        baseBet: 0.001,
        currentBet: 0.001,
        martingaleMultiplier: 2,
        maxMartingaleSteps: 5,
        lossStreak: 0,
        lastBetSide: "player",
        lastWinner: null,
        
        peakBalance: 0,
        
        targetWager: 0,
        targetProfit: 0,
        stopLoss: 0,
        stopOnWin: false,
        stopOnWinTriggered: false,
        
        pfPump: 0.15,
        pfDump: 0.05,
        diceDivider: 400
    };

    // ============ API TOKEN FUNCTIONS ============
    function getAuthToken() {
        const storedToken = localStorage.getItem('apitoken') || sessionStorage.getItem('apitoken');
        if (storedToken) return storedToken;
        
        const cookieMatch = document.cookie.match(/session=([^;]+)/);
        if (cookieMatch) return cookieMatch[1];
        
        const tokenInput = document.getElementById("p-api-token");
        if (tokenInput && tokenInput.value) {
            return tokenInput.value;
        }
        
        return null;
    }

    function saveToken(token) {
        if (token && token.length > 10) {
            localStorage.setItem('apitoken', token);
            bot.token = token;
        }
    }

    // ============ API CALLS ============
    const API = {
        async syncOnce() {
            bot.token = getAuthToken();
            if (!bot.token || bot.token.length < 30) {
                updateUILog("⚠️ Waiting for API token...");
                return false;
            }
            
            const query = `query{user{name balances{available{amount currency}}}}`;
            try {
                const res = await fetch(`${CONFIG.apiUrl}/graphql`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "x-access-token": bot.token },
                    body: JSON.stringify({ query })
                });
                const json = await res.json();
                if (json?.data?.user) {
                    bot.stakeUser = json.data.user.name;
                    const userEl = document.getElementById("bot-user");
                    if (userEl) userEl.innerText = bot.stakeUser;
                    
                    const bals = json.data.user.balances || [];
                    const sel = document.getElementById("p-currency");
                    if (sel && sel.options.length === 0) {
                        bals.forEach(b => {
                            const opt = document.createElement("option");
                            opt.value = b.available.currency;
                            opt.textContent = b.available.currency.toUpperCase();
                            if(b.available.currency === "pol") opt.selected = true;
                            sel.appendChild(opt);
                        });
                    }
                    if (sel) {
                        bot.selectedCurrency = sel.value;
                    }
                    const active = bals.find(b => b.available.currency === bot.selectedCurrency);
                    bot.stats.startBal = active ? parseFloat(active.available.amount) : 0;
                    bot.stats.peakBalance = bot.stats.startBal;
                    
                    const defaultBaseBet = bot.stats.startBal * 3e-5;
                    const minBetInput = document.getElementById("p-minbet");
                    const baseBetInput = document.getElementById("p-basebet");
                    if (baseBetInput && (!baseBetInput.value || baseBetInput.value === "0.001")) {
                        baseBetInput.value = defaultBaseBet.toFixed(8);
                        bot.baseBet = defaultBaseBet;
                        bot.currentBet = defaultBaseBet;
                    }
                    if (minBetInput && (!minBetInput.value || minBetInput.value === "0.00123")) {
                        minBetInput.value = "0.00123";
                    }
                    updateUILog(`✅ Logged in as: ${bot.stakeUser}`);
                    return true;
                } else {
                    updateUILog("❌ Invalid API Token or failed to fetch user data");
                }
            } catch (e) { 
                bot.lastError = "Sync Failed";
                updateUILog(`❌ Sync error: ${e.message}`);
            }
            return false;
        },
        
        async placeBet(amount, payout, game, side = null) {
            if (!bot.token) {
                bot.token = getAuthToken();
                if (!bot.token) {
                    throw new Error("No API token available");
                }
            }
            
            if (game === "mode1") {
                const endpoint = `${CONFIG.apiUrl}/casino/baccarat/bet`;
                const payload = {
                    currency: bot.selectedCurrency,
                    identifier: Math.random().toString(36).slice(2) + Date.now().toString(36),
                    player: 0,
                    banker: 0,
                    tie: 0
                };
                payload[side] = parseFloat(amount);
                
                return fetch(endpoint, {
                    method: "POST",
                    headers: { 
                        "Content-Type": "application/json", 
                        "x-access-token": bot.token,
                        "x-lockdown-token": "s5MNWtjTM5TvCMkAzxov"
                    },
                    body: JSON.stringify(payload)
                }).then(r => r.json());
            } else {
                const endpoint = `${CONFIG.apiUrl}/casino/dice/roll`;
                const payload = { 
                    amount: parseFloat(amount), 
                    currency: bot.selectedCurrency, 
                    identifier: Math.random().toString(36).slice(2),
                    target: 100 - (100 / payout),
                    condition: "above"
                };
                return fetch(endpoint, {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "x-access-token": bot.token },
                    body: JSON.stringify(payload)
                }).then(r => r.json());
            }
        }
    };

    // ============ BOT LOGIC ============
    function checkTargets() {
        const currentBalance = bot.stats.startBal + bot.stats.profit;
        
        if (bot.targetProfit > 0 && bot.stats.profit >= bot.targetProfit) {
            bot.isRunning = false;
            bot.currentStatus = "TARGET PROFIT REACHED";
            updateUILog("🎯 TARGET PROFIT REACHED! Bot stopped.");
            return true;
        }
        
        if (bot.stopLoss > 0 && bot.stats.profit <= -bot.stopLoss) {
            bot.isRunning = false;
            bot.currentStatus = "STOP LOSS TRIGGERED";
            updateUILog("🛑 STOP LOSS TRIGGERED! Bot stopped.");
            return true;
        }
        
        if (bot.targetWager > 0 && bot.stats.wagered >= bot.targetWager) {
            bot.isRunning = false;
            bot.currentStatus = "TARGET WAGER REACHED";
            updateUILog("🎯 TARGET WAGER REACHED! Bot stopped.");
            return true;
        }
        
        if (bot.stopOnWin && bot.stopOnWinTriggered) {
            bot.isRunning = false;
            bot.stopOnWinTriggered = false;
            bot.currentStatus = "STOP ON WIN";
            updateUILog("🛑 STOP ON WIN TRIGGERED! Bot stopped.");
            return true;
        }
        
        return false;
    }

    function updatePeakBalance() {
        const currentBalance = bot.stats.startBal + bot.stats.profit;
        if (currentBalance > bot.stats.peakBalance) {
            bot.stats.peakBalance = currentBalance;
        }
    }

    function shouldSwitchToMode2() {
        const currentBalance = bot.stats.startBal + bot.stats.profit;
        const dropFromPeak = ((bot.stats.peakBalance - currentBalance) / bot.stats.peakBalance) * 100;
        return dropFromPeak >= bot.pfDump;
    }

    function shouldSwitchToMode1() {
        const currentBalance = bot.stats.startBal + bot.stats.profit;
        const profitFromStart = ((currentBalance - bot.stats.startBal) / bot.stats.startBal) * 100;
        return profitFromStart >= bot.pfPump;
    }

    function getNextBetSide() {
        if (bot.lastWinner && bot.lastWinner !== "tie" && bot.lastWinner !== bot.lastBetSide) {
            return bot.lastWinner;
        }
        return bot.lastBetSide;
    }

    function resetMartingale() {
        bot.currentBet = bot.baseBet;
        bot.lossStreak = 0;
    }

    function updateMartingaleLoss() {
        if (bot.lossStreak + 1 < bot.maxMartingaleSteps) {
            bot.lossStreak++;
            bot.currentBet = bot.baseBet * Math.pow(bot.martingaleMultiplier, bot.lossStreak);
        } else {
            bot.lossStreak++;
            const totalLoss = Math.abs(bot.stats.profit);
            let tieBet = (totalLoss / 9) * 1.02;
            const minBet = parseFloat(document.getElementById("p-minbet").value) || 0.00123;
            if (tieBet < minBet) tieBet = minBet;
            bot.currentBet = tieBet;
            
            if (bot.lossStreak >= bot.maxMartingaleSteps + 1) {
                resetMartingale();
            }
        }
    }

    function updateMartingaleWin() {
        resetMartingale();
    }

    function updateUIStats() {
        const currentBalance = bot.stats.startBal + bot.stats.profit;
        document.getElementById("st-balance").innerText = currentBalance.toFixed(8);
        document.getElementById("st-profit").innerText = bot.stats.profit.toFixed(8);
        const profitEl = document.getElementById("st-profit");
        if (bot.stats.profit > 0) {
            profitEl.className = "bot-stat-value positive";
        } else if (bot.stats.profit < 0) {
            profitEl.className = "bot-stat-value negative";
        } else {
            profitEl.className = "bot-stat-value";
        }
        document.getElementById("st-wager").innerText = bot.stats.wagered.toFixed(8);
        document.getElementById("st-bets").innerText = bot.stats.bets;
        document.getElementById("st-wins").innerText = bot.stats.wins;
        document.getElementById("st-losses").innerText = bot.stats.loss;
        document.getElementById("st-winrate").innerText = bot.stats.bets > 0 ? ((bot.stats.wins / bot.stats.bets) * 100).toFixed(1) + "%" : "0%";
    }

    function processMode1Result(betResult, betSide, betAmount) {
        const state = betResult.state || {};
        const result = state.result || "unknown";
        const payout = betResult.payout || 0;
        const pnl = payout - betAmount;
        
        const isWin = (result === betSide);
        const isTie = (result === "tie");
        
        bot.stats.bets++;
        bot.stats.wagered += betAmount;
        
        if (isWin) {
            bot.stats.wins++;
            updateMartingaleWin();
            if (bot.stopOnWin) {
                bot.stopOnWinTriggered = true;
            }
        } else if (isTie) {
            bot.stats.ties++;
            bot.currentBet = betAmount;
        } else {
            bot.stats.loss++;
            updateMartingaleLoss();
        }
        
        bot.lastWinner = result;
        bot.lastBetSide = betSide;
        
        bot.stats.profit += pnl;
        
        if (bot.stats.profit < bot.stats.maxDD) {
            bot.stats.maxDD = bot.stats.profit;
        }
        
        updatePeakBalance();
        updateUIStats();
        
        return pnl;
    }

    function processMode2Result(betResult, betAmount) {
        const pnl = betResult.payout - betAmount;
        
        bot.stats.bets++;
        bot.stats.wagered += betAmount;
        
        if (pnl > 0) {
            bot.stats.wins++;
            if (bot.stopOnWin) {
                bot.stopOnWinTriggered = true;
            }
        } else {
            bot.stats.loss++;
        }
        
        bot.stats.profit += pnl;
        
        if (bot.stats.profit < bot.stats.maxDD) {
            bot.stats.maxDD = bot.stats.profit;
        }
        
        updatePeakBalance();
        updateUIStats();
        
        return pnl;
    }

    async function runLoop() {
        if (!bot.isRunning) return;
        
        if (checkTargets()) return;
        
        const currentBalanceForBet = bot.stats.startBal + bot.stats.profit;
        const defaultBaseBet = currentBalanceForBet * 3e-5;
        const minBet = parseFloat(document.getElementById("p-minbet").value) || 0.00123;
        
        let baseBetFromUI = parseFloat(document.getElementById("p-basebet").value) || defaultBaseBet;
        if (baseBetFromUI < minBet) baseBetFromUI = minBet;
        
        bot.baseBet = baseBetFromUI;
        bot.martingaleMultiplier = parseFloat(document.getElementById("p-multiplier").value) || 2;
        bot.maxMartingaleSteps = parseInt(document.getElementById("p-max-steps").value) || 5;
        bot.pfPump = parseFloat(document.getElementById("p-pfpump").value) || 0.15;
        bot.pfDump = parseFloat(document.getElementById("p-pfdump").value) || 0.05;
        bot.diceDivider = parseFloat(document.getElementById("p-divider").value) || 400;
        bot.targetWager = parseFloat(document.getElementById("p-target-wager").value) || 0;
        bot.targetProfit = parseFloat(document.getElementById("p-target-profit").value) || 0;
        bot.stopLoss = parseFloat(document.getElementById("p-stop-loss").value) || 0;
        
        if (bot.currentBet !== bot.baseBet && bot.lossStreak === 0) {
            bot.currentBet = bot.baseBet;
        }
        
        const currentBalance = bot.stats.startBal + bot.stats.profit;
        const profitPct = ((currentBalance - bot.stats.startBal) / bot.stats.startBal) * 100;
        
        if (bot.currentGame === "mode1") {
            if (shouldSwitchToMode1()) {
                bot.currentGame = "mode2";
                resetMartingale();
            }
        } else if (bot.currentGame === "mode2") {
            if (shouldSwitchToMode2()) {
                bot.currentGame = "mode1";
                resetMartingale();
            }
        }
        
        let nextbet, gameToPlay, payout, side = null;
        
        if (bot.currentGame === "mode1") {
            gameToPlay = "mode1";
            nextbet = bot.currentBet;
            
            if (nextbet < minBet) nextbet = minBet;
            
            side = getNextBetSide();
            
            try {
                const res = await API.placeBet(nextbet, null, "mode1", side);
                
                if (res.errors) { 
                    bot.lastError = res.errors[0].message; 
                    setTimeout(runLoop, 500); 
                    return; 
                }
                
                const data = res?.data || res;
                const betResult = data.baccaratBet || data;
                
                if (betResult && bot.isRunning) {
                    processMode1Result(betResult, side, nextbet);
                }
                
                if (bot.isRunning) {
                    setTimeout(runLoop, 0);
                }
                
            } catch (e) { 
                bot.lastError = "Network Error"; 
                if (bot.isRunning) setTimeout(runLoop, 800); 
            }
            
        } else {
            gameToPlay = "mode2";
            const chance = 99.98;
            payout = 100 / chance;
            
            nextbet = currentBalance / bot.diceDivider;
            
            if (nextbet < minBet) nextbet = minBet;
            
            try {
                const res = await API.placeBet(nextbet, payout, "mode2");
                
                if (res.errors) { 
                    bot.lastError = res.errors[0].message; 
                    setTimeout(runLoop, 500); 
                    return; 
                }
                
                const data = res?.data || res;
                const bet = data.diceRoll || data.diceBet;
                
                if (bet && bot.isRunning) {
                    processMode2Result(bet, nextbet);
                }
                
                if (bot.isRunning) {
                    setTimeout(runLoop, 0);
                }
                
            } catch (e) { 
                bot.lastError = "Network Error"; 
                if (bot.isRunning) setTimeout(runLoop, 800); 
            }
        }
    }

    function updateUILog(message) {
        // Simplified log for status only
        const statusEl = document.getElementById("bot-status");
        if (statusEl) {
            statusEl.innerText = message;
        }
    }

    function updateSpeed() {
        const speedEl = document.getElementById("st-speed");
        if (speedEl && bot.startTime && bot.isRunning) {
            const speed = (bot.stats.bets / ((new Date() - bot.startTime) / 1000 || 1)).toFixed(2);
            speedEl.innerText = speed;
        } else if (speedEl) {
            speedEl.innerText = "0";
        }
    }

