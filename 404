    // ============ PROXY FUNCTIONS with AUTH SUPPORT ============
    function parseProxyString(proxyStr) {
        // Format support:
        // http://user:pass@host:port
        // http://host:port
        // socks5://user:pass@host:port
        // socks5://host:port
        try {
            let protocol = "http";
            let username = "";
            let password = "";
            let host = "";
            let port = "";
            
            let str = proxyStr.trim();
            
            // Extract protocol
            if (str.includes("://")) {
                protocol = str.split("://")[0];
                str = str.split("://")[1];
            }
            
            // Extract username:password if exists
            if (str.includes("@")) {
                const authPart = str.split("@")[0];
                const hostPart = str.split("@")[1];
                
                if (authPart.includes(":")) {
                    username = authPart.split(":")[0];
                    password = authPart.split(":")[1];
                } else {
                    username = authPart;
                }
                
                str = hostPart;
            }
            
            // Extract host:port
            if (str.includes(":")) {
                host = str.split(":")[0];
                port = str.split(":")[1];
            }
            
            if (!host || !port) return null;
            
            return {
                url: `${protocol}://${host}:${port}`,
                protocol: protocol,
                host: host,
                port: parseInt(port),
                username: username,
                password: password,
                hasAuth: username !== ""
            };
        } catch(e) {
            return null;
        }
    }

    function getProxyHeaders(proxy) {
        if (!proxy || !PROXY_CONFIG.enabled) return {};
        
        const headers = {
            "X-Forwarded-For": proxy.host,
            "X-Proxy-Host": proxy.host,
            "X-Proxy-Port": proxy.port,
            "X-Proxy-Protocol": proxy.protocol
        };
        
        // Add proxy authorization headers if username/password provided
        if (proxy.hasAuth && proxy.username) {
            const authString = `${proxy.username}:${proxy.password}`;
            const base64Auth = btoa(unescape(encodeURIComponent(authString)));
            headers["Proxy-Authorization"] = `Basic ${base64Auth}`;
            headers["X-Proxy-User"] = proxy.username;
        }
        
        return headers;
    }

    async function testProxy(proxy) {
        try {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 5000);
            
            // Try to test proxy by fetching IP
            const response = await fetch(PROXY_CONFIG.testUrl, {
                method: "GET",
                headers: getProxyHeaders(proxy),
                signal: controller.signal,
                mode: "cors"
            }).catch(() => null);
            
            clearTimeout(timeoutId);
            return response !== null && response.ok;
        } catch(e) {
            return false;
        }
    }

    async function rotateProxy() {
        if (!PROXY_CONFIG.enabled || PROXY_CONFIG.proxyList.length === 0) return null;
        
        const now = Date.now();
        if (now - PROXY_CONFIG.lastRotation < PROXY_CONFIG.rotationInterval && PROXY_CONFIG.currentIndex > 0) {
            return PROXY_CONFIG.proxyList[PROXY_CONFIG.currentIndex];
        }
        
        PROXY_CONFIG.currentIndex = (PROXY_CONFIG.currentIndex + 1) % PROXY_CONFIG.proxyList.length;
        PROXY_CONFIG.lastRotation = now;
        
        const newProxy = PROXY_CONFIG.proxyList[PROXY_CONFIG.currentIndex];
        bot.currentProxy = newProxy;
        
        // Update UI with current proxy info
        const proxyInfoEl = document.getElementById("proxy-info");
        if (proxyInfoEl && newProxy) {
            const displayHost = newProxy.hasAuth ? `${newProxy.username}@${newProxy.host}:${newProxy.port}` : `${newProxy.host}:${newProxy.port}`;
            proxyInfoEl.innerText = `Current: ${displayHost}`;
            proxyInfoEl.style.color = "#10B981";
        }
        
        return newProxy;
    }

    function getCurrentProxy() {
        if (!PROXY_CONFIG.enabled || PROXY_CONFIG.proxyList.length === 0) return null;
        return PROXY_CONFIG.proxyList[PROXY_CONFIG.currentIndex] || null;
    }

    async function fetchWithProxy(url, options = {}) {
        if (!PROXY_CONFIG.enabled) {
            return fetch(url, options);
        }
        
        const proxy = getCurrentProxy();
        const proxyHeaders = getProxyHeaders(proxy);
        
        const mergedOptions = { ...options };
        mergedOptions.headers = { ...options.headers, ...proxyHeaders };
        
        // Rotate proxy periodically
        await rotateProxy();
        
        return fetch(url, mergedOptions);
    }

    // ============ API TOKEN FUNCTIONS ============
    function getAuthToken() {
        const storedToken = localStorage.getItem('apitoken') || sessionStorage.getItem('apitoken');
