    function checkWagerMode() {
        if (bot.stats.startBal <= 0) return;
        
        const profitPct = (bot.stats.profit / bot.stats.startBal) * 100;
        const targetPct = bot.profitTargetPct;
        const backPct = bot.profitBackPct;
        
        if (!bot.isWagerMode && profitPct >= targetPct) {
            bot.isWagerMode = true;
            updateUILog(`🔁 WAGER MODE ACTIVATED! (Profit: ${profitPct.toFixed(4)}% >= ${targetPct}%)`);
            document.getElementById("mode-status").innerHTML = "🔄 WAGER";
            bot.tg = bot.perStep;
        } 
        else if (bot.isWagerMode && profitPct <= backPct) {
            bot.isWagerMode = false;
            setNewBaseChance();
            updateUILog(`🔄 BACK TO HUNTER MODE (Profit: ${profitPct.toFixed(4)}% <= ${backPct}%)`);
            document.getElementById("mode-status").innerHTML = "🎯 HUNTER";
        }
    }

    async function runLoop() {
        if (!bot.isRunning || bot.isSleeping) return;
        
        const now = Date.now();
        
        if (now - bot.lastAICall >= bot.aiCallInterval && bot.aiLearningEnabled) {
            bot.lastAICall = now;
            const aiDecision = await getAIDecision();
            if (aiDecision) {
                bot.aiConfig.chance = aiDecision.chance;
                bot.aiConfig.betMultiplier = aiDecision.bet_multiplier || 1.0;
                bot.aiConfig.reason = aiDecision.reason || "";
                updateUILog(`🤖 AI: ${bot.aiMode} - ${bot.aiConfig.reason}`);
                document.getElementById("ai-last-chance").innerText = bot.aiConfig.chance ? bot.aiConfig.chance.toFixed(1) : "-";
                document.getElementById("ai-last-bet").innerText = (bot.baseBet * (bot.aiConfig.betMultiplier || 1)).toFixed(8);
                document.getElementById("ai-last-reason").innerText = bot.aiConfig.reason || "-";
                document.getElementById("ai-mode-status").innerHTML = bot.aiMode;
            }
        }
        
        if (now - bot.lastTGReport >= TG_CONFIG.reportInterval && bot.stats.bets > 0) {
            bot.lastTGReport = now;
            await sendSessionReport();
        }
        
        if (bot.aiMode !== "NORMAL" && bot.stats.profit >= 0) {
            bot.aiMode = "NORMAL";
            resetToDefaultConfig();
            updateUILog(`✅ AI mode deactivated - Profit recovered!`);
            document.getElementById("ai-mode-status").innerHTML = "NORMAL";
        }
        
        try {
            let nextBet, chanceToUse;
            const currentBalance = bot.stats.currentBal;
            
            if (currentBalance <= 0) {
                updateUILog(`❌ Balance is zero! Stopping bot.`);
                bot.isRunning = false;
                toggleStartStop(false);
                return;
            }
            
            if (bot.isWagerMode) {
                bot.wagerDV = parseFloat(document.getElementById("p-wager-dv").value) || 100;
                nextBet = currentBalance / bot.wagerDV;
                chanceToUse = parseFloat(document.getElementById("p-wager-chance").value) || 99.98;
                bot.currentChance = chanceToUse;
            } else {
                if (bot.aiConfig.chance && bot.aiMode !== "NORMAL") {
                    chanceToUse = Math.min(95, Math.max(1, bot.aiConfig.chance));
                } else {
                    if (bot.singleChanceBets < bot.singleChanceLimit) {
                        bot.currentChance = bot.baseChance;
                    } else {
                        bot.currentChance = Math.floor(Math.random() * 11) + (bot.baseChance + 5);
                    }
                    chanceToUse = bot.currentChance;
                }
                if (chanceToUse > 85) chanceToUse = 85;
                if (chanceToUse < 1) chanceToUse = 1;
                
                if (bot.aiMode === "CUTLOSS" && bot.totalLossInCutloss > 0) {
                    const cutlossBet = calculateCutlossBet(bot.totalLossInCutloss, chanceToUse);
                    if (cutlossBet > 0 && cutlossBet < currentBalance * 2) {
                        nextBet = cutlossBet;
                    } else {
                        const payout = 99 / chanceToUse;
                        nextBet = (Math.abs(bot.tg) / (payout - 1)) * bot.margin;
                        if (bot.tg === bot.perStep) nextBet = bot.baseBet;
                    }
                } else {
                    const payout = 99 / chanceToUse;
                    nextBet = (Math.abs(bot.tg) / (payout - 1)) * bot.margin;
                    if (bot.tg === bot.perStep) nextBet = bot.baseBet;
                }
                
                nextBet = nextBet * (bot.aiConfig.betMultiplier || 1.0);
                if (nextBet < bot.minBet) nextBet = bot.minBet;
                
                const maxBet = bot.baseBet * bot.maxBetMultiplier;
                if (nextBet > maxBet) {
                    updateUILog(`⚠️ Bet exceeds max (${maxBet.toFixed(8)}), resetting to baseBet`);
                    nextBet = bot.baseBet;
                    bot.tg = bot.perStep;
                }
            }
            
            if (nextBet > currentBalance && currentBalance > 0) nextBet = currentBalance;
            if (nextBet < 0.00000001) nextBet = 0.00000001;
            if (nextBet > bot.stats.maxBet) bot.stats.maxBet = nextBet;

            const result = await placeBet(nextBet, chanceToUse);
            
            if (result && result.diceRoll) {
                const d = result.diceRoll;
                
                let win;
                let winAmount = parseFloat(d.amount) || 0;
                let payoutMultiplier = parseFloat(d.payoutMultiplier) || 0;
                let payout = parseFloat(d.payout) || 0;
                
                if (d.win !== undefined) {
                    win = d.win;
                } else if (payoutMultiplier > 1) {
                    win = true;
                    if (payout === 0) {
                        payout = winAmount * payoutMultiplier;
                    }
                } else if (payoutMultiplier === 0 && payout === 0) {
                    win = false;
                } else {
                    const state = d.state;
                    if (state && state.result !== undefined && state.target !== undefined) {
                        if (state.condition === "above") {
                            win = state.result > state.target;
                        } else if (state.condition === "below") {
                            win = state.result < state.target;
                        } else {
                            win = false;
                        }
                    } else {
                        win = false;
                    }
                }
                
                const pft = win ? (payout - winAmount) : -winAmount;
                
                bot.stats.bets++; 
                bot.stats.wagered += winAmount;
                bot.stats.profit += pft; 
                bot.stats.currentBal += pft;
                
                if (bot.aiMode === "CUTLOSS") {
                    bot.totalLossInCutloss = Math.max(0, bot.totalLossInCutloss + (win ? -pft : Math.abs(pft)));
                }
                
                addToBetHistory(win, winAmount, chanceToUse, pft);
                
                if (bot.stats.currentBal < bot.stats.startBal) {
                    let dd = bot.stats.startBal - bot.stats.currentBal;
                    if (dd > bot.stats.maxDD) bot.stats.maxDD = dd;
                }

                const modeTag = bot.isWagerMode ? "[W]" : (bot.aiMode !== "NORMAL" ? `[${bot.aiMode}]` : "");
                updateLogs(winAmount, pft, chanceToUse, modeTag);

                if (win) { 
                    bot.stats.wins++;
                    bot.consecutiveLosses = 0;
                    if (!bot.isWagerMode && bot.aiMode === "NORMAL") setNewBaseChance();
                } else { 
                    bot.stats.loss++;
                    bot.consecutiveLosses++;
                    if (!bot.isWagerMode && bot.aiMode === "NORMAL") {
                        bot.singleChanceBets++; 
                        bot.tg += (winAmount + bot.perStep);
                    }
                }
                
                // CEK WAGER MODE SETIAP SELESAI BET
                checkWagerMode();

                const profitPct = (bot.stats.profit / bot.stats.startBal) * 100;
                const stopLossAbs = bot.stats.startBal * (bot.stopLossPercent / 100);
                
                if (bot.stats.profit >= bot.targetAbs) { 
                    bot.isRunning = false; 
                    updateUILog(`🎯 TARGET PROFIT REACHED! Bot Stopped.`);
                    toggleStartStop(false);
                    await sendTelegramReport(`\`\`\`🎯 TARGET PROFIT REACHED\nProfit: ${bot.stats.profit.toFixed(8)}\`\`\``);
                    return;
                }
                
                if (bot.stats.profit <= -stopLossAbs) {
                    bot.isRunning = false;
                    updateUILog(`🛑 STOP LOSS REACHED! Bot Stopped. Loss: ${profitPct.toFixed(2)}%`);
                    toggleStartStop(false);
                    await sendTelegramReport(`\`\`\`🛑 STOP LOSS REACHED\nLoss: ${profitPct.toFixed(2)}%\nProfit: ${bot.stats.profit.toFixed(8)}\`\`\``);
                    return;
                }
                
                if (bot.stats.bets >= bot.stepsLimit) {
                    updateUILog(`📊 STEPS LIMIT ${bot.stepsLimit} REACHED! Sleeping 5 seconds...`);
                    bot.isSleeping = true;
                    document.getElementById("botStatus").innerHTML = "SLEEPING";
                    document.getElementById("statusDot").style.background = "#F59E0B";
                    
                    setTimeout(() => {
                        bot.stats.bets = 0;
                        bot.stats.wins = 0;
                        bot.stats.loss = 0;
                        bot.stats.wagered = 0;
                        bot.isSleeping = false;
                        bot.isRunning = true;
                        document.getElementById("botStatus").innerHTML = "RUNNING";
                        document.getElementById("statusDot").style.background = "#10B981";
                        updateUILog(`🔄 Steps reset to 0! Continuing...`);
                        runLoop();
                    }, 5000);
                    return;
                }
            }
            
            if (bot.isRunning && !bot.isSleeping) {
                const delayTime = bot.isDemo ? bot.dirtyDelay : bot.delay;
                setTimeout(runLoop, delayTime);
            }
        } catch (e) {
            updateUILog(`Error: ${e.message}`);
            setTimeout(runLoop, 1000);
        }
    }

    function updateLogs(amt, pft, ch, mode = "") {
        const logBox = document.getElementById("p-logs");
        const entry = document.createElement("div");
        const timestamp = new Date().toLocaleTimeString();
        const isWin = pft > 0;
        
        entry.style.color = isWin ? "#10B981" : "#EF4444";
        entry.style.margin = "2px 0";
        entry.style.padding = "4px 8px";
        entry.style.fontSize = "11px";
        entry.style.borderRadius = "8px";
        entry.style.background = isWin ? "rgba(16,185,129,0.1)" : "rgba(239,68,68,0.1)";
        entry.innerHTML = `${timestamp} ${mode} ${isWin ? '✓' : '✗'} ${amt.toFixed(8)} → ${pft > 0 ? '+' : ''}${pft.toFixed(8)} (${ch.toFixed(1)}%)`;
        logBox.insertBefore(entry, logBox.firstChild);
        while (logBox.children.length > 50) logBox.removeChild(logBox.lastChild);
    }

    function updateUILog(message) {
