                        'x-lockdown-token': 's5MNWtjTM5TvCMkAzxov'
                    },
                    body: JSON.stringify(payload)
                });
                
                const result = await response.json();
                
                if (!result || !result.diceRoll) {
                    updateUILog(`❌ Invalid response format`);
                    const fallbackWin = Math.random() * 100 < chance;
                    const fallbackMultiplier = fallbackWin ? parseFloat((99 / chance).toFixed(4)) : 1;
                    const fallbackAmount = parseFloat(amount) || 0;
                    return { 
                        diceRoll: { 
                            amount: fallbackAmount, 
                            payout: fallbackWin ? fallbackAmount * fallbackMultiplier : 0, 
                            payoutMultiplier: fallbackMultiplier 
                        } 
                    };
                }
                
                const diceRoll = result.diceRoll;
                const safeAmount = parseFloat(amount) || 0;
                
                let win = false;
                let payoutMultiplier = parseFloat(diceRoll.payoutMultiplier) || 0;
                let payout = parseFloat(diceRoll.payout) || 0;
                
                if (payoutMultiplier > 1) {
                    win = true;
                } else if (payoutMultiplier === 0 && payout === 0) {
                    win = false;
                } else {
                    const state = diceRoll.state;
                    if (state && state.result !== undefined && state.target !== undefined) {
                        if (state.condition === "above") {
                            win = state.result > state.target;
                        } else if (state.condition === "below") {
                            win = state.result < state.target;
                        }
                    }
                }
                
                if (win && payout === 0) {
                    payout = safeAmount * payoutMultiplier;
                }
                
                const simulatedProfit = win ? (payout - safeAmount) : -safeAmount;
                const resultInfo = diceRoll.state ? `[${diceRoll.state.result.toFixed(2)} vs ${diceRoll.state.target}]` : '';
                
                updateUILog(`🎲 ${resultInfo} ${win ? 'WIN ✓' : 'LOSS ✗'} | Multiplier:${payoutMultiplier.toFixed(2)}x | Profit:${simulatedProfit > 0 ? '+' : ''}${simulatedProfit.toFixed(8)}`);
                
                return { 
                    diceRoll: { 
                        amount: safeAmount,
                        payout: payout,
                        payoutMultiplier: payoutMultiplier,
                        state: diceRoll.state,
                        win: win
                    } 
                };
                
            } catch (error) {
                updateUILog(`❌ Network Error: ${error.message}`);
                const fallbackWin = Math.random() * 100 < chance;
                const fallbackMultiplier = fallbackWin ? parseFloat((99 / chance).toFixed(4)) : 1;
                const fallbackAmount = parseFloat(amount) || 0;
                return { 
                    diceRoll: { 
                        amount: fallbackAmount, 
                        payout: fallbackWin ? fallbackAmount * fallbackMultiplier : 0, 
                        payoutMultiplier: fallbackMultiplier 
                    } 
                };
            }
        }
        
        const payload = { 
            amount: parseFloat(amount.toFixed(8)), 
            currency: bot.selectedCurrency, 
            target: target,
            condition: "above", 
            identifier: Math.random().toString(36).slice(2) 
        };
        
        try {
            const response = await fetch(`${CONFIG.apiUrl}/casino/dice/roll`, {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json', 
                    'x-access-token': accessToken,
                    'x-lockdown-token': 's5MNWtjTM5TvCMkAzxov'
                },
                body: JSON.stringify(payload)
            });
            
            const result = await response.json();
            
            if (result.error) {
                updateUILog(`❌ API Error: ${result.error}`);
                return null;
            }
            
            if (!result || !result.diceRoll) {
                updateUILog(`❌ Invalid response format`);
                return null;
            }
            
            return { diceRoll: result.diceRoll };
            
        } catch (error) {
            updateUILog(`❌ Network Error: ${error.message}`);
            return null;
        }
    }

