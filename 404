                    <div class="toggle-row"><span style="font-weight:500;">🧠 AI LEARNING</span><label class="md-switch"><input type="checkbox" id="p-ai-learning" checked><span class="md-slider"></span></label></div>
                    <div class="toggle-row"><span style="font-weight:500;">🤖 AI DYNAMIC TRIGGER</span><label class="md-switch"><input type="checkbox" id="p-ai-dynamic" checked><span class="md-slider"></span></label></div>
                </div>
                
                <div id="tab-wager" class="tab-content">
                    <div class="grid-2"><div class="md-field"><label>📈 PROFIT TRIGGER (%)</label><input type="number" id="p-profit-trigger" value="0.015" step="0.001"></div><div class="md-field"><label>📉 BACK TO NORMAL (%)</label><input type="number" id="p-profit-back" value="0.01" step="0.001"></div></div>
                    <div class="grid-2"><div class="md-field"><label>🔢 WAGER DV</label><input type="number" id="p-wager-dv" value="100"></div><div class="md-field"><label>🎲 WAGER CHANCE (%)</label><input type="number" id="p-wager-chance" value="99.98" step="0.01"></div></div>
                    <div class="stat-card" style="margin-top:16px;"><div class="label">ℹ️ INFO</div><div style="font-size:11px; margin-top:8px;">• Mode WAGER aktif saat profit ≥ Profit Trigger (0.015%)<br>• BaseBet = Balance / DV<br>• Kembali ke HUNTER saat profit turun ke Back to Normal (0.01%)</div></div>
                </div>
                
                <div id="tab-ai" class="tab-content">
                    <div class="stats-grid" style="grid-template-columns:repeat(2,1fr);">
                        <div class="stat-card"><div class="label">TOTAL AI CALLS</div><div class="value" id="ai-call-count">0</div></div>
                        <div class="stat-card"><div class="label">CURRENT MODE</div><div class="value" id="st-ai-mode" style="font-size:12px;">NORMAL</div></div>
                    </div>
                    <div class="ai-log-container" id="ai-log-container"><div style="text-align:center; padding:20px;">No AI decisions yet...</div></div>
                </div>
            </div>
        `;
        
        document.body.insertAdjacentHTML('beforeend', html);
        
        document.getElementById("botHeader").addEventListener('mousedown', dragMouseDown);
        
        const savedToken = getAuthToken();
        if (savedToken) document.getElementById("p-token").value = savedToken;
        
        document.getElementById("p-demo-toggle").onchange = (e) => { bot.isDemo = e.target.checked; updateUILog(bot.isDemo ? "DIRTY MODE ACTIVE - Bet 0 to API" : "REAL MODE ACTIVE"); };
        document.getElementById("p-ai-learning").onchange = (e) => { bot.aiLearningEnabled = e.target.checked; };
        document.getElementById("p-ai-dynamic").onchange = (e) => { bot.aiDynamicTrigger = e.target.checked; };
        
        document.getElementById("p-login").onclick = async () => {
            const token = document.getElementById("p-token").value.trim();
            if (!token || token.length < 30) { updateUILog("❌ Invalid API Token!"); return; }
            saveToken(token);
            const success = await syncUserInfo();
            if (success) {
                updateUILog(`✅ Login success! Welcome ${bot.stakeUser}`);
                document.getElementById("p-start").disabled = false;
                document.getElementById("st-balance").innerHTML = bot.realBalance.toFixed(8);
                await sendTelegramReport(`\`\`\`✅ LOGIN SUCCESS\nUser: ${bot.stakeUser}\nBalance: ${bot.realBalance.toFixed(8)}\`\`\``);
            } else { updateUILog("❌ Login failed!"); }
        };
        
        document.getElementById("p-refresh").onclick = async () => {
            if (!accessToken) { updateUILog("Please login first!"); return; }
            await syncUserInfo();
            document.getElementById("st-balance").innerHTML = bot.realBalance.toFixed(8);
            updateUILog("🔄 Refreshed!");
        };
        
        document.getElementById("p-start").onclick = async () => {
            if (!bot.isDemo && !accessToken) { updateUILog("Please login first!"); return; }
            
            bot.profitTargetPct = parseFloat(document.getElementById("p-profit-trigger").value) || 0.015;
            bot.profitBackPct = parseFloat(document.getElementById("p-profit-back").value) || 0.01;
            bot.selectedCurrency = document.getElementById("p-currency").value;
            bot.stepsLimit = parseInt(document.getElementById("p-steps").value) || 100000;
            bot.baseBet = parseFloat(document.getElementById("p-basebet").value) || 0.00123;
            bot.minBet = parseFloat(document.getElementById("p-minbet").value) || 0.00123;
            bot.maxBetMultiplier = parseFloat(document.getElementById("p-maxbet-multiplier").value) || 10;
            bot.margin = parseFloat(document.getElementById("p-margin").value) || 1.01;
            bot.delay = parseInt(document.getElementById("p-delay").value) || 60;
            bot.chanceMin = parseFloat(document.getElementById("p-ch-min").value) || 5;
            bot.chanceMax = parseFloat(document.getElementById("p-ch-max").value) || 12;
            bot.targetPercent = parseFloat(document.getElementById("p-target-pct").value) || 10;
            bot.stopLossPercent = parseFloat(document.getElementById("p-stop-pct").value) || 25;
            bot.dirtyBalance = parseFloat(document.getElementById("p-dirty-bal").value) || 460;
            bot.dirtyDelay = parseInt(document.getElementById("p-dirty-delay").value) || 50;
            bot.wagerDV = parseFloat(document.getElementById("p-wager-dv").value) || 100;
            bot.wagerChance = parseFloat(document.getElementById("p-wager-chance").value) || 99.98;
            bot.cutlossTrigger = parseFloat(document.getElementById("p-cutloss-trigger").value) || 0.15;
            bot.emergencyTrigger = parseFloat(document.getElementById("p-emergency-trigger").value) || 1.0;
            bot.aiLearningEnabled = document.getElementById("p-ai-learning").checked;
            bot.aiDynamicTrigger = document.getElementById("p-ai-dynamic").checked;
            
            let balance = bot.isDemo ? bot.dirtyBalance : bot.realBalance;
            if (!bot.isDemo && balance === 0) { updateUILog("Failed to get balance!"); return; }
            
            bot.stats = {
                profit: 0, wagered: 0, startBal: balance, currentBal: balance,
                bets: 0, wins: 0, loss: 0, startTime: Date.now(), maxDD: 0, maxBet: 0
            };
            bot.startTime = Date.now();
            bot.targetAbs = bot.stats.startBal * (bot.targetPercent / 100);
            bot.perStep = bot.targetAbs / bot.stepsLimit;
            
            bot.isRunning = true;
            bot.isWagerMode = false;
            bot.isSleeping = false;
            bot.aiMode = "NORMAL";
            bot.consecutiveLosses = 0;
            bot.aiHistory = [];
            bot.betHistory = [];
            bot.totalLossInCutloss = 0;
            bot.lastTGReport = Date.now();
            bot.lastAICall = Date.now() - 60000;
            
            setNewBaseChance();
            toggleStartStop(true);
            updateUILog(`🚀 BOT STARTED! Target: ${bot.targetAbs.toFixed(8)} | Max Bet: ${(bot.baseBet * bot.maxBetMultiplier).toFixed(8)}`);
            await sendTelegramReport(`\`\`\`🚀 BOT STARTED\nBalance: ${balance.toFixed(8)}\nTarget: ${bot.targetPercent}%\nMax Bet: ${(bot.baseBet * bot.maxBetMultiplier).toFixed(8)}\`\`\``);
            
            runLoop();
        };
        
        document.getElementById("p-stop").onclick = async () => {
            bot.isRunning = false;
            toggleStartStop(false);
            updateUILog("⏹ BOT STOPPED!");
            await sendSessionReport();
        };
        
        document.getElementById("p-currency").onchange = () => { bot.selectedCurrency = document.getElementById("p-currency").value; };
        
        setInterval(() => {
            document.getElementById("ai-call-count").innerText = bot.aiHistory.length;
            document.getElementById("st-ai-mode").innerHTML = bot.aiMode;
            updateStatsDisplay();
        }, 1000);
    }
    
    createUI();
    updateUILog("404 BOT v6.2 Loaded - Fixed WIN/LOSS detection & Wager Mode");
})();
