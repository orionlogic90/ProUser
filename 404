    }
    
    function updateAILogUI() {
        const container = document.getElementById("ai-log-container");
        if (!container) return;
        container.innerHTML = "";
        if (bot.aiHistory.length === 0) {
            container.innerHTML = '<div style="text-align:center; padding:20px;">No AI decisions yet...</div>';
