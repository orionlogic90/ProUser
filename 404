    function analyzeHistoryPattern() {
        if (bot.betHistory.length < 50) return null;
        const last200 = bot.betHistory.slice(0, 200);
        const wins = last200.filter(b => b.win).length;
        const winRate = (wins / last200.length) * 100;
        
        let currentLossStreak = 0;
        for (let i = 0; i < Math.min(last200.length, 20); i++) {
            if (!last200[i].win) currentLossStreak++;
            else break;
        }
        
        let currentWinStreak = 0;
        for (let i = 0; i < Math.min(last200.length, 20); i++) {
            if (last200[i].win) currentWinStreak++;
            else break;
        }
        
        let volatilityScore = 0;
        for (let i = 1; i < Math.min(last200.length, 50); i++) {
            if (last200[i].win !== last200[i-1].win) volatilityScore++;
        }
        const volatility = volatilityScore > 30 ? "HIGH" : (volatilityScore > 15 ? "MEDIUM" : "LOW");
        
        return { winRate, currentLossStreak, currentWinStreak, volatility, totalData: bot.betHistory.length };
    }
    
    function getAIDirective() {
        const pattern = analyzeHistoryPattern();
        if (!pattern) return null;
        
        let directive = { action: "maintain", suggestedChance: bot.currentChance, reason: "" };
        
        if (pattern.currentLossStreak >= 3 && bot.currentChance < 40) {
            directive.action = "increase";
            directive.suggestedChance = Math.min(75, bot.currentChance + 30);
            directive.reason = `Loss streak ${pattern.currentLossStreak}x, naikkan chance ke ${directive.suggestedChance}%`;
        } else if (pattern.currentWinStreak >= 3 && bot.currentChance > 50) {
            directive.action = "maintain";
            directive.reason = `Win streak ${pattern.currentWinStreak}x, pertahankan chance ${bot.currentChance}%`;
        } else if (pattern.volatility === "HIGH" && bot.currentChance < 40) {
            directive.action = "increase";
            directive.suggestedChance = Math.min(70, bot.currentChance + 25);
            directive.reason = `Volatility tinggi, naikkan chance ke ${directive.suggestedChance}%`;
        }
        return directive;
    }
    
    function calculateCutlossBet(lossAmount, aiChance) {
        if (lossAmount <= 0) return 0;
        const payout = 99 / aiChance;
        const netProfit = payout - 1;
        if (netProfit <= 0) return lossAmount;
        return lossAmount / netProfit;
    }
    
    async function getAIDecision() {
        const profitPct = (bot.stats.profit / bot.stats.startBal) * 100;
        const lossPct = Math.abs(profitPct);
        const pattern = analyzeHistoryPattern();
        const directive = getAIDirective();
        
        let mode = "NORMAL";
        let actualTrigger = bot.cutlossTrigger;
        
        if (bot.aiDynamicTrigger && pattern) {
            if (pattern.volatility === "HIGH") actualTrigger = Math.max(0.08, bot.cutlossTrigger * 0.7);
            else if (pattern.volatility === "LOW") actualTrigger = Math.min(0.3, bot.cutlossTrigger * 1.2);
        }
        
        if (lossPct >= bot.emergencyTrigger) mode = "EMERGENCY";
        else if (lossPct >= actualTrigger) mode = "CUTLOSS";
        
        if (mode !== bot.aiMode) {
            if (mode !== "NORMAL") {
                await sendAIModeReport(true, mode, lossPct, `Trigger at ${actualTrigger}%`);
                if (mode === "CUTLOSS") bot.totalLossInCutloss = Math.abs(bot.stats.profit);
            } else if (bot.aiMode !== "NORMAL" && bot.stats.profit >= 0) {
                await sendAIModeReport(false, bot.aiMode, 0, "");
                bot.totalLossInCutloss = 0;
            }
            bot.aiMode = mode;
        }
        
        let prompt = "";
        if (mode === "NORMAL") {
            prompt = `NORMAL MODE - Balance:${bot.stats.currentBal.toFixed(2)} Profit:${profitPct.toFixed(2)}% Chance:${bot.currentChance}% ${directive ? `Directive:${directive.reason}` : ''} Output JSON:{"chance":number,"bet_multiplier":number,"reason":"string"}`;
        } else if (mode === "CUTLOSS") {
            prompt = `CUTLOSS MODE - Loss:${lossPct.toFixed(2)}% Total Loss:${bot.totalLossInCutloss.toFixed(8)} Target:BEP Chance range 55-85% Output JSON:{"chance":number,"bet_multiplier":number,"reason":"string"}`;
        } else {
            prompt = `EMERGENCY MODE - Loss:${lossPct.toFixed(2)}% Chance range 80-95% Output JSON:{"chance":number,"bet_multiplier":number,"reason":"string"}`;
        }
        
        const response = await callGemini(prompt);
        if (response) {
            try {
                const jsonMatch = response.match(/\{[\s\S]*\}/);
                if (jsonMatch) {
                    const decision = JSON.parse(jsonMatch[0]);
                    bot.aiHistory.unshift({ timestamp: new Date().toLocaleTimeString(), mode: mode, lossPct: lossPct, decision: decision });
                    if (bot.aiHistory.length > 50) bot.aiHistory.pop();
                    updateAILogUI();
                    return decision;
                }
            } catch(e) {}
        }
        return { chance: mode === "CUTLOSS" ? 65 : mode === "EMERGENCY" ? 85 : Math.random() * 12 + 5, bet_multiplier: mode === "CUTLOSS" ? 0.6 : mode === "EMERGENCY" ? 0.4 : 1.0, reason: "Fallback" };
    }
    
