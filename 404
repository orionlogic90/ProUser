    function updateSpeed() {
        const speedEl = document.getElementById("st-speed");
        if (speedEl && bot.startTime && bot.isRunning) {
            const speed = (bot.stats.bets / ((new Date() - bot.startTime) / 1000 || 1)).toFixed(2);
            speedEl.innerText = speed;
        } else if (speedEl) {
            speedEl.innerText = "0";
        }
    }

    function loadProxyList() {
        const proxyInput = document.getElementById("p-proxy-list");
        const proxyInfoEl = document.getElementById("proxy-info");
        
        if (proxyInput && proxyInput.value) {
            const lines = proxyInput.value.split('\n');
            const newProxyList = [];
            let validCount = 0;
            
            for (const line of lines) {
                const trimmed = line.trim();
                if (trimmed && !trimmed.startsWith('#')) {
                    const proxy = parseProxyString(trimmed);
                    if (proxy) {
                        newProxyList.push(proxy);
                        validCount++;
                    } else if (proxyInfoEl) {
                        proxyInfoEl.innerText = `Invalid proxy: ${trimmed.substring(0, 30)}...`;
                        proxyInfoEl.style.color = "#EF4444";
                    }
                }
            }
            
            PROXY_CONFIG.proxyList = newProxyList;
            PROXY_CONFIG.currentIndex = 0;
            
            const statusEl = document.getElementById("proxy-status");
            if (statusEl) {
                statusEl.innerText = `${validCount} proxies loaded`;
                statusEl.style.color = "#10B981";
            }
            
            if (proxyInfoEl && validCount > 0) {
                const firstProxy = newProxyList[0];
                const displayHost = firstProxy.hasAuth ? `${firstProxy.username}@${firstProxy.host}:${firstProxy.port}` : `${firstProxy.host}:${firstProxy.port}`;
                proxyInfoEl.innerText = `Loaded: ${validCount} proxies (first: ${displayHost})`;
                proxyInfoEl.style.color = "#38BDF8";
            }
            
            updateUILog(`📡 Loaded ${validCount} proxies`);
        }
    }

    function toggleProxy() {
        const enabled = document.getElementById("p-proxy-enable").checked;
        PROXY_CONFIG.enabled = enabled;
        
        if (enabled) {
            loadProxyList();
            rotateProxy();
            updateUILog(`📡 Proxy mode ENABLED`);
        } else {
            updateUILog(`📡 Proxy mode DISABLED`);
        }
        
        const statusEl = document.getElementById("proxy-status");
        const proxyInfoEl = document.getElementById("proxy-info");
        
        if (statusEl) {
            if (enabled) {
                statusEl.innerText = PROXY_CONFIG.proxyList.length > 0 ? `Active (${PROXY_CONFIG.proxyList.length})` : "No proxies";
                statusEl.style.color = "#38BDF8";
            } else {
                statusEl.innerText = "Disabled";
                statusEl.style.color = "#64748B";
            }
        }
        
        if (proxyInfoEl && !enabled) {
            proxyInfoEl.innerText = "Proxy disabled";
            proxyInfoEl.style.color = "#64748B";
        }
    }

