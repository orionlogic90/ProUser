                if (res.errors) { 
                    bot.lastError = res.errors[0].message; 
                    setTimeout(runLoop, 800); 
                    return; 
                }
                
                const data = res?.data || res;
                const betResult = data.baccaratBet || data;
                
                if (betResult && bot.isRunning) {
                    const result = processRecoveryResult(betResult, side, nextbet);
                    bot.lastError = "None";
                    
                    const resultText = betResult.state?.result || "unknown";
                    const multiplier = getSequenceMultiplier();
                    console.log(`Recovery ${side} -> ${resultText} | Bet: ${nextbet.toFixed(8)} | Multiplier: ${multiplier}x`);
                    
                    if (result.emergencyStop) {
                        return;
                    }
                }
                
                if (bot.isRunning) {
                    setTimeout(runLoop, 0);
                }
                
            } catch (e) { 
                bot.lastError = "Network Error"; 
                if (bot.isRunning) setTimeout(runLoop, 1000); 
            }
        }
        
        // WAGER MODE
        else if (bot.bettingMode === "WAGER") {
            // Randomly choose between limbo and dice
            gameToPlay = getRandomWagerGame();
            bot.currentGame = gameToPlay;
            payout = getWagerPayout(gameToPlay);
            nextbet = bot.wagerModeBetSize;
            
            try {
                const res = await API.placeBet(nextbet, payout, gameToPlay);
                
                if (res.errors) { 
                    bot.lastError = res.errors[0].message; 
                    setTimeout(runLoop, 800); 
                    return; 
                }
                
                const data = res?.data || res;
                const bet = data.diceRoll || data.diceBet || data.limboBet;
                
                if (bet && bot.isRunning) {
                    bot.stats.bets++;
                    bot.stats.wagered += bet.amount;
                    const pft = (bet.payout - bet.amount);
                    bot.stats.profit += pft;
                    if (pft > 0) bot.stats.wins++; else bot.stats.loss++;
                    if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
                    bot.lastError = "None";
                    
                    console.log(`Wager Mode ${gameToPlay} | Bet: ${nextbet} | Payout: ${payout} | PnL: ${pft.toFixed(8)}`);
                }
                
                if (bot.isRunning) {
                    setTimeout(runLoop, 0);
                }
                
            } catch (e) { 
                bot.lastError = "Network Error"; 
                if (bot.isRunning) setTimeout(runLoop, 1000); 
            }
        }
    }

