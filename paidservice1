    // AI LEARNING FUNCTIONS
    function initAILearning() {
        bot.aiLearning.enabled = document.getElementById("p-ai-enable")?.checked || false;
        bot.aiLearning.learningRate = parseFloat(document.getElementById("p-ai-learning-rate")?.value) || 0.05;
