        document.getElementById("st-gap").innerText = bot.trailingCurrentGap.toFixed(3) + "%";
        document.getElementById("st-zone").innerText = bot.trailingZone;
        document.getElementById("st-trail-hits").innerText = bot.trailingHits;
        
        const runtimeElem = document.getElementById("st-runtime");
        if (runtimeElem) {
            runtimeElem.innerText = bot.runtime.hours + 'h ' + bot.runtime.minutes + 'm ' + bot.runtime.seconds + 's';
        }
        
        if (document.getElementById("st-mines-bets")) {
            document.getElementById("st-mines-bets").innerText = bot.mines.totalBets;
            document.getElementById("st-mines-wagered").innerText = bot.mines.totalWagered.toFixed(2);
            document.getElementById("st-mines-profit").innerText = bot.mines.totalProfit.toFixed(2);
            document.getElementById("st-mines-maxpayout").innerText = bot.mines.globalMaxPayout.toFixed(4);
            document.getElementById("st-mines-lastpayout").innerText = bot.mines.lastPayout.toFixed(4);
            
            const profitEl = document.getElementById("st-mines-profit");
            if (profitEl) {
                profitEl.className = "stat-value " + (bot.mines.totalProfit >= 0 ? "success" : "warning");
            }
            
            const minesModeStatus = document.getElementById("st-mines-mode");
            if (minesModeStatus) {
                minesModeStatus.innerText = bot.isMinesMode ? "ACTIVE" : "INACTIVE";
                minesModeStatus.className = "stat-value " + (bot.isMinesMode ? "success" : "");
            }
        }
    }

    function initMinesUI() {
        const minesSection = document.createElement("div");
        minesSection.className = "section";
        minesSection.id = "mines-section";
        minesSection.innerHTML = `
