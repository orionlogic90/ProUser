        const box = document.createElement("div");
        box.style.cssText = `
            background: #1a1a1a;
            padding: 20px;
            border-radius: 16px;
            width: 90%;
            max-width: 350px;
            border: 1px solid #8b5cf6;
        `;
        
        const title = document.createElement("div");
        title.style.cssText = `
            text-align: center;
            color: #8b5cf6;
            font-weight: bold;
            margin-bottom: 15px;
            font-size: 14px;
        `;
        title.textContent = "PILIH FIELD MINES (5x5)";
        box.appendChild(title);
        
        const grid = document.createElement("div");
        grid.style.cssText = `
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 8px;
            margin-bottom: 20px;
        `;
        
        const selectedFields = bot.minesFields.slice();
        
        for (let i = 0; i < 25; i++) {
            const cell = document.createElement("div");
            cell.style.cssText = `
                aspect-ratio: 1/1;
                background: #333;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                font-weight: bold;
                border-radius: 8px;
                color: #fff;
                font-size: 12px;
                transition: all 0.2s;
            `;
            cell.textContent = i;
            if (selectedFields.indexOf(i) !== -1) {
                cell.style.background = "#8b5cf6";
                cell.style.color = "#fff";
                cell.style.boxShadow = "0 0 10px #8b5cf6";
            }
            
            cell.onclick = function() {
                const idx = selectedFields.indexOf(i);
                if (idx !== -1) {
                    selectedFields.splice(idx, 1);
                    cell.style.background = "#333";
                    cell.style.color = "#fff";
                    cell.style.boxShadow = "none";
                } else {
                    selectedFields.push(i);
                    cell.style.background = "#8b5cf6";
                    cell.style.color = "#fff";
                    cell.style.boxShadow = "0 0 10px #8b5cf6";
                }
            };
            
            grid.appendChild(cell);
        }
        
        box.appendChild(grid);
        
        const info = document.createElement("div");
        info.style.cssText = `
            font-size: 11px;
            color: #94a3b8;
            margin-bottom: 15px;
            text-align: center;
        `;
        info.innerHTML = 'Pilih minimal ' + bot.minesMinesCount + ' field (sesuai Mines Count)';
        box.appendChild(info);
        
        const saveBtn = document.createElement("button");
        saveBtn.textContent = "💾 SIMPAN FIELDS";
        saveBtn.style.cssText = `
            width: 100%;
            padding: 12px;
            background: #8b5cf6;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
        `;
        
        saveBtn.onmouseover = function() {
            saveBtn.style.background = "#7c3aed";
        };
        
        saveBtn.onmouseout = function() {
            saveBtn.style.background = "#8b5cf6";
        };
        
        saveBtn.onclick = function() {
            if (selectedFields.length < bot.minesMinesCount) {
                alert('⚠️ Pilih minimal ' + bot.minesMinesCount + ' field!');
                return;
            }
            bot.minesFields = selectedFields;
            saveMinesFields(selectedFields);
            modal.remove();
        };
        
        box.appendChild(saveBtn);
        modal.appendChild(box);
        
        modal.onclick = function(e) {
            if (e.target === modal) modal.remove();
        };
        
        document.body.appendChild(modal);
    }

