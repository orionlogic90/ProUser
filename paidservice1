    function initTrailing() {
        bot.trailingPeak = bot.stats.currentBal;
        bot.trailingPeakProfit = 0;
        bot.trailingCurrentGap = 0.3;
        bot.trailingZone = 1;
        bot.trailingHits = 0;
        bot.trailingLastLossStreak = 0;
        bot.trailingLastWinStreak = 0;
        bot.isTrailingActive = true;
        
        const sensitivitySelect = document.getElementById("p-trail-sensitivity");
        if (sensitivitySelect) {
            const sensVal = sensitivitySelect.value;
            bot.trailingSensitivity = sensVal === 'low' ? 0.5 : (sensVal === 'high' ? 1.5 : 1.0);
        }
        
        bot.trailingMinGap = parseFloat(document.getElementById("p-trail-min")?.value) || 10.0;
        bot.trailingMaxGap = parseFloat(document.getElementById("p-trail-max")?.value) || 20.0;
    }
    
    function updateTrailingPeak() {
        if (!bot.isTrailingActive) return;
        
        if (bot.stats.currentBal > bot.trailingPeak) {
            bot.trailingPeak = bot.stats.currentBal;
            bot.trailingPeakProfit = ((bot.trailingPeak - bot.stats.startBal) / bot.stats.startBal) * 100;
            updateTrailingZone();
        }
    }
    
    function updateTrailingZone() {
        if (!bot.isTrailingActive || bot.trailingPeakProfit <= 0) {
            bot.trailingZone = 1;
            bot.trailingCurrentGap = 0.3;
            return;
        }
        
        const currentProfitPct = ((bot.stats.currentBal - bot.stats.startBal) / bot.stats.startBal) * 100;
        const profitRatio = currentProfitPct / bot.trailingPeakProfit;
        
        if (profitRatio < 0.3) bot.trailingZone = 1;
        else if (profitRatio < 0.7) bot.trailingZone = 2;
        else bot.trailingZone = 3;
        
        let baseGap;
        switch(bot.trailingZone) {
            case 1: baseGap = 0.5; break;
            case 2: baseGap = 0.2; break;
            case 3: baseGap = 0.05; break;
            default: baseGap = 0.3;
        }
        
        let adjustment = 1.0;
        if (bot.trailingLastLossStreak > 3) adjustment = 1.5;
        else if (bot.trailingLastLossStreak > 1) adjustment = 1.2;
        
        if (bot.trailingLastWinStreak > 3) adjustment = 0.7;
        else if (bot.trailingLastWinStreak > 1) adjustment = 0.9;
        
        adjustment *= bot.trailingSensitivity;
        
        let finalGap = baseGap * adjustment;
        if (finalGap < bot.trailingMinGap) finalGap = bot.trailingMinGap;
        if (finalGap > bot.trailingMaxGap) finalGap = bot.trailingMaxGap;
        
        bot.trailingCurrentGap = finalGap;
    }
    
    function checkTrailingGap() {
        if (!bot.isTrailingActive || bot.isMinesMode) return false;
        
        const threshold = bot.trailingPeak * (1 - (bot.trailingCurrentGap / 100));
        
        if (bot.stats.currentBal <= threshold) {
            bot.stats.currentBal = bot.stats.startBal;
            bot.stats.profit = 0;
            bot.tg = bot.perStep;
            
            bot.trailingPeak = bot.stats.startBal;
            bot.trailingPeakProfit = 0;
            bot.trailingZone = 1;
            bot.trailingHits++;
            
            setNewBaseChance();
            
            bot.trailingLastLossStreak = 0;
            bot.trailingLastWinStreak = 0;
            
            document.getElementById("st-trail-hits").innerText = bot.trailingHits;
            
            return true;
        }
        return false;
    }
    
    function updateTrailingStreaks(win) {
        if (!bot.isTrailingActive) return;
        if (win) {
            bot.trailingLastWinStreak++;
            bot.trailingLastLossStreak = 0;
        } else {
            bot.trailingLastLossStreak++;
            bot.trailingLastWinStreak = 0;
        }
    }

    function updateBaseBetFromSteps() {
        if (bot.stats.startBal <= 0 || bot.baseChance <= 0) return;
        
        const targetPct = parseFloat(document.getElementById("p-target-pct")?.value) || 3.0;
        const steps = parseInt(document.getElementById("p-steps")?.value) || 900000;
        const chance = bot.baseChance;
        
        const targetAbs = bot.stats.startBal * (targetPct / 100);
        const expectedBaseBet = (targetAbs / steps) / (99 / chance);
        
        const baseBetInput = document.getElementById("p-basebet");
        if (baseBetInput) baseBetInput.value = expectedBaseBet.toFixed(8);
        
        return expectedBaseBet;
    }

    function setNewBaseChance() {
        if (bot.isMinesMode) {
            bot.overhaulChanceMin = parseFloat(document.getElementById("p-overhaul-min")?.value) || 8.0;
            bot.overhaulChanceMax = parseFloat(document.getElementById("p-overhaul-max")?.value) || 10.0;
            bot.baseChance = parseFloat((Math.random() * (bot.overhaulChanceMax - bot.overhaulChanceMin) + bot.overhaulChanceMin).toFixed(1));
        } else if (bot.isWagerEnabled && bot.isWagerMode) {
            bot.baseChance = bot.profitWagerChance;
        } else {
            bot.chanceMin = parseFloat(document.getElementById("p-ch-min")?.value) || 45.0;
            bot.chanceMax = parseFloat(document.getElementById("p-ch-max")?.value) || 55.0;
            bot.baseChance = parseFloat((Math.random() * (bot.chanceMax - bot.chanceMin) + bot.chanceMin).toFixed(1));
        }
        
        bot.currentChance = bot.baseChance;
        bot.singleChanceBets = 0;
        bot.singleChanceLimit = Math.round(99 / bot.baseChance);
        bot.tg = bot.perStep;
        
        if (bot.stats.startBal > 0) updateBaseBetFromSteps();
    }

    function getChanceIncrement() {
        bot.chanceInc = parseFloat(document.getElementById("p-ch-inc")?.value) || 5.0;
        bot.chanceDec = parseFloat(document.getElementById("p-ch-dec")?.value) || 15.0;
        return Math.random() * (bot.chanceInc - bot.chanceDec) + bot.chanceDec;
    }

    function resetSteps() {
        bot.currentSteps = 0;
        bot.stepsResetCount++;
        
        bot.stats.currentBal = bot.stats.startBal;
        bot.stats.profit = 0;
        bot.tg = bot.perStep;
        
        bot.isMinesMode = false;
        bot.isWagerMode = false;
        bot.recoveryMode = false;
        bot.minesTotalLoss = 0;
        bot.minesBets = 0;
        
        if (bot.isTrailingActive) {
            bot.trailingPeak = bot.stats.startBal;
            bot.trailingPeakProfit = 0;
            bot.trailingZone = 1;
            bot.trailingLastLossStreak = 0;
            bot.trailingLastWinStreak = 0;
        }
        
        setNewBaseChance();
    }

    function checkMinesMode() {
        if (bot.isMinesMode) return;
        if (bot.recoveryMode) return;
        
        const lossPct = ((bot.stats.startBal - bot.stats.currentBal) / bot.stats.startBal) * 100;
        
        if (lossPct >= bot.minesLimit && bot.stats.bets > 0) {
            console.log('💣 MINES MODE TRIGGERED! Loss: ' + lossPct.toFixed(2) + '%');
            
            bot.isMinesMode = true;
            bot.minesStartBalance = bot.stats.currentBal;
            bot.minesTotalLoss = bot.stats.startBal - bot.stats.currentBal;
            bot.minesBets = 0;
            
            bot.minesMinesCount = parseInt(document.getElementById("p-mines-count")?.value) || 13;
            bot.minesMaxBets = parseInt(document.getElementById("p-mines-max-bets")?.value) || 5;
            bot.minesUseRandomFields = document.getElementById("p-mines-random")?.checked || false;
            
            const savedFields = loadMinesFields();
            bot.minesFields = savedFields.length > 0 ? savedFields : [0,1,2,3,4];
            
            setNewBaseChance();
            
            document.getElementById("st-mode").innerText = "MINES";
            document.getElementById("st-mode").style.background = "#8b5cf6";
            document.getElementById("st-mode").style.color = "#ffffff";
            
            API.sendTelegramMessage('💣 MINES MODE ACTIVATED!\nLoss: ' + bot.minesTotalLoss.toFixed(8) + ' (' + lossPct.toFixed(2) + '%)\nMax Bets: ' + bot.minesMaxBets);
        }
    }

    function calculateMinesBet() {
        if (!bot.isMinesMode) return null;
        
        const currentLoss = bot.stats.startBal - bot.stats.currentBal;
        
        if (currentLoss <= 0) {
            console.log("✅ MINES MODE EXIT - No loss");
            bot.isMinesMode = false;
            updateModeDisplay();
            setNewBaseChance();
            return null;
        }
        
        bot.minesBets++;
        
        if (bot.minesBets > bot.minesMaxBets) {
            console.log('⚠️ MINES MODE EXIT - Max bets reached (' + bot.minesMaxBets + ')');
            bot.isMinesMode = false;
            updateModeDisplay();
            return null;
        }
        
        let bet = Math.abs(currentLoss / 5);
        
        const minBetLimit = parseFloat(document.getElementById("p-minbet")?.value) || 0.00000002;
        if (bet < minBetLimit) bet = minBetLimit;
        
        if (bet > bot.stats.currentBal) bet = bot.stats.currentBal;
        
        console.log('💣 Mines Bet #' + bot.minesBets + ': ' + bet.toFixed(8) + ' (Loss: ' + currentLoss.toFixed(8) + ')');
        
        return bet;
    }

    async function executeMinesBet() {
        if (!bot.isMinesMode) return false;
        
        const betAmount = calculateMinesBet();
        if (betAmount === null) return false;
        
        try {
            let fields = bot.minesFields;
            if (bot.minesUseRandomFields) {
                fields = API.generateRandomFields(bot.minesMinesCount);
            }
            
            const result = await API.placeMinesBet(
                betAmount,
                bot.selectedCurrency,
                bot.minesMinesCount,
                fields
            );
            
            let data = null;
            if (result?.data?.minesBet) {
                data = result.data.minesBet;
            } else if (result?.minesBet) {
                data = result.minesBet;
            } else if (result?.d?.minesBet) {
                data = result.d.minesBet;
            } else if (result?.id) {
                data = result;
            }
            
            if (data) {
                bot.mines.totalBets++;
                bot.mines.totalWagered += betAmount;
                
                const payout = data.payoutMultiplier || 0;
                const id = data.id || 'unknown';
                
                if (payout > bot.mines.globalMaxPayout) {
                    bot.mines.globalMaxPayout = payout;
                }
                
                const profit = (betAmount * payout) - betAmount;
                bot.mines.totalProfit += profit;
                bot.mines.lastPayout = payout;
                bot.mines.lastId = id;
                
                bot.stats.currentBal += profit;
                bot.stats.profit += profit;
                bot.stats.wagered += betAmount;
                
                const logBox = document.getElementById("p-logs");
                const entry = document.createElement("div");
                entry.style.cssText = 'margin:1px 0; padding:1px 2px; font-size:10px; font-family: monospace; border-left:2px solid #8b5cf6; color:#d1d5db;';
                entry.innerHTML = '💣 MINES #' + bot.mines.totalBets + ' | ' + betAmount.toFixed(2) + ' | ' + payout.toFixed(2) + 'x | ' + (profit >= 0 ? '+' : '') + profit.toFixed(2);
                logBox.prepend(entry);
                if (logBox.children.length > 6) logBox.lastChild.remove();
                
                updateDisplay();
                
                if (bot.stats.currentBal >= bot.stats.startBal) {
                    console.log("✅ MINES MODE SUCCESS - Balance recovered!");
                    bot.isMinesMode = false;
                    updateModeDisplay();
                    
                    API.sendTelegramMessage('✅ MINES MODE SUCCESS!\nRecovered to ' + bot.stats.currentBal.toFixed(8) + '\nTotal Mines Bets: ' + bot.mines.totalBets);
                }
                
                if (payout > 10) {
                    API.sendTelegramMessage('💣 MINES HIT!\nPayout: ' + payout + 'x\nProfit: ' + profit.toFixed(2) + '\nRemaining Bets: ' + (bot.minesMaxBets - bot.minesBets));
                }
            }
            
            return true;
        } catch (e) {
            console.log("Mines bet error:", e);
            return false;
        }
    }

    function checkRecoveryMode() {
        if (bot.recoveryMode) return;
        
        if (!bot.isWagerMode && !bot.isMinesMode) return;
        
        const currentLoss = bot.stats.startBal - bot.stats.currentBal;
        const lossPct = (currentLoss / bot.stats.startBal) * 100;
        
        const inWagerMode = bot.isWagerEnabled && bot.isWagerMode;
        const minesModeFailed = bot.isMinesMode && bot.minesBets > bot.minesMaxBets && currentLoss > bot.minesTotalLoss * 1.5;
        
        if ((inWagerMode || minesModeFailed) && lossPct >= 5.0 && lossPct <= 15.0) {
            bot.recoveryMode = true;
            bot.recoveryStartLoss = currentLoss;
            bot.recoveryBets = 0;
            bot.recoveryBaseBet = bot.perStep;
            
            bot.recoverySmoothingFactor = parseFloat(document.getElementById("p-recovery-factor")?.value) || 0.3;
            bot.recoveryMaxBets = parseInt(document.getElementById("p-recovery-max")?.value) || 20;
            
            bot.wasInWagerMode = bot.isWagerMode;
            bot.wasInMinesMode = bot.isMinesMode;
            bot.isWagerMode = false;
            bot.isMinesMode = false;
            
            console.log('🔄 RECOVERY MODE ACTIVE - Loss: ' + currentLoss.toFixed(8) + ' (' + lossPct.toFixed(2) + '%)');
        }
    }
    
    function calculateRecoveryBet() {
        if (!bot.recoveryMode) return null;
        
        const currentLoss = bot.stats.startBal - bot.stats.currentBal;
        if (currentLoss <= 0) {
            bot.recoveryMode = false;
            bot.isWagerMode = bot.wasInWagerMode || false;
            bot.isMinesMode = bot.wasInMinesMode || false;
            return null;
        }
        
        bot.recoveryBets++;
        
        if (bot.recoveryBets > bot.recoveryMaxBets) {
            bot.recoveryMode = false;
            bot.isWagerMode = bot.wasInWagerMode || false;
            bot.isMinesMode = bot.wasInMinesMode || false;
            return null;
        }
        
        const chance = bot.baseChance;
        const payout = 99 / chance;
        
        const targetRecovery = currentLoss * 0.7;
        
        let baseRecoveryBet = targetRecovery / (payout - 1);
        
        const progress = bot.recoveryBets / bot.recoveryMaxBets;
        const smoothingMultiplier = 1 + (progress * bot.recoverySmoothingFactor);
        
        let bet = baseRecoveryBet * smoothingMultiplier;
        
        const minBetLimit = parseFloat(document.getElementById("p-minbet")?.value) || 0.00000002;
        if (bet < minBetLimit) bet = minBetLimit;
        if (bet > bot.stats.currentBal * 0.05) bet = bot.stats.currentBal * 0.05;
        
        return bet;
    }

    function checkWagerModeTriggers() {
        if (!bot.isWagerEnabled || bot.isMinesMode || bot.recoveryMode) {
            if (bot.isWagerMode) {
                bot.isWagerMode = false;
                bot.baseChance = bot.normalChance;
                updateModeDisplay();
            }
            return;
        }
        
        const baseBet = parseFloat(document.getElementById("p-basebet")?.value) || 0.00000001;
        const profitInBaseBet = baseBet > 0 ? bot.stats.profit / baseBet : 0;
        
        const triggerProfit = parseFloat(document.getElementById("p-profit-trigger-profit")?.value) || 100;
        const triggerLoss = parseFloat(document.getElementById("p-profit-trigger-loss")?.value) || 10;
        
        if (!bot.isWagerMode && profitInBaseBet >= triggerProfit) {
            console.log('🎯 PROFIT MODE: Target reached! Entering WAGER MODE. Profit: ' + bot.stats.profit.toFixed(8) + ' (' + profitInBaseBet.toFixed(2) + 'x baseBet)');
            enterWagerMode();
        }
        
        if (bot.isWagerMode && profitInBaseBet <= triggerLoss) {
            console.log('↩️ PROFIT MODE: Profit dropped to safe level. Exiting WAGER MODE. Profit: ' + bot.stats.profit.toFixed(8) + ' (' + profitInBaseBet.toFixed(2) + 'x baseBet)');
            exitWagerMode();
        }
    }
    
    function enterWagerMode() {
        bot.isWagerMode = true;
        bot.normalChance = bot.baseChance;
        
        bot.profitWagerChance = parseFloat(document.getElementById("p-profit-wager-chance")?.value) || 99.0;
        bot.profitWagerBetPct = parseFloat(document.getElementById("p-profit-wager-bet-pct")?.value) || 1.5;
        bot.baseChance = bot.profitWagerChance;
        
        updateModeDisplay();
    }
    
    function exitWagerMode() {
        bot.isWagerMode = false;
        bot.baseChance = bot.normalChance;
        updateModeDisplay();
    }

    function updateModeDisplay() {
        const modeEl = document.getElementById("st-mode");
        if (!modeEl) return;
        
        if (bot.recoveryMode) {
            modeEl.innerText = "RECOVERY";
            modeEl.style.background = "#f59e0b";
        } else if (bot.isMinesMode) {
            modeEl.innerText = "MINES";
            modeEl.style.background = "#8b5cf6";
        } else if (bot.isWagerEnabled && bot.isWagerMode) {
            modeEl.innerText = "WAGER";
            modeEl.style.background = "#10b981";
        } else {
            modeEl.innerText = bot.isTrailingActive ? "TRAIL" : (bot.isDemo ? "DEMO" : "REAL");
            modeEl.style.background = bot.isTrailingActive ? "#3b82f6" : (bot.isDemo ? "#f59e0b" : "#4b5563");
        }
        modeEl.style.color = "#ffffff";
    }

    function updateBetSpeed() {
        const now = Date.now();
        const timeDiff = (now - bot.lastSpeedUpdate) / 1000;
        
        if (timeDiff >= 1) {
            bot.betSpeed = bot.speedBetsCount / timeDiff;
            bot.speedBetsCount = 0;
            bot.lastSpeedUpdate = now;
            
            const speedValEl = document.getElementById("st-speed-val");
            if (speedValEl) {
                speedValEl.innerText = bot.betSpeed.toFixed(2) + "/s";
                if (bot.betSpeed < 10) {
                    speedValEl.style.color = "#f59e0b";
                } else {
                    speedValEl.style.color = "#10b981";
                }
            }
        }
    }

    // ==================== PERBAIKAN UTAMA: RUN LOOP ====================
    async function runLoop() {
        if (!bot.isRunning) return;
        
        try {
            bot.lastBetTime = Date.now();
            
            // CEK APAKAH INI BET PERTAMA
            if (bot.stats.bets === 0) {
                console.log("🎲 First bet - Starting with base bet...");
                // Pastikan base chance sudah diset
                if (bot.baseChance === 0) {
                    setNewBaseChance();
                }
            }
            
            // CEK MINES MODE
            checkMinesMode();
            
            // JIKA DALAM MINES MODE
            if (bot.isMinesMode) {
                const executed = await executeMinesBet();
                if (executed && bot.isRunning) {
                    setTimeout(runLoop, 500);
                    return;
                }
            }
            
            // JIKA TIDAK DALAM MINES MODE, JALANKAN DICE
            if (!bot.isMinesMode) {
                if (bot.isTrailingActive) updateTrailingPeak();
                
                if (bot.isTrailingActive && !bot.recoveryMode) {
                    const wasReset = checkTrailingGap();
                    if (wasReset && bot.isRunning) {
                        setTimeout(runLoop, 0);
                        return;
                    }
                }
                
                checkRecoveryMode();
                checkWagerModeTriggers();
                
                // HITUNG BET AMOUNT
                let nextBet, currentChance;
                
                if (bot.recoveryMode) {
                    currentChance = bot.baseChance;
                    nextBet = calculateRecoveryBet();
                    
                    if (nextBet === null) {
                        bot.recoveryMode = false;
                        updateModeDisplay();
                    }
                }
                
                if (!bot.recoveryMode) {
                    // SET CHANCE
                    if (bot.singleChanceBets < bot.singleChanceLimit) {
                        bot.currentChance = bot.baseChance;
                    } else {
                        bot.currentChance = Math.min(98, bot.baseChance + getChanceIncrement());
                    }
                    currentChance = bot.currentChance;
                    
                    // HITUNG BET
                    if (bot.isWagerEnabled && bot.isWagerMode) {
                        bot.profitWagerBetPct = parseFloat(document.getElementById("p-profit-wager-bet-pct")?.value) || 1.5;
                        nextBet = bot.stats.currentBal * (bot.profitWagerBetPct / 100);
                        
                        const minBetLimit = parseFloat(document.getElementById("p-minbet")?.value) || 0.00000002;
                        if (nextBet < minBetLimit) nextBet = minBetLimit;
                    } else {
                        const payout = 99 / currentChance;
                        const margin = parseFloat(document.getElementById("p-margin")?.value) || 1.005;
                        const minBetLimit = parseFloat(document.getElementById("p-minbet")?.value) || 0.00000002;
                        
                        // UNTUK BET PERTAMA, PAKAI BASE BET
                        if (bot.stats.bets === 0) {
                            const baseBet = parseFloat(document.getElementById("p-basebet")?.value) || 0.00000001;
                            nextBet = baseBet;
                            console.log("Using base bet for first bet:", nextBet);
                        } else {
                            nextBet = (Math.abs(bot.tg) / (payout - 1)) * margin;
                            if (nextBet < minBetLimit) nextBet = minBetLimit;
                        }
                    }
                    
                    if (nextBet > bot.stats.currentBal && bot.stats.currentBal > 0) nextBet = bot.stats.currentBal;
                }

                // LAKUKAN BET
                if (nextBet && currentChance) {
                    console.log(`Placing bet: ${nextBet} ${bot.selectedCurrency} @ ${currentChance}%`);
                    
                    const res = await API.placeBet(nextBet, currentChance);
                    const d = res?.data?.diceRoll || res?.diceRoll;

                    if (d) {
                        bot.speedBetsCount++;
                        updateBetSpeed();
                        
                        const win = d.payout > 0;
                        
                        if (bot.isTrailingActive) updateTrailingStreaks(win);
                        
                        const pft = d.payout - d.amount;
                        bot.stats.bets++; 
                        bot.currentSteps++;
                        bot.stats.wagered += d.amount;
                        bot.stats.profit += pft; 
                        bot.stats.currentBal += pft;
                        bot.lastBetAmount = d.amount;

                        if (!bot.stats.history) bot.stats.history = [];
                        bot.stats.history.push(bot.stats.currentBal);
                        if (bot.stats.history.length > 50) bot.stats.history.shift();

                        if (bot.stats.currentBal < bot.stats.startBal) {
                            let dd = bot.stats.startBal - bot.stats.currentBal;
                            let ddPerc = (dd / bot.stats.startBal) * 100;
                            if (dd > bot.stats.maxDD) bot.stats.maxDD = dd;
                            if (ddPerc > bot.stats.maxDDPerc) bot.stats.maxDDPerc = ddPerc;
                        }

                        updateLogs(d.amount, currentChance, bot.stats.profit, win, bot.recoveryMode);

                        if (win) { 
                            bot.stats.wins++; 
                            
                            if (bot.recoveryMode) {
                                const currentLoss = bot.stats.startBal - bot.stats.currentBal;
                                if (currentLoss <= bot.recoveryStartLoss * 0.5) {
                                    bot.recoveryMode = false;
                                    bot.isWagerMode = bot.wasInWagerMode || false;
                                    bot.isMinesMode = bot.wasInMinesMode || false;
                                    console.log("✅ RECOVERY COMPLETE");
                                }
                            }
                            
                            setNewBaseChance();
                        } else { 
                            bot.stats.loss++; 
                            
                            if (!bot.recoveryMode) {
                                bot.singleChanceBets++; 
                                bot.tg += (d.amount + bot.perStep);
                            }
                        }

                        updateDisplay();

                        // CHECK CHART REPORT
                        const currentWagerFloor = Math.floor(bot.stats.wagered / bot.chartReportInterval);
                        const lastWagerFloor = Math.floor(bot.lastChartWagerAmount / bot.chartReportInterval);
                        
                        if (currentWagerFloor > lastWagerFloor && bot.stats.bets > 0) {
                            console.log('📊 Wagered reached ' + (currentWagerFloor * bot.chartReportInterval) + ' - sending chart report...');
                            await API.sendChartReport();
                        }
                        
                        bot.lastChartWagerAmount = bot.stats.wagered;

                        // CEK TARGET/STOP LOSS
                        if (bot.stats.profit >= bot.targetAbs) { 
                            alert("🎯 TARGET REACHED! " + bot.stats.profit.toFixed(8)); 
                            bot.isRunning = false; 
                        }
                        else if (bot.stats.profit <= -bot.stopLossAbs) { 
                            alert("🛑 STOP LOSS TRIGGERED! " + bot.stats.profit.toFixed(8)); 
                            bot.isRunning = false; 
                        }
                        else if (bot.currentSteps >= bot.maxSteps) { 
                            resetSteps();
                        }
                    }
                }
            }
            
            // UPDATE TELEGRAM
            const tgNow = Date.now();
            if (tgNow - bot.lastTelegramTime >= bot.telegramInterval) {
                await API.sendTelegramReport();
                bot.lastTelegramTime = tgNow;
            }
            
            // UPDATE RUNTIME
            const runtime = Math.floor((Date.now() - bot.stats.startTime) / 1000);
            bot.runtime.hours = Math.floor(runtime / 3600);
            bot.runtime.minutes = Math.floor((runtime % 3600) / 60);
            bot.runtime.seconds = runtime % 60;
            
            // LOOP LAGI
            if (bot.isRunning) {
                setTimeout(runLoop, 10); // Delay 10ms biar tidak overload
            }
            
        } catch (e) { 
            console.log("Loop error:", e);
            if (bot.isRunning) {
                setTimeout(runLoop, 100);
            }
        }
    }
    // ==================== AKHIR PERBAIKAN ====================

    function updateLogs(amt, ch, totalProfit, isWin, isRecovery) {
        if (isRecovery === undefined) isRecovery = false;
        const logBox = document.getElementById("p-logs");
        const entry = document.createElement("div");
        
        const amtStr = amt.toFixed(8).padStart(12, ' ');
        const chStr = ch.toFixed(2).padStart(6, ' ');
        const profitStr = (totalProfit >= 0 ? '+' : '') + totalProfit.toFixed(8);
        
        let borderColor = isWin ? "#10b981" : "#ef4444";
        if (isRecovery) borderColor = "#f59e0b";
        
        entry.style.cssText = 'margin:1px 0; padding:1px 2px; font-size:10px; font-family: "Menlo", "Monaco", "Courier New", monospace; border-left:2px solid ' + borderColor + '; color:#d1d5db;';
        entry.innerHTML = amtStr + ' | ' + chStr + '% | ' + profitStr;
        logBox.prepend(entry);
        if (logBox.children.length > 6) logBox.lastChild.remove();
    }

