            // Load recovery chances
            bot.chanceRecovery = [];
            for (let i = 1; i <= 20; i++) {
                const val = parseFloat(document.getElementById(`p-recovery-${i}`)?.value);
                bot.chanceRecovery.push(val || (i <= 5 ? 85 - (i-1)*5 : 
                                               i <= 10 ? 65 - (i-6)*5 : 
                                               i <= 15 ? 40 - (i-11)*2 : 30));
            }
            
            // Initialize AI Learning
            initAILearning();
            
            bot.stats.startBal = await API.getBalance(bot.selectedCurrency);
            bot.stats.currentBal = bot.stats.startBal;
            bot.stats.history = [bot.stats.startBal];
            bot.lastChartWagerAmount = 0;
            
            bot.chartReportInterval = 500;
            
            const targetPct = parseFloat(document.getElementById("p-target-pct")?.value) || 3.0;
            bot.targetAbs = bot.stats.startBal * (targetPct / 100);
            bot.stopLossAbs = bot.stats.startBal * (parseFloat(document.getElementById("p-stop-pct")?.value) / 100);
            
            calculateBaseBet();
            setNewBaseChance();
            updateModeDisplay();
            
            await API.sendTelegramReport();
            runLoop();
        };

        document.getElementById("p-stop").onclick = async () => { 
            bot.isRunning = false; 
            document.getElementById("p-start").disabled = false;
            document.getElementById("p-stop").disabled = true;
            await API.sendTelegramReport();
        };

        setInterval(() => {
            if (!document.getElementById("st-p")) return;
            
            const profitEl = document.getElementById("st-p");
            if (profitEl) profitEl.innerText = (bot.stats.profit || 0).toFixed(8);
            
            const balanceEl = document.getElementById("st-bal");
            if (balanceEl) balanceEl.innerText = (bot.stats.currentBal || 0).toFixed(8) + " " + (bot.selectedCurrency || 'doge').toUpperCase();
            
            const rollsEl = document.getElementById("st-r");
            if (rollsEl) rollsEl.innerText = `${bot.stats.bets || 0} (${bot.stats.wins || 0}/${bot.stats.loss || 0})`;
            
            const wageredEl = document.getElementById("st-wagered");
            if (wageredEl) wageredEl.innerText = (bot.stats.wagered || 0).toFixed(8);
            
            const modeText = bot.mode === 0 ? "WAGER" : (bot.mode === 1 ? "RECOVERY" : "LOCKED");
            const modeDisplayEl = document.getElementById("st-mode-display");
            if (modeDisplayEl) modeDisplayEl.innerText = modeText;
            
            const nextChart = (Math.floor((bot.stats.wagered || 0) / bot.chartReportInterval) + 1) * bot.chartReportInterval;
            const nextChartEl = document.getElementById("st-next-chart");
            if (nextChartEl) nextChartEl.innerText = nextChart.toFixed(0);
            
            const aiStatus = document.getElementById("st-ai-status");
            if (aiStatus) {
                aiStatus.innerText = bot.aiLearning.enabled ? "ACTIVE" : "OFF";
                aiStatus.style.color = bot.aiLearning.enabled ? "#10b981" : "#94a3b8";
            }
        }, 500);
    }

    // Initialize
    createUI();
    setTimeout(() => API.syncOnce(), 1000);
})();
