    async function runLoop() {
        if (!bot.isRunning) return;
        
        try {
            bot.lastBetTime = Date.now();
            
            const profit = (bot.stats.currentBal || 0) - (bot.stats.startBal || 0);
            
            // LOCK MODE
            if (bot.mode === 2) {
                bot.currentChance = bot.chanceWager;
                let nextBet = parseFloat(document.getElementById("p-minbet")?.value) || 0.001;
                
                const res = await API.placeBet(nextBet, bot.currentChance);
                const d = res?.data?.diceRoll || res?.diceRoll;
                
                if (d) {
                    processBetResult(d, nextBet, bot.currentChance);
                }
                
                if (bot.isRunning) setTimeout(runLoop, 10);
                return;
            }
            
            // CHECK RECOVERY ENTRY
            if (bot.mode === 0 && profit < 0) {
                bot.mode = 1;
                bot.step = 1;
                bot.loss_total = -profit;
                updateModeDisplay();
            }
            
            // CHECK RECOVERY EXIT
            if (bot.mode === 1 && (bot.stats.currentBal || 0) >= (bot.stats.startBal || 0)) {
                bot.mode = 0;
                bot.step = 0;
                bot.loss_total = 0;
                updateModeDisplay();
            }
            
            let nextBet, currentChance;
            
            // WAGER MODE
            if (bot.mode === 0) {
                currentChance = bot.chanceWager;
                nextBet = calculateBaseBet();
                
                if (profit < 0) {
                    bot.mode = 2;
                    currentChance = bot.chanceWager;
                    nextBet = parseFloat(document.getElementById("p-minbet")?.value) || 0.001;
                    updateModeDisplay();
                }
            }
            
            // RECOVERY MODE
            if (bot.mode === 1) {
                if (bot.step > bot.max_step) {
                    currentChance = bot.chanceWager;
                    nextBet = parseFloat(document.getElementById("p-minbet")?.value) || 0.001;
                } else {
                    currentChance = bot.aiLearning.enabled ? 
                        getOptimalChanceForStep(bot.step) : 
                        bot.chanceRecovery[bot.step - 1];
                    
                    const payout = (100 / currentChance) - 1;
                    
                    if (payout > 0) {
                        nextBet = Math.abs(bot.loss_total || 0) / payout;
                    } else {
                        nextBet = parseFloat(document.getElementById("p-minbet")?.value) || 0.001;
                    }
                }
            }
            
            // SAFETY CHECKS
            const minBet = parseFloat(document.getElementById("p-minbet")?.value) || 0.001;
            if (nextBet < minBet) nextBet = minBet;
            if (nextBet > (bot.stats.currentBal || 0)) {
                nextBet = minBet;
            }
            
            bot.currentChance = currentChance;
            
            const res = await API.placeBet(nextBet, currentChance);
            const d = res?.data?.diceRoll || res?.diceRoll;
            
            if (d) {
                processBetResult(d, nextBet, currentChance);
            }
            
            updateRuntime();
            
            const tgNow = Date.now();
            if (tgNow - bot.lastTelegramTime >= bot.telegramInterval) {
                await API.sendTelegramReport();
                bot.lastTelegramTime = tgNow;
            }
            
            if (bot.isRunning) {
                setTimeout(runLoop, 10);
            }
        } catch (e) { 
            console.log("Loop error:", e);
            if (bot.isRunning) {
                setTimeout(runLoop, 100);
            }
        }
    }
    
    function processBetResult(d, amount, chance) {
        bot.speedBetsCount++;
        updateBetSpeed();
        
        const win = d.payout > 0;
        const pft = (d.payout || 0) - (d.amount || amount);
        
        bot.stats.bets = (bot.stats.bets || 0) + 1; 
        bot.stats.wagered = (bot.stats.wagered || 0) + (d.amount || amount);
        bot.stats.profit = (bot.stats.profit || 0) + pft; 
        bot.stats.currentBal = (bot.stats.currentBal || bot.stats.startBal || 0) + pft;
        bot.lastBetAmount = d.amount;
        
        if (!bot.stats.history) bot.stats.history = [];
        bot.stats.history.push(bot.stats.currentBal);
        if (bot.stats.history.length > 50) bot.stats.history.shift();
        
        if ((bot.stats.currentBal || 0) < (bot.stats.startBal || 0)) {
            let dd = (bot.stats.startBal || 0) - (bot.stats.currentBal || 0);
            let ddPerc = (dd / (bot.stats.startBal || 1)) * 100;
            if (dd > (bot.stats.maxDD || 0)) bot.stats.maxDD = dd;
            if (ddPerc > (bot.stats.maxDDPerc || 0)) bot.stats.maxDDPerc = ddPerc;
        }
        
        updateLogs(amount, chance, bot.stats.profit, win, bot.mode === 1);
        
        if (win) { 
            bot.stats.wins = (bot.stats.wins || 0) + 1; 
            
            if (bot.mode === 1) {
                bot.loss_total = Math.max(0, (bot.loss_total || 0) - pft);
                trackRecoveryAttempt(bot.step, chance, true);
            }
        } else { 
            bot.stats.loss = (bot.stats.loss || 0) + 1; 
            
            if (bot.mode === 1) {
                bot.loss_total = (bot.loss_total || 0) + amount;
                bot.step = Math.min((bot.step || 0) + 1, bot.max_step + 1);
                trackRecoveryAttempt(bot.step - 1, chance, false);
            }
        }
        
        updateDisplay();
        
        // CHECK FOR CHART REPORT
        const currentWagerFloor = Math.floor((bot.stats.wagered || 0) / bot.chartReportInterval);
        const lastWagerFloor = Math.floor((bot.lastChartWagerAmount || 0) / bot.chartReportInterval);
        
        if (currentWagerFloor > lastWagerFloor && (bot.stats.bets || 0) > 0) {
            API.sendChartReport();
        }
        
        bot.lastChartWagerAmount = bot.stats.wagered;
        
        if ((bot.stats.profit || 0) >= (bot.targetAbs || Infinity)) { 
            alert("🎯 TARGET REACHED! " + (bot.stats.profit || 0).toFixed(8)); 
            bot.isRunning = false; 
            document.getElementById("p-start").disabled = false;
            document.getElementById("p-stop").disabled = true;
        }
        else if ((bot.stats.profit || 0) <= -(bot.stopLossAbs || 0)) { 
            alert("🛑 STOP LOSS TRIGGERED! " + (bot.stats.profit || 0).toFixed(8)); 
            bot.isRunning = false; 
            document.getElementById("p-start").disabled = false;
            document.getElementById("p-stop").disabled = true;
        }
    }

