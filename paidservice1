                    </div>
                </div>
            </div>

            <div id="tab-status" class="tab-content">
                <div class="stat-row">
                    <span>Runtime</span>
                    <span class="stat-value" id="st-runtime">0h 0m 0s</span>
                </div>
                <div class="stat-row">
                    <span>Balance</span>
                    <span class="stat-value" id="st-bal">0</span>
                </div>
                <div class="stat-row">
                    <span>Profit</span>
                    <span class="stat-value" id="st-p" style="color:#10b981">0</span>
                </div>
                <div class="stat-row">
                    <span>Speed</span>
                    <span class="stat-value" id="st-speed"><span id="st-speed-val">0.00/s</span></span>
                </div>
                <div class="stat-row">
                    <span>Mode/Step</span>
                    <span class="stat-value"><span id="st-mode-display">WAGER</span> <span id="st-step">0/20</span></span>
                </div>
                <div class="stat-row">
                    <span>Chance</span>
                    <span class="stat-value" id="st-chance">99.98%</span>
                </div>
                <div class="stat-row">
                    <span>Rolls (W/L)</span>
                    <span class="stat-value" id="st-r">0 (0/0)</span>
                </div>
                <div class="stat-row">
                    <span>Wagered</span>
                    <span class="stat-value" id="st-wagered">0</span>
                </div>
                <div class="stat-row">
                    <span>AI Status</span>
                    <span class="stat-value" id="st-ai-status">OFF</span>
                </div>
                <div class="stat-row">
                    <span>Next Chart @</span>
                    <span class="stat-value" id="st-next-chart">500</span>
                </div>

                <div class="section" style="margin-top:12px;">
                    <div class="section-header" onclick="toggleSection('logs')">
                        <span class="title">📝 LIVE LOGS</span>
                        <span class="collapse-btn" id="collapse-logs">▼</span>
                    </div>
                    <div class="section-content" id="content-logs">
                        <div style="font-size:9px; color:#64748b; margin-bottom:4px; font-family: monospace; display: grid; grid-template-columns: 1fr 1fr 1fr;">
                            <span>Amount</span>
                            <span style="text-align:center;">Chance</span>
                            <span style="text-align:right;">Profit</span>
