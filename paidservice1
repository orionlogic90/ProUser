    async function runLoop() {
        if (!bot.isRunning) return;
        
        try {
            bot.lastBetTime = Date.now();
            
            const profit = bot.stats.currentBal - bot.stats.startBal;
            
            // =====================
            // LOCK MODE (MATI TOTAL)
            // =====================
            if (bot.mode === 2) {
                bot.currentChance = bot.chanceWager;
                let nextBet = parseFloat(document.getElementById("p-minbet")?.value) || 0.001;
                
                const res = await API.placeBet(nextBet, bot.currentChance);
                const d = res?.data?.diceRoll || res?.diceRoll;
                
                if (d) {
                    processBetResult(d, nextBet, bot.currentChance);
                }
                
                updateRuntime();
                updateDisplay();
                
                setTimeout(runLoop, 0);
                return;
            }
            
            // =====================
            // MASUK RECOVERY
            // =====================
            if (bot.mode === 0 && profit < 0) {
                bot.mode = 1;
                bot.step = 1;
                bot.loss_total = -profit;
                console.log(`🔄 ENTERING RECOVERY MODE - Loss: ${bot.loss_total.toFixed(8)}`);
                updateModeDisplay();
            }
            
            // =====================
            // KELUAR RECOVERY
            // =====================
            if (bot.mode === 1 && bot.stats.currentBal >= bot.stats.startBal) {
                bot.mode = 0;
                bot.step = 0;
                bot.loss_total = 0;
                console.log(`✅ EXITING RECOVERY MODE - Back to profit`);
                updateModeDisplay();
            }
            
            let nextBet, currentChance;
            
            // =====================
            // WAGER MODE
            // =====================
            if (bot.mode === 0) {
                currentChance = bot.chanceWager;
                nextBet = calculateBaseBet();
                
                if (profit < 0) {
                    bot.mode = 2;
                    currentChance = bot.chanceWager;
                    nextBet = parseFloat(document.getElementById("p-minbet")?.value) || 0.001;
                    updateModeDisplay();
                }
            }
            
            // =====================
            // RECOVERY MODE
            // =====================
            if (bot.mode === 1) {
                if (bot.step > bot.max_step) {
                    currentChance = bot.chanceWager;
                    nextBet = parseFloat(document.getElementById("p-minbet")?.value) || 0.001;
                } else {
                    // Gunakan AI optimized chance jika enabled
                    currentChance = bot.aiLearning.enabled ? 
                        getOptimalChanceForStep(bot.step) : 
                        bot.chanceRecovery[bot.step - 1];
                    
                    const payout = (100 / currentChance) - 1;
                    
                    if (payout > 0) {
                        nextBet = Math.abs(bot.loss_total) / payout;
                    } else {
                        nextBet = parseFloat(document.getElementById("p-minbet")?.value) || 0.001;
                    }
                }
            }
            
            // =====================
            // SAFETY CHECKS
            // =====================
            const minBet = parseFloat(document.getElementById("p-minbet")?.value) || 0.001;
            if (nextBet < minBet) nextBet = minBet;
            if (nextBet > bot.stats.currentBal) {
                nextBet = minBet;
            }
            
            bot.currentChance = currentChance;
            
            const res = await API.placeBet(nextBet, currentChance);
            const d = res?.data?.diceRoll || res?.diceRoll;
            
            if (d) {
                processBetResult(d, nextBet, currentChance);
            }
            
            updateRuntime();
            
            const tgNow = Date.now();
            if (tgNow - bot.lastTelegramTime >= bot.telegramInterval) {
                await API.sendTelegramReport();
                bot.lastTelegramTime = tgNow;
            }
            
            if (bot.isRunning) {
                setTimeout(runLoop, 0);
            }
        } catch (e) { 
            console.log("Loop error:", e);
            if (bot.isRunning) {
                setTimeout(runLoop, 0);
            }
        }
    }
    
    function processBetResult(d, amount, chance) {
        bot.speedBetsCount++;
        updateBetSpeed();
        
        const win = d.payout > 0;
        const pft = d.payout - d.amount;
        
        bot.stats.bets++; 
        bot.stats.wagered += d.amount;
        bot.stats.profit += pft; 
        bot.stats.currentBal += pft;
        bot.lastBetAmount = d.amount;
        
        // Track history untuk chart
        if (!bot.stats.history) bot.stats.history = [];
        bot.stats.history.push(bot.stats.currentBal);
        if (bot.stats.history.length > 50) bot.stats.history.shift();
        
        if (bot.stats.currentBal < bot.stats.startBal) {
            let dd = bot.stats.startBal - bot.stats.currentBal;
            let ddPerc = (dd / bot.stats.startBal) * 100;
            if (dd > bot.stats.maxDD) bot.stats.maxDD = dd;
            if (ddPerc > bot.stats.maxDDPerc) bot.stats.maxDDPerc = ddPerc;
        }
        
        updateLogs(amount, chance, bot.stats.profit, win, bot.mode === 1);
        
        if (win) { 
            bot.stats.wins++; 
            
            if (bot.mode === 1) {
                bot.loss_total = Math.max(0, bot.loss_total - pft);
                console.log(`✅ Recovery win! Remaining loss: ${bot.loss_total.toFixed(8)}`);
                
                // Track successful recovery step
                trackRecoveryAttempt(bot.step, chance, true);
            }
        } else { 
            bot.stats.loss++; 
            
            if (bot.mode === 1) {
                bot.loss_total = bot.loss_total + amount;
                bot.step = Math.min(bot.step + 1, bot.max_step + 1);
                console.log(`❌ Recovery loss #${bot.step}, Total loss: ${bot.loss_total.toFixed(8)}`);
                
                // Track failed recovery step
                trackRecoveryAttempt(bot.step - 1, chance, false);
            }
        }
        
        updateDisplay();
        
        // CHECK FOR CHART REPORT
        const currentWagerFloor = Math.floor(bot.stats.wagered / bot.chartReportInterval);
        const lastWagerFloor = Math.floor(bot.lastChartWagerAmount / bot.chartReportInterval);
        
        if (currentWagerFloor > lastWagerFloor && bot.stats.bets > 0) {
            console.log(`📊 Wagered reached ${currentWagerFloor * bot.chartReportInterval} - sending chart report...`);
            API.sendChartReport();
        }
        
        bot.lastChartWagerAmount = bot.stats.wagered;
        
        if (bot.stats.profit >= bot.targetAbs) { 
            alert("🎯 TARGET REACHED! " + bot.stats.profit.toFixed(8)); 
            bot.isRunning = false; 
        }
        else if (bot.stats.profit <= -bot.stopLossAbs) { 
            alert("🛑 STOP LOSS TRIGGERED! " + bot.stats.profit.toFixed(8)); 
            bot.isRunning = false; 
        }
    }

    function updateLogs(amt, ch, totalProfit, isWin, isRecovery = false) {
        const logBox = document.getElementById("p-logs");
        const entry = document.createElement("div");
        
        const amtStr = amt.toFixed(8).padStart(12, ' ');
        const chStr = ch.toFixed(2).padStart(6, ' ');
        const profitStr = (totalProfit >= 0 ? '+' : '') + totalProfit.toFixed(8);
        
        let borderColor = isWin ? "#10b981" : "#ef4444";
        if (isRecovery) borderColor = "#f59e0b";
        
        entry.style.cssText = `margin:1px 0; padding:1px 2px; font-size:10px; font-family: 'Menlo', 'Monaco', 'Courier New', monospace; border-left:2px solid ${borderColor}; color:#d1d5db;`;
        entry.innerHTML = `${amtStr} | ${chStr}% | ${profitStr}`;
        logBox.prepend(entry);
        if (logBox.children.length > 6) logBox.lastChild.remove();
    }

