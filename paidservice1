        document.getElementById("st-chance").innerText = bot.baseChance.toFixed(1) + "%";
        document.getElementById("st-next").innerText = bot.currentChance.toFixed(1) + "%";
        document.getElementById("st-steps").innerText = bot.currentSteps + "/" + bot.maxSteps.toLocaleString();
