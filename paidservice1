        bot.aiLearning.adjustmentInterval = parseInt(document.getElementById("p-ai-interval")?.value) || 10;
    }
    
    function trackRecoveryAttempt(step, chance, success) {
        if (!bot.aiLearning.enabled) return;
        
        bot.aiLearning.totalRecoveries++;
        
        if (!bot.aiLearning.successRate[step]) {
            bot.aiLearning.successRate[step] = { attempts: 0, successes: 0 };
        }
        
        bot.aiLearning.successRate[step].attempts++;
        if (success) {
            bot.aiLearning.successRate[step].successes++;
            bot.aiLearning.successfulRecoveries++;
        }
        
        bot.aiLearning.recoveryAttempts.push({
            step: step,
            chance: chance,
            success: success,
            timestamp: Date.now()
        });
        
        if (bot.aiLearning.recoveryAttempts.length > 100) {
            bot.aiLearning.recoveryAttempts.shift();
        }
        
        bot.aiLearning.lastAdjustment++;
        if (bot.aiLearning.lastAdjustment >= bot.aiLearning.adjustmentInterval) {
            adjustRecoveryChances();
            bot.aiLearning.lastAdjustment = 0;
        }
    }
    
    function adjustRecoveryChances() {
        if (!bot.aiLearning.enabled || bot.aiLearning.totalRecoveries < 10) return;
        
        for (let step = 1; step <= bot.max_step; step++) {
            const stats = bot.aiLearning.successRate[step];
            if (!stats || stats.attempts < 3) continue;
            
            const successRate = stats.successes / stats.attempts;
            const currentChance = bot.chanceRecovery[step - 1];
            
            const targetRate = 0.55;
            const error = successRate - targetRate;
            
            let adjustment = error * bot.aiLearning.learningRate * 100;
            
            if (successRate < 0.3) {
                adjustment = -bot.aiLearning.adaptationSpeed * 20;
            } else if (successRate > 0.8) {
                adjustment = bot.aiLearning.adaptationSpeed * 15;
            }
            
            let newChance = currentChance - adjustment;
            newChance = Math.max(bot.aiLearning.minChance, Math.min(bot.aiLearning.maxChance, newChance));
            
            bot.chanceRecovery[step - 1] = currentChance * (1 - bot.aiLearning.adaptationSpeed) + 
                                           newChance * bot.aiLearning.adaptationSpeed;
        }
    }
    
    function getOptimalChanceForStep(step) {
        if (!bot.aiLearning.enabled) {
            return bot.chanceRecovery[step - 1];
        }
        
        const stats = bot.aiLearning.successRate[step];
        if (!stats || stats.attempts < 5) {
            return bot.chanceRecovery[step - 1];
        }
        
        const successRate = stats.successes / stats.attempts;
        const currentChance = bot.chanceRecovery[step - 1];
        
        if (successRate > 0.7) {
            return Math.max(bot.aiLearning.minChance, currentChance - bot.aiLearning.adaptationSpeed * 5);
        }
        
        if (successRate < 0.4) {
            return Math.min(bot.aiLearning.maxChance, currentChance + bot.aiLearning.adaptationSpeed * 8);
        }
        
        return currentChance;
    }

