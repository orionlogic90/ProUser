    function calculateBaseBet() {
        if (bot.stats.startBal <= 0) return 0;
        
        const minBet = parseFloat(document.getElementById("p-minbet")?.value) || 0.001;
        const divider = parseFloat(document.getElementById("p-base-divider")?.value) || 10000;
        
        let baseBet = bot.stats.startBal / divider;
