    function loadMinesFields() {
        try {
            const fields = JSON.parse(localStorage.getItem('mine_fields'));
            return fields && fields.length > 0 ? fields : [0,1,2,3,4];
        } catch (e) {
            return [0,1,2,3,4];
        }
    }
    
    function saveMinesFields(fields) {
        localStorage.setItem('mine_fields', JSON.stringify(fields));
    }
    
    function createMinesFieldSelector() {
        const existingModal = document.getElementById("mines-fields-modal");
        if (existingModal) existingModal.remove();
        
        const modal = document.createElement("div");
        modal.id = "mines-fields-modal";
        modal.style.cssText = `
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
