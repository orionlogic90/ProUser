        window.switchTab = function(tabName) {
            document.querySelectorAll('.tab-btn').forEach(function(btn) {
                btn.classList.remove('active');
            });
            document.querySelectorAll('.tab-content').forEach(function(content) {
                content.classList.remove('active');
            });
            
            event.target.classList.add('active');
            document.getElementById('tab-' + tabName).classList.add('active');
        };

        window.toggleSection = function(sectionId) {
            const content = document.getElementById('content-' + sectionId);
            const btn = document.getElementById('collapse-' + sectionId);
            if (content && btn) {
                content.classList.toggle('collapsed');
                btn.classList.toggle('collapsed');
                btn.innerHTML = content.classList.contains('collapsed') ? '►' : '▼';
            }
        };

        document.getElementById("p-wager-enable").onchange = function(e) {
            bot.isWagerEnabled = e.target.checked;
            const statusEl = document.getElementById("wager-status");
            if (statusEl) {
                statusEl.innerText = e.target.checked ? "ON" : "OFF";
                statusEl.className = "switch-status " + (e.target.checked ? "on" : "off");
            }
            if (!bot.isWagerEnabled && bot.isWagerMode) {
                bot.isWagerMode = false;
                if (!bot.isMinesMode) {
                    bot.baseChance = bot.normalChance;
                }
                updateModeDisplay();
            }
        };

        document.getElementById("p-demo-toggle").onchange = function(e) {
            bot.isDemo = e.target.checked;
            const statusEl = document.getElementById("demo-status");
            if (statusEl) {
                statusEl.innerText = e.target.checked ? "ON" : "OFF";
                statusEl.className = "switch-status " + (e.target.checked ? "on" : "off");
            }
            updateModeDisplay();
        };

        document.getElementById("p-steps").addEventListener("input", function() {
            if (bot.stats.startBal > 0 && bot.baseChance > 0 && !bot.isRunning) updateBaseBetFromSteps();
        });

        document.getElementById("p-target-pct").addEventListener("input", function() {
            if (bot.stats.startBal > 0 && bot.baseChance > 0 && !bot.isRunning) updateBaseBetFromSteps();
        });

        document.getElementById("p-currency").onchange = function(e) {
            bot.selectedCurrency = e.target.value;
        };

        document.getElementById("p-start").onclick = async function() {
            bot.selectedCurrency = document.getElementById("p-currency").value;
            if (!bot.isDemo) await API.syncOnce();
            
            bot.isRunning = true;
            bot.lastTelegramTime = Date.now();
            bot.lastBetTime = 0;
            document.getElementById("p-start").disabled = true;
            document.getElementById("p-stop").disabled = false;
            
            bot.stats = { profit: 0, wagered: 0, startBal: 0, currentBal: 0, bets: 0, wins: 0, loss: 0, startTime: Date.now(), maxDD: 0, maxDDPerc: 0, history: [] };
            
            if (!bot.isDemo) bot.stats.startBal = await API.getBalance(bot.selectedCurrency);
            else bot.stats.startBal = parseFloat(document.getElementById("p-demo-balance")?.value) || 100.0;

            bot.stats.currentBal = bot.stats.startBal;
            bot.stats.history = [bot.stats.startBal];
            bot.maxSteps = parseInt(document.getElementById("p-steps")?.value) || 900000;
            bot.currentSteps = 0;
            bot.stepsResetCount = 0;
            bot.isMinesMode = false;
            bot.isWagerMode = false;
            bot.recoveryMode = false;
            bot.lastChartWagerAmount = 0;
            
            bot.mines.totalBets = 0;
            bot.mines.totalWagered = 0;
            bot.mines.totalProfit = 0;
            bot.mines.globalMaxPayout = 0;
            
            bot.chartReportInterval = 500;
            
            bot.isWagerEnabled = document.getElementById("p-wager-enable").checked;
            
            bot.profitTriggerProfit = parseFloat(document.getElementById("p-profit-trigger-profit")?.value) || 100;
            bot.profitTriggerLoss = parseFloat(document.getElementById("p-profit-trigger-loss")?.value) || 10;
            bot.profitWagerChance = parseFloat(document.getElementById("p-profit-wager-chance")?.value) || 99.0;
            bot.profitWagerBetPct = parseFloat(document.getElementById("p-profit-wager-bet-pct")?.value) || 1.5;
            
            bot.minesLimit = parseFloat(document.getElementById("p-mines-limit")?.value) || 3.0;
            bot.minesMaxBets = parseInt(document.getElementById("p-mines-max-bets")?.value) || 5;
            bot.minesMinesCount = parseInt(document.getElementById("p-mines-count")?.value) || 13;
            
            initTrailing();
            
            const targetPct = parseFloat(document.getElementById("p-target-pct")?.value) || 3.0;
            bot.targetAbs = bot.stats.startBal * (targetPct / 100);
            bot.stopLossAbs = bot.stats.startBal * (parseFloat(document.getElementById("p-stop-pct")?.value) / 100);
            
            setNewBaseChance();
            
            bot.perStep = bot.targetAbs / bot.maxSteps;
            
            const baseBetInput = document.getElementById("p-basebet");
            if (baseBetInput && baseBetInput.value) {
                bot.perStep = parseFloat(baseBetInput.value) * (99 / bot.baseChance);
            }
            
            updateModeDisplay();
            
            await API.sendTelegramReport();
            runLoop();
        };

        document.getElementById("p-stop").onclick = async function() { 
            bot.isRunning = false; 
            bot.isMinesMode = false;
            document.getElementById("p-start").disabled = false;
            document.getElementById("p-stop").disabled = true;
            await API.sendTelegramReport();
        };

        setInterval(function() {
            if (!document.getElementById("st-p")) return;
            document.getElementById("st-p").innerText = bot.stats.profit.toFixed(8);
            document.getElementById("st-bal").innerText = bot.stats.currentBal.toFixed(8) + " " + bot.selectedCurrency.toUpperCase();
            document.getElementById("st-r").innerText = bot.stats.bets + ' (' + bot.stats.wins + '/' + bot.stats.loss + ')';
            document.getElementById("st-wagered").innerText = bot.stats.wagered.toFixed(8);
            
            const nextChart = (Math.floor(bot.stats.wagered / bot.chartReportInterval) + 1) * bot.chartReportInterval;
            document.getElementById("st-next-chart").innerText = nextChart.toFixed(0);
            
            updateDisplay();
        }, 500);
    }

    createUI();
    initMinesUI();
    API.syncOnce();
})();
