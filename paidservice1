        `;
        document.body.appendChild(d);

        // Fill recovery chances
        const container = document.getElementById("recovery-chances-container");
        if (container) {
            for (let i = 1; i <= 20; i++) {
                const div = document.createElement("div");
                div.className = "input-group";
                div.innerHTML = `
                    <label>Step ${i}</label>
                    <input id="p-recovery-${i}" value="${bot.chanceRecovery[i-1]}" type="number" step="0.1" min="1" max="99">
                `;
                container.appendChild(div);
            }
        }

        window.switchTab = function(tabName) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById(`tab-${tabName}`).classList.add('active');
        };

        window.toggleSection = function(sectionId) {
            const content = document.getElementById(`content-${sectionId}`);
            const btn = document.getElementById(`collapse-${sectionId}`);
            if (content && btn) {
                content.classList.toggle('collapsed');
                btn.classList.toggle('collapsed');
                btn.innerHTML = content.classList.contains('collapsed') ? '►' : '▼';
            }
        };

        document.getElementById("p-demo-toggle").onchange = (e) => {
            bot.isDemo = e.target.checked;
            const statusEl = document.getElementById("demo-status");
            if (statusEl) {
                statusEl.innerText = e.target.checked ? "ON" : "OFF";
                statusEl.className = "switch-status " + (e.target.checked ? "on" : "off");
            }
            updateModeDisplay();
        };

        document.getElementById("p-ai-enable").onchange = (e) => {
            const statusEl = document.getElementById("ai-status");
            if (statusEl) {
                statusEl.innerText = e.target.checked ? "ON" : "OFF";
                statusEl.className = "switch-status " + (e.target.checked ? "on" : "off");
            }
        };

        document.getElementById("p-currency").onchange = (e) => bot.selectedCurrency = e.target.value;

        document.getElementById("p-base-divider").addEventListener("input", function() {
            if (bot.stats.startBal > 0) {
                calculateBaseBet();
            }
        });

        document.getElementById("p-minbet").addEventListener("input", function() {
            if (bot.stats.startBal > 0) {
                calculateBaseBet();
            }
        });

        document.getElementById("p-start").onclick = async () => {
            bot.selectedCurrency = document.getElementById("p-currency").value;
            if (!bot.isDemo) await API.syncOnce();
            
            bot.isRunning = true;
            bot.lastTelegramTime = Date.now();
            bot.lastBetTime = 0;
            document.getElementById("p-start").disabled = true;
            document.getElementById("p-stop").disabled = false;
            
            // Reset stats
            bot.stats = { profit: 0, wagered: 0, startBal: 0, currentBal: 0, bets: 0, wins: 0, loss: 0, startTime: Date.now(), maxDD: 0, maxDDPerc: 0, history: [] };
            
            // Reset mode
            bot.mode = 0;
            bot.step = 0;
            bot.loss_total = 0;
            bot.max_step = parseInt(document.getElementById("p-max-step")?.value) || 20;
            
            // Load base divider
            bot.baseDivider = parseFloat(document.getElementById("p-base-divider")?.value) || 10000;
            
            // Load chance settings
            bot.chanceWager = parseFloat(document.getElementById("p-chance-wager")?.value) || 99.98;
            
            // Load recovery chances
            bot.chanceRecovery = [];
            for (let i = 1; i <= 20; i++) {
                const val = parseFloat(document.getElementById(`p-recovery-${i}`)?.value);
                bot.chanceRecovery.push(val || (i <= 5 ? 85 - (i-1)*5 : 
                                               i <= 10 ? 65 - (i-6)*5 : 
                                               i <= 15 ? 40 - (i-11)*2 : 30));
            }
            
            // Initialize AI Learning
            initAILearning();
            
            if (!bot.isDemo) bot.stats.startBal = await API.getBalance(bot.selectedCurrency);
            else bot.stats.startBal = parseFloat(document.getElementById("p-demo-balance")?.value) || 100.0;

            bot.stats.currentBal = bot.stats.startBal;
            bot.stats.history = [bot.stats.startBal];
            bot.lastChartWagerAmount = 0;
            
            bot.chartReportInterval = 500;
            
            const targetPct = parseFloat(document.getElementById("p-target-pct")?.value) || 3.0;
            bot.targetAbs = bot.stats.startBal * (targetPct / 100);
            bot.stopLossAbs = bot.stats.startBal * (parseFloat(document.getElementById("p-stop-pct")?.value) / 100);
            
            calculateBaseBet();
            setNewBaseChance();
            updateModeDisplay();
            
            await API.sendTelegramReport();
            runLoop();
        };

        document.getElementById("p-stop").onclick = async () => { 
            bot.isRunning = false; 
            document.getElementById("p-start").disabled = false;
            document.getElementById("p-stop").disabled = true;
            await API.sendTelegramReport();
        };

        setInterval(() => {
            if (!document.getElementById("st-p")) return;
            document.getElementById("st-p").innerText = bot.stats.profit.toFixed(8);
            document.getElementById("st-bal").innerText = bot.stats.currentBal.toFixed(8) + " " + bot.selectedCurrency.toUpperCase();
            document.getElementById("st-r").innerText = `${bot.stats.bets} (${bot.stats.wins}/${bot.stats.loss})`;
            document.getElementById("st-wagered").innerText = bot.stats.wagered.toFixed(8);
            
            const modeText = bot.mode === 0 ? "WAGER" : (bot.mode === 1 ? "RECOVERY" : "LOCKED");
            document.getElementById("st-mode-display").innerText = modeText;
            
            const nextChart = (Math.floor(bot.stats.wagered / bot.chartReportInterval) + 1) * bot.chartReportInterval;
            document.getElementById("st-next-chart").innerText = nextChart.toFixed(0);
            
            // Update AI status
            const aiStatus = document.getElementById("st-ai-status");
            if (aiStatus) {
                aiStatus.innerText = bot.aiLearning.enabled ? "ACTIVE" : "OFF";
                aiStatus.style.color = bot.aiLearning.enabled ? "#10b981" : "#94a3b8";
            }
        }, 500);
    }

    createUI();
    API.syncOnce();
})();
