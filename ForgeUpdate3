            backgroundColor: 'rgba(158, 192, 124, 0.1)',
            borderWidth: 2,
            pointRadius: 0,
            pointHoverRadius: 4,
            tension: 0.1,
            fill: true
        }];
        
        var harvestPoints = [];
        for (var i = 0; i < bot.harvestMarkers.length; i++) {
            var marker = bot.harvestMarkers[i];
            var idx = -1;
            for (var j = 0; j < bot.balanceHistory.length; j++) {
                if (bot.balanceHistory[j].betNumber === marker.betNumber) {
                    idx = j;
                    break;
                }
            }
            if (idx !== -1) {
                harvestPoints.push({ x: labels[idx], y: data[idx] });
            }
        }
        
        if (harvestPoints.length > 0) {
            datasets.push({
                label: 'Harvest',
                data: harvestPoints,
                type: 'scatter',
                pointStyle: 'triangle',
                pointBackgroundColor: '#ff6b81',
                pointBorderColor: '#ff6b81',
                pointRadius: 6,
                pointHoverRadius: 8,
                showLine: false
            });
        }
        
        var gapPoints = [];
        for (var i = 0; i < bot.gapMarkers.length; i++) {
            var marker = bot.gapMarkers[i];
            var idx = -1;
            for (var j = 0; j < bot.balanceHistory.length; j++) {
                if (bot.balanceHistory[j].betNumber === marker.betNumber) {
                    idx = j;
                    break;
