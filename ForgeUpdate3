    // ==================== JOURNAL FUNCTIONS (seperti MT5) ====================
    function addJournalEntry(chance, betAmount, result, profit, streak, balance, isCutLoss) {
        var entry = {
            id: Date.now() + Math.random(),
            chance: chance,
            betAmount: betAmount,
            result: result, // 'WIN' or 'LOSS'
            profit: profit,
            streak: streak,
            balance: balance,
            isCutLoss: isCutLoss || false,
            timestamp: new Date()
        };
        journalEntries.unshift(entry);
        
        // Keep only last 50 entries
        while (journalEntries.length > 50) {
            journalEntries.pop();
        }
        
        renderJournal();
    }
    
