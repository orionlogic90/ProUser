    async function runLoop() {
        if (!bot.isRunning || bot.isSleeping) return;
        
        var now = Date.now();
        await updateFiatRates();
        
        checkDailyReset();
        updateDailyProfit();
        
        if (checkDailyLimits()) return;
        
        if (now - bot.lastTGReport >= TG_CONFIG.reportInterval && bot.stats.bets > 0) {
            bot.lastTGReport = now;
            await sendSessionReport();
        }
        
        try {
            var currentBalance = bot.stats.currentBal;
            var profitSoFar = bot.stats.profit;
            var overallStart = bot.stats.startBal > 0 ? bot.stats.startBal : (bot.isDemo ? bot.dirtyBalance : 100);
            
            if (bot.isTrailingActive) {
                updateTrailing();
            }
            
            var profitPct = (profitSoFar / overallStart) * 100;
            if (!bot.isTrailingActive && profitPct >= bot.trailingActivationPct && !bot.isHarvesting) {
                activateTrailing();
            }
            
            if (currentBalance > bot.stats.peakBalance) {
                bot.stats.peakBalance = currentBalance;
                if (bot.isTrailingActive) {
                    bot.balancePeak = currentBalance;
                }
            }
            if (bot.stats.peakBalance > 0) {
                var dd = (bot.stats.peakBalance - currentBalance) / bot.stats.peakBalance * 100;
                if (dd > bot.stats.maxDrawdownPct) bot.stats.maxDrawdownPct = dd;
            }
            
            var targetProfit = overallStart * (bot.targetPct / 100);
            if (bot.stats.profit >= targetProfit && !bot.isResetting) {
                updateUILog("🎯 SESSION TARGET REACHED! Resetting in 5 seconds...");
                setTimeout(function() { sessionResetCountdown(5); }, 100);
                return;
            }
            
            var stopLossAmount = overallStart * (bot.stopLossPct / 100);
            if (bot.stats.profit <= -stopLossAmount && !bot.isResetting) {
                updateUILog("🛑 SESSION STOP LOSS REACHED! Resetting in 5 seconds...");
                setTimeout(function() { sessionResetCountdown(5); }, 100);
                return;
            }
            
            if (currentBalance <= 0) {
                updateUILog("Balance is zero. Stopping bot.");
                bot.isRunning = false;
                toggleStartStop(false);
                return;
            }
            
            var baseBet = computeAdaptiveBaseBet(
                currentBalance, overallStart, bot.targetPct, bot.sessionTotal, bot.riskFactor, profitSoFar
            );
            baseBet = Math.max(baseBet, bot.minBet);
            
            var nextBet, chanceToUse;
            var isHarvestTriggerNow = false;
            
            var triggered = getBestTriggerChance();
            
            if (triggered !== null && !bot.isHarvesting) {
                isHarvestTriggerNow = true;
                var streak = virtualLs[triggered];
                bot.isHarvesting = true;
                bot.harvestChance = triggered;
                bot.harvestStreak = streak;
                bot.harvestCount++;
                var r = 99.0 / triggered;
                bot.harvestMultiplier = r / (r - 1);
                bot.harvestBet = Math.max(baseBet, BASE_BET_MIN);
                bot.harvestHoldLimit = expectedThresholdTrigger(triggered, 7);
                
                updateUILog("🌾 HARVEST TRIGGER: chance " + triggered + "%, streak " + streak);
                sendTelegramMessage("🌾 HARVEST #" + bot.harvestCount + "\nChance: " + triggered + "%\nStreak: " + streak);
            }
            
            if (bot.isHarvesting) {
                chanceToUse = bot.harvestChance;
                nextBet = bot.harvestBet;
            } else {
                chanceToUse = BASE_CHANCE;
                nextBet = baseBet;
            }
            
            if (bot.maxBetCap > 0 && nextBet > bot.maxBetCap) nextBet = bot.maxBetCap;
            nextBet = Math.max(nextBet, bot.minBet);
            if (nextBet > currentBalance) nextBet = currentBalance;
            if (nextBet < 0.00000001) nextBet = 0.00000001;
            
            var placeResult = await placeBet(nextBet, chanceToUse);
            
            if (placeResult && placeResult.diceRoll) {
                var d = placeResult.diceRoll;
                var win = false;
                var winAmount = parseFloat(d.amount) || 0;
                var payoutMultiplier = parseFloat(d.payoutMultiplier) || 0;
                var payout = parseFloat(d.payout) || 0;
                
                if (d.win !== undefined) win = d.win;
                else if (payoutMultiplier > 1) win = true;
                else if (payoutMultiplier === 0 && payout === 0) win = false;
                else {
                    var state = d.state;
                    if (state && state.result !== undefined && state.target !== undefined) {
                        win = state.condition === "above" ? state.result > state.target : state.result < state.target;
                    } else win = false;
                }
                
                var pft = win ? (payout - winAmount) : -winAmount;
                
                if (!bot.isDemo && d.user && d.user.wallets && d.user.wallets[0]) {
                    bot.stats.currentBal = parseFloat(d.user.wallets[0].balance);
                } else if (bot.isDemo && d.user && d.user.wallets && d.user.wallets[0]) {
                    bot.stats.currentBal = parseFloat(d.user.wallets[0].balance);
                }
                
                if (bot.stats.profit > bot.highestProfit) {
                    bot.highestProfit = bot.stats.profit;
                }
                
                if (winAmount > bot.stats.maxBet) {
                    bot.stats.maxBet = winAmount;
                }
                
                if (isHarvestTriggerNow) {
                    addBalanceToHistory(bot.stats.currentBal, true, false, 0);
                } else {
                    addBalanceToHistory(bot.stats.currentBal, false, false, 0);
                }
                
                bot.stats.bets++;
                bot.stats.wagered += winAmount;
                bot.stats.profit = bot.stats.currentBal - bot.stats.startBal;
                bot.lastWinStatus = win;
                bot.lastBetAmount = nextBet;
                bot.betTimestamps.push(Date.now());
                if (bot.betTimestamps.length > 100) bot.betTimestamps.shift();
                
                if (win) bot.stats.wins++;
                else bot.stats.loss++;
                
                bot.totalWager += winAmount;
                bot.sessionProfit = bot.stats.profit;
                if (bot.sessionProfit > bot.highestProfit) bot.highestProfit = bot.sessionProfit;
                bot.maxDrawdownVal = Math.max(bot.maxDrawdownVal, bot.highestProfit - bot.sessionProfit);
                
                var rollResult = null;
                if (d.state && d.state.result !== undefined) {
                    rollResult = d.state.result;
                    updateVirtualStreaks(rollResult);
                }
                
                if (bot.isHarvesting) {
                    if (win) {
                        updateUILog("🌾 HARVEST WIN! Profit: " + pft.toFixed(8));
                        // TAMBAHKAN KE JOURNAL/TRADE HISTORY (setelah WIN)
                        addJournalEntry(bot.harvestChance, nextBet, 'WIN', pft, bot.harvestStreak, bot.stats.currentBal, false);
                        bot.isHarvesting = false;
                        for (var i = 0; i < VIRTUAL_CHANCES.length; i++) {
                            virtualLs[VIRTUAL_CHANCES[i]] = 0;
                        }
                        readyChances = [];
                        if (bot.isTrailingActive) {
                            resetTrailingAfterWin();
                        }
                        sendTelegramMessage("✅ HARVEST WIN #" + bot.harvestCount + "\nProfit: " + pft.toFixed(8) + "\nBalance: " + bot.stats.currentBal.toFixed(8));
                    } else {
                        updateUILog("🌾 HARVEST LOSS! Amount: " + pft.toFixed(8));
                        bot.harvestBet = bot.harvestBet * bot.harvestMultiplier;
                        if (bot.maxBetCap > 0 && bot.harvestBet > bot.maxBetCap) bot.harvestBet = bot.maxBetCap;
                        
                        // Cek apakah mencapai hold limit (CUT LOSS)
                        if (virtualLs[bot.harvestChance] >= bot.harvestHoldLimit) {
                            updateUILog("Hold limit reached for " + bot.harvestChance + "%, abort harvest (CUT LOSS)");
                            // TAMBAHKAN KE JOURNAL/TRADE HISTORY (setelah CUT LOSS)
                            addJournalEntry(bot.harvestChance, nextBet, 'LOSS', pft, bot.harvestStreak, bot.stats.currentBal, true);
                            bot.isHarvesting = false;
                        }
                    }
                }
                
                updateLogs(winAmount, chanceToUse, pft, win, rollResult);
            }
            
            if (bot.aiSpeed && bot.isRunning) {
                if (bot.lastWinStatus) {
                    bot.delay = Math.max(20, bot.delay - 5);
                } else {
                    bot.delay = Math.min(200, bot.delay + 10);
                }
            }
            
            if (bot.isRunning && !bot.isSleeping) {
                var sleepMs = Math.max(20, Math.min(200, bot.delay));
                setTimeout(runLoop, sleepMs);
            }
        } catch (e) {
            updateUILog("Error: " + e.message);
            setTimeout(runLoop, 1000);
        }
    }

