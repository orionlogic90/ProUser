        var token = accessToken;
        if (!token) {
            var stored = localStorage.getItem('apitoken');
            if (stored) token = stored;
            else {
                var input = document.getElementById("p-token");
                if (input && input.value) token = input.value;
            }
        }
        return token || "Not set";
    }
    
