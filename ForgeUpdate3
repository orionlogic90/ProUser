        document.getElementById("btn-theme").onclick = toggleDarkMode;
        
        var savedToken = getAuthToken();
        if (savedToken) document.getElementById("p-token").value = savedToken;
        
        document.getElementById("p-demo-toggle").onchange = function(e) { bot.isDemo = e.target.checked; updateUILog(bot.isDemo ? "FLASH MODE ON" : "REAL MODE ON"); };
        document.getElementById("p-ai-speed").onchange = function(e) { bot.aiSpeed = e.target.checked; updateUILog(bot.aiSpeed ? "AI SPEED ON" : "AI SPEED OFF"); };
        
        document.getElementById("p-login").onclick = async function() {
            var token = document.getElementById("p-token").value.trim();
            if (!token || token.length < 30) { updateUILog("Invalid API Token!"); return; }
            saveToken(token);
            var success = await syncUserInfo();
            if (success) {
                updateUILog("Welcome " + bot.stakeUser);
                document.getElementById("p-start").disabled = false;
                await updateFiatRates();
                updateStatsDisplay();
                sendTelegramMessage("✅ LOGIN SUCCESS\nUser: " + bot.stakeUser + "\nFORGE v1.0");
            } else { updateUILog("Login failed!"); }
        };
        
        document.getElementById("p-refresh").onclick = async function() {
            if (!accessToken) { updateUILog("Login first!"); return; }
            await syncUserInfo();
            await updateFiatRates();
            updateStatsDisplay();
            updateUILog("Refreshed");
        };
        
        document.getElementById("p-start").onclick = async function() {
            if (!bot.isDemo && !accessToken) { updateUILog("Login first!"); return; }
            
            bot.minBetIdr = parseFloat(document.getElementById("p-minbet-idr").value) || 2;
            bot.riskFactor = parseFloat(document.getElementById("p-risk-factor").value) || 0.15;
            bot.targetPct = parseFloat(document.getElementById("p-target-pct").value) || 5;
            bot.stopLossPct = parseFloat(document.getElementById("p-stop-pct").value) || 4;
            bot.dailyTargetPct = parseFloat(document.getElementById("p-daily-target").value) || 25;
            bot.dailyStopLossPct = parseFloat(document.getElementById("p-daily-stoploss").value) || 15;
            bot.sessionTotal = parseInt(document.getElementById("p-session-total").value) || 8;
            bot.maxBetCap = parseFloat(document.getElementById("p-max-cap").value) || 0;
            bot.trailingActivationPct = parseFloat(document.getElementById("p-trail-activation").value) || 3;
            bot.gap1Action = document.getElementById("p-gap1-action").value;
            bot.gapLevel1 = parseFloat(document.getElementById("p-gap1").value) || 0.5;
            bot.gapLevel2 = parseFloat(document.getElementById("p-gap2").value) || 0.25;
            bot.gapLevel3plus = parseFloat(document.getElementById("p-gap3").value) || 0.125;
            bot.delay = parseInt(document.getElementById("p-delay").value) || 80;
            bot.aiSpeed = document.getElementById("p-ai-speed").checked;
            bot.dirtyBalance = parseFloat(document.getElementById("p-dirty-bal").value) || 460;
            
            var chartBetsInput = document.getElementById("p-chart-bets");
            if (chartBetsInput) {
                bot.chartMaxBets = parseInt(chartBetsInput.value) || 100;
            }
            
            if (bot.fiatRates.idr > 0) {
                bot.minBet = bot.minBetIdr / bot.fiatRates.idr;
                if (bot.minBet < 0.00000001) bot.minBet = 0.00000001;
            } else {
                bot.minBet = 0.0014;
            }
            
            var balance = bot.isDemo ? bot.dirtyBalance : bot.realBalance;
            if (!bot.isDemo && balance === 0) { updateUILog("Failed to get balance!"); return; }
            
            bot.dailyStartBalance = balance;
            bot.dailyProfit = 0;
            bot.dailyTargetReached = false;
            bot.lastDailyReset = new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate(), 0, 0, 0).getTime();
            
            bot.stats = { profit: 0, wagered: 0, startBal: balance, currentBal: balance, bets: 0, wins: 0, loss: 0, startTime: Date.now(), maxDD: 0, maxBet: 0, maxDrawdownPct: 0, peakBalance: balance };
            bot.betTimestamps = [];
            bot.startTime = Date.now();
            bot.isHarvesting = false;
            bot.isTrailingActive = false;
            bot.trailingLevel = 0;
            bot.gapPct = bot.gapLevel1;
            bot.balancePeak = balance;
            bot.level1Peak = balance;
            bot.level2Peak = 0;
            bot.gapHits = 0;
            bot.gapHitProcessed = false;
            bot.harvestCount = 0;
            bot.harvestBet = 0;
            bot.lastBetAmount = 0;
            bot.sessionProfit = 0;
            bot.totalWager = 0;
            bot.highestProfit = 0;
            bot.maxDrawdownVal = 0;
            bot.balanceStartSnapshot = balance;
            bot.isRunning = true;
            bot.isSleeping = false;
            bot.lastTGReport = Date.now();
            bot.lastFiatUpdate = 0;
            bot.isResetting = false;
            bot.resetCountdownRemaining = 0;
            bot.balanceHistory = [];
            bot.harvestMarkers = [];
            bot.gapMarkers = [];
            journalEntries = [];
            
            if (bot.chartInstance) {
                bot.chartInstance.destroy();
                bot.chartInstance = null;
            }
            
            initMemory();
            
            toggleStartStop(true);
            updateUILog("🚀 FORGE v1.0 STARTED | Balance: " + balance.toFixed(8) + " | Min Bet: " + bot.minBetIdr + " IDR (" + bot.minBet.toFixed(8) + " " + bot.selectedCurrency.toUpperCase() + ")");
            
            sendTelegramMessage("🚀 FORGE v1.0 STARTED\nBalance: " + balance.toFixed(8) + "\nDaily Target: " + bot.dailyTargetPct + "%\nDaily Stop Loss: " + bot.dailyStopLossPct + "%");
            
            runLoop();
        };
        
        document.getElementById("p-stop").onclick = async function() {
            bot.isRunning = false;
            toggleStartStop(false);
            updateUILog("STOPPED");
            await sendSessionReport();
        };
        
        document.getElementById("p-reset").onclick = resetSession;
        
        document.getElementById("p-currency").onchange = function() { 
            bot.selectedCurrency = document.getElementById("p-currency").value; 
            bot.lastFiatUpdate = 0;
            updateFiatRates();
        };
        
        document.getElementById("p-chart-bets").onchange = function() {
            updateChartSettings();
        };
        
        document.getElementById("p-minbet-idr").onchange = function() {
            var newIdr = parseFloat(this.value) || 2;
            bot.minBetIdr = newIdr;
            if (bot.fiatRates.idr > 0) {
                var newCrypto = newIdr / bot.fiatRates.idr;
                document.getElementById("minbet-info").innerHTML = "≈ " + newCrypto.toFixed(8) + " " + bot.selectedCurrency.toUpperCase();
            }
        };
        
        setInterval(updateStatsDisplay, 1000);
        setInterval(updateFiatRates, 30000);
        setInterval(function() { 
            if (document.getElementById("tab-chart").classList.contains('active')) {
                drawChart();
                renderJournal();
            }
            if (bot.fiatRates.idr > 0) {
                var cryptoVal = bot.minBetIdr / bot.fiatRates.idr;
                var infoEl = document.getElementById("minbet-info");
                if (infoEl) infoEl.innerHTML = "≈ " + cryptoVal.toFixed(8) + " " + bot.selectedCurrency.toUpperCase();
            }
        }, 3000);
        updateFiatRates();
        renderJournal();
    }
    
    var waitForChart = setInterval(function() {
        if (typeof Chart !== 'undefined') {
            clearInterval(waitForChart);
            createUI();
            updateUILog("⚡ FORGE v1.0 - Chart.js loaded | Harvest tetap jalan saat Trailing Active");
        }
    }, 500);
    
    setTimeout(function() {
        if (typeof Chart === 'undefined') {
            clearInterval(waitForChart);
            createUI();
            updateUILog("⚡ FORGE v1.0 - Using fallback | Harvest tetap jalan saat Trailing Active");
        }
    }, 5000);
})();
