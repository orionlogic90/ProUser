    function getDuration() {
        if (!bot.startTime) return "0s";
        const seconds = Math.floor((Date.now() - bot.startTime) / 1000);
        const hours = Math.floor(seconds / 3600);
        const minutes = Math.floor((seconds % 3600) / 60);
        const secs = seconds % 60;
        if (hours > 0) return `${hours}h ${minutes}m ${secs}s`;
        if (minutes > 0) return `${minutes}m ${secs}s`;
        return `${secs}s`;
    }

    // ========== BACCARAT FUNCTIONS ==========
    function parseBaccaratCards(betResult) {
        const state = betResult.state || {};
        const cards = state.cards || {};
        const result = state.result || "unknown";
        bot.baccaratCards = { player: cards.player || [], banker: cards.banker || [], winner: result };
    }

    // ========== BASEBET FUNCTION ==========
    function getBaseBet() {
        const useAuto = document.getElementById("p-basebet-auto").checked;
        let bet;
        
        if (useAuto) {
            const currentBalance = bot.stats.startBal + bot.stats.profit;
            const divisor = parseFloat(document.getElementById("p-basebet-divisor").value) || 300000;
            bet = currentBalance / divisor;
        } else {
            bet = parseFloat(document.getElementById("p-basebet-fixed").value) || 0.001;
        }
        
        if (bet < 0.00000001) bet = 0.00000001;
        return enforceMinBet(bet);
    }

    // ========== STAGE 1: BACCARAT REVERSE ==========
    function getReverseBetSide() {
        if (bot.baccaratReverse.lastResult === "player") return "banker";
        if (bot.baccaratReverse.lastResult === "banker") return "player";
        return "player";
    }

    function calculateStage1Bet() {
        const baseBet = getBaseBet();
        const multiplier = parseFloat(document.getElementById("p-baccarat-multiplier").value) || 1;
        
        if (bot.baccaratReverse.lastBetAmount === 0) {
            return enforceMinBet(baseBet);
        }
        
        let nextBet = bot.baccaratReverse.lastBetAmount * multiplier;
        
        const currentBalance = bot.stats.startBal + bot.stats.profit;
        if (currentBalance > bot.stats.peakBalance) {
            bot.stats.peakBalance = currentBalance;
            bot.baccaratReverse.sessionPeak = currentBalance;
            bot.baccaratReverse.betsInSession = 0;
            updateConsoleLog(`🎯 New peak! Reset to base: ${baseBet.toFixed(8)}`);
            return enforceMinBet(baseBet);
        }
        
        return enforceMinBet(nextBet);
    }

    function processStage1Result(betResult, betAmount, betSide) {
        const state = betResult.state || {};
        const result = state.result || "unknown";
        const payout = betResult.payout || 0;
        const pnl = payout - betAmount;
        
        parseBaccaratCards(betResult);
        
        const isWin = (result === betSide);
        const isTie = (result === "tie");
        
        if (isWin) {
            bot.stats.wins++;
            bot.baccaratReverse.consecutiveLosses = 0;
            updateConsoleLog(`✅ WIN! ${betSide.toUpperCase()} | +${pnl.toFixed(8)}`);
        } else if (isTie) {
            bot.stats.ties = (bot.stats.ties || 0) + 1;
            updateConsoleLog(`🤝 TIE! Bet returned`);
        } else {
            bot.stats.loss++;
            bot.baccaratReverse.consecutiveLosses++;
            updateConsoleLog(`❌ LOSS! ${betSide.toUpperCase()} | ${pnl.toFixed(8)}`);
        }
        
        bot.baccaratReverse.lastResult = result;
        bot.baccaratReverse.lastBetAmount = betAmount;
        bot.baccaratReverse.betsInSession++;
        bot.stats.bets++;
        bot.stats.wagered += betAmount;
        bot.stats.profit += pnl;
        
        if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
        
        const currentBalance = bot.stats.startBal + bot.stats.profit;
        if (bot.baccaratReverse.betsInSession >= 100 && currentBalance <= bot.stats.peakBalance) {
            updateConsoleLog(`⚠️ 100 bets no profit! Moving to Stage 2 (DICE RECOVERY)`);
            bot.currentStage = "DICE_RECOVERY";
            const lossAmount = bot.stats.peakBalance - currentBalance;
            bot.diceRecovery.targetLoss = lossAmount;
            bot.diceRecovery.remainingBets = parseInt(document.getElementById("p-dice-bets").value) || 5;
            bot.diceRecovery.currentChance = 50;
            sendTelegram(`📊 *STAGE CHANGE*\n→ STAGE 2: DICE RECOVERY\nLoss to recover: ${lossAmount.toFixed(8)} ${bot.selectedCurrency}`, false);
        }
        
        const profitTrigger = parseFloat(document.getElementById("p-profit-trigger").value) || 0.01;
        if (bot.stats.profit >= profitTrigger) {
            updateConsoleLog(`🎉 Profit target! Moving to WAGERING`);
            bot.currentStage = "WAGERING";
            bot.wagering.betsInWagering = 0;
            sendTelegram(`🎉 *STAGE CHANGE*\n→ WAGERING MODE (${document.getElementById("p-wagering-bets").value} bets)`, false);
        }
        
        return pnl;
    }

    // ========== STAGE 2: DICE RECOVERY ==========
    function calculateStage2Bet() {
        if (bot.diceRecovery.remainingBets <= 0) return 0;
        
        const lossAmount = bot.diceRecovery.targetLoss;
        const chance = bot.diceRecovery.currentChance;
        const multiplier = (100 / chance) - 1;
        if (multiplier <= 0) return 0.00000001;
        
        const buffer = parseFloat(document.getElementById("p-dice-buffer").value) || 3.3;
        let bet = Math.abs(lossAmount) / multiplier * (1 + (buffer / 100));
        if (bet < 0.00000001) bet = 0.00000001;
        
        bot.diceRecovery.currentBet = bet;
        return enforceMinBet(bet);
    }
    
    function updateDiceChance() {
        const lossAmount = Math.abs(bot.diceRecovery.targetLoss);
        const maxLoss = bot.stats.startBal * 0.1;
        let ratio = Math.min(1, lossAmount / maxLoss);
        const minChance = parseFloat(document.getElementById("p-dice-min").value) || 24;
        const maxChance = parseFloat(document.getElementById("p-dice-max").value) || 50;
        let newChance = maxChance - (ratio * (maxChance - minChance));
        newChance = Math.max(minChance, Math.min(maxChance, newChance));
        bot.diceRecovery.currentChance = Math.floor(newChance);
        updateConsoleLog(`🎲 Dice chance: ${bot.diceRecovery.currentChance}%`);
    }

    function processStage2Result(betResult, betAmount, chance) {
        const payout = betResult.payout || 0;
        const pnl = payout - betAmount;
        
        bot.stats.profit += pnl;
        bot.stats.bets++;
        bot.stats.wagered += betAmount;
        bot.diceRecovery.remainingBets--;
        
        if (pnl > 0) {
            bot.stats.wins++;
            updateConsoleLog(`✅ DICE WIN! ${chance}% | +${pnl.toFixed(8)}`);
            const currentLoss = bot.diceRecovery.targetLoss + bot.stats.profit;
            if (currentLoss <= 0) {
                updateConsoleLog(`🎉 Loss recovered! Moving to WAGERING`);
                bot.currentStage = "WAGERING";
                bot.wagering.betsInWagering = 0;
                sendTelegram(`🎉 *RECOVERY SUCCESS*\nLoss recovered! → WAGERING MODE`, false);
                return;
            }
            bot.diceRecovery.targetLoss = currentLoss;
            updateDiceChance();
        } else {
            bot.stats.loss++;
            updateConsoleLog(`❌ DICE LOSS! ${chance}% | ${pnl.toFixed(8)} | Remaining: ${bot.diceRecovery.remainingBets}`);
        }
        
        if (bot.diceRecovery.remainingBets <= 0) {
            const currentLoss = bot.diceRecovery.targetLoss + bot.stats.profit;
            if (currentLoss > 0) {
                updateConsoleLog(`⚠️ ${document.getElementById("p-dice-bets").value} DICE bets done. Moving to STAGE 3 (TIE RECOVERY)`);
                bot.currentStage = "TIE_RECOVERY";
                bot.tieRecovery.targetLoss = currentLoss;
                sendTelegram(`📊 *STAGE CHANGE*\n→ STAGE 3: TIE RECOVERY\nRemaining loss: ${currentLoss.toFixed(8)} ${bot.selectedCurrency}`, false);
            }
        }
        
        if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
    }

    // ========== STAGE 3: TIE RECOVERY ==========
    function calculateStage3Bet() {
        const lossAmount = Math.abs(bot.tieRecovery.targetLoss);
        const divisor = parseFloat(document.getElementById("p-tie-divisor").value) || 7;
        const buffer = parseFloat(document.getElementById("p-tie-buffer").value) || 10;
        let bet = (lossAmount / divisor) * (1 + (buffer / 100));
        if (bet < 0.00000001) bet = 0.00000001;
        bot.tieRecovery.currentBet = bet;
        return enforceMinBet(bet);
    }

    function processStage3Result(betResult, betAmount) {
        const state = betResult.state || {};
        const result = state.result || "unknown";
        const payout = betResult.payout || 0;
        const pnl = payout - betAmount;
        
        parseBaccaratCards(betResult);
        
        const isWin = (result === "tie");
        
        if (isWin) {
            bot.stats.wins++;
            updateConsoleLog(`✅ TIE WIN! +${pnl.toFixed(8)}`);
            bot.currentStage = "WAGERING";
            bot.wagering.betsInWagering = 0;
            sendTelegram(`🎉 *RECOVERY SUCCESS*\nTie win! → WAGERING MODE`, false);
        } else {
            bot.stats.loss++;
            updateConsoleLog(`❌ TIE LOSS! ${pnl.toFixed(8)} | Continuing...`);
            bot.tieRecovery.targetLoss = Math.abs(bot.tieRecovery.targetLoss) + Math.abs(pnl);
        }
        
        bot.stats.bets++;
        bot.stats.wagered += betAmount;
        bot.stats.profit += pnl;
        if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
        
        return pnl;
    }

    // ========== WAGERING MODE ==========
    function calculateWageringBet() {
        const useDynamic = document.getElementById("p-wagering-dynamic").checked;
        let baseBet;
        
        if (useDynamic) {
            const currentBalance = bot.stats.startBal + bot.stats.profit;
            const divisor = parseFloat(document.getElementById("p-wagering-divisor").value) || 300000;
            baseBet = currentBalance / divisor;
        } else {
            baseBet = parseFloat(document.getElementById("p-wagering-basebet").value) || 0.001;
        }
        
        const multiplier = parseFloat(document.getElementById("p-wagering-multiplier").value) || 1;
        let bet = baseBet * multiplier;
        
        if (bet < 0.00000001) bet = 0.00000001;
        return enforceMinBet(bet);
    }

    function getWageringChance() {
        return parseFloat(document.getElementById("p-wagering-chance").value) || 99.98;
    }

    function getWageringPayout() {
        const chance = getWageringChance();
        return 100 / chance;
    }

    function processWageringResult(betResult, betAmount) {
        const payout = betResult.payout || 0;
        const pnl = payout - betAmount;
        
        bot.stats.profit += pnl;
        bot.wagering.betsInWagering++;
        bot.stats.bets++;
        bot.stats.wagered += betAmount;
        
        if (pnl > 0) bot.stats.wins++;
        else if (pnl < 0) bot.stats.loss++;
        
        if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
        
        updateConsoleLog(`🎲 WAGERING [${bot.wagering.betsInWagering}/${document.getElementById("p-wagering-bets").value}] | ${pnl >= 0 ? '✅' : '❌'} | PnL: ${pnl >= 0 ? '+' : ''}${pnl.toFixed(8)}`);
        
        const maxBets = parseInt(document.getElementById("p-wagering-bets").value) || 30;
        if (bot.wagering.betsInWagering >= maxBets) {
            updateConsoleLog(`📊 ${maxBets} WAGERING bets completed! Resetting stats...`);
            
            const totalWagered = bot.stats.wagered;
            const newBalance = bot.stats.startBal + bot.stats.profit;
            
            bot.stats = {
                profit: 0,
                wagered: totalWagered,
                startBal: newBalance,
                bets: 0,
                wins: 0,
                loss: 0,
                maxDD: 0,
                ties: 0,
                peakBalance: newBalance
            };
            
            bot.wagering.betsInWagering = 0;
            
            bot.currentStage = "BACCARAT_REVERSE";
            bot.baccaratReverse = {
                lastBetSide: "player",
                lastBetAmount: 0,
                lastResult: null,
                consecutiveLosses: 0,
                sessionPeak: newBalance,
                betsInSession: 0,
                currentBet: 0
            };
            
            sendTelegram(`📊 *WAGERING COMPLETE*\nNew balance: ${newBalance.toFixed(8)} ${bot.selectedCurrency}\nReturning to Stage 1`, false);
            updateStatsDisplay();
        }
    }

    // ========== MAIN LOOP ==========
    async function runLoop() {
        if (!bot.isRunning) return;
        
        updateIdrPrice();
        updateUsdPrice();
        
        let betAmount = 0;
        let gameToPlay = "baccarat";
        let betSide = null;
        let chance = null;
        
        switch(bot.currentStage) {
            case "BACCARAT_REVERSE":
                gameToPlay = "baccarat";
                betSide = getReverseBetSide();
                betAmount = calculateStage1Bet();
                const multiplier = parseFloat(document.getElementById("p-baccarat-multiplier").value) || 1;
                const baseInfo = document.getElementById("p-basebet-auto").checked ? "auto" : "fixed";
                bot.currentStatus = `STAGE 1: BACCARAT REVERSE (${betSide.toUpperCase()} | ${multiplier}x | ${baseInfo})`;
                break;
                
            case "DICE_RECOVERY":
                gameToPlay = "dice";
                betAmount = calculateStage2Bet();
                if (betAmount <= 0 || bot.diceRecovery.remainingBets <= 0) {
                    bot.currentStage = "TIE_RECOVERY";
                    runLoop();
                    return;
                }
                chance = bot.diceRecovery.currentChance;
                bot.currentStatus = `STAGE 2: DICE ${chance}% (${bot.diceRecovery.remainingBets}/${document.getElementById("p-dice-bets").value})`;
                break;
                
            case "TIE_RECOVERY":
                gameToPlay = "baccarat";
                betSide = "tie";
                betAmount = calculateStage3Bet();
                bot.currentStatus = `STAGE 3: TIE RECOVERY (8:1)`;
                break;
                
            case "WAGERING":
                gameToPlay = "dice";
                betAmount = calculateWageringBet();
                chance = getWageringChance();
                bot.currentStatus = `WAGERING (${bot.wagering.betsInWagering + 1}/${document.getElementById("p-wagering-bets").value} | ${chance}%)`;
                break;
                
            default:
                bot.currentStage = "BACCARAT_REVERSE";
                runLoop();
                return;
        }
        
        try {
            let res;
            
            if (gameToPlay === "baccarat") {
                res = await placeBetWithToken(betAmount, null, "baccarat", betSide);
                if (res.errors) { bot.lastError = res.errors[0].message; setTimeout(runLoop, 400); return; }
                const data = res?.data || res;
                const betResult = data.baccaratBet || data;
                
                if (betResult && bot.isRunning) {
                    if (bot.currentStage === "BACCARAT_REVERSE") {
                        processStage1Result(betResult, betAmount, betSide);
                    } else if (bot.currentStage === "TIE_RECOVERY") {
                        processStage3Result(betResult, betAmount);
                    }
                    bot.lastError = "None";
                }
            } else if (gameToPlay === "dice") {
                const payout = getWageringPayout();
                res = await placeBetWithToken(betAmount, payout, "dice", null, chance);
                if (res.errors) { bot.lastError = res.errors[0].message; setTimeout(runLoop, 400); return; }
                const data = res?.data || res;
                const betResult = data.diceRoll || data;
                
                if (betResult && bot.isRunning) {
                    if (bot.currentStage === "DICE_RECOVERY") {
                        processStage2Result(betResult, betAmount, chance);
                    } else if (bot.currentStage === "WAGERING") {
                        processWageringResult(betResult, betAmount);
                    }
                    bot.lastError = "None";
                }
            }
            
            updateStatsDisplay();
            if (bot.isRunning) setTimeout(runLoop, 0);
            
        } catch (e) { 
            bot.lastError = e.message; 
            if (bot.isRunning) setTimeout(runLoop, 500); 
        }
    }

    function updateConsoleLog(msg) {
        const logEl = document.getElementById("st-log");
        if (logEl) {
            const time = new Date().toLocaleTimeString();
            logEl.innerHTML = `[${time}] ${msg}<br>` + logEl.innerHTML;
            if (logEl.innerHTML.length > 5000) logEl.innerHTML = logEl.innerHTML.substring(0, 3000);
        }
        console.log(msg);
    }

