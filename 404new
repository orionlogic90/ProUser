                        <div class="orion-input-group"><label>BET COUNTER</label><input class="orion-input" id="basebet-info" value="Bet #0" disabled></div>
                    </div>
                </div>
                
                <div class="orion-card">
                    <div class="orion-card-title">🎲 STAGE 2: DICE RECOVERY</div>
                    <div class="orion-grid">
                        <div class="orion-input-group"><label>MIN CHANCE (%)</label><input id="p-dice-min" class="orion-input" value="24"></div>
                        <div class="orion-input-group"><label>MAX CHANCE (%)</label><input id="p-dice-max" class="orion-input" value="50"></div>
                        <div class="orion-input-group"><label>MAX BETS</label><input id="p-dice-bets" class="orion-input" value="5"></div>
                        <div class="orion-input-group"><label>BUFFER (%)</label><input id="p-dice-buffer" class="orion-input" value="3.3"></div>
                    </div>
                </div>
                
                <div class="orion-card">
                    <div class="orion-card-title">🃏 STAGE 3: TIE RECOVERY (8:1)</div>
                    <div class="orion-grid">
                        <div class="orion-input-group"><label>PROFIT DIVISOR</label><input id="p-tie-divisor" class="orion-input" value="7"></div>
                        <div class="orion-input-group"><label>BUFFER (%)</label><input id="p-tie-buffer" class="orion-input" value="10"></div>
                        <div class="orion-input-group row-full"><label class="text-muted">Rumus: bet = (loss / divisor) × (1 + buffer/100)</label></div>
                    </div>
                </div>
                
                <div class="orion-card">
                    <div class="orion-card-title">💰 STAGE 4: WAGERING (DICE)</div>
                    <div class="orion-grid">
                        <div class="orion-input-group"><label>CHANCE (%)</label><input id="p-wagering-chance" class="orion-input" value="99.98" step="0.01"></div>
                        <div class="orion-input-group"><label>NUMBER OF BETS</label><input id="p-wagering-bets" class="orion-input" value="30"></div>
                        <div class="orion-input-group"><label>BET MULTIPLIER</label><input id="p-wagering-multiplier" class="orion-input" value="1" step="0.1"></div>
                        <div class="orion-input-group row-full">
                            <div class="orion-checkbox">
                                <input type="checkbox" id="p-wagering-dynamic" checked>
                                <label>Dynamic base bet (Balance / Divisor)</label>
                            </div>
                        </div>
                        <div class="orion-input-group"><label>DIVISOR</label><input id="p-wagering-divisor" class="orion-input" value="300000"></div>
                        <div class="orion-input-group"><label>FIXED BASE BET</label><input id="p-wagering-basebet" class="orion-input" value="0.001"></div>
