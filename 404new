        `;
        
        document.body.appendChild(d);
        
        // Tab switching
        const tabs = document.querySelectorAll('.orion-tab');
        const tabContents = document.querySelectorAll('.orion-tab-content');
        
        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                const tabName = tab.getAttribute('data-tab');
                tabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                tabContents.forEach(content => content.classList.remove('active'));
                document.getElementById(`tab-${tabName}`).classList.add('active');
            });
        });
        
        // Fiat currency change
        document.getElementById("p-fiat-currency").addEventListener("change", () => {
            updateStatsDisplay();
        });
        
        // Base bet mode toggle
        const autoRadio = document.getElementById("p-basebet-auto");
        const fixedRadio = document.getElementById("p-basebet-fixed-mode");
        const divisorInput = document.getElementById("p-basebet-divisor");
        const fixedBetInput = document.getElementById("p-basebet-fixed");
        
        function toggleBaseBetMode() {
            const isAuto = autoRadio.checked;
            divisorInput.disabled = !isAuto;
            fixedBetInput.disabled = isAuto;
        }
        
        autoRadio.addEventListener("change", toggleBaseBetMode);
        fixedRadio.addEventListener("change", toggleBaseBetMode);
        toggleBaseBetMode();
        
        // Toggle dynamic/fixed wagering
        const dynamicCheckbox = document.getElementById("p-wagering-dynamic");
        const wageringDivisor = document.getElementById("p-wagering-divisor");
        const wageringFixed = document.getElementById("p-wagering-basebet");
        
        function toggleWageringInputs() {
            const isDynamic = dynamicCheckbox.checked;
            wageringDivisor.disabled = !isDynamic;
            wageringFixed.disabled = isDynamic;
        }
        dynamicCheckbox.addEventListener("change", toggleWageringInputs);
        toggleWageringInputs();
        
        // Update dice config from UI
        function updateDiceConfig() {
            bot.diceRecovery.minChance = parseFloat(document.getElementById("p-dice-min").value) || 24;
            bot.diceRecovery.maxChance = parseFloat(document.getElementById("p-dice-max").value) || 50;
            bot.diceRecovery.remainingBets = parseInt(document.getElementById("p-dice-bets").value) || 5;
        }
        
        document.getElementById("p-dice-min").addEventListener("change", updateDiceConfig);
        document.getElementById("p-dice-max").addEventListener("change", updateDiceConfig);
        document.getElementById("p-dice-bets").addEventListener("change", updateDiceConfig);
        
        document.getElementById("p-login").onclick = async () => {
            const token = document.getElementById("p-api-token").value.trim();
            if (!token || token.length < 30) { updateConsoleLog("❌ Invalid API Token!"); return; }
            saveToken(token);
            const success = await syncUserInfo();
            if (success) {
                document.getElementById("p-start").disabled = false;
                document.getElementById("p-stop").disabled = false;
                updateConsoleLog(`✅ Login success! Welcome ${bot.stakeUser}`);
                await sendFullReport("LOGIN");
            }
        };
        
        document.getElementById("p-refresh").onclick = async () => {
            if (!accessToken) { updateConsoleLog("Please login first!"); return; }
            await syncUserInfo();
            updateConsoleLog("🔄 Refreshed!");
        };
        
        document.getElementById("p-start").onclick = async () => {
            if (!accessToken) { updateConsoleLog("Please login first!"); return; }
            if (bot.isRunning) return;
            
            await syncUserInfo();
            updateDiceConfig();
            
            bot.stats = { 
                profit: 0, 
                wagered: 0, 
                startBal: bot.realBalance, 
                bets: 0, 
                wins: 0, 
                loss: 0, 
                maxDD: 0, 
                ties: 0, 
                peakBalance: bot.realBalance 
            };
            bot.startTime = Date.now();
            bot.isRunning = true;
            bot.currentStage = "BACCARAT_REVERSE";
            
            bot.baccaratReverse = {
                lastBetSide: "player",
                lastBetAmount: 0,
                lastResult: null,
                consecutiveLosses: 0,
                sessionPeak: bot.realBalance,
                betsInSession: 0,
                currentBet: 0
            };
            
            bot.diceRecovery = {
                remainingBets: parseInt(document.getElementById("p-dice-bets").value) || 5,
                targetLoss: 0,
                currentChance: 50,
                minChance: parseFloat(document.getElementById("p-dice-min").value) || 24,
                maxChance: parseFloat(document.getElementById("p-dice-max").value) || 50,
                currentBet: 0
            };
            
            bot.tieRecovery = { targetLoss: 0, currentBet: 0 };
            bot.wagering = { betsInWagering: 0, totalWagered: 0 };
            bot.baccaratCards = { player: [], banker: [], winner: null };
            
            const baseBet = getBaseBet();
            const minBet = getMinBetInCoin();
            const minBetFiat = getMinBetInFiat();
            updateConsoleLog(`🚀 404 ULTIMATE STARTED | Balance: ${bot.realBalance.toFixed(8)} | Base bet: ${baseBet.toFixed(8)} | Min bet: ${minBet.toFixed(8)} (${minBetFiat})`);
            await sendFullReport("START");
            
            if (reportInterval) clearInterval(reportInterval);
            reportInterval = setInterval(async () => { 
                if (bot.isRunning) {
                    await sendFullReport("PERIODIC");
                }
            }, 300000);
            
            runLoop();
        };
        
        document.getElementById("p-stop").onclick = async () => {
            bot.isRunning = false;
            if (reportInterval) { clearInterval(reportInterval); reportInterval = null; }
            updateConsoleLog("🛑 404 ULTIMATE STOPPED");
            await sendFullReport("STOP");
        };
        
        setInterval(() => {
            if (!bot.isRunning) return;
            const elapsed = (Date.now() - bot.startTime) / 1000;
            const hours = Math.floor(elapsed / 3600);
            const minutes = Math.floor((elapsed % 3600) / 60);
            const seconds = Math.floor(elapsed % 60);
            document.getElementById("st-time").innerText = `${hours.toString().padStart(2,'0')}:${minutes.toString().padStart(2,'0')}:${seconds.toString().padStart(2,'0')}`;
            updateStatsDisplay();
        }, 400);
        
        updateConsoleLog("✅ 404 Ultimate Ready - Enter API Token to Login");
    }
    
    createUI();
})();
