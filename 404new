    // ========== FIAT CONVERSION ==========
    function toFiat(amount) {
        const fiat = document.getElementById("p-fiat-currency").value;
        if (fiat === "IDR" && bot.idrPrice > 0) {
            return (amount * bot.idrPrice).toLocaleString('id-ID', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
        } else if (fiat === "USD" && bot.usdPrice > 0) {
            return (amount * bot.usdPrice).toFixed(4);
        }
        return "0";
    }

    function getMinBetInCoin() {
        const fiat = document.getElementById("p-fiat-currency").value;
        let minFiat = 2;
        
        if (fiat === "IDR" && bot.idrPrice > 0) {
            return minFiat / bot.idrPrice;
        } else if (fiat === "USD" && bot.usdPrice > 0) {
            return 0.00014 / bot.usdPrice;
        }
        return 0.00000001;
    }

    function getMinBetInFiat() {
        const fiat = document.getElementById("p-fiat-currency").value;
        if (fiat === "IDR") return "Rp 2";
        return "$0.00014";
    }

    function enforceMinBet(betAmount) {
