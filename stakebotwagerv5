                            <div class="orion-stat"><div class="orion-stat-label">LOSSES</div><div class="orion-stat-value" id="st-loss" style="color:#ff4757">0</div></div>
                            <div class="orion-stat"><div class="orion-stat-label">WIN RATE</div><div class="orion-stat-value" id="st-wr">0%</div></div>
                        </div>
                    </div>
                </div>
                
                <!-- MONITOR PANEL -->
                <div class="orion-panel" id="panel-monitor">
                    <div class="orion-card">
                        <div class="orion-card-title">🎯 SYSTEM STATUS</div>
                        <div class="orion-stats-grid">
                            <div class="orion-stat"><div class="orion-stat-label">CURRENT PHASE</div><div class="orion-stat-value" id="mon-phase">WAGERING</div></div>
                            <div class="orion-stat"><div class="orion-stat-label">ACTIVE MODE</div><div class="orion-stat-value" id="mon-mode">DICE</div></div>
                            <div class="orion-stat"><div class="orion-stat-label">CURRENT MULT</div><div class="orion-stat-value" id="mon-mult">—</div></div>
                            <div class="orion-stat"><div class="orion-stat-label">PAYOUT / STEP</div><div class="orion-stat-value" id="mon-payout">—</div></div>
                        </div>
                    </div>
                    <div class="orion-log" id="mon-log">🟢 READY</div>
                    <div class="orion-recovery-detail" id="recovery-detail"></div>
