    function checkLossTrigger() {
        if (!bot.recoveryEnabled) return false;
        const lossPercent = ((bot.startBalance - bot.currentBalance) / bot.startBalance) * 100;
        if (lossPercent >= bot.recoveryLossTriggerPercent && bot.phase === "WAGERING") {
            bot.phase = "RECOVERY";
            bot.recoveryStartBalance = bot.currentBalance;
            bot.recoveryCurrentMultiplier = 1;
            bot.recoveryCurrentPayoutIndex = 0;
            bot.recoveryCurrentStepInPayout = 0;
            sendToTelegram(`🔥 RECOVERY TRIGGERED (Loss: ${lossPercent.toFixed(2)}%)`, true);
            return true;
        }
        return false;
    }
    
    function checkRecoveryComplete() {
        if (bot.phase !== "RECOVERY") return false;
        const targetBalance = bot.startBalance * (1 + bot.recoveryTargetProfitPercent / 100);
        if (bot.currentBalance >= targetBalance) {
            bot.phase = "WAGERING";
            sendToTelegram(`✅ RECOVERY COMPLETE (Balance: ${bot.currentBalance.toFixed(8)} | Target: ${targetBalance.toFixed(8)})`, true);
            return true;
        }
        return false;
    }
    
    function getRecoveryBetAmount() {
        return bot.recoveryBaseBet * bot.recoveryCurrentMultiplier;
    }
    
    function advanceRecoveryStep() {
        bot.recoveryCurrentStepInPayout++;
        
        if (bot.recoveryCurrentStepInPayout >= bot.recoveryCycleCount) {
            bot.recoveryCurrentStepInPayout = 0;
            bot.recoveryCurrentPayoutIndex++;
            
            if (bot.recoveryCurrentPayoutIndex >= bot.recoveryPayouts.length) {
                bot.recoveryCurrentPayoutIndex = 0;
                bot.recoveryCurrentMultiplier *= bot.recoveryCycleMultiplier;
                
                if (bot.recoveryCurrentMultiplier > bot.recoveryMaxMultiplier) {
                    sendToTelegram(`💀 MAX MULTIPLIER REACHED (${bot.recoveryMaxMultiplier}x) - STOPPING`, true);
                    bot.isRunning = false;
                    bot.phase = "WAGERING";
                    loopRunning = false;
                    return false;
                }
                sendToTelegram(`🔄 RECOVERY CYCLE UPGRADE | Multiplier: ${bot.recoveryCurrentMultiplier}x | Bet: ${getRecoveryBetAmount().toFixed(8)}`, true);
            }
        }
        return true;
    }
    
    async function processWageringDice() {
        const betAmount = bot.wageringDiceBaseBet;
        const res = await API.placeDiceBet(betAmount);
        
        if (!res?.errors && res) {
            const data = res?.data || res;
            const bet = data.diceRoll || data.diceBet;
            if (bet) {
                const pnl = bet.payout - bet.amount;
                bot.currentBalance += pnl;
                bot.stats.profit += pnl;
                bot.stats.wagered += bet.amount;
                bot.stats.bets++;
                if (pnl > 0) bot.stats.wins++;
                else bot.stats.loss++;
                if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
                bot.lastError = "None";
            }
        } else if (res?.errors) {
            bot.lastError = res.errors[0].message;
        }
        
        bot.wageringDiceCount++;
        if (bot.wageringDiceCount >= bot.wageringDiceCycles) {
            bot.wageringDiceCount = 0;
            bot.wageringMode = "baccarat";
        }
    }
    
    async function processWageringBaccarat() {
        const playerBet = bot.wageringBaccaratPlayerBet;
        const bankerBet = bot.wageringBaccaratBankerBet;
        const totalBet = playerBet + bankerBet;
        
        const res = await API.placeBaccaratDoubleBet(playerBet, bankerBet);
        
        if (!res?.errors && res) {
            const data = res?.data || res;
            const bet = data.baccaratBet || data;
            if (bet) {
                const result = bet.state?.result || "unknown";
                const playerPayout = result === "player" ? playerBet * 2 : 0;
                const bankerPayout = result === "banker" ? bankerBet * 1.95 : 0;
                const totalPayout = playerPayout + bankerPayout;
                const pnl = totalPayout - totalBet;
                
                bot.currentBalance += pnl;
                bot.stats.profit += pnl;
                bot.stats.wagered += totalBet;
                bot.stats.bets++;
                if (pnl > 0) bot.stats.wins++;
                else bot.stats.loss++;
                if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
                bot.lastBaccaratResult = { result, playerBet, bankerBet, pnl };
                bot.lastError = "None";
            }
        } else if (res?.errors) {
            bot.lastError = res.errors[0].message;
        }
        
        bot.wageringBaccaratCount++;
        if (bot.wageringBaccaratCount >= bot.wageringBaccaratCycles) {
            bot.wageringBaccaratCount = 0;
            bot.wageringMode = "dice";
        }
    }
    
    async function processRecoveryLimbo() {
        const payout = bot.recoveryPayouts[bot.recoveryCurrentPayoutIndex];
        const betAmount = getRecoveryBetAmount();
        
        const res = await API.placeLimboBet(betAmount, payout);
        
        if (!res?.errors && res) {
            const data = res?.data || res;
            const bet = data.limboBet || data;
            if (bet) {
                const pnl = bet.payout - bet.amount;
                bot.currentBalance += pnl;
                bot.stats.profit += pnl;
                bot.stats.wagered += bet.amount;
                bot.stats.bets++;
                bot.lastLimboResult = { payout, betAmount, pnl, multiplier: bet.multiplier };
                
                if (pnl > 0) {
                    bot.stats.wins++;
                    bot.lastError = "None";
                    if (checkRecoveryComplete()) return;
                    bot.recoveryCurrentStepInPayout = 0;
                    bot.recoveryCurrentPayoutIndex++;
                    if (bot.recoveryCurrentPayoutIndex >= bot.recoveryPayouts.length) {
                        bot.recoveryCurrentPayoutIndex = 0;
                        bot.recoveryCurrentMultiplier *= bot.recoveryCycleMultiplier;
                        if (bot.recoveryCurrentMultiplier > bot.recoveryMaxMultiplier) {
                            sendToTelegram(`💀 MAX MULTIPLIER REACHED - STOPPING`, true);
                            bot.isRunning = false;
                            bot.phase = "WAGERING";
                            loopRunning = false;
                            return;
                        }
                        sendToTelegram(`🔄 RECOVERY UPGRADE | Mult: ${bot.recoveryCurrentMultiplier}x | Bet: ${getRecoveryBetAmount().toFixed(8)}`, true);
                    }
                } else {
                    bot.stats.loss++;
                    const continueFlag = advanceRecoveryStep();
                    if (!continueFlag) return;
                }
                
                if (bot.stats.profit < bot.stats.maxDD) bot.stats.maxDD = bot.stats.profit;
            }
        } else if (res?.errors) {
            bot.lastError = res.errors[0].message;
            advanceRecoveryStep();
        }
    }
    
    async function runLoop() {
        if (!bot.isRunning) { loopRunning = false; return; }
        if (loopRunning) return;
        loopRunning = true;
        
        try {
            if (bot.phase === "WAGERING") {
                checkLossTrigger();
            }
            
            if (bot.phase === "WAGERING") {
                if (bot.wageringMode === "dice") {
                    await processWageringDice();
                } else {
                    await processWageringBaccarat();
                }
            } else if (bot.phase === "RECOVERY") {
                await processRecoveryLimbo();
            }
            
            loopRunning = false;
            if (bot.isRunning) runLoop();
            
        } catch (err) {
            console.error("Loop error:", err);
            bot.lastError = err.message;
            loopRunning = false;
            if (bot.isRunning) setTimeout(() => runLoop(), 100);
        }
    }
    
