        document.body.appendChild(root);
        
        // Tab switcher
        document.querySelectorAll('.orion-tab').forEach(tab => {
            tab.onclick = () => {
                document.querySelectorAll('.orion-tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.orion-panel').forEach(p => p.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById(`panel-${tab.dataset.tab}`).classList.add('active');
            };
        });
        
        // Start button
        document.getElementById("orion-start").onclick = async () => {
            if (!bot.isRunning) {
                await API.syncOnce();
                
                bot.wageringDiceBaseBet = parseFloat(document.getElementById("p-dice-bet")?.value) || 0.001;
                bot.wageringDiceCycles = parseInt(document.getElementById("p-dice-cycles")?.value) || 3;
                bot.wageringBaccaratPlayerBet = parseFloat(document.getElementById("p-bac-player")?.value) || 0.001;
                bot.wageringBaccaratBankerBet = parseFloat(document.getElementById("p-bac-banker")?.value) || 0.001;
                bot.wageringBaccaratCycles = parseInt(document.getElementById("p-bac-cycles")?.value) || 1;
                
                bot.recoveryEnabled = document.getElementById("p-recovery-enable")?.checked;
                bot.recoveryBaseBet = parseFloat(document.getElementById("p-rec-basebet")?.value) || 0.001;
                bot.recoveryLossTriggerPercent = parseFloat(document.getElementById("p-rec-trigger")?.value) || 0.5;
                bot.recoveryCycleMultiplier = parseFloat(document.getElementById("p-rec-multiplier")?.value) || 2;
                bot.recoveryMaxMultiplier = parseFloat(document.getElementById("p-rec-maxmult")?.value) || 32;
                bot.recoveryTargetProfitPercent = parseFloat(document.getElementById("p-rec-target")?.value) || 1.0;
                bot.recoveryCycleCount = parseInt(document.getElementById("p-rec-repetition")?.value) || 10;
                
                const payoutsStr = document.getElementById("p-rec-payouts")?.value || "[2,3,4]";
                try { bot.recoveryPayouts = JSON.parse(payoutsStr); } catch(e) { bot.recoveryPayouts = [2,3,4]; }
                
                bot.startBalance = bot.currentBalance;
                bot.stats = { profit: 0, wagered: 0, bets: 0, wins: 0, loss: 0, maxDD: 0 };
                bot.phase = "WAGERING";
                bot.wageringMode = "dice";
                bot.recoveryCurrentMultiplier = 1;
                bot.recoveryCurrentPayoutIndex = 0;
                bot.recoveryCurrentStepInPayout = 0;
                bot.isRunning = true;
                bot.startTime = Date.now();
                
                if (reportInterval) clearInterval(reportInterval);
                reportInterval = setInterval(() => { if(bot.isRunning) sendToTelegram("📊 PERIODIC", true); }, 180000);
                sendToTelegram("🚀 ORION WAGER ACTIVATED", true);
                runLoop();
            }
        };
        
        document.getElementById("orion-stop").onclick = () => {
            if (bot.isRunning) {
                bot.isRunning = false;
                if (reportInterval) clearInterval(reportInterval);
                sendToTelegram("🛑 STOPPED", true);
            }
        };
        
        // Draggable
        const dragEl = document.getElementById("orion-root");
        const handle = document.getElementById("orion-drag-handle");
        let isDragging = false, dragX = 0, dragY = 0;
        
        handle.addEventListener("mousedown", (e) => {
            if (e.target.closest("button") || e.target.closest("select") || e.target.closest("input")) return;
            isDragging = true;
            const rect = dragEl.getBoundingClientRect();
            dragX = e.clientX - rect.left;
            dragY = e.clientY - rect.top;
        });
        document.addEventListener("mousemove", (e) => {
            if (!isDragging) return;
            let left = e.clientX - dragX;
            let top = e.clientY - dragY;
            left = Math.max(5, Math.min(window.innerWidth - dragEl.offsetWidth - 5, left));
            top = Math.max(5, Math.min(window.innerHeight - dragEl.offsetHeight - 5, top));
            dragEl.style.left = left + "px";
            dragEl.style.top = top + "px";
            dragEl.style.right = "auto";
            dragEl.style.bottom = "auto";
        });
        document.addEventListener("mouseup", () => { isDragging = false; });
    }
    
    // UI Updater
    setInterval(() => {
        if (!document.getElementById("st-balance")) return;
        
        const badge = document.getElementById("orion-badge");
        if (badge) {
            badge.innerText = bot.isRunning ? "● RUNNING" : "○ STOPPED";
            badge.className = bot.isRunning ? "orion-badge running" : "orion-badge";
        }
        
        const wageringPhase = document.getElementById("phase-wagering");
        const recoveryPhase = document.getElementById("phase-recovery");
        
        if (bot.phase === "WAGERING") {
            wageringPhase?.classList.add("active-wagering");
            wageringPhase?.classList.remove("active-recovery");
            recoveryPhase?.classList.remove("active-recovery", "active-wagering");
        } else {
            recoveryPhase?.classList.add("active-recovery");
            recoveryPhase?.classList.remove("active-wagering");
            wageringPhase?.classList.remove("active-wagering", "active-recovery");
        }
        
        document.getElementById("st-balance").innerHTML = bot.currentBalance.toFixed(8);
        const profitEl = document.getElementById("st-profit");
        profitEl.innerHTML = bot.stats.profit.toFixed(8);
        profitEl.className = `orion-stat-value ${bot.stats.profit >= 0 ? 'profit-positive' : 'profit-negative'}`;
        document.getElementById("st-wagered").innerHTML = bot.stats.wagered.toFixed(8);
        document.getElementById("st-maxdd").innerHTML = bot.stats.maxDD.toFixed(8);
        document.getElementById("st-bets").innerHTML = bot.stats.bets;
        document.getElementById("st-wins").innerHTML = bot.stats.wins;
        document.getElementById("st-loss").innerHTML = bot.stats.loss;
        
        const winRate = bot.stats.bets > 0 ? ((bot.stats.wins / bot.stats.bets) * 100).toFixed(1) : 0;
        document.getElementById("st-wr").innerHTML = `${winRate}%`;
        
        document.getElementById("mon-phase").innerHTML = bot.phase.toLowerCase();
        document.getElementById("mon-mode").innerHTML = bot.wageringMode === "dice" ? "DICE" : "BACCARAT";
        
        if (bot.phase === "RECOVERY") {
            document.getElementById("mon-mult").innerHTML = `${bot.recoveryCurrentMultiplier}x`;
            const payout = bot.recoveryPayouts[bot.recoveryCurrentPayoutIndex] || "-";
            document.getElementById("mon-payout").innerHTML = `${payout}x / ${bot.recoveryCurrentStepInPayout+1}/${bot.recoveryCycleCount}`;
            const detail = document.getElementById("recovery-detail");
            if (detail) {
                detail.style.display = "block";
                detail.innerHTML = `🔄 RECOVERY ACTIVE<br>⚡ Multiplier: ${bot.recoveryCurrentMultiplier}x<br>💵 Bet: ${(bot.recoveryBaseBet * bot.recoveryCurrentMultiplier).toFixed(8)}<br>🎯 Payout: ${payout}x | Step: ${bot.recoveryCurrentStepInPayout+1}/${bot.recoveryCycleCount}`;
            }
        } else {
            document.getElementById("mon-mult").innerHTML = "—";
            document.getElementById("mon-payout").innerHTML = "—";
            const detail = document.getElementById("recovery-detail");
            if (detail) detail.style.display = "none";
        }
        
        const logEl = document.getElementById("mon-log");
        if (logEl) {
            const speed = bot.stats.bets > 0 ? (bot.stats.bets / ((Date.now() - bot.startTime) / 1000 || 1)).toFixed(1) : 0;
            logEl.innerHTML = `${speed} bet/s | Errors: ${bot.lastError !== "None" ? bot.lastError : "None"}`;
        }
    }, 200);
    
    createUI();
    API.syncOnce();
})();
