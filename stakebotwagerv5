                        <div class="orion-field"><label>PAYOUT ARRAY</label><input id="p-rec-payouts" value="[2,3,4]"></div>
                    </div>
                </div>
                
                <!-- STATS PANEL -->
                <div class="orion-panel" id="panel-stats">
                    <div class="orion-card">
                        <div class="orion-card-title">📈 LIVE STATISTICS</div>
                        <div class="orion-stats-grid">
                            <div class="orion-stat"><div class="orion-stat-label">BALANCE</div><div class="orion-stat-value" id="st-balance">0.00000000</div></div>
                            <div class="orion-stat"><div class="orion-stat-label">PROFIT</div><div class="orion-stat-value" id="st-profit">0.00000000</div></div>
                            <div class="orion-stat"><div class="orion-stat-label">WAGERED</div><div class="orion-stat-value" id="st-wagered">0.00000000</div></div>
                            <div class="orion-stat"><div class="orion-stat-label">MAX DRAWDOWN</div><div class="orion-stat-value" id="st-maxdd">0.00000000</div></div>
                            <div class="orion-stat"><div class="orion-stat-label">BETS</div><div class="orion-stat-value" id="st-bets">0</div></div>
