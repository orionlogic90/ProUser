    // ==================== MIN BET OTOMATIS 2 IDR ====================
    async function updateFiatRates() {
        var now = Date.now();
        if (now - bot.lastFiatUpdate < 30000) return;
        bot.lastFiatUpdate = now;
        
        let useCache = false;
        try {
            var coin = bot.selectedCurrency.toUpperCase();
            var coinRes = await fetch('https://api.binance.com/api/v3/ticker/price?symbol=' + coin + 'USDT').then(function(r) { return r.json(); }).catch(function() { return {price:"0"}; });
            var idrRes = await fetch('https://api.binance.com/api/v3/ticker/price?symbol=USDTIDR').then(function(r) { return r.json(); }).catch(function() { return {price:"0"}; });
            
            if (coinRes && coinRes.price && parseFloat(coinRes.price) > 0) bot.fiatRates.usdt = parseFloat(coinRes.price);
            if (idrRes && idrRes.price && parseFloat(idrRes.price) > 0) bot.fiatRates.usdtIdr = parseFloat(idrRes.price);
            bot.fiatRates.idr = bot.fiatRates.usdt * bot.fiatRates.usdtIdr;
            bot.priceCache = { usdt: bot.fiatRates.usdt, idr: bot.fiatRates.idr, usdtIdr: bot.fiatRates.usdtIdr, lastSuccess: now };
            bot.lastPriceUpdate = now;
            useCache = false;
        } catch(e) {
            useCache = true;
        }
        
        if (useCache && bot.priceCache.lastSuccess > 0) {
            bot.fiatRates = { usdt: bot.priceCache.usdt, idr: bot.priceCache.idr, usdtIdr: bot.priceCache.usdtIdr };
            updateUILog("⚠️ Using cached price (Binance unavailable)");
        }
        
        if (bot.fiatRates.idr > 0) {
            bot.minBet = bot.minBetIdr / bot.fiatRates.idr;
            if (bot.minBet < 0.00000001) bot.minBet = 0.00000001;
        }
        
        let priceStatus = document.getElementById("price-status");
        if (priceStatus) priceStatus.innerHTML = useCache ? "⚠️ CACHE" : "✅ LIVE";
    }

    // ==================== RECOVERY MODE ====================
    function calculateRecoveryBet(baseBet, balance, harvestChance) {
        if (!bot.recoveryMode) return baseBet;
        if (balance < bot.minBalanceRecovery) return baseBet;
        if (bot.recoveryStep >= bot.maxRecoveryStep) return baseBet;
        if (bot.totalHarvestLoss <= 0) return baseBet;
        
        if (bot.lastHarvestLossTime > 0 && (Date.now() - bot.lastHarvestLossTime) < bot.cooldownAfterLoss * 1000) {
            return baseBet;
        }
        
        let THL = bot.totalHarvestLoss;
        let RF = 1 + (THL / balance);
        let CM = 99 / harvestChance;
        let DF = bot.useDrawdownFactor ? 1 + (bot.stats.maxDrawdownPct / 100) : 1;
        let CL = 1 + (bot.consecutiveLoss * 0.1);
        let TD = 1;
        if (bot.useTimeDecay && bot.recoveryElapsed > 0) {
            TD = Math.max(0.1, 1 - (bot.recoveryElapsed / 86400));
        }
        
        let recoveryBet = baseBet * RF * CM * DF * CL * TD;
        
        let maxBetByCap = baseBet * bot.maxRecoveryBet;
        recoveryBet = Math.min(recoveryBet, maxBetByCap);
        let maxPercentBet = balance * (bot.maxRecoveryPercent / 100);
        recoveryBet = Math.min(recoveryBet, maxPercentBet);
        
        return Math.max(recoveryBet, baseBet);
    }
    
    function resetRecovery() {
        bot.totalHarvestLoss = 0;
        bot.consecutiveLoss = 0;
        bot.recoveryStep = 0;
        bot.recoveryElapsed = 0;
        updateUILog("🔄 Recovery mode reset");
        renderHarvestTable();
    }
    
    function updateRecoveryAfterWin(profit) {
        if (!bot.recoveryMode || bot.totalHarvestLoss <= 0) return;
        bot.totalHarvestLoss = Math.max(0, bot.totalHarvestLoss - profit);
        if (bot.totalHarvestLoss <= 0) {
            bot.consecutiveLoss = 0;
            bot.recoveryStep = 0;
            bot.recoveryElapsed = 0;
            updateUILog("✅ Recovery complete! Total loss recovered.");
        }
        renderHarvestTable();
    }
    
    function updateRecoveryAfterLoss(loss) {
        if (!bot.recoveryMode) return;
        bot.totalHarvestLoss += Math.abs(loss);
        bot.consecutiveLoss++;
        bot.recoveryStep++;
        bot.recoveryElapsed = 0;
        bot.lastHarvestLossTime = Date.now();
        if (bot.recoveryStep >= bot.maxRecoveryStep) {
            updateUILog("⚠️ Max recovery step reached. Resetting recovery.");
            resetRecovery();
        }
        renderHarvestTable();
    }

