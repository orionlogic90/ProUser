delay" value="80"></div></div><div class="toggle-row"><span>🤖 AI SPEED</span><label class="md-switch"><input type="checkbox" id="p-ai-speed" checked><span class="md-slider"></span></label></div><div class="grid-2"><div class="md-field"><label>💣 DIRTY BALANCE</label><input type="number" id="p-dirty-bal" value="460" step="0.1"></div></div>
