    // ==================== DRAG & DROP ====================
    var pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;
    
    function dragMouseDown(e) { 
        if (e.target.closest && (e.target.closest('button, input, select'))) return; 
        e = e || window.event; 
        e.preventDefault(); 
        pos3 = e.clientX; 
        pos4 = e.clientY; 
        document.onmouseup = closeDragElement; 
        document.onmousemove = elementDrag; 
    }
    
    function elementDrag(e) { 
        var elmnt = document.getElementById("BotConsole"); 
        e = e || window.event; 
        e.preventDefault(); 
        pos1 = pos3 - e.clientX; 
        pos2 = pos4 - e.clientY; 
        pos3 = e.clientX; 
        pos4 = e.clientY; 
        var newTop = elmnt.offsetTop - pos2; 
        var newLeft = elmnt.offsetLeft - pos1; 
        var maxLeft = window.innerWidth - elmnt.offsetWidth; 
        var maxTop = window.innerHeight - elmnt.offsetHeight; 
        if (newLeft < 0) newLeft = 0; 
        if (newTop < 0) newTop = 0; 
        if (newLeft > maxLeft) newLeft = maxLeft; 
        if (newTop > maxTop) newTop = maxTop; 
        elmnt.style.top = newTop + "px"; 
        elmnt.style.left = newLeft + "px"; 
        elmnt.style.right = "auto"; 
    }
    
    function closeDragElement() { 
        document.onmouseup = null; 
        document.onmousemove = null; 
    }
    
