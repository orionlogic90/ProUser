        var savedWagered = bot.stats.wagered || 0;
        bot.stats = { 
            profit: 0, 
            wagered: savedWagered, 
            startBal: bot.stats.currentBal || 0, 
            currentBal: bot.stats.currentBal || 0, 
            bets: 0, 
            wins: 0, 
            loss: 0, 
            startTime: Date.now(), 
            maxDD: 0, 
            maxBet: 0, 
            maxDrawdownPct: 0, 
            peakBalance: bot.stats.currentBal || 0 
        };
        
        if (bot.isHarvesting && bot.openHarvest) {
            closeOpenHarvest(false, (bot.stats.currentBal || 0) - (bot.openHarvest.startBalance || 0), bot.stats.currentBal || 0, "Session Reset");
        }
        
        bot.isHarvesting = false;
        bot.isTrailingActive = false;
        bot.trailingLevel = 0;
        bot.harvestChance = 0;
        bot.harvestBet = 0;
        bot.harvestCount = 0;
        bot.lastBetAmount = 0;
        bot.sessionProfit = 0;
        bot.totalWager = 0;
        bot.highestProfit = 0;
        bot.maxDrawdownVal = 0;
        bot.balanceStartSnapshot = bot.stats.currentBal || 0;
        bot.gapHits = 0;
        bot.harvestMarkers = [];
        bot.gapMarkers = [];
        bot.openHarvest = null;
        
        resetRecovery();
        initMemory();
        updateUILog("Stats reset!");
        drawGapVisual();
        renderHarvestTable();
    }

    async function runLoop() {
        if (!bot.isRunning || bot.isSleeping) return;
        
        await updateFiatRates();
        checkDailyReset();
        updateDailyProfit();
        if (checkDailyLimits()) return;
        
        var now = Date.now();
        if (now - bot.lastTGReport >= TG_CONFIG.reportInterval && (bot.stats.bets || 0) > 0) {
            bot.lastTGReport = now;
            await sendSessionReport();
        }
        
        try {
            var currentBalance = bot.stats.currentBal || 0;
            var profitSoFar = bot.stats.profit || 0;
            var overallStart = bot.stats.startBal > 0 ? bot.stats.startBal : (bot.isDemo ? bot.dirtyBalance : 100);
            
            if (bot.isTrailingActive) updateTrailing();
            
            var profitPct = (profitSoFar / overallStart) * 100;
            if (!bot.isTrailingActive && profitPct >= bot.trailingActivationPct && !bot.isHarvesting) {
                activateTrailing();
            }
            
            if (currentBalance > (bot.stats.peakBalance || 0)) {
                bot.stats.peakBalance = currentBalance;
                if (bot.isTrailingActive) bot.balancePeak = currentBalance;
            }
            
            if ((bot.stats.peakBalance || 0) > 0) {
                var dd = ((bot.stats.peakBalance || 0) - currentBalance) / (bot.stats.peakBalance || 1) * 100;
                if (dd > (bot.stats.maxDrawdownPct || 0)) bot.stats.maxDrawdownPct = dd;
            }
            
            var targetProfit = overallStart * (bot.targetPct / 100);
            if (profitSoFar >= targetProfit && !bot.isResetting) {
                updateUILog("🎯 SESSION TARGET REACHED! Resetting in 5 seconds...");
                setTimeout(() => sessionResetCountdown(5), 100);
                return;
            }
            
            var stopLossAmount = overallStart * (bot.stopLossPct / 100);
            if (profitSoFar <= -stopLossAmount && !bot.isResetting) {
                updateUILog("🛑 SESSION STOP LOSS REACHED! Resetting in 5 seconds...");
                setTimeout(() => sessionResetCountdown(5), 100);
                return;
            }
            
            if (currentBalance <= 0) {
                updateUILog("Balance is zero. Stopping bot.");
                bot.isRunning = false;
                toggleStartStop(false);
                return;
            }
            
            var baseBet = currentBalance * (bot.baseBetPercent / 100);
            baseBet = Math.max(baseBet, bot.minBet || 0.00000001);
            
            var nextBet, chanceToUse;
            var isHarvestTriggerNow = false;
            var triggered = getBestTriggerChance();
            let isRecoveryHarvest = false;
            
            if (triggered !== null && !bot.isHarvesting) {
                isHarvestTriggerNow = true;
                var streak = virtualLs[triggered];
                bot.isHarvesting = true;
                bot.harvestChance = triggered;
                bot.harvestStreak = streak;
                bot.harvestCount = (bot.harvestCount || 0) + 1;
                var r = 99.0 / triggered;
                bot.harvestMultiplier = r / (r - 1);
                bot.harvestBet = Math.max(baseBet, bot.minBet || 0.00000001);
                
                if (bot.recoveryMode && bot.totalHarvestLoss > 0 && bot.recoveryStep < bot.maxRecoveryStep) {
                    isRecoveryHarvest = true;
                    bot.harvestBet = calculateRecoveryBet(bot.harvestBet, currentBalance, triggered);
                }
                
                bot.harvestHoldLimit = expectedThresholdTrigger(triggered, 7);
                bot.harvestStartTime = Date.now();
                bot.harvestStartBalance = currentBalance;
                startOpenHarvest(triggered, bot.harvestBet, isRecoveryHarvest);
                updateUILog("🌾 HARVEST TRIGGER: chance " + triggered + "%, streak " + streak + (isRecoveryHarvest ? " (RECOVERY)" : ""));
                sendTelegramMessage("🌾 HARVEST #" + bot.harvestCount + "\nChance: " + triggered + "%\nStreak: " + streak + (isRecoveryHarvest ? "\n🔄 RECOVERY MODE ACTIVE" : ""));
            }
            
            if (bot.isHarvesting) {
                chanceToUse = bot.harvestChance;
                nextBet = bot.harvestBet;
                updateOpenHarvest(nextBet, bot.harvestStreak, bot.harvestBet);
            } else {
                chanceToUse = bot.baseChance || 98;
                nextBet = baseBet;
            }
            
            if (bot.maxBetCap > 0 && nextBet > bot.maxBetCap) nextBet = bot.maxBetCap;
            nextBet = Math.max(nextBet, bot.minBet || 0.00000001);
            if (nextBet > currentBalance) nextBet = currentBalance;
            if (nextBet < 0.00000001) nextBet = 0.00000001;
            
            var placeResult = await placeBet(nextBet, chanceToUse);
            
            if (placeResult?.diceRoll) {
                var d = placeResult.diceRoll;
                var win = d.win !== undefined ? d.win : (d.payoutMultiplier > 1);
                var winAmount = parseFloat(d.amount) || 0;
                var pft = win ? (parseFloat(d.payout) - winAmount) : -winAmount;
                
                if (d.user?.wallets?.[0]) {
                    bot.stats.currentBal = parseFloat(d.user.wallets[0].balance);
                }
                
                if ((bot.stats.profit || 0) > (bot.highestProfit || 0)) bot.highestProfit = bot.stats.profit;
                if (winAmount > (bot.stats.maxBet || 0)) bot.stats.maxBet = winAmount;
                
                if (isHarvestTriggerNow) {
                    addBalanceToHistory(bot.stats.currentBal || 0, true, false, 0);
                } else {
                    addBalanceToHistory(bot.stats.currentBal || 0, false, false, 0);
                }
                
                bot.stats.bets = (bot.stats.bets || 0) + 1;
                bot.stats.wagered = (bot.stats.wagered || 0) + winAmount;
                bot.stats.profit = (bot.stats.currentBal || 0) - (bot.stats.startBal || 0);
                bot.lastWinStatus = win;
                bot.lastBetAmount = nextBet;
                bot.betTimestamps.push(Date.now());
                if (bot.betTimestamps.length > 100) bot.betTimestamps.shift();
                
                if (win) {
                    bot.stats.wins = (bot.stats.wins || 0) + 1;
                } else {
                    bot.stats.loss = (bot.stats.loss || 0) + 1;
                }
                
                var rollResult = d.state?.result;
                if (rollResult !== undefined) updateVirtualStreaks(rollResult);
                
                if (bot.isHarvesting) {
                    if (win) {
                        var harvestProfit = (bot.stats.currentBal || 0) - (bot.harvestStartBalance || 0);
                        updateUILog("🌾 HARVEST WIN! Profit: " + harvestProfit.toFixed(8));
                        closeOpenHarvest(true, harvestProfit, bot.stats.currentBal || 0, "Win");
                        bot.isHarvesting = false;
                        for (var i = 0; i < VIRTUAL_CHANCES.length; i++) virtualLs[VIRTUAL_CHANCES[i]] = 0;
                        readyChances = [];
                        if (bot.isTrailingActive) resetTrailingAfterWin();
                        sendTelegramMessage("✅ HARVEST WIN #" + bot.harvestCount + "\nProfit: " + harvestProfit.toFixed(8) + "\nBalance: " + (bot.stats.currentBal || 0).toFixed(8));
                    } else {
                        bot.harvestBet = (bot.harvestBet || 0) * (bot.harvestMultiplier || 1);
                        bot.harvestStreak = (bot.harvestStreak || 0) + 1;
                        if (bot.maxBetCap > 0 && bot.harvestBet > bot.maxBetCap) bot.harvestBet = bot.maxBetCap;
                        updateOpenHarvest(bot.harvestBet, bot.harvestStreak, bot.harvestBet);
                        
                        if (virtualLs[bot.harvestChance] >= (bot.harvestHoldLimit || 999)) {
                            var harvestLoss = (bot.stats.currentBal || 0) - (bot.harvestStartBalance || 0);
                            updateUILog("Hold limit reached for " + bot.harvestChance + "%, abort harvest");
                            closeOpenHarvest(false, harvestLoss, bot.stats.currentBal || 0, "Hold Limit");
                            bot.isHarvesting = false;
                        }
                    }
                }
                
                updateLogs(winAmount, chanceToUse, pft, win, rollResult);
            }
            
            if (bot.aiSpeed && bot.isRunning) {
                bot.delay = bot.lastWinStatus ? Math.max(20, (bot.delay || 80) - 5) : Math.min(200, (bot.delay || 80) + 10);
            }
            
            if (bot.isRunning && !bot.isSleeping) {
                setTimeout(runLoop, Math.max(20, Math.min(200, bot.delay || 80)));
            }
        } catch (e) {
            updateUILog("Error: " + e.message);
            setTimeout(runLoop, 1000);
        }
    }

    function updateLogs(amt, ch, pft, win, roll) {
        var logBox = document.getElementById("p-logs");
        if (!logBox) return;
        var entry = document.createElement("div");
        entry.style.color = win ? "#00A86B" : "#FF4757";
        entry.style.padding = "2px 6px";
        entry.style.fontSize = "9px";
        entry.style.fontFamily = "monospace";
        entry.style.borderBottom = "1px solid " + (bot.darkMode ? "#1a1a2e" : "#f0f0f0");
        var mode = bot.isHarvesting ? " [H]" : (bot.isTrailingActive ? " [T" + (bot.trailingLevel || 0) + "]" : "");
        var rollTxt = (roll !== null && roll !== undefined) ? " R:" + roll.toFixed(2) : "";
        entry.textContent = new Date().toLocaleTimeString() + mode + " " + (amt || 0).toFixed(8) + "|" + (ch || 0).toFixed(1) + "%|" + (pft > 0 ? '+' : '') + (pft || 0).toFixed(8) + rollTxt;
        logBox.insertBefore(entry, logBox.firstChild);
        while (logBox.children.length > 100) logBox.removeChild(logBox.lastChild);
    }
    
    function updateUILog(message) {
        var logBox = document.getElementById("p-logs");
        if (!logBox) return;
        var entry = document.createElement("div");
        entry.style.color = "#4A90D9";
        entry.style.padding = "2px 6px";
        entry.style.fontSize = "9px";
        entry.style.fontFamily = "monospace";
        entry.style.borderBottom = "1px solid " + (bot.darkMode ? "#1a1a2e" : "#f0f0f0");
        entry.textContent = new Date().toLocaleTimeString() + " " + message;
        logBox.insertBefore(entry, logBox.firstChild);
        while (logBox.children.length > 100) logBox.removeChild(logBox.lastChild);
    }

    // ==================== UI UPDATE (STABIL) ====================
    function updateStatsDisplay() {
        if (!bot.stats || typeof bot.stats.currentBal === 'undefined') return;
        if (!bot.fiatRates || typeof bot.fiatRates.idr === 'undefined') return;
        if (!bot.dailyStartBalance) bot.dailyStartBalance = bot.stats.currentBal || 0;
        
        var profitPct = bot.stats.startBal > 0 ? ((bot.stats.profit || 0) / bot.stats.startBal * 100) : 0;
        var dailyProfitPct = bot.dailyStartBalance > 0 ? ((bot.dailyProfit || 0) / bot.dailyStartBalance * 100) : 0;
        var winRate = (bot.stats.bets || 0) > 0 ? ((bot.stats.wins || 0) / (bot.stats.bets || 1) * 100) : 0;
        var runTime = getDuration();
        var rakeback = (bot.stats.wagered || 0) * 0.00098;
        var betSpeed = getBetSpeed();
        
        var balanceInIdr = (bot.stats.currentBal || 0) * (bot.fiatRates.idr || 0);
        var balanceInUsdt = (bot.stats.currentBal || 0) * (bot.fiatRates.usdt || 0);
        var profitInIdr = (bot.stats.profit || 0) * (bot.fiatRates.idr || 0);
        var profitInUsdt = (bot.stats.profit || 0) * (bot.fiatRates.usdt || 0);
        
        var status = bot.isHarvesting ? "🌾 H" + (bot.harvestChance || 0) + "%" : (bot.isTrailingActive ? "🔱 T" + (bot.trailingLevel || 0) + "/" + (bot.gapPct || 0) + "%" : "⚡ " + (bot.baseChance || 98) + "%");
        var dailyStatus = ((bot.dailyProfit || 0) >= 0 ? '+' : '') + (bot.dailyProfit || 0).toFixed(8) + " (" + (dailyProfitPct >= 0 ? '+' : '') + dailyProfitPct.toFixed(2) + "%)";
        var timerDisplay = bot.isResetting ? "⏰ " + (bot.resetCountdownRemaining || 0) + "s" : "--";
        
        var elements = {
            "st-user": bot.stakeUser || "-",
            "st-running-time": runTime,
            "st-balance": (bot.stats.currentBal || 0).toFixed(8) + " " + (bot.selectedCurrency || "doge").toUpperCase(),
            "st-balance-fiat": "Rp " + shortFiat(balanceInIdr) + " | " + balanceInUsdt.toFixed(2) + " USDT",
            "st-profit": ((bot.stats.profit || 0) >= 0 ? '+' : '') + (bot.stats.profit || 0).toFixed(8) + " (" + (profitPct >= 0 ? '+' : '') + profitPct.toFixed(2) + "%)",
            "st-profit-fiat": "Rp " + shortFiat(profitInIdr) + " | " + profitInUsdt.toFixed(2) + " USDT",
            "st-daily": dailyStatus,
            "st-wagered": (bot.stats.wagered || 0).toFixed(8),
            "st-wagered-fiat": "Rp " + shortFiat((bot.stats.wagered || 0) * (bot.fiatRates.idr || 0)) + " | " + ((bot.stats.wagered || 0) * (bot.fiatRates.usdt || 0)).toFixed(2) + " USDT",
            "st-rakeback": "+" + rakeback.toFixed(8),
            "st-rakeback-fiat": "Rp " + shortFiat(rakeback * (bot.fiatRates.idr || 0)) + " | " + (rakeback * (bot.fiatRates.usdt || 0)).toFixed(2) + " USDT",
            "st-bets": (bot.stats.bets || 0) + " | WR " + winRate.toFixed(0) + "%",
            "st-speed": betSpeed.toFixed(1) + "b/s",
            "st-maxdd": (bot.stats.maxDrawdownPct || 0).toFixed(1) + "%",
            "st-maxbet": (bot.stats.startBal > 0 ? (((bot.stats.maxBet || 0) / bot.stats.startBal) * 100) : 0).toFixed(1) + "%",
            "st-chance": status,
            "st-gaphits": (bot.gapHits || 0).toString(),
            "st-timer": timerDisplay,
            "st-rate": "1 " + (bot.selectedCurrency || "doge").toUpperCase() + " = " + (bot.fiatRates.usdt || 0).toFixed(2) + " USDT"
        };
        
        for (var id in elements) {
            var el = document.getElementById(id);
            if (el) el.textContent = elements[id];
        }
        
        var profitEl = document.getElementById("st-profit");
        if (profitEl) profitEl.style.color = (bot.stats.profit || 0) >= 0 ? "#00A86B" : "#FF4757";
        
        drawGapVisual();
    }
    
    function shortFiat(num) {
        if (isNaN(num) || typeof num !== 'number') num = 0;
        var abs = Math.abs(num);
        var sign = num < 0 ? "-" : "";
        if (abs >= 1000000) return sign + "Rp" + (abs/1000000).toFixed(1) + "M";
        if (abs >= 1000) return sign + "Rp" + (abs/1000).toFixed(1) + "K";
        return sign + "Rp" + abs.toFixed(0);
    }
    
