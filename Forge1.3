    // ==================== CHART FUNCTIONS (STABIL - TIDAK KEDIP) ====================
    function addBalanceToHistory(balance, isHarvest, isGapEscalate, newLevel) {
        var betNum = bot.stats.bets;
        bot.balanceHistory.push({
            balance: balance,
            betNumber: betNum,
            timestamp: Date.now()
        });
        
        if (isHarvest) {
            bot.harvestMarkers.push({ betNumber: betNum });
        }
        if (isGapEscalate && newLevel) {
            bot.gapMarkers.push({ betNumber: betNum, level: newLevel });
        }
        
        while (bot.balanceHistory.length > bot.chartMaxBets) {
            bot.balanceHistory.shift();
        }
        while (bot.harvestMarkers.length > 50) bot.harvestMarkers.shift();
        while (bot.gapMarkers.length > 50) bot.gapMarkers.shift();
        
        drawChart();
    }
    
    function drawChart() {
        var canvas = document.getElementById("balanceChart");
        if (!canvas) return;
        
        if (bot.balanceHistory.length < 2) return;
        
        var labels = bot.balanceHistory.map(function(d) { return d.betNumber; });
        var data = bot.balanceHistory.map(function(d) { return d.balance; });
        
        var datasets = [{
            label: 'Balance',
            data: data,
            borderColor: '#9ec07c',
            backgroundColor: 'rgba(158, 192, 124, 0.1)',
            borderWidth: 2,
            pointRadius: 0,
            pointHoverRadius: 4,
            tension: 0.1,
            fill: true
        }];
        
        var harvestPoints = [];
        for (var i = 0; i < bot.harvestMarkers.length; i++) {
            var marker = bot.harvestMarkers[i];
            for (var j = 0; j < bot.balanceHistory.length; j++) {
                if (bot.balanceHistory[j].betNumber === marker.betNumber) {
                    harvestPoints.push({ x: labels[j], y: data[j] });
                    break;
                }
            }
        }
        
        if (harvestPoints.length > 0) {
            datasets.push({
                label: 'Harvest',
                data: harvestPoints,
                type: 'scatter',
                pointStyle: 'triangle',
                pointBackgroundColor: '#ff6b81',
                pointBorderColor: '#ff6b81',
                pointRadius: 6,
                pointHoverRadius: 8,
                showLine: false
            });
        }
        
        var gapPoints = [];
        for (var i = 0; i < bot.gapMarkers.length; i++) {
            var marker = bot.gapMarkers[i];
            for (var j = 0; j < bot.balanceHistory.length; j++) {
                if (bot.balanceHistory[j].betNumber === marker.betNumber) {
                    gapPoints.push({ x: labels[j], y: data[j] });
                    break;
                }
            }
        }
        
        if (gapPoints.length > 0) {
            datasets.push({
                label: 'Gap Escalate',
                data: gapPoints,
                type: 'scatter',
                pointStyle: 'triangle',
                pointBackgroundColor: '#00e5c0',
                pointBorderColor: '#00e5c0',
                pointRadius: 6,
                pointHoverRadius: 8,
                rotation: 180,
                showLine: false
            });
        }
        
        var isDark = bot.darkMode;
        
        if (bot.chartInstance) {
            bot.chartInstance.destroy();
