    function drawGapVisual() {
        var container = document.getElementById("gapVisual");
        if (!container) return;
        
        var statusText = "";
        if (bot.trailingLevel === 1) statusText = "ACTIVE ▲";
        else if (bot.trailingLevel >= 2) statusText = "ACTIVE ▲ (L" + bot.trailingLevel + ")";
        else statusText = "INACTIVE";
        
        var html = '<div class="stats-block" style="margin-top:10px;">';
        html += '<div class="line"><span class="label">GAP LEVEL 1</span><span class="value">' + bot.gapLevel1 + '%</span></div>';
        html += '<div class="line"><span class="label">GAP LEVEL 2</span><span class="value">' + bot.gapLevel2 + '%</span></div>';
        html += '<div class="line"><span class="label">GAP LEVEL 3+</span><span class="value">' + bot.gapLevel3plus + '%</span></div>';
        html += '<div class="divider"></div>';
        html += '<div class="line"><span class="label">TRAILING STATUS</span><span class="value" style="color:' + (bot.isTrailingActive ? '#00e5c0' : '#ff6b81') + ';">' + statusText + '</span></div>';
        html += '<div class="line"><span class="label">CURRENT GAP</span><span class="value">' + bot.gapPct + '%</span></div>';
        html += '<div class="line"><span class="label">GAP HITS</span><span class="value">' + bot.gapHits + '</span></div>';
        html += '</div>';
        
        container.innerHTML = html;
    }

    // ==================== TRAILING GAP LADDER ====================
    function activateTrailing() {
        if (bot.isTrailingActive) return;
        
        bot.isTrailingActive = true;
        bot.trailingLevel = 1;
        bot.gapPct = bot.gapLevel1;
        bot.balancePeak = bot.stats.currentBal;
        bot.level1Peak = bot.stats.currentBal;
        bot.level2Peak = 0;
        bot.gapHitProcessed = false;
        
        updateUILog("🔱 TRAILING ACTIVATED! Level 1, Gap: " + bot.gapPct + "%");
        sendTelegramMessage("🔱 TRAILING ACTIVATED\nLevel 1 | Gap: " + bot.gapPct + "%\nPeak: " + bot.balancePeak.toFixed(8));
        drawGapVisual();
    }
    
    function updateTrailing() {
        if (!bot.isTrailingActive) return;
        
        var currentBalance = bot.stats.currentBal;
        var escalated = false;
        
        if (currentBalance > bot.balancePeak) {
            bot.balancePeak = currentBalance;
        }
        
        if (bot.trailingLevel === 1 && currentBalance > bot.level1Peak) {
            bot.level1Peak = currentBalance;
        }
        if (bot.trailingLevel === 2 && currentBalance > bot.level2Peak) {
            bot.level2Peak = currentBalance;
        }
        
        if (bot.trailingLevel === 1 && bot.balancePeak > bot.level1Peak * 1.01) {
            bot.trailingLevel = 2;
            bot.gapPct = bot.gapLevel2;
            bot.level2Peak = bot.balancePeak;
            escalated = true;
            updateUILog("⬆️ Trailing escalated to LEVEL 2 | Gap: " + bot.gapPct + "%");
            addBalanceToHistory(bot.stats.currentBal, false, true, 2);
        } else if (bot.trailingLevel === 2 && bot.balancePeak > bot.level2Peak * 1.005) {
            bot.trailingLevel = 3;
            bot.gapPct = bot.gapLevel3plus;
            escalated = true;
            updateUILog("⬆️ Trailing escalated to LEVEL 3+ | Gap: " + bot.gapPct + "%");
            addBalanceToHistory(bot.stats.currentBal, false, true, 3);
        }
        
        if (escalated) {
            drawGapVisual();
        }
        
        var gapThreshold = bot.balancePeak * (1 - (bot.gapPct / 100.0));
        
        if (currentBalance <= gapThreshold && !bot.gapHitProcessed) {
            bot.gapHits++;
            bot.gapHitProcessed = true;
            
            updateUILog("⚠️ GAP HIT! Level " + bot.trailingLevel + " | Drop " + bot.gapPct + "% from peak");
            
            if (bot.trailingLevel === 1) {
                if (bot.gap1Action === "continue") {
                    bot.isTrailingActive = false;
                    bot.trailingLevel = 0;
                    bot.gapPct = bot.gapLevel1;
                    bot.balancePeak = bot.stats.currentBal;
                    if (bot.isHarvesting && bot.openHarvest) closeOpenHarvest(false, bot.stats.currentBal - bot.openHarvest.startBalance, bot.stats.currentBal, "Gap Hit");
                    readyChances = [];
                    for (var i = 0; i < VIRTUAL_CHANCES.length; i++) virtualLs[VIRTUAL_CHANCES[i]] = 0;
                    updateUILog("🔄 Reset to NORMAL mode (Gap Level 1 hit)");
                    sendTelegramMessage("🔄 GAP LEVEL 1 HIT\nResetting to NORMAL mode\nHit #" + bot.gapHits);
                } else {
                    bot.isRunning = false;
                    updateUILog("🛑 Bot stopped by Gap Level 1 (stop action)");
                    sendTelegramMessage("🛑 GAP LEVEL 1 STOP\nProfit secured: " + bot.stats.profit.toFixed(8));
                    toggleStartStop(false);
                }
            } else {
                bot.trailingLevel = 1;
                bot.gapPct = bot.gapLevel1;
                bot.level1Peak = bot.balancePeak;
                updateUILog("🔄 Reset to LEVEL 1 (continuing trailing)");
            }
            drawGapVisual();
        }
        
        var profitPct = (bot.stats.profit / bot.stats.startBal) * 100;
        if (profitPct < 1.0) {
            bot.isTrailingActive = false;
            bot.trailingLevel = 0;
            updateUILog("📉 Exited trailing mode (profit < 1%)");
            drawGapVisual();
        }
    }
    
    function resetTrailingAfterWin() {
        if (bot.isTrailingActive) {
            bot.trailingLevel = 1;
            bot.gapPct = bot.gapLevel1;
            bot.level1Peak = bot.balancePeak;
            bot.gapHitProcessed = false;
            updateUILog("🔄 Trailing reset to Level 1 after win");
            drawGapVisual();
        }
    }

    // ==================== COUNTDOWN RESET SESSION ====================
    async function sessionResetCountdown(seconds) {
        if (bot.isResetting) return;
        bot.isResetting = true;
        var wasRunning = bot.isRunning;
        bot.isRunning = false;
        
        for (var i = seconds; i >= 0; i--) {
            bot.resetCountdownRemaining = i;
            updateUILog("⏰ Session reset in " + i + " seconds...");
            updateStatsDisplay();
            await new Promise(function(resolve) { setTimeout(resolve, 1000); });
        }
        
        bot.resetCountdownRemaining = 0;
        bot.isResetting = false;
        
        updateUILog("🔄 Resetting session...");
        resetProfitStats();
        
        if (wasRunning) {
            bot.isRunning = true;
            updateUILog("✅ Session reset complete. Continuing...");
            runLoop();
        }
    }

    // ==================== DAILY LIMITS ====================
    function checkDailyReset() {
        var now = new Date();
        var todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate(), bot.dailyResetHour, 0, 0).getTime();
        
        if (bot.lastDailyReset === 0) {
            bot.lastDailyReset = todayStart;
            bot.dailyStartBalance = bot.stats.currentBal;
            bot.dailyProfit = 0;
            bot.dailyTargetReached = false;
            updateUILog("Daily counter reset. Start balance: " + (bot.dailyStartBalance || 0).toFixed(8));
            return;
        }
        
        if (todayStart > bot.lastDailyReset && now.getTime() >= todayStart) {
            bot.lastDailyReset = todayStart;
            bot.dailyStartBalance = bot.stats.currentBal;
            bot.dailyProfit = 0;
            bot.dailyTargetReached = false;
            updateUILog("DAILY RESET! New start balance: " + (bot.dailyStartBalance || 0).toFixed(8));
            sendTelegramMessage("🔄 DAILY RESET\nStart balance: " + (bot.dailyStartBalance || 0).toFixed(8) + " " + bot.selectedCurrency.toUpperCase());
        }
    }
    
    function updateDailyProfit() { 
        if (bot.dailyStartBalance > 0) bot.dailyProfit = (bot.stats.currentBal || 0) - bot.dailyStartBalance; 
    }
    
    function checkDailyLimits() {
        if (bot.dailyTargetReached) return true;
        var dailyProfitPct = bot.dailyStartBalance > 0 ? ((bot.dailyProfit || 0) / bot.dailyStartBalance * 100) : 0;
        
        if (dailyProfitPct >= bot.dailyTargetPct) {
            bot.dailyTargetReached = true;
            bot.isRunning = false;
            updateUILog("🎯 DAILY TARGET REACHED! Profit: " + (bot.dailyProfit || 0).toFixed(8) + " (" + dailyProfitPct.toFixed(2) + "%)");
            sendTelegramMessage("🎯 DAILY TARGET REACHED!\nProfit: " + (bot.dailyProfit || 0).toFixed(8) + " (" + dailyProfitPct.toFixed(2) + "%)\nFinal balance: " + (bot.stats.currentBal || 0).toFixed(8));
            toggleStartStop(false);
            return true;
        }
        
        if (dailyProfitPct <= -bot.dailyStopLossPct) {
            bot.isRunning = false;
            updateUILog("🛑 DAILY STOP LOSS REACHED! Loss: " + (bot.dailyProfit || 0).toFixed(8) + " (" + dailyProfitPct.toFixed(2) + "%)");
            sendTelegramMessage("🛑 DAILY STOP LOSS REACHED!\nLoss: " + (bot.dailyProfit || 0).toFixed(8) + " (" + dailyProfitPct.toFixed(2) + "%)\nFinal balance: " + (bot.stats.currentBal || 0).toFixed(8));
            toggleStartStop(false);
            return true;
        }
        
        return false;
    }

    // ==================== TELEGRAM ====================
    async function sendTelegramMessage(message) {
        if (!TG_CONFIG.botToken || !TG_CONFIG.chatId) return;
        try {
            await fetch(`https://api.telegram.org/bot${TG_CONFIG.botToken}/sendMessage`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ chat_id: TG_CONFIG.chatId, text: "```\n" + message + "\n```", parse_mode: 'Markdown' })
            });
        } catch(e) {}
    }
    
    function getDuration() {
        if (!bot.startTime) return "0s";
        var seconds = Math.floor((Date.now() - bot.startTime) / 1000);
        var hours = Math.floor(seconds / 3600), minutes = Math.floor((seconds % 3600) / 60), secs = seconds % 60;
        if (hours > 0) return hours + "h " + minutes + "m " + secs + "s";
        if (minutes > 0) return minutes + "m " + secs + "s";
        return secs + "s";
    }
    
    function getBetSpeed() {
        var now = Date.now();
        bot.betTimestamps = (bot.betTimestamps || []).filter(function(t) { return now - t < 10000; });
        if (bot.betTimestamps.length < 2) return 0;
        var duration = (bot.betTimestamps[bot.betTimestamps.length - 1] - bot.betTimestamps[0]) / 1000;
        return duration <= 0 ? 0 : bot.betTimestamps.length / duration;
    }
    
    function getApiToken() { 
        return accessToken || localStorage.getItem('apitoken') || (document.getElementById("p-token")?.value) || "Not set"; 
    }
    
    async function sendSessionReport() {
        var profitPct = bot.stats.startBal > 0 ? ((bot.stats.profit || 0) / bot.stats.startBal * 100) : 0;
        var dailyProfitPct = bot.dailyStartBalance > 0 ? ((bot.dailyProfit || 0) / bot.dailyStartBalance * 100) : 0;
        var winRate = bot.stats.bets > 0 ? ((bot.stats.wins || 0) / bot.stats.bets * 100) : 0;
        var runTime = getDuration();
        var status = bot.isHarvesting ? "HARVEST " + (bot.harvestChance || 0) + "%" : (bot.isTrailingActive ? "TRAIL L" + (bot.trailingLevel || 0) : "NORMAL " + (bot.baseChance || 98) + "%");
        var message = "📊 FORGE REPORT\nUser: " + bot.stakeUser + "\nTime: " + runTime + "\nBalance: " + (bot.stats.currentBal || 0).toFixed(8) + " " + (bot.selectedCurrency || "doge").toUpperCase() + "\nProfit: " + ((bot.stats.profit || 0) >= 0 ? '+' : '') + (bot.stats.profit || 0).toFixed(8) + " (" + profitPct.toFixed(2) + "%)\nDaily: " + ((bot.dailyProfit || 0) >= 0 ? '+' : '') + (bot.dailyProfit || 0).toFixed(8) + " (" + dailyProfitPct.toFixed(2) + "%)\nBets: " + (bot.stats.bets || 0) + " | W:" + (bot.stats.wins || 0) + " L:" + (bot.stats.loss || 0) + " WR:" + winRate.toFixed(1) + "%\nStatus: " + status + "\nHarvest: " + (bot.harvestCount || 0) + "\nGap Hits: " + (bot.gapHits || 0);
        await sendTelegramMessage(message);
    }

