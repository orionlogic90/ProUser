        document.body.insertAdjacentHTML('beforeend', html);
        
        document.getElementById("botHeader").addEventListener('mousedown', dragMouseDown);
        document.getElementById("btn-minimize").onclick = toggleMinimize;
        document.getElementById("btn-theme").onclick = toggleDarkMode;
        
        var savedToken = getAuthToken();
        if (savedToken) document.getElementById("p-token").value = savedToken;
        
        document.getElementById("p-demo-toggle").onchange = function(e) { 
            bot.isDemo = e.target.checked; 
            updateUILog(bot.isDemo ? "FLASH MODE ON" : "REAL MODE ON"); 
        };
        
        document.getElementById("p-ai-speed").onchange = function(e) { 
            bot.aiSpeed = e.target.checked; 
            updateUILog(bot.aiSpeed ? "AI SPEED ON" : "AI SPEED OFF"); 
        };
        
        document.getElementById("p-recovery-mode").onchange = function(e) { 
            bot.recoveryMode = e.target.checked; 
            if (!bot.recoveryMode) resetRecovery(); 
            updateUILog(bot.recoveryMode ? "RECOVERY MODE ACTIVE" : "RECOVERY MODE OFF"); 
            saveSettings(); 
        };
        
        document.getElementById("p-login").onclick = async function() { 
            var token = document.getElementById("p-token").value.trim(); 
            if (!token || token.length < 30) { 
                updateUILog("Invalid API Token!"); 
                return; 
            } 
            saveToken(token); 
            if (await syncUserInfo()) { 
                updateUILog("Welcome " + bot.stakeUser); 
                document.getElementById("p-start").disabled = false; 
                await updateFiatRates(); 
                updateStatsDisplay(); 
                sendTelegramMessage("✅ LOGIN SUCCESS\nUser: " + bot.stakeUser + "\nFORGE v1.1"); 
            } else { 
                updateUILog("Login failed!"); 
            } 
        };
        
        document.getElementById("p-refresh").onclick = async function() { 
            if (!accessToken) { 
                updateUILog("Login first!"); 
                return; 
            } 
            await syncUserInfo(); 
            await updateFiatRates(); 
            updateStatsDisplay(); 
            updateUILog("Refreshed"); 
        };
        
        document.getElementById("p-start").onclick = async function() {
            if (!bot.isDemo && !accessToken) { 
                updateUILog("Login first!"); 
                return; 
            }
            
            bot.baseChance = parseFloat(document.getElementById("p-base-chance").value) || 98;
            bot.baseBetPercent = parseFloat(document.getElementById("p-base-bet-pct").value) || 1;
            bot.riskFactor = parseFloat(document.getElementById("p-risk-factor").value) || 0.15;
            bot.targetPct = parseFloat(document.getElementById("p-target-pct").value) || 5;
            bot.stopLossPct = parseFloat(document.getElementById("p-stop-pct").value) || 4;
            bot.dailyTargetPct = parseFloat(document.getElementById("p-daily-target").value) || 25;
            bot.dailyStopLossPct = parseFloat(document.getElementById("p-daily-stoploss").value) || 15;
            bot.sessionTotal = parseInt(document.getElementById("p-session-total").value) || 8;
            bot.maxBetCap = parseFloat(document.getElementById("p-max-cap").value) || 0;
            bot.trailingActivationPct = parseFloat(document.getElementById("p-trail-activation").value) || 3;
            bot.gap1Action = document.getElementById("p-gap1-action").value;
            bot.gapLevel1 = parseFloat(document.getElementById("p-gap1").value) || 0.5;
            bot.gapLevel2 = parseFloat(document.getElementById("p-gap2").value) || 0.25;
            bot.gapLevel3plus = parseFloat(document.getElementById("p-gap3").value) || 0.125;
            bot.delay = parseInt(document.getElementById("p-delay").value) || 80;
            bot.aiSpeed = document.getElementById("p-ai-speed").checked;
            bot.dirtyBalance = parseFloat(document.getElementById("p-dirty-bal").value) || 460;
            bot.chartMaxBets = parseInt(document.getElementById("p-chart-bets").value) || 100;
            bot.recoveryMode = document.getElementById("p-recovery-mode").checked;
            bot.maxRecoveryBet = parseFloat(document.getElementById("p-max-recovery-bet").value) || 20;
            bot.maxRecoveryStep = parseInt(document.getElementById("p-max-recovery-step").value) || 3;
            bot.maxRecoveryPercent = parseFloat(document.getElementById("p-max-recovery-percent").value) || 50;
            bot.minBalanceRecovery = parseFloat(document.getElementById("p-min-balance-recovery").value) || 10;
            bot.cooldownAfterLoss = parseInt(document.getElementById("p-cooldown-loss").value) || 30;
            bot.useDrawdownFactor = document.getElementById("p-use-dd-factor").checked;
            bot.useTimeDecay = document.getElementById("p-use-time-decay").checked;
            
            saveSettings();
            await updateFiatRates();
            
            var balance = bot.isDemo ? bot.dirtyBalance : bot.realBalance;
            if (!bot.isDemo && balance === 0) { 
                updateUILog("Failed to get balance!"); 
                return; 
            }
            
            bot.dailyStartBalance = balance;
            bot.dailyProfit = 0;
            bot.dailyTargetReached = false;
            bot.lastDailyReset = new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate(), 0, 0, 0).getTime();
            
            bot.stats = { 
                profit: 0, wagered: 0, startBal: balance, currentBal: balance, 
                bets: 0, wins: 0, loss: 0, startTime: Date.now(), maxDD: 0, maxBet: 0, 
                maxDrawdownPct: 0, peakBalance: balance 
            };
            
            bot.betTimestamps = [];
            bot.startTime = Date.now();
            bot.isHarvesting = false;
            bot.isTrailingActive = false;
            bot.trailingLevel = 0;
            bot.gapPct = bot.gapLevel1;
            bot.balancePeak = balance;
            bot.level1Peak = balance;
            bot.level2Peak = 0;
            bot.gapHits = 0;
            bot.gapHitProcessed = false;
            bot.harvestCount = 0;
            bot.harvestBet = 0;
            bot.lastBetAmount = 0;
            bot.sessionProfit = 0;
            bot.totalWager = 0;
            bot.highestProfit = 0;
            bot.maxDrawdownVal = 0;
            bot.balanceStartSnapshot = balance;
            bot.isRunning = true;
            bot.isSleeping = false;
            bot.lastTGReport = Date.now();
            bot.lastFiatUpdate = 0;
            bot.isResetting = false;
            bot.resetCountdownRemaining = 0;
            bot.balanceHistory = [];
            bot.harvestMarkers = [];
            bot.gapMarkers = [];
            bot.harvestHistory = [];
            bot.openHarvest = null;
            
            resetRecovery();
            
            if (bot.chartInstance) {
                bot.chartInstance.destroy();
                bot.chartInstance = null;
            }
            
            initMemory();
            toggleStartStop(true);
            updateUILog("🚀 FORGE v1.1 STARTED | Balance: " + balance.toFixed(8) + " | Base Chance: " + bot.baseChance + "% | Recovery: " + (bot.recoveryMode ? "ON" : "OFF"));
            sendTelegramMessage("🚀 FORGE v1.1 STARTED\nBalance: " + balance.toFixed(8) + "\nBase Chance: " + bot.baseChance + "%\nRecovery Mode: " + (bot.recoveryMode ? "ON" : "OFF"));
            
            renderHarvestTable();
            runLoop();
        };
        
        document.getElementById("p-stop").onclick = async function() { 
            bot.isRunning = false; 
            toggleStartStop(false); 
            updateUILog("STOPPED"); 
            await sendSessionReport(); 
        };
        
        document.getElementById("p-reset").onclick = resetSession;
        
        document.getElementById("p-currency").onchange = function() { 
            bot.selectedCurrency = document.getElementById("p-currency").value; 
            bot.lastFiatUpdate = 0; 
            updateFiatRates(); 
        };
        
        document.getElementById("p-chart-bets").onchange = function() { 
            var newMax = parseInt(this.value); 
            if (newMax > 0 && newMax !== bot.chartMaxBets) { 
                bot.chartMaxBets = newMax; 
                while (bot.balanceHistory.length > bot.chartMaxBets) bot.balanceHistory.shift(); 
                drawChart(); 
            } 
        };
        
        setInterval(function() { 
            updateStatsDisplay(); 
        }, 1000);
        
        setInterval(function() { 
            updateFiatRates(); 
        }, 30000);
        
        updateFiatRates();
    }
    
    var waitForChart = setInterval(function() { 
        if (typeof Chart !== 'undefined') { 
            clearInterval(waitForChart); 
            createUI(); 
            updateUILog("⚡ FORGE v1.1 Final - Chart stabil | Recovery Mode | Gap di MAIN"); 
        } 
    }, 500);
    
    setTimeout(function() { 
        if (typeof Chart === 'undefined') { 
            clearInterval(waitForChart); 
            createUI(); 
            updateUILog("⚡ FORGE v1.1 - Fallback mode"); 
        } 
    }, 5000);
