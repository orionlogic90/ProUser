    async function syncUserInfo() {
        accessToken = getAuthToken();
        if (!accessToken || accessToken.length < 30) { 
            updateUILog("Waiting for API token..."); 
            return false; 
        }
        
        try {
            var res = await fetch(CONFIG.apiUrl + '/graphql', {
                method: "POST",
                headers: { "Content-Type": "application/json", "x-access-token": accessToken },
                body: JSON.stringify({ query: 'query{user{name balances{available{amount currency}}}}' })
            });
            var json = await res.json();
            if (json?.data?.user) {
                bot.stakeUser = json.data.user.name;
                var bals = json.data.user.balances || [];
                var sel = document.getElementById("p-currency");
                if (sel && sel.options.length === 0) {
                    for (var i = 0; i < bals.length; i++) {
                        var opt = document.createElement("option");
                        opt.value = bals[i].available.currency;
                        opt.textContent = bals[i].available.currency.toUpperCase();
                        if(bals[i].available.currency.toLowerCase() === cur) opt.selected = true;
                        sel.appendChild(opt);
                    }
                    if (sel.options.length === 0) {
                        for (var j = 0; j < FALLBACK_CURRENCIES.length; j++) {
                            var opt2 = document.createElement("option");
                            opt2.value = FALLBACK_CURRENCIES[j].toLowerCase();
                            opt2.textContent = FALLBACK_CURRENCIES[j];
                            sel.appendChild(opt2);
                        }
                        sel.value = cur;
                    }
                }
                if (sel) bot.selectedCurrency = sel.value;
                var active = bals.find(b => b.available.currency.toLowerCase() === (bot.selectedCurrency || "doge").toLowerCase());
                if (active) bot.realBalance = parseFloat(active.available.amount);
                updateUILog("Logged in as: " + bot.stakeUser);
                return true;
            }
        } catch (e) { 
            updateUILog("Sync error: " + e.message); 
        }
        return false;
    }

    // ==================== PLACE BET ====================
    async function placeBet(amount, chance) {
        var target = 100 - chance;
        
        if (bot.isDemo) {
            try {
                var response = await fetch(CONFIG.apiUrl + '/casino/dice/roll', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'x-access-token': accessToken, 'x-lockdown-token': 's5MNWtjTM5TvCMkAzxov' },
                    body: JSON.stringify({ amount: 0, currency: bot.selectedCurrency, target: target, condition: "above", identifier: Math.random().toString(36).slice(2) })
                });
                var result = await response.json();
                if (!result?.diceRoll) {
                    var fallbackWin = Math.random() * 100 < chance;
                    var fallbackMultiplier = fallbackWin ? (99 / chance) : 1;
                    return { diceRoll: { amount: parseFloat(amount) || 0, payout: fallbackWin ? (parseFloat(amount) || 0) * fallbackMultiplier : 0, payoutMultiplier: fallbackMultiplier } };
                }
                var diceRoll = result.diceRoll;
                var safeAmount = parseFloat(amount) || 0;
                var win = diceRoll.payoutMultiplier > 1;
                var multiplier = win ? (99 / chance) : 1;
                var winAmount = win ? safeAmount * multiplier : 0;
                return { diceRoll: { amount: safeAmount, payout: winAmount, payoutMultiplier: multiplier, win: win, user: { wallets: [{ balance: (bot.stats.currentBal || 0) + (winAmount - safeAmount) }] } } };
            } catch(e) {
                var fallbackWin = Math.random() * 100 < chance;
                var fallbackMultiplier = fallbackWin ? (99 / chance) : 1;
                return { diceRoll: { amount: parseFloat(amount) || 0, payout: fallbackWin ? (parseFloat(amount) || 0) * fallbackMultiplier : 0, payoutMultiplier: fallbackMultiplier, win: fallbackWin, user: { wallets: [{ balance: (bot.stats.currentBal || 0) + (fallbackWin ? (parseFloat(amount) || 0) * fallbackMultiplier - (parseFloat(amount) || 0) : -(parseFloat(amount) || 0)) }] } } };
            }
        }
        
        try {
            var res = await fetch(CONFIG.apiUrl + '/casino/dice/roll', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'x-access-token': accessToken, 'x-lockdown-token': 's5MNWtjTM5TvCMkAzxov' },
                body: JSON.stringify({ amount: parseFloat(amount.toFixed(8)), currency: bot.selectedCurrency, target: target, condition: "above", identifier: Math.random().toString(36).slice(2) })
            });
            var json = await res.json();
            if (json.error) { 
                updateUILog("API Error: " + json.error); 
                return null; 
            }
            return json;
        } catch(e) { 
            updateUILog("Network Error: " + e.message); 
            return null; 
        }
    }

