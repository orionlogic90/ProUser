    function closeOpenHarvest(win, profit, balanceAfter, reason) {
        if (bot.openHarvest) {
            var duration = Math.floor((Date.now() - bot.openHarvest.startTime) / 1000);
            addHarvestToHistory(
                bot.openHarvest.chance,
                bot.openHarvest.totalBet,
                win ? (99 / bot.openHarvest.chance).toFixed(2) : 0,
                win,
                profit,
                balanceAfter,
                duration,
                reason,
                bot.openHarvest.isRecovery
            );
            if (win) updateRecoveryAfterWin(profit);
            else updateRecoveryAfterLoss(profit);
            bot.openHarvest = null;
            renderHarvestTable();
        }
    }
    
